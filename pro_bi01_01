		AND sale.adviserUID <> '4006226' -- Excluding the test UID
		AND pol.ApplicationDate >=	CONVERT(DATE, @startdate,103)
		AND pol.ApplicationDate <= CONVERT(DATE, @enddate,103)

	GROUP BY 
		pol.ApplicationDate,
		DAY(pol.ApplicationDate),
		MONTH(pol.ApplicationDate),
		YEAR(pol.ApplicationDate),
		sale.AdviserUID,
		uh.BusinessUID,
		ah.agentstartdate,
		pr.Promotiondate,
		pt.FrequencyDescription,
		CASE WHEN YEAR(pol.ApplicationDate) = YEAR(GETDATE()) THEN 'Curr YTD' 
			WHEN pol.ApplicationDate BETWEEN DATEADD(YEAR, -1, DATEADD(YEAR, DATEDIFF(YEAR, 0, GETDATE()), 0)) AND DATEADD(YEAR, -1, DATEADD(DAY, DATEDIFF(DAY, 0, GETDATE()), 0)) THEN 'Prior YTD' 
			ELSE 'Not YTD' 
		END),
