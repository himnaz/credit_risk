					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*9, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn9_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*10, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn10_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*11, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn11_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*12, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn12_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*13, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn13_' + @COL + ','
					END
		END

		-- Additional periods for weekly written - Current MTD, Pevious week, Rolling 30 days
		
		BEGIN 
				IF @wwrit = 1
				-- Current Month
					BEGIN
					SET @CMD = @CMD + 'sum(case when #f.month = datepart(m,dateadd(week, datediff(week, ''1900-01-01'', getdate()), ''1900-01-01'')) and #f.year = datepart(yy,dateadd(week, datediff(week, ''1900-01-01'', getdate()), ''1900-01-01'')) then #f.' + @COl + ' else 0 end) as Cur_month' + @COL + ','

				-- Previous week
					SET @CMD = @CMD + 'sum(case when #f.date < dateadd(week, datediff(week, ''1900-01-01'', getdate()), ''1900-01-01'') and #f.date >= dateadd(week, datediff(week, ''1900-01-01'', getdate())-1, ''1900-01-01'') then #f.' + @COl + ' else 0 end) as PrevWk_' + @COL + ','


				-- Rolling 30 Days
					SET @CMD = @CMD + 'sum(case when #f.date >= dateadd(dd, datediff(dd, ''1900-01-01'', getdate()),-30) then #f.' + @COl + ' else 0 end) as R30Day_' + @COL + ','
					END

		END


				-- Additional periods for WtoI2 scan (Current MTD, Current Week TD (Monday onwards)

		BEGIN 
				IF @WtoI2 = 1
					BEGIN
					-- Current MTD
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, GETDATE()), 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, GETDATE())+1, 0)	then #f.' + @COL + ' else 0 end) as Curr_MTD' + @COL + ','
					
					-- Current Week TD (Monday onwards)
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(dd, DATEDIFF(dd, 0, dateadd(day,-datepart(weekday,getdate())+1,getdate())), 0) then #f.' + @COL + ' else 0 end) as Curr_WeekTD'  + @COL + ','
					
					END
		END

				-- Additional periods for recruitment report - Total production, first 6 months from adviser start date
		
		BEGIN 
				IF @wrec1 = 1
				-- Total Production 
					BEGIN
					SET @CMD = @CMD + 'sum(#f.' + @COl + ') as Total_Writ' + @COL + ','

				-- First 6 months from adviser start date
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(mm, 6, #f.startdate)+1 then #f.' + @COl + ' else 0 end) as First6Mnth' + @COL + ','
					END

		END
		END
			
	 ELSE IF @COL IN ('%Date%')
		BEGIN
		SET @CMD = @CMD + 'CONVERT(varchar(10),' + @COL + ',103) Date,'
		END
	 ELSE
		BEGIN
		SET @CMD = @CMD + @COL + ','
		END
	 FETCH NEXT FROM COLUMN_CURSOR INTO @COL	 

	END

BEGIN
