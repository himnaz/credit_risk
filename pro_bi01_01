Script Name:	20. Agent View OSPAS Correction.sql

*******************************************************************************************************************/

Create Procedure [BI].[pr_020_AgentViewOPASCorrection]

as

SELECT     cscv_AgentsHierarchy.AgentCode, CASE WHEN (COALESCE(LTRIM(RTRIM(cscv_AgentsHierarchy.ASDName)),'') = 'Pat McKenna' AND cscv_AgentsHierarchy.AgentTypeDescription = 'Principal') THEN 'Adviser' when cscv_AgentsHierarchy.AgentTypeDescription = 'Seller' then 'Adviser' else cscv_AgentsHierarchy.AgentTypeDescription end AS AgentTypeDescription, LTRIM(RTRIM(cscv_AgentsHierarchy.AgentDesc)) AS AgentDesc, cscv_AgentsHierarchy.FirmFranchiseType, 
           cscv_AgentsHierarchy.AgentCategoryDescription, COALESCE(CASE WHEN (LEFT(mstt_Agents_3.AgentCategoryDescription, 4) = 'NASP' AND 
                      dbo.cscv_AgentsHierarchy.AgentCategoryDescription = 'Administrator') 



                      THEN 'NASP Seller' ELSE mstt_Agents_3.AgentCategoryDescription END,'') AS Agent_Cat, COALESCE(cscv_AgentsHierarchy.OscarAgentId, '') AS OscarAgentId, COALESCE(cscv_AgentsHierarchy.AgentOscarCode, '') AS AgentOscarCode, 
	
		   CASE When COALESCE(LTRIM(RTRIM(cscv_AgentsHierarchy.ASDName)),'') = 'Pat McKenna' then 
				(case when UH.UserEmploymentStatuscode not in (2,5,6) --Ignoring Left,NPW,Deceased
					and UH.UserContractStatuscode not in (2,3,4) -- Ignoring Out of Contract,Pre-contract,Vetting
					and UH.UserJobTitleCodeSeller in (52,61,62,63) then 'Active' end)
		  		
		   when cscv_AgentsHierarchy.AgentCode = '1002505' THEN 'Left' WHEN cscv_AgentsHierarchy.AgentCode = '1001364' THEN 'Left' WHEN (mstt_Agents.EMAIL
                      LIKE '%Deceased%' AND cscv_AgentsHierarchy.AgentType = 43) 
                      THEN 'Left' ELSE cscv_AgentsHierarchy.CompetentStatusdescription END AS CompetentStatusdescription,
								   
			CASE WHEN (RIGHT(dbo.mstt_Agents.SupervisorTypeCode, 2) = 'NA' AND dbo.mstt_Agents.
			GivesAdvice = 'Y') OR
                      dbo.cscv_AgentsHierarchy.AgentCode = '1005202' THEN 'N' ELSE dbo.mstt_Agents.GivesAdvice END AS Gives_Advice,
					   cscv_AgentsHierarchy.AgentStartDate, cscv_AgentsHierarchy.AgentLeftDate AS AgentLeftDat, COALESCE(RTRIM(cscv_AgentsHierarchy.FirmDescn),'') AS FirmDescn,
			COALESCE(cscv_AgentsHierarchy.FirmTypeDescription, '') AS FirmTypeDescription, COALESCE(cscv_AgentsHierarchy.FirmCode, '') AS FirmCode, COALESCE(cscv_AgentsHierarchy.FirmOscarAgentId,'') AS FirmOscarAgentId, COALESCE(cscv_AgentsHierarchy.FirmOscarCode,'') AS FirmOscarCode,
			cscv_AgentsHierarchy.FranchiseType, COALESCE(RTRIM(cscv_AgentsHierarchy.RSMName),'') AS RSMName, COALESCE(RTRIM(cscv_AgentsHierarchy.ASDName),'') AS ASDName, 
			COALESCE(CASE WHEN (RTRIM(mstt_Agents.EMAIL) IS NULL OR
                      RTRIM(mstt_Agents.EMAIL) = '') THEN RTRIM(mstt_Clients.EMAIL) ELSE RTRIM(mstt_Agents.EMAIL) END,'') AS Email,
		    COALESCE(mstt_Agents.ReasonForLeaving,'') AS ReasonForLeaving, A.FirstDate, COALESCE(CASE WHEN mstt_Agents.LicenceNumber = 'Excluded' THEN '' ELSE mstt_Agents.LicenceNumber END,'') AS LicenceNumber, COALESCE(CONVERT(varchar, mstt_Clients.BIRTHDATE, 103),'') AS DOB, 
			COALESCE(dbo.mstt_Agents.TELEPHONE,'') AS Telephone, Case when (dbo.mstt_Agents.Salutation <> 'Ocademy' OR dbo.mstt_Agents.Salutation IS NULL) then '' else dbo.mstt_Agents.Salutation end as Ocademy 
			
			-- Gender Info
			--case when dbo.mstt_Agents.Title = 'Mr' Then 'M' when (dbo.mstt_Agents.Title = 'Mrs' or dbo.mstt_Agents.Title =  'Miss' or dbo.mstt_Agents.Title =  'Ms') then 'F' else 'NULL' END as 'Gender'
			                       
FROM         dbo.mstt_Agents INNER JOIN
                      dbo.cscv_AgentsHierarchy ON mstt_Agents.CODE = cscv_AgentsHierarchy.AgentCode INNER JOIN
                          (SELECT     CODE, MIN(ValidFromDate) AS FirstDate
                            FROM          dbo.mstt_AgentsHistory
                            GROUP BY CODE) AS A ON A.CODE = cscv_AgentsHierarchy.AgentCode LEFT OUTER JOIN
                      dbo.mstt_Agents AS mstt_Agents_3 ON mstt_Agents.Firm = mstt_Agents_3.CODE LEFT OUTER JOIN
                      dbo.mstt_Clients ON cscv_AgentsHierarchy.AgentCode = mstt_Clients.AgentCode LEFT OUTER JOIN
                      dbo.mstt_Agents AS mstt_Agents_2 ON mstt_Agents.SpanSupervisorCode = mstt_Agents_2.CODE LEFT OUTER JOIN
                      dbo.mstt_Agents AS mstt_Agents_1 ON mstt_Agents.SaleSupervisorCode = mstt_Agents_1.CODE LEFT JOIN
					  mi_insight_UserHierarchy UH on UH.UserUID = dbo.cscv_AgentsHierarchy.AgentCode 


