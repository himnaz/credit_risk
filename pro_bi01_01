					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, DATEADD(yy, DATEDIFF(yy, 0, GETDATE())-1, 0))+3,0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, DATEADD(yy, DATEDIFF(yy, 0, GETDATE())-1, 0))+6, 0) then #f.' + @COL + ' else 0 end) as PrevQ2_' + @COL + ','
