	--,0 AS 'Mortgage Loan Amount'
	--,Frequency

	--,'' AS 'UpfrontFee'
	--,'' AS 'MortgageCat'
	--,'' AS 'MortgageTrans'
	,'Owl' AS Channel

	FROM i LEFT JOIN 
		(SELECT UserUID UID FROM  mi_insight_userhierarchyallusers WHERE userjobtitlecodeseller = 61 AND effectiveenddate > GETDATE()) Panel	
		ON panel.UID = CASE WHEN i.Priadviser = '4007583' THEN '4007584' ELSE i.Priadviser END
		
	GROUP BY 
	Type
	,Adminmethod
	,PriAdviser
	,Firm
	,Productgroupname
	,Date
	,Day
	,ProductSubGroup
	,Month
	,Year 
	,YTD)
	--,Frequency)
	-------------- END OF FINAL OWL SUMMARY TABLE -------------------------------------------------

	-------------- FINAL WRITTEN BUSINESS OUTPUT CREATION ------------------------------
	INSERT dbo.WrittenBusiness
				([Type]
				,[Adviser]
				,[Firm]
				,[Date]
				,[Day]
				,[Month]
				,[Year]
				,[Premium]
				,[APE]
				,[NewPolicies]
				,[DA]
				,[Margin]
				,[ProductGroupName]
				,[ProductSubGroup]
				,[AdminMethod]
				,[Channel]
				)
		SELECT	 ISNULL([Type], '')
				,ISNULL([Adviser], '')
				,ISNULL([Firm], '')
				,ISNULL([Date], CAST('00010101' AS DATE))
				,ISNULL([Day], 1)
				,ISNULL([Month], 1)
				,ISNULL([Year], 1)
				,ISNULL([Premium], 0.0)
				,ISNULL([APE], 0.0)
				,ISNULL([NewPolicies], 0.0)
				,ISNULL([DA], 0.0)
				,ISNULL([Margin], 0.0)
				,ISNULL([ProductGroupName], '')
				,ISNULL([ProductSubGroup], '')
				,ISNULL([AdminMethod], '')
				,ISNULL([Channel], '')
		FROM	OW_Prod
		UNION ALL
		SELECT	 ISNULL([Type], '')
				,ISNULL([Adviser], '')
				,ISNULL([Firm], '')
				,ISNULL([Date], CAST('00010101' AS DATE))
				,ISNULL([Day], 1)
				,ISNULL([Month], 1)
				,ISNULL([Year], 1)
				,ISNULL([Premium], 0.0)
				,ISNULL([APE], 0.0)
				,ISNULL([NewPolicies], 0.0)
				,ISNULL([DA], 0.0)
				,ISNULL([Margin], 0.0)
				,ISNULL([ProductGroupName], '')
				,ISNULL([ProductSubGroup], '')
				,ISNULL([AdminMethod], '')
				,ISNULL([Channel], '')
		FROM	Owl_Prod;
END
