/******************************************************************************************************************

Date Created:	31/05/2019

Source:			Sarah Inglis (MI Team)

Script Name:	16. Policy Lifecycle Dates v0.22.sql

*******************************************************************************************************************/

CREATE Procedure [BI].[pr_016_PolicyLifecycleDates]

as

---------------------------
--issuedate
select distinct --min(createdatetime) issdate, 

CONVERT(DATE,min(ag.createdatetime),103) as createdatetime, min(coalesce(ex.cashreceiveddate,ex2.cashreceiveddate,ex3.cashreceiveddate)) as cashreceiveddate,
ag.providerref, ag.caseid
 into #iss from
 
mstt_PaymentsPending ag left join
msit_commissionstatement cs ON cs.PendingPaymentID = ag.id left join
mstt_expectation ex ON ex.id = cs.expectationid LEFT JOIN
(select max(cashreceiveddate) as cashreceiveddate, amount_rec, transactionid from mstt_expectation group by transactionid, amount_rec) ex2 ON ex2.transactionid = ag.transactionid and ag.amount = ex2.amount_rec LEFT OUTER JOIN
(select max(cashreceiveddate) as cashreceiveddate, transactionid from mstt_expectation group by transactionid) ex3 ON ex3.transactionid = ag.transactionid

where (ag.agent_code <> '10002' or ag.agent_code <> '1011623')
and ag.amount <> 0
and ag.commissiontype in ('1','4','10','17','18','19')
group  by ag.providerref, ag.caseid


---------------------------
--paiddate
select min(paymentdate) Paydate, policy,caseid into #paid from msit_OpenworkAdviserListing group by policy,caseid
---------------------------

select
pol.policyid,spol.cont_num--, pol.internalproductid
,pers.datecreated cl_createdate
,prod.displayname ows_prodName,prod.producttype ows_Prodtype, sd.Description ows_statusdesc

,pol.applicationdate ows_applicationdate,pol.datecreated ows_poldatecreated

,s.datesubmitted ows_datesubmitted
--,spol.CLIENT_NUM,
,spol.start_date swift_pol_startdate,spol.prop_date swift_propdate
,spol.inforce swift_inforcedate
,iss.cashreceiveddate swift_cashreceiveddate
,iss.createdatetime swift_iss_date
,paid.paydate swift_paydate
,s.adviseruid
,case when ag.manager2code = '1011671' then 'OWL' else'Openwork' end Brand


,case when ((left(prod.productcodeswift,2) in ('OW','OZ') AND prod.productcodeswift NOT IN ('OWADHOC','OWADVICE')) or prod.productcodeswift = 'OFHBSIPP' or ph.productprovidercode = 'Zurich PLT' or ph.productprovidercode = 'Pru PLT') then 'COB Platform'
      when prod.producttype in ('Pensions','Investment') then 'COB Off-Platform'
	  else prod.producttype end as 'ProductGroupName'


into #cbc


 from sa_ows_policies pol left join mstt_policies spol on spol.policyref = pol.policyid
						  left join sa_ows_Sale s on s.SaleID = pol.SaleID	
						  left join StaticData.sa_ows_PolicyStatus sd on sd.PolicyStatusID = pol.status
						  left join StaticData.sa_ows_ProductMergeView prod on prod.internalproductid = pol.internalproductid 
						  left join #iss iss on iss.caseid = spol.policyref and iss.providerref = spol.cont_num
						  left join #paid paid on paid.caseid = spol.policyref and paid.policy = spol.cont_num
						  left join sa_ows_person pers on pers.personid = s.personid
						  left join mstt_agents ag on ag.Code = s.adviseruid
						  left join mstt_ProductHierarchy ph on ph.productcode = prod.productcodeswift
	
 order by policyid desc


 select distinct

 year(ows_applicationdate) year,ProductGroupName, brand

 ,count(ows_applicationdate) ows_applicationdate 
 ,sum(case when ows_poldatecreated is not null  then 1 else 0 end) ows_poldatecreated
 ,sum(case when ows_datesubmitted is not null  then 1 else 0 end) ows_datesubmitted
 ,sum(case when swift_propdate is not null  then 1 else 0 end) 'swift_propdate(Writdate)'
 ,sum(case when swift_iss_date is not null  then 1 else 0 end) swift_issdate
 ,sum(case when swift_cashreceiveddate is not null  then 1 else 0 end) swift_cashreceiveddate
 ,sum(case when swift_paydate is not null  then 1 else 0 end) swift_paydate
 from #cbc

 where year(ows_applicationdate) >2010 and  year(ows_applicationdate) <= year(getdate())
 and ows_statusdesc not like 'Removed'
 group by  year(ows_applicationdate), ProductGroupName, brand

 order by[year] asc


 ------------------
 select year(ows_applicationdate) year,ProductGroupName, brand
, avg(datediff(dd,ows_applicationdate,ows_datesubmitted)) 'ows_datesubmitted-ows_applicationdate'
, avg(datediff(dd,ows_applicationdate,swift_propdate))	'swift_propdate-ows_applicationdate'
, avg(datediff(dd,ows_applicationdate,swift_iss_date))	'swift_iss_date-ows_applicationdate'
, avg(datediff(dd,ows_applicationdate,swift_cashreceiveddate))	'swift_cashreceiveddate-ows_applicationdate'
, avg(datediff(dd,ows_applicationdate,swift_paydate))	'swift_paydate-ows_applicationdate'

 from #cbc
 where  ows_statusdesc not like 'Removed'
 and year(ows_applicationdate) >2010 and  year(ows_applicationdate) <= year(getdate())
 group by year(ows_applicationdate),ProductGroupName, brand
 order by [year] asc


----------------------------------------------------
----------------------------------------------------

 select distinct

 year(ows_applicationdate) year,ProductGroupName, brand

,(count(cl_createdate)/count(cl_createdate))*100 'clients_created%'
,(count(ows_applicationdate)/count(ows_applicationdate))*100 'policies%'
,(sum(case when ows_poldatecreated is not null  then 1 else 0 end)/count(ows_applicationdate))*100 'policysubmitted%'
,round((convert(float,sum(case when swift_iss_date is not null  then 1 else 0 end))/convert(float,count(ows_applicationdate))*100),2) 'policyissued%'
,round((convert(float,sum(case when swift_paydate is not null  then 1 else 0 end))/convert(float,count(ows_applicationdate))*100),2) 'policypayed%'


 from #cbc

 where year(ows_applicationdate) >2010 and  year(ows_applicationdate) <= year(getdate())
 and ows_statusdesc not like 'Removed'
 group by  year(ows_applicationdate), ProductGroupName, brand

 order by[year] asc

 drop table #iss,#paid, #cbc


GO
