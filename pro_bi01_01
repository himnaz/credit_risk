                      CASE WHEN up6.UPS_JobTitle = '14' THEN ud6.USR_Name ELSE NULL END) AS [AD Name], UP.UPS_UserType, 
						s.STAF_IRN, s.STAF_ControlledFunctionStartdate, s.STAF_CustomerFunction
FROM         dbo.sa_insight_UserDetails AS UD LEFT OUTER JOIN
                          (SELECT     dbo.sa_insight_UserPosition.UPS_UserID, dbo.sa_insight_UserPosition.UPS_ID, dbo.sa_insight_Distributor.DIST_CompanyName, 
                                                   dbo.sa_insight_Distributor.DIST_Type, dbo.sa_insight_Distributor.DIST_ExternalID, dbo.sa_insight_Distributor.DIST_Category, 
