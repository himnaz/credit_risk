Source:			Sarah Inglis (MI Team)

Script Name:	11. OWL SODAN and Translator Cases.sql

*******************************************************************************************************************/

Create Procedure [BI].[pr_011_OwlSODANAndTranslatorCases]

as

select  distinct
convert(date,s.datesubmitted) datesubmitted
,pol.policyid, s.saleid, s.adviseruid, s.personid, cd.persontypeid
,pers.firstname,pers.lastname
,st1.valuename speakenglishid
,st2.valuename appropriateforspecialcare 

,st3.valuename deliverymethod
,spc.hasclientacceptedofferid, thirdpartypoaname, specialcaredeclinedreason

into #a
from sa_ows_policies pol inner join sa_ows_sale s on s.saleid = pol.saleid
						 inner join mstt_Agents ag on ag.Code = s.adviseruid

						 left join  sa_ows_FactFindOverviewClientDetails cd on cd.saleid = s.saleid
						 left join StaticData.sa_ows_InputValues st1 on st1.inputid = cd.speakenglishid
						 left join StaticData.sa_ows_InputValues st2 on st2.inputid = cd.appropriateforspecialcareid
						 left join sa_ows_FactFindOverviewSpecialCare spc on spc.saleid = s.saleid

						 left join SubmissionCondor.sa_ows_DispatchDocument con_dd on con_dd.saleid = s.saleid -- SODAN Status's
						 left join StaticData.sa_ows_InputValues st3 on st3.inputid =  con_dd.deliverymethod

						 left join sa_ows_person pers on pers.personid = s.personid


where ag.Manager2Code = '1011671' --and con_dd.deliverymethod is not null
		and year(s.datesubmitted) >= 2017
		and cd.persontypeid = 1
		--and hasclientacceptedofferid = 20

		
order  by policyid desc

----Sodan Types
select

deliverymethod,
sum(case when year(a.datesubmitted) = 2018 then 1 else 0 end) '2018_YTD'
,sum(case when year(a.datesubmitted) = 2017 then 1 else 0 end) '2017_Full'

from #a a

group by deliverymethod


--Translator Types

select 

Speakenglishid,hasclientacceptedofferid
,sum(case when year(a.datesubmitted) = 2018 and a.hasclientacceptedofferid <>20 then 1 else 0 end) '2018_YTD'
,sum(case when year(a.datesubmitted) = 2017 and a.hasclientacceptedofferid <>20 then 1 else 0 end) '2017_Full'

from #a a
group by Speakenglishid,hasclientacceptedofferid

drop table #a
