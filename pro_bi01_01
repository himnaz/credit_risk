WHILE @@FETCH_STATUS = 0

BEGIN 

	 IF @COL IN ('Premium','APE','NewPolicies','DA','Margin')
		--YTD
		BEGIN 
		BEGIN	 IF @s3YTD = 1
					BEGIN
					SET @CMD = @CMD + 'sum(case when #f.date >=convert(datetime,DATEADD(yy, DATEDIFF(yy, 0, GETDATE()), 0)) then #f.' + @COL + ' else 0 end) YTD_' + @COL + ','
					END
		END
		
		--Previous YTD
		BEGIN	 IF @s3YTD_Prev = 1
					BEGIN
					SET @CMD = @CMD + 'sum(case when #f.date >= convert(datetime,DATEADD(yy, DATEDIFF(yy, 0, GETDATE())-1, 0)) and #f.date <= convert(datetime,dateadd(yy,-1,DATEADD(dd, DATEDIFF(dd, 0, GETDATE()), 0))) then #f.' + @COL + ' else 0 end) Prev_YTD_' + @COL + ','
					END
		END	

		--All
		BEGIN	 IF @s3All = 1
					BEGIN
					SET @CMD = @CMD + 'sum(' + @COL + ') All_' + @COL + ','
					END
		END	

		-- Previous 52 weeks (monday to sunday) (loop) for weekly written (APE Only)

		BEGIN	IF @s3weekly = 1 and @COL in ('APE')
			BEGIN
			DECLARE Cursor_Wk CURSOR FOR

			select distinct convert(int,week) from msdt_CalendarTime  where week between 0 and 51 order by convert(int,week) desc;

			OPEN Cursor_Wk
			FETCH NEXT FROM Cursor_Wk INTO @wk
			WHILE @@FETCH_STATUS = 0
			BEGIN 
			
				SET @CMD = @CMD + 'sum(case when date <= convert(date,dateadd(dd, -7*' + @wk + ',getdate() - datepart(dw,getdate()))) and date > convert('
				SET @CMD = @CMD + 'date,dateadd(dd, -7*' + convert(varchar,@wk + 1) + ',getdate() - datepart(dw,getdate()))) then '+@COL+' else 0 end) ''Wk_'+@wk+'_' + @COL + ''','

			FETCH NEXT FROM Cursor_Wk INTO @wk
			END	
			


			CLOSE Cursor_Wk
			DEALLOCATE Cursor_Wk
			END	
	
		END
		 --Current Year Quarterly
		BEGIN	IF @s3Quart = 1
					BEGIN  
					SET @CMD = @CMD + 'sum(case when #f.date >=convert(datetime,DATEADD(yy, DATEDIFF(yy, 0, GETDATE()), 0)) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, DATEADD(yy, DATEDIFF(yy, 0, GETDATE()), 0))+3, 0) then #f.' + @COL + ' else 0 end) as Q1_' + @COL +','
