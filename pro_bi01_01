                      THEN 'No' ELSE 'Yes' END AS Selling, cd5.Code_Description AS [Adviser Employment Status], cd7.Code_Description AS [Contract Status], 
                      N.DIST_TradingName, 
                      CASE WHEN up1.UPS_JobTitle = '8' THEN ud1.USR_ExternalID END AS [Supervisor UID], 
                      CASE WHEN up1.UPS_JobTitle = '8' THEN ud1.USR_Name END AS [Supervisor Name], 
                      COALESCE (CASE WHEN up1.UPS_JobTitle = '7' THEN ud1.USR_ExternalID ELSE NULL END, 
                      CASE WHEN up2.UPS_JobTitle = '7' THEN ud2.USR_ExternalID ELSE NULL END) AS [BQM UID], 
                      COALESCE (CASE WHEN up1.UPS_JobTitle = '7' THEN ud1.USR_Name ELSE NULL END, 
                      CASE WHEN up2.UPS_JobTitle = '7' THEN ud2.USR_Name ELSE NULL END) AS [BQM Name], 
                      COALESCE (CASE WHEN up1.UPS_JobTitle = '9' THEN ud1.USR_ExternalID ELSE NULL END, 
                      CASE WHEN up2.UPS_JobTitle = '9' THEN ud2.USR_ExternalID ELSE NULL END, 
                      CASE WHEN up3.UPS_JobTitle = '9' THEN ud3.USR_ExternalID ELSE NULL END) AS [AQM UID], 
                      COALESCE (CASE WHEN up1.UPS_JobTitle = '9' THEN ud1.USR_Name ELSE NULL END, 
                      CASE WHEN up2.UPS_JobTitle = '9' THEN ud2.USR_Name ELSE NULL END, CASE WHEN up3.UPS_JobTitle = '9' THEN ud3.USR_Name ELSE NULL 
                      END) AS [AQM Name], COALESCE (CASE WHEN up1.UPS_JobTitle = '14' THEN ud1.USR_ExternalID ELSE NULL END, 
                      CASE WHEN up2.UPS_JobTitle = '14' THEN ud2.USR_ExternalID ELSE NULL END, 
                      CASE WHEN up3.UPS_JobTitle = '14' THEN ud3.USR_ExternalID ELSE NULL END, 
                      CASE WHEN up4.UPS_JobTitle = '14' THEN ud4.USR_ExternalID ELSE NULL END, 
                      CASE WHEN up6.UPS_JobTitle = '14' THEN ud6.USR_ExternalID ELSE NULL END) AS [AD UID], 
                      COALESCE (CASE WHEN up1.UPS_JobTitle = '14' THEN ud1.USR_Name ELSE NULL END, 
                      CASE WHEN up2.UPS_JobTitle = '14' THEN ud2.USR_Name ELSE NULL END, CASE WHEN up3.UPS_JobTitle = '14' THEN ud3.USR_Name ELSE NULL 
                      END, CASE WHEN up4.UPS_JobTitle = '14' THEN ud4.USR_Name ELSE NULL END, 
                      CASE WHEN up6.UPS_JobTitle = '14' THEN ud6.USR_Name ELSE NULL END) AS [AD Name], UP.UPS_UserType, 
						s.STAF_IRN, s.STAF_ControlledFunctionStartdate, s.STAF_CustomerFunction
FROM         dbo.sa_insight_UserDetails AS UD LEFT OUTER JOIN
                          (SELECT     dbo.sa_insight_UserPosition.UPS_UserID, dbo.sa_insight_UserPosition.UPS_ID, dbo.sa_insight_Distributor.DIST_CompanyName, 
                                                   dbo.sa_insight_Distributor.DIST_Type, dbo.sa_insight_Distributor.DIST_ExternalID, dbo.sa_insight_Distributor.DIST_Category, 
                                                   dbo.sa_insight_Distributor.DIST_Status, dbo.sa_insight_Distributor.DIST_TradingName
                            FROM          dbo.sa_insight_UserPosition INNER JOIN
                                                   dbo.sa_insight_HierarchyNodeLink AS hnl1 ON hnl1.HNL_ParentID = dbo.sa_insight_UserPosition.UPS_ID AND GETDATE() BETWEEN 
                                                   hnl1.HNL_DateFrom AND ISNULL(hnl1.HNL_DateTo, 'Dec 31, 9999') INNER JOIN
                                                   dbo.sa_insight_HierarchyNodeLink AS hnl2 ON hnl2.HNL_NodeID = hnl1.HNL_NodeID AND GETDATE() BETWEEN 
                                                   hnl2.HNL_DateFrom AND ISNULL(hnl2.HNL_DateTo, 'Dec 31, 9999') INNER JOIN
                                                   dbo.sa_insight_HierarchyNodeLink AS hnl3 ON hnl3.HNL_NodeID = hnl2.HNL_ParentID AND GETDATE() BETWEEN 
                                                   hnl3.HNL_DateFrom AND ISNULL(hnl3.HNL_DateTo, 'Dec 31, 9999') INNER JOIN
                                                   dbo.sa_insight_Distributor ON dbo.sa_insight_Distributor.DIST_ID = hnl3.HNL_ParentID
                            WHERE      (dbo.sa_insight_UserPosition.UPS_UserType = 3) AND (GETDATE() BETWEEN dbo.sa_insight_UserPosition.UPS_DateFrom AND 
                                                   ISNULL(dbo.sa_insight_UserPosition.UPS_DateTo, 'Dec 31, 9999'))) AS N ON N.UPS_UserID = UD.USR_ID INNER JOIN
                      dbo.sa_insight_Staff AS S ON UD.USR_ID = S.STAF_UserID INNER JOIN
                      dbo.sa_insight_UserPosition AS UP ON UD.USR_ID = UP.UPS_UserID INNER JOIN
                      dbo.sa_insight_UserPositionLink AS UPL ON UP.UPS_ID = UPL.UPSL_ChildUserPositionID INNER JOIN
                      dbo.sa_insight_UserPosition AS up1 ON UPL.UPSL_ParentUserPositionID = up1.UPS_ID INNER JOIN
                      dbo.sa_insight_UserDetails AS ud1 ON up1.UPS_UserID = ud1.USR_ID INNER JOIN
                      dbo.sa_insight_UserPositionLink AS upl1 ON up1.UPS_ID = upl1.UPSL_ChildUserPositionID INNER JOIN
                      dbo.sa_insight_UserPosition AS up2 ON upl1.UPSL_ParentUserPositionID = up2.UPS_ID INNER JOIN
                      dbo.sa_insight_UserDetails AS ud2 ON up2.UPS_UserID = ud2.USR_ID INNER JOIN
                      dbo.sa_insight_UserPositionLink AS upl2 ON up2.UPS_ID = upl2.UPSL_ChildUserPositionID INNER JOIN
                      dbo.sa_insight_UserPosition AS up3 ON upl2.UPSL_ParentUserPositionID = up3.UPS_ID INNER JOIN
                      dbo.sa_insight_UserDetails AS ud3 ON up3.UPS_UserID = ud3.USR_ID INNER JOIN
                      dbo.sa_insight_UserPositionLink AS upl3 ON up3.UPS_ID = upl3.UPSL_ChildUserPositionID INNER JOIN
                      dbo.sa_insight_UserPosition AS up4 ON upl3.UPSL_ParentUserPositionID = up4.UPS_ID INNER JOIN
                      dbo.sa_insight_UserDetails AS ud4 ON up4.UPS_UserID = ud4.USR_ID INNER JOIN
                      dbo.sa_insight_UserPositionLink AS upl4 ON up4.UPS_ID = upl4.UPSL_ChildUserPositionID INNER JOIN
                      dbo.sa_insight_UserPosition AS up6 ON upl4.UPSL_ParentUserPositionID = up6.UPS_ID LEFT OUTER JOIN
                      dbo.sa_insight_UserPosition AS up5 ON UD.USR_ID = up5.UPS_UserID AND DATEADD(dd, 0, DATEDIFF(dd, 0, GETDATE())) BETWEEN 
                      up5.UPS_DateFrom AND ISNULL(up5.UPS_DateTo, 'Dec 31, 9999') AND up5.UPS_JobTitle IN (4, 42) INNER JOIN
                      dbo.sa_insight_UserDetails AS ud6 ON up6.UPS_UserID = ud6.USR_ID LEFT OUTER JOIN
                      dbo.sa_insight_CodeDescription ON UP.UPS_JobTitle = dbo.sa_insight_CodeDescription.Code_Code AND 
                      sa_insight_CodeDescription.Code_CodeType = 54 LEFT OUTER JOIN
                      dbo.sa_insight_CodeDescription AS cd1 ON up1.UPS_JobTitle = cd1.Code_Code AND cd1.Code_CodeType = 54 LEFT OUTER JOIN
                      dbo.sa_insight_CodeDescription AS cd2 ON up2.UPS_JobTitle = cd2.Code_Code AND cd2.Code_CodeType = 54 LEFT OUTER JOIN
                      dbo.sa_insight_CodeDescription AS cd3 ON up3.UPS_JobTitle = cd3.Code_Code AND cd3.Code_CodeType = 54 LEFT OUTER JOIN
                      dbo.sa_insight_CodeDescription AS cd4 ON up4.UPS_JobTitle = cd4.Code_Code AND cd4.Code_CodeType = 54 LEFT OUTER JOIN
                      dbo.sa_insight_CodeDescription AS cd5 ON S.STAF_EmploymentStatus = cd5.Code_Code AND cd5.Code_CodeType = 125 LEFT OUTER JOIN
                      dbo.sa_insight_CodeDescription AS cd6 ON UD.USR_Type = cd6.Code_Code AND cd6.Code_CodeType = 11 LEFT OUTER JOIN
                      dbo.sa_insight_CodeDescription AS cd7 ON S.STAF_ContractStatus = cd7.Code_Code AND cd7.Code_CodeType = 527 LEFT OUTER JOIN
                      dbo.sa_insight_CodeDescription AS cd8 ON up6.UPS_JobTitle = cd8.Code_Code AND cd8.Code_CodeType = 54
WHERE     (UPL.UPSL_DateTo IS NULL) AND (upl1.UPSL_DateTo IS NULL) AND (upl2.UPSL_DateTo IS NULL) AND (upl3.UPSL_DateTo IS NULL) AND 
                      (UP.UPS_JobTitle NOT IN (28, 29, 30)) AND (NOT (UP.UPS_UserType IN (5, 10, 201))) AND (upl4.UPSL_DateTo IS NULL) --AND 
                      --(S.STAF_ContractStatus <> '3')
