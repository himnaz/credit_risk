/******************************************************************************************************************

Date Created:	31/05/2019

Source:			Sarah Inglis (MI Team)

Script Name:	10. Owl Mortgage Referral Payaway.sql

*******************************************************************************************************************/

Create Procedure [BI].[pr_010_OwlMortgageReferralPayaway]

as

Declare @Month int
Set @Month = DATEPART(month,dateadd(month,-1,getdate()))


-- Config payment thresholds
Select
0 as LowFee,
124999 as HighFee,
142 as SellingAdviser
into #ReferralFeeRates
Union
Select
125000 as LowFee,
249999 as HighFee,
213 as SellingAdviser
Union
Select
250000 as LowFee,
399999 as HighFee,
284 as SellingAdviser
Union
Select
400000 as LowFee,
10000000 as HighFee,
355 as SellingAdviser

--drop table #ReferralFeeRates

select 
 uh.UserUID
,left(STAF_Forename,1) + ' ' + STAF_Surname as AdviserName
,uh.OwlASMUID1 as ASM
,STAF_RecruitedByName as Introducer
,STAF_NoticePeriod as MOM
,cd.Code_Description
,left(cd.Code_description,3) as PanelMarker
into #Payaway
from mi_insight_UserHierarchy uh
join sa_insight_Staff staf on staf.STAF_UserID = uh.UserGUID
join sa_insight_UserPosition ups on ups.UPS_UserID = uh.UserGUID and UPS_UserType = 3 and UPS_DateTo is null
join sa_insight_CodeDescription cd on cd.Code_Code = ups.UPS_Section and cd.Code_CodeType = 53
where ADUID = 4005013 and UserContractStatusCode = 1

Select '010' as Panel,30 as ASM,0 as ESM,0 as Introducer
into #OwlSplits
Union
Select '011' as Panel,20 as ASM,0 as ESM,15 as Introducer
Union
Select '012' as Panel,20 as ASM,0 as ESM,20 as Introducer
Union
Select '013' as Panel,30 as ASM,5 as ESM,0 as Introducer
Union
Select '014' as Panel,20 as ASM,5 as ESM,20 as Introducer
Union
Select '015' as Panel,20 as ASM,5 as ESM,15 as Introducer
Union
Select '016' as Panel,0 as ASM,0 as ESM,0 as Introducer
Union
Select '017' as Panel,40 as ASM,0 as ESM,0 as Introducer
Union
Select '018' as Panel,20 as ASM,0 as ESM,30 as Introducer
Union
Select '019' as Panel,40 as ASM,0 as ESM,5 as Introducer
Union
Select '020' as Panel,20 as ASM,0 as ESM,30 as Introducer
Union
Select '021' as Panel,30 as ASM,20 as ESM,0 as Introducer
Union
Select '022' as Panel,10 as ASM,20 as ESM,30 as Introducer
Union
Select '023' as Panel,15 as ASM,0 as ESM,0 as Introducer
Union
Select '025' as Panel,15 as ASM,0 as ESM,20 as Introducer
Union
Select '026' as Panel,15 as ASM,5 as ESM,20 as Introducer
Union
Select '027' as Panel,0 as ASM,0 as ESM,20 as Introducer
Union
Select '029' as Panel,5 as ASM,0 as ESM,30 as Introducer
Union
Select '033' as Panel,25 as ASM,0 as ESM,10 as Introducer
Union
Select '034' as Panel,25 as ASM,5 as ESM,10 as Introducer


Select 
MorgtageAdviceID,
case when mrf.BrokerFeeReceivedDate > edic.CommissionReceivedDate then mrf.BrokerFeeReceivedDate else edic.CommissionReceivedDate end as LatestDate,
CaseID,
Left(pers.FirstName,1)+' '+pers.LastName as Client,
comp.DESCN,
ReferrerUID,
pol.CONT_NUM,
edic.PremiumAmount,
rfr.SellingAdviser,
pay.AdviserName,
pay.PanelMarker,
pay.ASM as ASMCode,
spl.ASM,
pay.Introducer as IntroCode,
spl.Introducer,
pay.MOM as ESMCode,
spl.ESM
into #MortgageReferralTotals
from MBFAPP.dbo.MortgageReferralFees mrf
join mstt_Policies pol on pol.PolicyRef = mrf.CaseID
join sa_swift_EDIFACTCommissionStatementContents edic on edic.PolicyNumber = pol.CONT_NUM
join #ReferralFeeRates rfr on edic.PremiumAmount between rfr.LowFee and rfr.HighFee
join #Payaway pay on pay.UserUID = ReferrerUID
join #OwlSplits spl on spl.Panel = pay.PanelMarker
join sa_ows_Sale sale on sale.SaleID = MorgtageAdviceID
join sa_ows_Person pers on pers.PersonID = sale.PersonID
join sa_swift_S_COMANY comp on comp.CODE = pol.COMP_CODE
where BrokerFeeReceived = 'Y' and ProcFeeMatched = 'Yes' and Deleted = 0

Select
DATEADD(MONTH, DATEDIFF(MONTH, 0, LatestDate), 0) as LatestDate,
'0000106' as SOCode,
uh.BusinessUID,
convert(varchar,getdate(),103) as StartDate,
convert(varchar,dateadd(day,2,getdate()),103) as EndDate,
'6' as Type,
round(mrt.SellingAdviser,2) as Amount,
Left((convert(varchar(7),mrt.MorgtageAdviceID)+ ' ' + mrt.DESCN + ' Clt:' + mrt.Client),50) as SODescription 
into #StandingOrderData
from #MortgageReferralTotals mrt
join mi_insight_UserHierarchy uh on uh.UserUID = mrt.ReferrerUID
Union
Select
DATEADD(MONTH, DATEDIFF(MONTH, 0, LatestDate), 0) as LatestDate,
'0000106' as SOCode,
uh.BusinessUID,
convert(varchar,getdate(),103) as StartDate,
convert(varchar,dateadd(day,2,getdate()),103) as EndDate,
'6' as Type,
cast(round((convert(decimal(10,2),mrt.SellingAdviser)*convert(decimal(10,2),mrt.ASM)/100),2)as decimal(10,2)) as Amount,
Left((convert(varchar(7),mrt.MorgtageAdviceID) + ' Clt:' + mrt.Client + ' '+ mrt.ReferrerUID),50)
from #MortgageReferralTotals mrt
join mi_insight_UserHierarchy uh on uh.UserUID = mrt.ASMCode
Union
Select
DATEADD(MONTH, DATEDIFF(MONTH, 0, LatestDate), 0) as LatestDate,
'0000106' as SOCode,
uh.BusinessUID,
convert(varchar,getdate(),103) as StartDate,
convert(varchar,dateadd(day,2,getdate()),103) as EndDate,
'6' as Type,
round(convert(decimal(10,2),mrt.SellingAdviser)*convert(decimal(10,2),mrt.Introducer)/100,2) as Amount,
left((convert(varchar(7),mrt.MorgtageAdviceID) + ' Clt:' + mrt.Client + ' Adv:' + mrt.ReferrerUID),50)
from #MortgageReferralTotals mrt
join mi_insight_UserHierarchy uh on uh.UserUID = mrt.IntroCode
Union
Select
DATEADD(MONTH, DATEDIFF(MONTH, 0, LatestDate), 0) as LatestDate,
'0000106' as SOCode,
uh.BusinessUID,
convert(varchar,getdate(),103) as StartDate,
convert(varchar,dateadd(day,2,getdate()),103) as EndDate,
'6' as Type,
round(convert(decimal(10,2),mrt.SellingAdviser)*convert(decimal(10,2),mrt.ESM)/100,2) as Amount,
Left((convert(varchar(7),mrt.MorgtageAdviceID) + ' Clt:' + mrt.Client + ' Adv:' + mrt.ReferrerUID),50)
from #MortgageReferralTotals mrt
join mi_insight_UserHierarchy uh on uh.UserUID = mrt.ESMCode
order by SODescription

--Standing orders to be saved in notepad as .csv and sent to Payments to implement
Select
SOCode + ','+convert(varchar(7),BusinessUID) +','+StartDate+','+EndDate+','+convert(varchar,cast(Amount as decimal(18,2)))+','+convert(varchar(1),Type)+','+SODescription
from #StandingOrderData
where Year(LatestDate) = 2018 and Month(LatestDate) = @Month

--Breakdown at case level of completions in month
Select * from #MortgageReferralTotals where Year(LatestDate) = 2018 and Month(LatestDate) = @Month

--Breakdown at payment level of completions in month
Select * from #StandingOrderData where Year(LatestDate) = 2018 and Month(LatestDate) = @Month



drop table #StandingOrderData,#MortgageReferralTotals,#OwlSplits,#Payaway, #ReferralFeeRates
GO
