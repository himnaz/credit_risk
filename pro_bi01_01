DECLARE COLUMN_CURSOR CURSOR FOR
select distinct year(pers.datecreated) year from sa_ows_person pers inner join mstt_agents ag on ag.code = pers.adviseruid and ag.manager2code ='1011671' order by year
OPEN COLUMN_CURSOR
FETCH NEXT FROM COLUMN_CURSOR INTO @COL
WHILE @@FETCH_STATUS = 0
BEGIN 

		SET @CMD = @CMD + 'sum(case when year(datecreated) = '+ @COL + ' then 1 else null end) ''' + @COL + '_Clients'','

