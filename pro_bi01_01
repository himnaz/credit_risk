                      dbo.sa_insight_UserDetails AS ud6 ON up6.UPS_UserID = ud6.USR_ID LEFT OUTER JOIN
                      dbo.sa_insight_CodeDescription ON UP.UPS_JobTitle = dbo.sa_insight_CodeDescription.Code_Code AND 
                      sa_insight_CodeDescription.Code_CodeType = 54 LEFT OUTER JOIN
                      dbo.sa_insight_CodeDescription AS cd1 ON up1.UPS_JobTitle = cd1.Code_Code AND cd1.Code_CodeType = 54 LEFT OUTER JOIN
