	(case when providercode in ('Payment shield', 'PYMTSHLD') then month - 27 else month end) >= DATEADD(yy, DATEDIFF(yy, 0, GETDATE()) - 2, 0)
	and providercode in ('GI', 'Payment shield', 'PYMTSHLD')
	and feetype <> 'RC'
	and feetype <> 'Trail'
	and feetype <> 'TF'
	and APE <> 0
	and (rtrim(ah.ASDName) NOT IN('Pat Mckenna', 'Owl Sales Director') or oa.sellercode <> '1011623' or ah.ASDName is Null)
	group by 
