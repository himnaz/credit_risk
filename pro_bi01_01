                            FROM          dbo.sa_insight_UserPosition INNER JOIN
                                                   dbo.sa_insight_HierarchyNodeLink AS hnl1 ON hnl1.HNL_ParentID = dbo.sa_insight_UserPosition.UPS_ID AND GETDATE() BETWEEN 
                                                   hnl1.HNL_DateFrom AND ISNULL(hnl1.HNL_DateTo, 'Dec 31, 9999') INNER JOIN
                                                   dbo.sa_insight_HierarchyNodeLink AS hnl2 ON hnl2.HNL_NodeID = hnl1.HNL_NodeID AND GETDATE() BETWEEN 
                                                   hnl2.HNL_DateFrom AND ISNULL(hnl2.HNL_DateTo, 'Dec 31, 9999') INNER JOIN
                                                   dbo.sa_insight_HierarchyNodeLink AS hnl3 ON hnl3.HNL_NodeID = hnl2.HNL_ParentID AND GETDATE() BETWEEN 
                                                   hnl3.HNL_DateFrom AND ISNULL(hnl3.HNL_DateTo, 'Dec 31, 9999') INNER JOIN
                                                   dbo.sa_insight_Distributor ON dbo.sa_insight_Distributor.DIST_ID = hnl3.HNL_ParentID
                            WHERE      (dbo.sa_insight_UserPosition.UPS_UserType = 3) AND (GETDATE() BETWEEN dbo.sa_insight_UserPosition.UPS_DateFrom AND 
                                                   ISNULL(dbo.sa_insight_UserPosition.UPS_DateTo, 'Dec 31, 9999'))) AS N ON N.UPS_UserID = UD.USR_ID INNER JOIN
                      dbo.sa_insight_Staff AS S ON UD.USR_ID = S.STAF_UserID INNER JOIN
                      dbo.sa_insight_UserPosition AS UP ON UD.USR_ID = UP.UPS_UserID INNER JOIN
                      dbo.sa_insight_UserPositionLink AS UPL ON UP.UPS_ID = UPL.UPSL_ChildUserPositionID INNER JOIN
                      dbo.sa_insight_UserPosition AS up1 ON UPL.UPSL_ParentUserPositionID = up1.UPS_ID INNER JOIN
                      dbo.sa_insight_UserDetails AS ud1 ON up1.UPS_UserID = ud1.USR_ID INNER JOIN
                      dbo.sa_insight_UserPositionLink AS upl1 ON up1.UPS_ID = upl1.UPSL_ChildUserPositionID INNER JOIN
                      dbo.sa_insight_UserPosition AS up2 ON upl1.UPSL_ParentUserPositionID = up2.UPS_ID INNER JOIN
                      dbo.sa_insight_UserDetails AS ud2 ON up2.UPS_UserID = ud2.USR_ID INNER JOIN
                      dbo.sa_insight_UserPositionLink AS upl2 ON up2.UPS_ID = upl2.UPSL_ChildUserPositionID INNER JOIN
                      dbo.sa_insight_UserPosition AS up3 ON upl2.UPSL_ParentUserPositionID = up3.UPS_ID INNER JOIN
                      dbo.sa_insight_UserDetails AS ud3 ON up3.UPS_UserID = ud3.USR_ID INNER JOIN
                      dbo.sa_insight_UserPositionLink AS upl3 ON up3.UPS_ID = upl3.UPSL_ChildUserPositionID INNER JOIN
                      dbo.sa_insight_UserPosition AS up4 ON upl3.UPSL_ParentUserPositionID = up4.UPS_ID INNER JOIN
                      dbo.sa_insight_UserDetails AS ud4 ON up4.UPS_UserID = ud4.USR_ID INNER JOIN
