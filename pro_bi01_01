	else (case when ph.productsubgroupname like '%Annuity' then 'COB Off Platform' else ph.productgroupname end) end,

	(case when ((ph.productgroupname <> 'Mortgage' and co.adminmethod NOT IN ('A','G')) or ph.productsubgroupname like '%Guaranteed Account%' or rp.reportingproductname = 'Zurich Bank Structured Product' or ph.productsubgroupname like '%Group Pension%' or po.comp_code = 'Zurich Leg' or co.productcode = 'ZGUA' or po.comp_code = 'Close' or po.comp_code = 'MSQ') then 'Non Advised' else 'Advised' end)
	,rp.reportingproductname

	set @RowCount = @@ROWCOUNT

	set @Message = '#Issued_Swift Population 2'
	exec BI.pr_ProcessLog @PhaseLog, @Message, @Module, @Client, @RowCount

	/****************************************************************************

		Populate temp table with Openwork legacy

	****************************************************************************/

	insert into #Issued_Swift
	(
		Type,
		Adviser,
		Firm,
		Date,
		Day,
		Month,
		Year,
		Premium,
		APE,
		NewPolicies,
		Cases,
		DA,
		Margin,
		NBI,
		reportingproductname,
		ProductGroupName,
		ProductGroupName2,
		ProductSubGroup,
		Adminmethod,
		Channel
	)
	select 
	'Issued' as "Type",
	REPLACE(CAST(oa.sellercode AS varchar), Char(9),'') AS Adviser,
	oa.businesscode as Firm,
	CAST(oa.month AS DATE) as Date, 
	'1' as "Day", month(oa.month) as "Month", year(oa.month) as "Year",
	sum(oa.ape) as "Premium",
	sum(oa.ape) as "APE",
	"NewPolicies" = 0,
	0 as Cases,
	sum(case when ph.productgroupname = 'Mortgage' then oa.ape else oa.totdue_enhd/0.8163 end) as "DA",

	sum(case when ph.productgroupname = 'Mortgage' then oa.ape - oa.totdue_enhd else ((oa.totdue_enhd/0.8163) - oa.totdue_enhd) end) as "Margin",
	
	sum((case when ph.productgroupname = 'Mortgage' then oa.ape else oa.totdue_enhd/0.8163 end) - (case when ph.productgroupname = 'Mortgage' then oa.ape - oa.totdue_enhd else ((oa.totdue_enhd/0.8163) - oa.totdue_enhd) end)) as NBI,
	rp.reportingproductname as reportingproductname,

	case when oa.provider='General Insurance' then 'GI' when oa.provider='SIML' then 'COB Off Platform' when oa.provider='Sterling' then 'COB Off Platform' when oa.provider='Scottish Equitable' then 'COB Off Platform' when oa.prodtype = 'PE' then 'COB Off Platform' when ph.productgroupname in ('Pensions','Investment') then 'COB Off Platform' else isNull(ph.productgroupname,'Protection') end as productgroupname,
	'Legacy ' + case when oa.provider='General Insurance' then 'GI' when oa.provider='SIML' then 'COB Off Platform' when oa.provider='Sterling' then 'COB Off Platform' when oa.provider='Scottish Equitable' then 'COB Off Platform' when oa.prodtype = 'PE' then 'COB Off Platform' else (case when isNull(ph.productgroupname,'Protection') = 'Protection' then 'Zurich' else isNull(ph.productgroupname,'Protection') end) end as productgroupname2,

	'Legacy ' + case when oa.provider='General Insurance' then 'GI' when oa.provider='SIML' then 'COB Off Platform' when oa.provider='Sterling' then 'COB Off Platform' when oa.provider='Scottish Equitable' then 'COB Off Platform' when oa.prodtype = 'PE' then 'COB Off Platform' else (case when isNull(ph.productgroupname,'Protection') = 'Protection' then 'Zurich' else isNull(ph.productgroupname,'Protection') end) end as productsubgroupname,

	'Non Advised' as "AdminMethod"

	,CASE WHEN (ah.ASDCode in('4019902') OR oa.businesscode = '2016789') THEN 'Owl AR' ELSE 'Openwork' END AS Channel
	--,'Openwork' AS Channel

	from msit_openworkadviserlisting oa left outer join 
	msit_feesNonSwiftFeeListing fnsfl on fnsfl.ID = oa.sourceID left outer join
	mstt_producthierarchy ph on 'NBI_'+ fnsfl.productCode = ph.productCode left outer join
	cscv_AgentsHierarchy ah ON oa.businesscode = ah.agentcode left outer join
	cscv_AgentsHierarchy ah1 ON oa.sellercode = ah1.agentcode LEFT OUTER JOIN
	msit_CodeReportingProductCode rp ON rp.Code = ph.ReportingProductCode

	where
	(oa.month) >= @StartDate --DATEADD(yy, DATEDIFF(yy, 0, GETDATE()) - 2, 0)
	and oa.feetype <> 'RC'
	and oa.feetype <> 'Trail'
	and oa.feetype <> 'TF'
	and oa.source = 'openwork 2005'
	and oa.providercode <> 'GI'
	and ((ape + totdue_enhd) <> 0)
	and (fnsfl.id <> '27617494' or fnsfl.id is NULL)
	----------------------------EXCLUDE ALL GROUP PENSION BUSINESS--------------------------------
	and (case when ph.productsubgroupname NOT IN ('Group Pension') then 1 when (ph.productsubgroupname = 'Group Pension'and year(oa.month) <2016) then 1 else 0 end) = 1
	----------------------------------------------------------------------------------------------
	group by

	CAST (oa.month AS DATE), oa.businesscode, oa.sellercode,
	month(oa.month), year(oa.month),
	CASE WHEN (ah.ASDCode in('4019902') OR oa.businesscode = '2016789') THEN 'Owl AR' ELSE 'Openwork' END,
	case when oa.provider='General Insurance' then 'GI' when oa.provider='SIML' then 'COB Off Platform' when oa.provider='Sterling' then 'COB Off Platform' when oa.provider='Scottish Equitable' then 'COB Off Platform' when oa.prodtype = 'PE' then 'COB Off Platform' when ph.productgroupname in ('Pensions','Investment') then 'COB Off Platform' else isNull(ph.productgroupname,'Protection') end,
	case when oa.provider='General Insurance' then 'GI' when oa.provider='SIML' then 'COB Off Platform' when oa.provider='Sterling' then 'COB Off Platform' when oa.provider='Scottish Equitable' then 'COB Off Platform' when oa.prodtype = 'PE' then 'COB Off Platform' when ph.productgroupname in ('Pensions','Investment') then 'COB Off Platform' else isNull(ph.productgroupname,'Protection') end,

	'Legacy ' + case when oa.provider='General Insurance' then 'GI' when oa.provider='SIML' then 'COB Off Platform' when oa.provider='Sterling' then 'COB Off Platform' when oa.provider='Scottish Equitable' then 'COB Off Platform' when oa.prodtype = 'PE' then 'COB Off Platform' else (case when isNull(ph.productgroupname,'Protection') = 'Protection' then 'Zurich' else isNull(ph.productgroupname,'Protection') end) end
	,rp.reportingproductname

	set @RowCount = @@ROWCOUNT

	set @Message = '#Issued_Swift Population 3'
	exec BI.pr_ProcessLog @PhaseLog, @Message, @Module, @Client, @RowCount

	/****************************************************************************

		Populate temp table with Openwork GI

	****************************************************************************/

	insert into #Issued_Swift
	(
		Type,
		Adviser,
		Firm,
		Date,
		Day,
		Month,
		Year,
		Premium,
		APE,
		NewPolicies,
		Cases,
		DA,
		Margin,
		NBI,
		reportingproductname,
		ProductGroupName,
		ProductGroupName2,
		ProductSubGroup,
		Adminmethod,
		Channel
	)
	select
	'Issued' as "Type",
	REPLACE(CAST(oa.sellercode AS varchar), Char(9),'') AS Adviser,
	oa.businesscode as Firm,
	CAST((case when providercode in ('Payment shield', 'PYMTSHLD') then month - 27 else month end)AS DATE) as Date, 
	'1' as Day,
	month(case when providercode in ('Payment shield', 'PYMTSHLD') then month - 27 else month end) as month, 
	year(case when providercode in ('Payment shield', 'PYMTSHLD') then month - 27 else month end) as year,
	sum(case when providercode = 'GI' then ((totdue_base/27.5)*35) else ape end) as "Premium",
	sum(case when providercode = 'GI' then ((totdue_base/27.5)*35) else ape end) as "APE",
	
	Round(SUM(CASE WHEN oa.ProviderCode = 'GI' THEN ((totdue_base/27.5)*35)/121
			 ELSE Case WHEN oa.Remarks = 'New Business' THEN 1 
					   ELSE 0 
				  END
		 END),2) as "NewPolicies",

	Round(sum(case when providercode = 'GI' then ((totdue_base/27.5)*35) else ape end / 121),2) as "Cases",

	sum(case when providercode = 'GI' then ((totdue_base/27.5)*35) else ape end) as "DA",
	sum(case when (businesscode <> '1010904' AND rtrim(ah.asdname) = 'GHL') then (case when oa.providercode = 'GI' then ((totdue_base/27.5)*35) else (ape) end- (totdue_enhd))-((case when oa.providercode = 'GI' then ((totdue_base/27.5)*35) else (ape) end - (totdue_enhd)) *0.7) when rtrim(ah.asdname) = 'First Affinity' then (case when oa.providercode = 'GI' then ((totdue_base/27.5)*35) else (ape) end - (totdue_enhd)) -((totdue_enhd)*(10.0/9) - (totdue_enhd)) else case when oa.providercode = 'GI' then ((totdue_base/27.5)*35) else (ape) end - (totdue_enhd) end) as "Margin", 

	sum(case when (businesscode <> '1010904' AND rtrim(ah.asdname) = 'GHL') then (totdue_enhd)+ ((case when oa.providercode = 'GI' then ((totdue_base/27.5)*35) else (ape) end - (totdue_enhd))*0.7) when rtrim(ah.asdname) = 'First Affinity' then (totdue_enhd)*(10.0/9) else (totdue_enhd) end) as NBI,
	'GI' as reportingproductname,
	'GI' as ProductGroupName,
	'GI' as ProductGroupName2,
	providercode as ProductSubGroupName,
	'Advised' as AdminMethod
	,CASE WHEN (ah.ASDCode in('4019902') OR oa.businesscode = '2016789') THEN 'Owl AR' ELSE 'Openwork' END AS Channel
	--,'Openwork' AS Channel

	-- paymentshield month - 31 as paymentshield in open access has been pushed forward
	from msit_openworkadviserlisting oa LEFT OUTER JOIN
	cscv_AgentsHierarchy ah ON oa.businesscode = ah.agentcode
	where 
	(case when providercode in ('Payment shield', 'PYMTSHLD') then month - 27 else month end) >= @StartDate --DATEADD(yy, DATEDIFF(yy, 0, GETDATE()) - 2, 0)
	and providercode in ('GI', 'Payment shield', 'PYMTSHLD')
	and feetype <> 'RC'
	and feetype <> 'Trail'
	and feetype <> 'TF'
	and APE <> 0
	and (rtrim(ah.ASDName) NOT IN('Pat Mckenna', 'Owl Sales Director') or oa.sellercode <> '1011623' or ah.ASDName is Null)
	group by 
	CAST((case when providercode in ('Payment shield', 'PYMTSHLD') then month - 27 else month end)AS DATE), 
	month(case when providercode in ('Payment shield', 'PYMTSHLD') then month - 27 else month end), 
	year(case when providercode in ('Payment shield', 'PYMTSHLD') then month - 27 else month end),
	providercode, oa.businesscode, oa.sellercode,
	CASE WHEN (ah.ASDCode in('4019902') OR oa.businesscode = '2016789') THEN 'Owl AR' ELSE 'Openwork' END

	set @RowCount = @@ROWCOUNT

	set @Message = '#Issued_Swift Population 4'
	exec BI.pr_ProcessLog @PhaseLog, @Message, @Module, @Client, @RowCount

	/****************************************************************************

		Populate temp table with Openwork Mortgage Broker Fees

	****************************************************************************/

	insert into #Issued_Swift
	(
		Type,
		Adviser,
		Firm,
		Date,
		Day,
		Month,
		Year,
		Premium,
		APE,
		NewPolicies,
		Cases,
		DA,
		Margin,
		NBI,
		reportingproductname,
		ProductGroupName,
		ProductGroupName2,
		ProductSubGroup,
		Adminmethod,
		Channel
	)
	Select 
	'Issued' as "Type",
	CAST(MBF.AdviserUID AS varchar) AS Adviser,
	MBF.FirmUID AS Firm, 
	CAST(MBF.PaymentMatchedDate AS DATE) as "Date", 
	Day(MBF.PaymentMatchedDate) as "Day", 
	Month(MBF.PaymentMatchedDate) as "Month", 
	Year(MBF.PaymentMatchedDate) as "Year",
	' ' as Premium, 
	SUM(MBF.APE) as "APE", 
	SUM(MBF.AgentSplit)/100 as "New Policies",
	SUM(MBF.AgentSplit)/100 as "Cases",
	SUM(MBF.APE) as "DA", 
	Sum(MBF.DeductionAmount*-1) as "Margin", 
	SUM((MBF.AdviceFeeAmount*(MBF.AgentSplit/100))+MBF.DeductionAmount) as 'Net Comm',
	'Mortgage Broker Fee' AS reportingproductname,
	'Mortgage Broker Fee' as productgroupname,
	'Mortgage Broker Fee' as productgroupname2,
	'MBF' as ProductSubGroupName,
	'Advised' as "AdminMethod"
	,CASE WHEN (ah.ASDCode in('4019902') OR MBF.FirmUID = '2016789') THEN 'Owl AR' ELSE 'Openwork' END AS Channel
	--,'Openwork' AS Channel

	FROM dbo.owt_MortgageBrokerFees MBF JOIN
	cscv_AgentsHierarchy ah ON MBF.FirmUID = ah.agentcode

	where
	(MBF.PaymentMatchedDate) >= @StartDate --DATEADD(yy, DATEDIFF(yy, 0, GETDATE()) - 2, 0)
	and (MBF.AdviceFeeCharged = 'Yes' AND MBF.AdviceFeeAmount > 0)
	and transactionID = (select max(TransactionID)
									from dbo.owt_MortgageBrokerFees MBF2
									where MBF2.policyID = MBF.PolicyID)
	and MBF.PolicyID NOT IN ('553043388','552888151','553107012') --- EXCLUDE INCORRECT CASES EG. CASE ID 553043388 INCORRECT IN CH AT £500,000 INSTEAD OF £500

	Group by CAST(MBF.PaymentMatchedDate AS DATE)
	, Day(MBF.PaymentMatchedDate)
	, Month(MBF.PaymentMatchedDate)
	, Year(MBF.PaymentMatchedDate)
	, MBF.FirmUID
	, MBF.AdviserUID
	, CASE WHEN (ah.ASDCode in('4019902') OR MBF.FirmUID = '2016789') THEN 'Owl AR' ELSE 'Openwork' END

	set @RowCount = @@ROWCOUNT

	set @Message = '#Issued_Swift Population 5'
	exec BI.pr_ProcessLog @PhaseLog, @Message, @Module, @Client, @RowCount

	/****************************************************************************

		BSC Rebate - agent uplifts

	****************************************************************************/

	--Create Agent Uplift Rate table with start and end date
	Select 
	ROW_NUMBER() over(partition by au.agentcode, au.productcode order by au.dateinforce) as RowNum,
	au.AgentCode,
	au.DateInForce,
	au.ProductCode,
	au.UpliftRate,
	au.Status,
	au.PolicyType
	into #AgentUpliftTable
	from sa_swift_AgentUplifts au
	join mstt_ProductHierarchy ph on ph.ProductCode = au.ProductCode and ph.ProductCategoryCode = 1
	where status = 0

	set @RowCount = @@ROWCOUNT

	set @Message = '#AgentUpliftTable Population'
	exec BI.pr_ProcessLog @PhaseLog, @Message, @Module, @Client, @RowCount

	/****************************************************************************

		BSC Rebate - enterprise uplifts

	****************************************************************************/

	Select
	aut.RowNum,
	aut.AgentCode,
	aut.DateInForce,
	aut.UpliftRate,
	aut.ProductCode,
	isnull(dateadd(day,-1,aut2.dateinforce),'31-Dec-3099')  as EndDate,
	aut2.RowNum as NewRow
	into #FranchiseUpliftRate
	from #AgentUpliftTable aut
	left join #AgentUpliftTable aut2 on aut2.AgentCode = aut.AgentCode 
									and aut2.ProductCode = aut.ProductCode
									and aut2.RowNum = aut.RowNum +1

	set @RowCount = @@ROWCOUNT

	set @Message = '#FranchiseUpliftRate Population'
	exec BI.pr_ProcessLog @PhaseLog, @Message, @Module, @Client, @RowCount

	/****************************************************************************

		BSC Rebate - expectation ID

	****************************************************************************/

	Select
	pacc_id
	into #pacc
	from mstt_PaymentsPending
	where AGENT_CODE = '1011587'
	and CommissionMonth >= @PaymentMonth

	set @RowCount = @@ROWCOUNT

	set @Message = '#pacc Population'
	exec BI.pr_ProcessLog @PhaseLog, @Message, @Module, @Client, @RowCount

	/****************************************************************************

		BSC Rebate - DA amount

	****************************************************************************/

	Select
	pp.PACC_ID,
	sum(amount) as DA
	into #DAAmount
	from mstt_PaymentsPending pp
	join #pacc pc on pc.PACC_ID = pp.PACC_ID
	where CommissionMonth >= @PaymentMonth
	Group by pp.PACC_ID

	set @RowCount = @@ROWCOUNT

	set @Message = '#DAAmount Population'
	exec BI.pr_ProcessLog @PhaseLog, @Message, @Module, @Client, @RowCount

	/****************************************************************************

		BSC Rebate - Create Table of all payments in month

	****************************************************************************/

	Select pp.ID, pacc_id, AGENT_CODE, AGENT_PERC, isnull(franchiseagentcode,AccessAgentCode) as franchiseagentcode, TransactionID, CaseID, ProviderRef
	into #FirmPayments
	from mstt_paymentspending pp
	join mstt_clients clt on clt.client_num = firstclientid 
	where 
	manager2code != '1011671' and
	CommissionMonth >= @PaymentMonth

	set @RowCount = @@ROWCOUNT

	set @Message = '#FirmPayments Population'
	exec BI.pr_ProcessLog @PhaseLog, @Message, @Module, @Client, @RowCount

	/****************************************************************************

		BSC Rebate - Create split of payments across BSC/Margin/Other Splits

	****************************************************************************/
	
	Select
	ROW_Number() over (Partition By fp.pacc_ID order by fp.Agent_Code) as Row_Num,
	fp.ID,
	fp.Pacc_id, 
	fp.AGENT_CODE,
	fp.Agent_Perc,
	fp.franchiseagentcode,
	fp.TransactionID,
	fp.CaseID,
	fp.ProviderRef,
	convert(date,pp.createdatetime) as CreateDate,
	case when ph.rdrtype is not null then 'Wealth' else ProductCategoryName end as Product,
	sum(case when pp.franchiseagentcode = fp.FranchiseAgentcode then pp.Amount end) as FirmPayment,
	sum(case when pp.franchiseagentcode != fp.franchiseAgentcode and pp.franchiseAgentCode is not null then pp.Amount end) as OtherFirmPayment,
	sum(case when pp.franchiseagentcode != fp.franchiseAgentcode and pp.franchiseAgentCode is not null then pp.Agent_perc end) as OtherFirmPct,
	sum(case when pp.agent_code = '10002' then pp.Amount end) as OWMargin,
	sum(case when pp.agent_code = '1011543' then pp.Amount end) as OWFeeMargin,
	sum(case when pp.agent_code = '1011543' then pp.AGent_perc end) as OWFeePct,
	sum(case when pp.agent_code = '1011587' then pp.Amount end) as BSC,
	sum(case when pp.agent_code = '1011587' then pp.agent_perc end) as BSCPct,
	pp.FirstClientID
	into #Payment
	from #FirmPayments fp
	Join mstt_paymentspending pp on pp.pacc_id = fp.pacc_id
	join mstt_producthierarchy ph on ph.productcode = pp.tranproduct
	group by fp.id, fp.Pacc_id, 
	fp.AGENT_CODE,
	convert(date,pp.createdatetime),
	fp.franchiseagentcode, 
	pp.FirstClientID,
	case when ph.rdrtype is not null then 'Wealth' else ProductCategoryName end,
	fp.TransactionID, fp.CaseID, fp.ProviderRef, fp.agent_perc

	set @RowCount = @@ROWCOUNT

	set @Message = '#Payment Population'
	exec BI.pr_ProcessLog @PhaseLog, @Message, @Module, @Client, @RowCount

	/****************************************************************************

		BSC Rebate - Limit to only where there is BSC present and calculate splits

	****************************************************************************/

	Select
	p.id,
	p.AGENT_CODE,
	p.agent_perc,
	p.FranchiseAgentCode,
	agt.Descn,
	agt.CompetentStatusDescription,
	p.TransactionID,
	p.CaseID,
	p.ProviderRef,
	p.PACC_ID,
	p.firmpayment,
	p.OtherFirmPayment,
	p.OWFeeMargin,
	p.BSC,
	p.BSCPct,
	p.OWFeePct,
	com.FranchiseUpliftPercent,
	pt.ProposalDate,
	p3.Agent_code as agent3Code,
	p3.Agent_perc as agent3pct,
	com3.franchiseupliftpercent as agent3uplift,
	p3.Agent_Perc/(com3.franchiseupliftpercent-20)*100 as Agent3Gross,
	p2.Agent_code as Agent2Code,
	p2.Agent_perc as Agent2Pct,
	com2.franchiseupliftpercent as agent2uplift,
	p2.Agent_Perc/(com2.franchiseupliftpercent-20)*100 as Agent2Gross,
	p.Agent_Perc/(com.franchiseupliftpercent-20)*100 as Agent1Gross,
	100 - p.BSCPct as RemainingSplit,
	p.AGENT_PERC/(isnull(com.franchiseupliftpercent,fur.upliftrate)-20)*100 as TruePCt,
	round(((p.AGENT_PERC/(isnull(com.franchiseupliftpercent,fur.upliftrate)-20))*100)/(100 - p.BSCPct)*100,0)
	 as AgentTruePct,
	isnull(com.franchiseupliftpercent,fur.upliftrate)-20 as PaymentUpliftRate,
	da.DA,
	p.FirstClientID,
	p.CreateDate
	into #FinalRebateTable
	from #Payment p
	join mstt_agents agt on agt.code = franchiseagentcode
	join mstt_PolicyTransactions pt on pt.id = p.TransactionID
	left join #DAAmount da on da.PACC_ID = p.PACC_ID
	left join mstt_Commissions com on com.TransactionID = p.transactionid and com.CommissionType = 1 and p.AGENT_CODE = com.AGENT_CODE
	left join #Payment p2 on p2.pacc_id = p.pacc_id and p2.Row_num =  case when p.Row_Num = 1 then 2
																		   when p.Row_Num = 2 then 1
																		   when p.Row_num = 3 then 1 end
	left join #Payment p3 on p3.pacc_id = p.pacc_id and p3.Row_num =  case when p.Row_Num = 1 then 3
																		   when p.Row_Num = 2 then 3
																		   when p.Row_num = 3 then 2 end
	left join mstt_Commissions com2 on com2.TransactionID = p2.transactionid and com2.CommissionType = 1 and p2.AGENT_CODE = com2.AGENT_CODE
	left join mstt_Commissions com3 on com3.TransactionID = p3.transactionid and com3.CommissionType = 1 and p3.AGENT_CODE = com3.AGENT_CODE
	left join #FranchiseUpliftRate fur on fur.AgentCode = p.franchiseagentcode and pt.ProposalDate between fur.DateInForce and fur.EndDate and pt.CommProductCode = fur.ProductCode
	left join #FranchiseUpliftRate fur2 on fur2.AgentCode = p2.franchiseagentcode and pt.ProposalDate between fur2.DateInForce and fur2.EndDate and pt.CommProductCode = fur2.ProductCode
	left join #FranchiseUpliftRate fur3 on fur3.AgentCode = p3.franchiseagentcode and pt.ProposalDate between fur3.DateInForce and fur3.EndDate and pt.CommProductCode = fur3.ProductCode
	where p.BSC is not null

	set @RowCount = @@ROWCOUNT

	set @Message = '#FinalRebateTable Population'
	exec BI.pr_ProcessLog @PhaseLog, @Message, @Module, @Client, @RowCount

	/****************************************************************************

		BSC Rebate - Calculate Rebate Amount

	****************************************************************************/

	Select 
	ID,
	Agent_code,
	Agent_perc,
	FranchiseAgentCode,
	Descn,
	CompetentStatusDescription,
	CaseID,
	ProviderRef,
	Pacc_ID,
	FirmPayment,
	BSC,
	BSCPct,
	ProposalDate,
	RemainingSplit,
	AgentTruePct,
	PaymentUpliftRate,
	case when FranchiseUpliftPercent is null then 'Derived' else 'Actual' end as CalcType,
	CASE WHEN frt.CreateDate < '1 Jun 2021' THEN BSC*(AgentTruePct/100)*(PaymentUpliftRate/100)*0.5
	ELSE BSC*(AgentTruePct/100)*(PaymentUpliftRate/100)
	END AS AmountDue,
	BSC*(AgentTruePct/100) as BSCSplitAmount,
	frt.DA as OngoingDA,
	frt.TransactionID,
	FirstClientID,
	frt.CreateDate
	into #QuickCheck
	from #FinalRebateTable frt

	UNION

	Select pp.id, com.agent_code, com.agent_perc,com.franchiseagentcode,agt.descn,agt.competentstatusdescription, pp.caseid, pp.providerref,pp.pacc_id,0, pp.Amount, pp.Agent_perc, com.proposaldate,0,com.agent_perc,com.franchiseupliftpercent-20,'Derived - All BSC',
	--pp.Amount*(com.franchiseupliftpercent-20)/100*0.5,
	CASE WHEN convert(date,pp.CreateDateTime) < '1 Jun 2021' THEN pp.Amount*(com.franchiseupliftpercent-20)/100*0.5
		 ELSE pp.Amount*(com.franchiseupliftpercent-20)/100
	END,
	pp.Amount*(com.agent_perc/100) as BSCSplitAmount,pp.AMOUNT,pp.TransactionID, pp.FirstClientID, convert(date,pp.CreateDateTime)
	from mstt_paymentspending pp
	join mstt_commissions com on com.transactionid = pp.transactionid and com.commissiontype = 1 and com.agent_code != '10002'
	join mstt_agents agt on agt.code = com.franchiseagentcode
	where pp.commissionmonth >= @PaymentMonth and pp.agent_code = '1011587' and pp.Agent_perc = 100 and pp.agent_code != '1006886'

	set @RowCount = @@ROWCOUNT

	set @Message = '#QuickCheck Population'
	exec BI.pr_ProcessLog @PhaseLog, @Message, @Module, @Client, @RowCount

	/****************************************************************************

		BSC Rebate - Final Rebate Amount

	****************************************************************************/

	Select
	'Issued' AS Type,
	Cast(Agent_code AS varchar) AS Adviser,
	FranchiseAgentCode AS Firm,
	qc.CreateDate as Date,
	DAY(qc.CreateDate) as Day,
	Month(qc.createdate) as Month,
	Year(qc.Createdate) as Year,
	0 as Premium,
	0 as APE,
	0 as NewPolicies,
	0 as Cases,
	--sum(AmountDue)*-1 as DA, --BSCRebate,
	0 as DA,
	sum(AmountDue)*-1 as Margin, --BSCRebate,
	sum(AmountDue) as NBI,
	'BSC Rebate' AS reportingproductname,
	'Recurring Income' AS ProductGroupName,
	'BSC Rebate' AS ProductGroupName2,
	'BSC Rebate' AS ProductSubGroup,
	'' AS AdminMethod,
	case when agt.Manager2Code = '4010386' or Firm = '2016789' then 'Owl AR' else 'Openwork' end as Channel
	--'Openwork' AS Channel
	into #FinalBSCRebate
	from #QuickCheck qc
	join mstt_Clients clt on CLIENT_NUM = FirstClientID
	join mstt_PolicyTransactions pt on pt.ID = TransactionID
	join mstt_agents agt on agt.CODE = qc.AGENT_CODE
	WHERE Firm NOT IN ('2004449', '1001031') --Excludes Firms who do not get BSC Rebate Newcastle Financial Advisers (1002524) & JMD (2005309) Now included
	Group by
	DAY(qc.CreateDate),
	Month(qc.createdate),
	Year(qc.Createdate),
	Agent_code,
	FranchiseAgentCode,
	case when agt.Manager2Code = '4010386' or Firm = '2016789' then 'Owl AR' else 'Openwork' end,
	qc.CreateDate

	set @RowCount = @@ROWCOUNT

	set @Message = '#FinalBSCRebate Population'
	exec BI.pr_ProcessLog @PhaseLog, @Message, @Module, @Client, @RowCount

	/****************************************************************************

		Empty final table
		Note: the proxy account that runs the SQL Agent Job doesn't have 
		permission to TRUNCATE the table. Hence a DELETE is needed.

	****************************************************************************/

	DELETE bi.IssuedBusiness

	/****************************************************************************

		Populate final table

	****************************************************************************/

	INSERT bi.IssuedBusiness
				([Type]
				,[Adviser]
				,[Firm]
				,[Date]
				,[Day]
				,[Month]
				,[Year]
				,[Premium]
				,[APE]
				,[NewPolicies]
/**********************************************************************
NEW COLUMNS ADDED
**********************************************************************/
				
				,[Cases]

/*********************************************************************/
				,[DA]
				,[Margin]
/**********************************************************************
NEW COLUMNS ADDED
**********************************************************************/
				,[NBI]
				,[reportingproductname]
/*********************************************************************/
				,[ProductGroupName]
				,[ProductGroupName2]
				,[ProductSubGroup]
				,[AdminMethod]
				,[Channel]
				)
		SELECT	 ISNULL([Type], '')
				,ISNULL([Adviser], '')
				,ISNULL([Firm], '')
				,ISNULL([Date], CAST('00010101' AS DATE))
				,ISNULL([Day], 1)
				,ISNULL([Month], 1)
				,ISNULL([Year], 1)
				,ISNULL([Premium], 0.0)
				,ISNULL([APE], 0.0)
				,ISNULL([NewPolicies], 0.0)
/**********************************************************************
NEW COLUMNS ADDED
**********************************************************************/
				,ISNULL([Cases], 0.0)
/*********************************************************************/
				,ISNULL([DA], 0.0)
				,ISNULL([Margin], 0.0)
/**********************************************************************
NEW COLUMNS ADDED
**********************************************************************/
