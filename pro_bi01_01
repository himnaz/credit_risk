                      dbo.sa_insight_UserPosition AS up6 ON upl4.UPSL_ParentUserPositionID = up6.UPS_ID LEFT OUTER JOIN
                      dbo.sa_insight_UserPosition AS up5 ON UD.USR_ID = up5.UPS_UserID AND DATEADD(dd, 0, DATEDIFF(dd, 0, GETDATE())) BETWEEN 
