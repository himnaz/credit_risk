		,sum(case when f.date >= convert(date,DATEADD(mm, datediff(mm, 0, getdate()-1), 0)) then 1 else 0 end) Cur_monthTD

		--quarter
		,sum(case when f.date >= convert(date,@quarts, 0) then 1 else 0 end) Cur_quarterTD

		--year
		,sum(case when f.date >= convert(date,DATEADD(yy, datediff(yy, 0, getdate()-1), 0)) then 1 else 0 end) Cur_yearTD

		-------------
