                             ADD NBI, TOTAL CASES & ReportingProductName INTO FINAL TABLE
***********************************************************************************************************************/
			SUM(mdaf.brokerfeeamount*AGENT_PERC/100) - SUM(CASE WHEN ah.ASDName in ('First Affinity','GHL') THEN ((mdaf.brokerfeeamount*AGENT_PERC/100)*0.05) 
																ELSE (((mdaf.brokerfeeamount*AGENT_PERC/100) * (100 - (FranchiseUpliftPercent - (CASE WHEN sale.businessUID = '2005309' THEN 22.79 
																																					  ELSE 20 
																																				  END)))/100)) 
