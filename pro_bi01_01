Source:			Sarah Inglis (MI Team)

Script Name:	15. Panel Lapses.sql

*******************************************************************************************************************/

Create Procedure [BI].[pr_015_PanelLapses]

as

select  distinct

ps.caseid,ps.ProviderRef
into #panclaw
from mstt_paymentspending ps
 inner join mi_insight_userhierarchyallusers uh on uh.useruid = ps.agent_code and uh.EffectiveEndDate >getdate() and aduid = '4005013'

 left join sa_ows_policies p on p.policyid = ps.CaseID
 inner join sa_ows_sale s on s.saleid = p.SaleID
 
 
 where userjobtitlecodeseller between 60 and 63
  and ps.amount <0
 and TranProduct not like '%owl%'


 ------------------------------------------------------------------------------------------------
 ------------------------------------------------------------------------------------------------
 ------------------------------------------------------------------------------------------------
 -- NTU's
 select
 ps.CaseID,ps.ProviderRef,ps.TranProduct
 ,sum(case when commissiontypedesc like 'initi%' then amount else 0 end) Intitial
 ,sum(case when commissiontypedesc not like 'initi%' then amount else 0 end) Claw	
   into #ntu  
  from mstt_paymentspending ps inner join #panclaw c on c.CaseID = ps.caseid and c.ProviderRef = ps.providerref

group by  ps.CaseID,ps.ProviderRef,ps.TranProduct

having sum(case when commissiontypedesc like 'initi%' then amount else 0 end) +
 sum(case when commissiontypedesc not like 'initi%' then amount else 0 end) = 0	

 order by [caseid] desc,[providerref] desc


 ------------------------------------------------------------------------------------------------
 ------------------------------------------------------------------------------------------------
 ------------------------------------------------------------------------------------------------

 -- Not NTU's (for manual process)
 select
 ps.CaseID,ps.ProviderRef,ps.TranProduct--,ps.DUE_DATE
 ,sum(case when commissiontypedesc like 'initi%' then amount else 0 end) Intitial
 ,sum(case when commissiontypedesc not like 'initi%' then amount else 0 end) Claw	
 ,sum(ps.amount) 'All'
 
     

  from mstt_paymentspending ps inner join #panclaw c on c.CaseID = ps.caseid and c.ProviderRef = ps.providerref
  left join #ntu ntu on ntu.CaseID = ps.CaseID and ntu.ProviderRef = ps.ProviderRef

  where ntu.CaseID is null
   
group by  ps.CaseID,ps.ProviderRef,ps.TranProduct--,ps.DUE_DATE
having not sum(case when commissiontypedesc like 'initi%' then amount else 0 end)/sum(ps.amount) between 1.98 and 2.01
 
 order by [caseid] desc,[providerref] desc



 select * from #ntu
 --drop table #panclaw, #ntu


  select top 100 * From mstt_paymentspending where providerref = 'PR000003S1D' order by due_Date desc
GO
