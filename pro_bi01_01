		writdate,
		Promotiondate
	)
	select
	'Issued' as 'Type',
	convert(varchar, case when dp.adviserUID = '1012011' then '1012002' else dp.adviserUID end) AS Adviser,
	ah.FirmCode AS Firm,
	'Advised' as adminmethod,
	CASE WHEN dp.Source LIKE 'WESSEX' THEN 'GI' ELSE 'Protection' END as productgroupname,
	CASE WHEN dp.Source LIKE 'WESSEX' THEN 'GI' ELSE 'Protection' END as productgroupname2,
	CASE WHEN dp.Source LIKE 'L&G' THEN 'L&GASU OWL'											--|
		 WHEN dp.Source LIKE 'WESSEX' THEN 'WESSEX OWL'											--| ADDED WESSESX TO BOTH THE 
	END AS ProductSubGroup,																		--| PRODUCT SUB GROUP AND THE
	CASE WHEN dp.Source LIKE 'L&G' THEN 'LPL&G'													--|	PRODUCTSUBTYPE STATEMENT
		 WHEN dp.Source LIKE 'WESSEX' THEN 'LPWESSEX'											--| 
	END AS Productsubtype,
	'LP OWL' Daily_Category,
	dateadd(mm,1,dp.Commissionmonth) as date,
	day(dateadd(mm,1,dp.Commissionmonth)) as day,
	month(dateadd(mm,1,dp.Commissionmonth)) as month,
	year(dateadd(mm,1,dp.Commissionmonth)) as year,
	sum((dp.GrossPremium)) as premium,
	sum((dp.GrossPremium)) as APE,
	sum((case when e.transactionID = dp.ID then 1 else 0 end)) as Newpolicies,
	0 Cases,
	sum((dp.GrossPremium*0.35)) as DA,
	sum((dp.OpenworkActualMarginamt)) as Margin,
	 0 NBI,
	CASE 
		 WHEN dp.Source LIKE 'L&G' THEN 'L&GASU OWL'		
		 WHEN dp.Source LIKE 'WESSEX' THEN 'WESSEX OWL'		
	END AS reportingproductname,
	ah.agentstartdate as startdate,
	dp.CommissionAuthorisationDate,
	pr.Promotiondate
	from dbo.owt_OwlDirectPayments dp
		 left join #Pol_Ref_Count e on e.transactionID = dp.ID
		 left join cscv_AgentsHierarchy ah on ah.Agentcode = dp.adviserUID
		 left join #Manager_Prom pr on pr.Usr_login = dp.adviserUID
		 left join #Comm_Month p on p.policyreference = dp.policyreference
	where
		((Transactiontype like '%New%Business%'					--| WRAP SOURCE LIKE 'L&G' AND TRANS TYPE IN BRACKETS
		and dp.source like 'L&G') OR dp.source Like 'Wessex')	--| ADD ADDITIONAL CLAUSE 'OR SOURCE LIKE WESSEX'
		and Grosspremium >=0 and Grosspremium is not null
		and e.policyreference = dp.policyreference
		and (dp.Commissionmonth) >= @StartDate
		and (dp.Commissionmonth) <= @EndDate
		and p.policyreference is null
	group by
	dp.adviserUID,
	ah.FirmCode,
	CASE WHEN dp.Source LIKE 'WESSEX' THEN 'GI' ELSE 'Protection' END,
	CASE WHEN dp.Source LIKE 'WESSEX' THEN 'GI' ELSE 'Protection' END,
	CASE 
		 WHEN dp.Source LIKE 'L&G' THEN 'L&GASU OWL'		--|
		 WHEN dp.Source LIKE 'WESSEX' THEN 'WESSEX OWL'		--| ADDED WESSESX TO BOTH THE 
	END,													--| PRODUCT SUB GROUP AND THE
	CASE WHEN dp.Source LIKE 'L&G' THEN 'LPL&G'				--|	PRODUCTSUBTYPE STATEMENT
		 WHEN dp.Source LIKE 'WESSEX' THEN 'LPWESSEX'		--| 
	END,
	dp.Commissionmonth,
	day(dp.Commissionmonth),
	month(dp.Commissionmonth),
	year(dp.Commissionmonth),
	ah.agentstartdate,
	dp.CommissionAuthorisationDate,
	pr.Promotiondate

	set @RowCount = @@ROWCOUNT

	set @Message = '#Owl_Issued_Swift Population 2'
	exec BI.pr_ProcessLog @PhaseLog, @Message, @Module, @Client, @RowCount

