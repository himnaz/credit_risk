"Gross DA" = 0, "DA Claw" = 0, "Net DA" = 0, "Gross Comm" = 0, "Comm Claw" = 0,  "Net Comm" = 0, "Gross Margin (Pre Claw)" = 0, "Margin Claw" = 0,
"Comm Adj" = 0, "Gross Margin" = 0, "Net Charges" = 0, "Contribution" = 0


from 
mstt_Commissions co LEFT OUTER JOIN
mstt_Policytransactions pt on co.transactionid = pt.id LEFT OUTER JOIN
mstt_Policies po on pt.policyid = po.pol_num LEFT OUTER JOIN
mstt_ProductHierarchy ph ON co.ProductCode = ph.productcode LEFT OUTER JOIN
msit_CodeReportingProductCode rp ON rp.Code = ph.ReportingProductCode LEFT OUTER JOIN
msit_CodeCommissionShape ccs ON ccs.id = pt.codecommissionshapeid LEFT OUTER JOIN
cscv_AgentsHierarchy ah ON co.firm = ah.agentcode LEFT OUTER JOIN
#b b on b.transactionid = co.transactionid


where
co.agent_code <> '10002'
and pt.createdatetime >= @StartDate
and pt.createdatetime <= @EndDate
and co.commissiontype = 1
and ph.rdrtype is not null
and pt.comminitialamount <= 0 and pt.amount > 0
and co.poltrantranstype = 17
----------EXCLUDE ALL GROUP PENSION BUSINESS---------------------------
and (case when ph.productsubgroupname NOT IN ('Group Pension') then 1 when (ph.productsubgroupname = 'Group Pension'and year(pt.createdatetime) <2016) then 1 else 0 end) = 1
-----------------------------------------------------------------------

group by 
month(pt.createdatetime), year(pt.createdatetime),
case when ph.productsubgroupname like '%Annuity' then 'Annuity' when ((left(co.productcode,2) in ('OW','OZ')) or co.productcode = 'OFHBSIPP' or co.productprovidercode = 'Zurich PLT' or co.productprovidercode = 'Pru PLT') then 'COB Platform' when ph.productgroupname in ('Pensions','Investment') then 'COB Off-Platform' else ph.productgroupname end

UNION ALL
---LEGACY

select 

month(oa.month) as "month", year(oa.month) as "year", 
case when oa.provider='General Insurance' then 'GI' when oa.provider='SIML' then 'COB Off-Platform' when oa.provider='Sterling' then 'COB Off-Platform' when oa.provider='Scottish Equitable' then 'COB Off-Platform' when oa.prodtype = 'PE' then 'Annuity' when ph.productgroupname in ('Pensions','Investment') then 'COB Off-Platform' else isNull(ph.productgroupname,'Protection') end as productgroupname,
"Written NB APE" = 0, "Written NB Cases" = 0,
sum(oa.ape) as "Issued APE",
"NB Cases" = 0,
sum(case when oa.ape < 0 then -oa.agentsplit/100 when oa.ape = 0 then 0 else oa.agentsplit/100 end) as Cases,

sum(case when ph.productgroupname = 'Mortgage' then oa.ape else oa.totdue_enhd/0.8163 end) as "Gross DA",
"DA Claw" = 0,
sum(case when ph.productgroupname = 'Mortgage' then oa.ape else oa.totdue_enhd/0.8163 end) as "Net DA",
sum(oa.totdue_enhd) as "Gross Comm",
"Comm Claw" = 0,
sum(oa.totdue_enhd) as "Net Comm",
sum(case when ph.productgroupname = 'Mortgage' then oa.ape - oa.totdue_enhd else ((oa.totdue_enhd/0.8163) - oa.totdue_enhd) end) as "Gross Margin (Pre Claw)",
"Margin Claw" = 0,
"Comm Adj" = 0,
sum(case when ph.productgroupname = 'Mortgage' then oa.ape - oa.totdue_enhd else ((oa.totdue_enhd/0.8163) - oa.totdue_enhd) end) as "Gross Margin",
"Net Charges" = 0,
sum(case when ph.productgroupname = 'Mortgage' then oa.ape - oa.totdue_enhd else ((oa.totdue_enhd/0.8163) - oa.totdue_enhd) end) as "Contribution"

