					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(dd, DATEDIFF(dd, 0, ''' + convert(varchar,@rundate) + ''')-365, 0) then #f.' + @COl + ' else 0 end) as R12Month' + @COL + ','
					END

			
		END
		-- Previous Year Quarterly
		BEGIN	IF @s3QuartP = 1
					BEGIN
					SET @CMD = @CMD + 'sum(case when #f.date >=convert(datetime,DATEADD(yy, DATEDIFF(yy, 0, ''' + convert(varchar,@rundate) + ''')-1, 0)) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, DATEADD(yy, DATEDIFF(yy, 0, ''' + convert(varchar,@rundate) + ''')-1, 0))+3, 0) and #f.date <= ''' + convert(varchar,dateadd(yy,-1,@rundate)-1)+ ''' then #f.' + @COL + ' else 0 end) as PrevQ1_' + @COL +','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, DATEADD(yy, DATEDIFF(yy, 0, ''' + convert(varchar,@rundate) + ''')-1, 0))+3,0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, DATEADD(yy, DATEDIFF(yy, 0, ''' + convert(varchar,@rundate) + ''')-1, 0))+6, 0) and #f.date <= ''' + convert(varchar,dateadd(yy,-1,@rundate)-1)+ ''' then #f.' + @COL + ' else 0 end) as PrevQ2_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, DATEADD(yy, DATEDIFF(yy, 0, ''' + convert(varchar,@rundate) + ''')-1, 0))+6,0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, DATEADD(yy, DATEDIFF(yy, 0, ''' + convert(varchar,@rundate) + ''')-1, 0))+9, 0) and #f.date <= ''' + convert(varchar,dateadd(yy,-1,@rundate)-1)+ ''' then #f.' + @COL + ' else 0 end) as PrevQ3_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, DATEADD(yy, DATEDIFF(yy, 0, ''' + convert(varchar,@rundate) + ''')-1, 0))+9,0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, DATEADD(yy, DATEDIFF(yy, 0, ''' + convert(varchar,@rundate) + ''')-1, 0))+12, 0) and #f.date <= ''' + convert(varchar,dateadd(yy,-1,@rundate)-1)+ ''' then #f.' + @COL + ' else 0 end) as PrevQ4_' + @COL +','
					END
		END  

		-- Custom Dates

		BEGIN	IF @s3cust = 1
					BEGIN  
					SET @CMD = @CMD + 'sum(case when #f.date >=''' + @s3custsdate + ''' and #f.date <=''' + @s3custedate + ''' then #f.' + @COL + ' else 0 end) as Custom_' + @COL +','
					END
		END

		-- Monthly
		BEGIN 
				IF @s3Month = 1
					BEGIN
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + '''), 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')+1, 0)	then #f.' + @COL + ' else 0 end) as ' + left(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate), 0),107),3) + right(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate), 0),107),2)  + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-1, 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + '''), 0)	then #f.' + @COL + ' else 0 end) as ' + left(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-1, 0),107),3) + right(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-1, 0),107),2) + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-2, 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-1, 0) then #f.' + @COL + ' else 0 end) as ' + left(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-2, 0),107),3) + right(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-2, 0),107),2) + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0,''' + convert(varchar,@rundate) + ''')-3, 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-2, 0) then #f.' + @COL + ' else 0 end) as ' + left(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-3, 0),107),3) + right(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-3, 0),107),2) + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-4, 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0,''' + convert(varchar,@rundate) + ''')-3, 0) then #f.' + @COL + ' else 0 end) as ' + left(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-4, 0),107),3) + right(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-4, 0),107),2) + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-5, 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-4, 0) then #f.' + @COL + ' else 0 end) as ' + left(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-5, 0),107),3) + right(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-5, 0),107),2) + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-6, 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-5, 0) then #f.' + @COL + ' else 0 end) as ' + left(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-6, 0),107),3) + right(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-6, 0),107),2) + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-7, 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-6, 0) then #f.' + @COL + ' else 0 end) as ' + left(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-7, 0),107),3) + right(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-7, 0),107),2) + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-8, 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-7, 0) then #f.' + @COL + ' else 0 end) as ' + left(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-8, 0),107),3) + right(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-8, 0),107),2) + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-9, 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-8, 0) then #f.' + @COL + ' else 0 end) as ' + left(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-9, 0),107),3) + right(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-9, 0),107),2) + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0,''' + convert(varchar,@rundate) + ''')-10, 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-9, 0) then #f.' + @COL + ' else 0 end) as ' + left(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-10, 0),107),3) + right(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-10, 0),107),2) + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-11, 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-10, 0) then #f.' + @COL + ' else 0 end) as ' + left(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-11, 0),107),3) + right(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-11, 0),107),2) + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-12, 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')-11, 0) then #f.' + @COL + ' else 0 end) as ' + left(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-12, 0),107),3) + right(convert(varchar,DATEADD(mm, DATEDIFF(mm, 0, @rundate)-12, 0),107),2) + @COL + ','
					END
		END
				BEGIN 
				IF @s3CumMonth = 1
					BEGIN
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*1, #f.startdate)+1 then #f.' + @COl + ' else 0 end) as Mn1_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*2, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn2_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*3, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn3_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*4, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn4_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*5, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn5_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*6, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn6_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*7, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn7_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*8, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn8_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*9, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn9_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*10, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn10_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*11, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn11_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*12, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn12_' + @COL + ','
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(dd, 28*13, #f.startdate)+1 then #f.' + @COl + ' else 0 end)  as Mn13_' + @COL + ','
					END
		END

		-- Additional periods for weekly written - Current MTD, Pevious week, Rolling 30 days
		
		BEGIN 
				IF @wwrit = 1
				-- Current Month
					BEGIN
					SET @CMD = @CMD + 'sum(case when #f.month = datepart(m,dateadd(week, datediff(week, ''1900-01-01'', ''' + convert(varchar,@rundate) + '''), ''1900-01-01'')) and #f.year = datepart(yy,dateadd(week, datediff(week, ''1900-01-01'', ''' + convert(varchar,@rundate) + '''), ''1900-01-01'')) then #f.' + @COl + ' else 0 end) as Cur_month' + @COL + ','

				-- Previous week
					SET @CMD = @CMD + 'sum(case when #f.date < dateadd(week, datediff(week, ''1900-01-01'', ''' + convert(varchar,@rundate) + '''), ''1900-01-01'') and #f.date >= dateadd(week, datediff(week, ''1900-01-01'', ''' + convert(varchar,@rundate) + ''')-1, ''1900-01-01'') then #f.' + @COl + ' else 0 end) as PrevWk_' + @COL + ','


				-- Rolling 30 Days
					SET @CMD = @CMD + 'sum(case when #f.date >= dateadd(dd, datediff(dd, ''1900-01-01'', ''' + convert(varchar,@rundate) + '''),-30) then #f.' + @COl + ' else 0 end) as R30Day_' + @COL + ','
					END

		END


				-- Additional periods for WtoI2 scan (Current MTD, Current Week TD (Monday onwards)

		BEGIN 
				IF @WtoI2 = 1
					BEGIN
					-- Current MTD
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + '''), 0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, ''' + convert(varchar,@rundate) + ''')+1, 0)	then #f.' + @COL + ' else 0 end) as Curr_MTD' + @COL + ','
					
					-- Current Week TD (Monday onwards)
					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(dd, DATEDIFF(dd, 0, dateadd(day,-datepart(weekday,''' + convert(varchar,@rundate) + ''')+1,''' + convert(varchar,@rundate) + ''')), 0) then #f.' + @COL + ' else 0 end) as Curr_WeekTD'  + @COL + ','
					
					END
		END

				-- Additional periods for recruitment report - Total production, first 6 months from adviser start date
		
		BEGIN 
				IF @wrec1 = 1
				-- Total Production 
					BEGIN
					SET @CMD = @CMD + 'sum(#f.' + @COl + ') as Total_Writ' + @COL + ','

				-- First 6 months from adviser start date
					SET @CMD = @CMD + 'sum(case when #f.date < DATEADD(mm, 6, #f.startdate)+1 then #f.' + @COl + ' else 0 end) as First6Mnth' + @COL + ','
					END

		END
		END
			
	 ELSE IF @COL IN ('%Date%')
		BEGIN
		SET @CMD = @CMD + 'CONVERT(varchar(10),' + @COL + ',103) Date,'
		END
	 ELSE
		BEGIN
		SET @CMD = @CMD + @COL + ','
		END
	 FETCH NEXT FROM COLUMN_CURSOR INTO @COL	 

	END

BEGIN
	 SET	@CMD = left(@CMD,len(@CMD)-1)
	 SET	@CMD = @CMD + ' FROM #f GROUP BY '
END

CLOSE COLUMN_CURSOR




OPEN COLUMN_CURSOR
FETCH NEXT FROM COLUMN_CURSOR INTO @COL
WHILE @@FETCH_STATUS = 0
BEGIN
	 IF @COL IN ('%Date%')
