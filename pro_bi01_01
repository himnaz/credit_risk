CREATE PROCEDURE [BI].[AutomationMaster]
AS
BEGIN
	SET NOCOUNT ON;

	declare	@PhaseStart				varchar(50),
			@PhaseEnd				varchar(50),
			@PhaseError				varchar(50),
			@PhaseLog				varchar(50),
			@ProcName				varchar(100),
			@ErrMsg					nvarchar(4000),
			@ErrNum					int,
			@ErrSev					int,
			@ErrLine				int,
			@Client					varchar(50),
			@Module					Varchar(50),
			@WrittenCBCStartDate	datetime,
			@WrittenCBCEndDate		datetime,
			@IssuedCBCStartDate		datetime,
			@IssuedCBCEndDate		datetime,
			@IssuedYearStr			varchar(4),
			@ProfPaymentMonth		date,
			@ProfStartDate			datetime,
			@ProfEndDate			datetime,
			@Today					datetime

	/****************************************************************************

		Set initial parameters																
																		
	****************************************************************************/

	set @ProcName				= object_name(@@procid)
	set @PhaseStart				= 'START'
	set @PhaseEnd				= 'END'
	set @PhaseError				= 'ERROR'
	set @PhaseLog				= 'LOG'
	set @Client					= 'Openwork'
	set @Module					= 'MI Team Automation'

	set @WrittenCBCStartDate	= convert(datetime,'01/01/2006', 103)
	set @WrittenCBCEndDate		= dateadd(day,datediff(day,0,getdate()),0)

	set @IssuedYearStr			= convert(varchar(4),year(getdate()))
	set @IssuedCBCStartDate		= convert(datetime,'01/01/2006', 103) --convert(datetime,'01/01/'+@IssuedYearStr,103)
	set @IssuedCBCEndDate		= dateadd(day,datediff(day,0,getdate()),0)

	--set @ProfPaymentMonth		= '01-Mar-2020'
	--set @ProfStartDate			= convert(datetime,DATEFROMPARTS (DATEPART(yyyy, GETDATE()) - 2, 1, 1), 103)
	--set @ProfEndDate			= convert(datetime,DATEADD(MONTH, DATEDIFF(MONTH, -1, GETDATE())-1, 0), 103)

	set @Today = CAST(GETDATE() AS DATE)

	exec BI.pr_ProcessLog @PhaseStart, @ProcName, @Module, @Client

	/****************************************************************************

		Main processing																
																		
	****************************************************************************/

	BEGIN TRY

		--exec BI.pr_ProcessLog @PhaseStart, 'BI.GetWrittenBusinessNBI', @Module, @Client
		exec BI.GetWrittenBusinessNBI -- Includes additional columns and writes to bi.WrittenBusiness
		--exec BI.pr_ProcessLog @PhaseEnd, 'BI.GetWrittenBusinessNBI', @Module, @Client
		
		--exec BI.pr_ProcessLog @PhaseStart, 'BI.GetWrittenBusiness', @Module, @Client
		--exec BI.GetWrittenBusiness -- Writes to dbo.WrittenBusiness
		--exec BI.pr_ProcessLog @PhaseEnd, 'BI.GetWrittenBusiness', @Module, @Client

		exec BI.GetIssuedBusinessNBI -- Includes additional columns and writes to BI.IssuedBusiness
		
		--exec BI.GetIssuedBusiness	--This proc logs internally - writes to dbo.IssuedBusiness
		

		exec BI.pr_WrittenBusinessCaseByCase @WrittenCBCStartDate, @WrittenCBCEndDate

		IF DATENAME(WEEKDAY,@Today) = 'Sunday'	
			exec BI.pr_IssuedBusinessCaseByCase @IssuedCBCStartDate, @IssuedCBCEndDate, 'N'	--Full rebuild
		else
			exec BI.pr_IssuedBusinessCaseByCase @IssuedCBCStartDate, @IssuedCBCEndDate, 'Y'	--Incremental update

		--exec BI.pr_Profitability @ProfPaymentMonth, @ProfStartDate, @ProfEndDate

		--exec Bi.pr_ProfitabilityHistoric @ProfPaymentMonth, @ProfStartDate, @ProfEndDate

		
		exec bi.pr_148_SellingHeadCounttoTable  -- Populate selling headcount table (bi.SellingHeadCount)
		

		exec bi.pr_195_OwlHeadcount -- Populate Owl headcount table (bi.OwlHeadCount)
		
		IF MONTH(Cast(DATEADD(DAY,-1,GETDATE()) as date)) <>  MONTH(GETDATE()) -- Execute Procs on 1st of the Month only
			BEGIN
						exec bi.pr_206_Finstat9Table -- Populate Finstat 9 table (bi.Finstat10)
						exec bi.pr_205_Finstat10Table -- Populate Finstat 10 table (bi.Finstat10)
						exec bi.pr_216_Finstat9TableFull-- Populate Finstat 9 table Full (bi.Finstat10)
						exec bi.pr_219_Finstat10TableFull-- Populate Finstat 10 table Full (bi.Finstat10)

						exec [BI].[pr_223_FINANCE_Weekly_DailyWrittenOwl]
						exec [BI].[pr_225_FINANCE_Weekly_WrittenMortgageScorecard]
						exec [BI].[pr_226_FINANCE_Weekly_WrittenProductionCBC]
						exec [BI].[pr_230_FINANCE_Weekly_WrittenCBCMaster(Protection)]
						exec [BI].[pr_231_FINANCE_Weekly_WrittenCBCMaster(Mortgage)]
						exec [BI].[pr_232_FINANCE_Weekly_WrittenCBCMaster(Wealth)]
						exec [BI].[pr_222_FINANCE_Weekly_DailyIssuedOwl]
						exec [BI].[pr_224_FINANCE_Weekly_IssuedProductionCBC]
						exec [BI].[pr_227_FINANCE_Weekly_IssuedCBCMaster(Protection)]
						exec [BI].[pr_228_FINANCE_Weekly_IssuedCBCMaster(Mortgage)]
						exec [BI].[pr_229_FINANCE_Weekly_IssuedCBCMaster(Wealth)]
			END

		IF DATENAME(WEEKDAY,@Today) = 'Monday' AND MONTH(Cast(DATEADD(DAY,-1,GETDATE()) as date)) =  MONTH(GETDATE()) -- Execute Procs each Monday (That's not the first)
			BEGIN
						exec [BI].[pr_223_FINANCE_Weekly_DailyWrittenOwl]
						exec [BI].[pr_225_FINANCE_Weekly_WrittenMortgageScorecard]
						exec [BI].[pr_226_FINANCE_Weekly_WrittenProductionCBC]
						exec [BI].[pr_230_FINANCE_Weekly_WrittenCBCMaster(Protection)]
						exec [BI].[pr_231_FINANCE_Weekly_WrittenCBCMaster(Mortgage)]
						exec [BI].[pr_232_FINANCE_Weekly_WrittenCBCMaster(Wealth)]
			END

		IF DATENAME(WEEKDAY,@Today) = 'Tuesday' AND MONTH(Cast(DATEADD(DAY,-1,GETDATE()) as date)) =  MONTH(GETDATE()) -- Execute Procs each Tuesday  (That's not the first)
			BEGIN
						exec [BI].[pr_222_FINANCE_Weekly_DailyIssuedOwl]
						exec [BI].[pr_224_FINANCE_Weekly_IssuedProductionCBC]
						exec [BI].[pr_227_FINANCE_Weekly_IssuedCBCMaster(Protection)]
						exec [BI].[pr_228_FINANCE_Weekly_IssuedCBCMaster(Mortgage)]
						exec [BI].[pr_229_FINANCE_Weekly_IssuedCBCMaster(Wealth)]

			END		 

	END TRY

	BEGIN CATCH 

		select @ErrNum = ERROR_NUMBER(), @ErrMsg = ERROR_MESSAGE(), @ErrSev = ERROR_SEVERITY(), @ErrLine = ERROR_LINE()
		set @ErrMsg = REPLACE(@ErrMsg, '.', '') + ' (error no: ' + CAST(@ErrNum AS VARCHAR(10)) + ') on line ' + CAST(@ErrLine AS VARCHAR(10))

		EXEC msdb.dbo.sp_send_dbmail
			@recipients = 'datarequests@theopenworkpartnership.com',
			--@recipients = 'Alan.Groves@theopenworkpartnership.com',
			@subject = 'PAN01: MI Automation Job - FAILED!!!!!!!',
			@body = @ErrMsg,
			@body_format = 'HTML' 

		exec BI.pr_ProcessLog @PhaseError, @ProcName, @Module, @Client, null, @ErrMsg

		RAISERROR(@ErrMsg, @ErrSev, 1)

	END CATCH

	/****************************************************************************

			E N D															

	****************************************************************************/

	exec BI.pr_ProcessLog @PhaseEnd, @ProcName, @Module, @Client

END



