	year(case when providercode in ('Payment shield', 'PYMTSHLD') then month - 27 else month end),
	providercode, oa.businesscode, oa.sellercode,
	CASE WHEN (ah.ASDCode in('4019902') OR oa.businesscode = '2016789') THEN 'Owl AR' ELSE 'Openwork' END

