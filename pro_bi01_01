		,sum(case when f.date >= convert(date,DATEADD(yy, -1, getdate()-1)) then 1 else 0 end) R12Month


	--previous

		--day
		,sum(case when f.date = dateadd(yy,-1,convert(date,getdate()-1)) then 1 else 0 end) PrevYear_day
	
		--week
		,sum(case when f.date >= convert(date,dateadd(week,-1,getdate()-1 - datepart(dw,getdate()-1)+1)) and f.date <= convert(date,dateadd(dd,datepart(dw,getdate()-1),dateadd(week,-1,getdate()-1 - datepart(dw,getdate()-1))))  then 1 else 0 end) Prev_weekTD 
		,sum(case when f.date >= convert(date,dateadd(yy,-1,getdate()-1 - datepart(dw,getdate()-1)+1)) and f.date <=convert(date,dateadd(dd,datepart(dw,getdate()-1),dateadd(yy,-1,getdate()-1 - datepart(dw,getdate()-1))))  then 1 else 0 end) PrevYear_weekTD

		--month
		,sum(case when f.date >= convert(date,DATEADD(mm, datediff(mm, 0, getdate()-1)-1, 0)) and f.date <= convert(date,DATEADD(mm,-1, getdate()-1)) then 1 else 0 end) Prev_monthTD 
		,sum(case when f.date >= convert(date,dateadd(yy,-1,DATEADD(mm, datediff(mm, 0, getdate()-1)-1, 0))) and f.date <= convert(date,dateadd(yy,-1,DATEADD(mm,-1, getdate()-1))) then 1 else 0 end) PrevYear_monthTD


		--quarter
		,sum(case when f.date >= convert(date,dateadd(quarter,-1,@quarts)) and f.date <= convert(date,dateadd(quarter,-1,getdate()-1)) then 1 else 0 end) Prev_quarterTD
		,sum(case when f.date >= convert(date,dateadd(yy,-1,@quarts)) and f.date <= convert(date,dateadd(yy,-1,getdate()-1)) then 1 else 0 end) PrevYear_quarterTD 

		--year
		,sum(case when f.date >= convert(date,DATEADD(yy, datediff(yy, 0, getdate()-1)-1, 0)) and f.date <= convert(date,DATEADD(yy,-1, getdate()-1)) then 1 else 0 end) Prev_yearTD 
		

	from #f	f	

	group by 
	f.Priadviser,f.experience
	) tem
	group by experience
	END
	
