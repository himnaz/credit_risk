group by cast(co.AGENT_CODE as int), round((case when (ph.productgroupname = 'Mortgage' and ccs.description is null) then ((pt.mortgageamount * (co.agent_perc/100)) * 0.0045) else co.Turnover end),2), po.policyref, po.cont_num, datepart(week,(pt.writtendate)), year(pt.writtendate), ph.productgroupname,co.agent_code) wr

where
wr.writtendate >= @StartDate
and wr.writtendate < @EndDate	
--and wr.adviser = '1003198'
--and wr.originatingsource = '5'
and (wr.caseid not in ('500020430','500020431','550550857') or wr.caseid is null)
and case when wr.productsubgroupname like '%Annuity' then 'Annuities' when ((left(wr.productcode,2) in ('OW','OZ')) or wr.productcode = 'OFHBSIPP' or wr.provider = 'Zurich PLT' or wr.provider = 'Pru PLT') then 'COB Platform' when wr.productgroupname in ('Pensions','Investment') then 'COB Off-Platform' else wr.productgroupname end in ('Mortgage')

