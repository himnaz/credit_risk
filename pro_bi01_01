set ansi_warnings off
select
		'Written' Type

		,s.AdviserUID Priadviser
		,p.policyid
		,convert(Date,s.datesubmitted) Date
		,pmv.DisplayName productgroupname
		,day(s.datesubmitted) Day,month(s.datesubmitted) Month,year(s.datesubmitted) Year
		,sum(isnull(pps.premiumamount,lpps.PremiumAmount)*12) Premium
	    ,sum(isnull(pps.premiumamount,lpps.PremiumAmount)*12) APE
	    ,count(p.PolicyID) NewPolicies
		,uh.UserDateFrom as startdate
	    ,svar.UID temp_uid
		,pr.Promotiondate
		,s.personid

into #h
from sa_ows_policies p 
	 inner join sa_ows_sale s on s.SaleID = p.SaleID	
 	 inner join mstt_agents ag on ag.code = s.AdviserUID and manager2code = '1011671'
	 
	 left join policy.sa_ows_ProtectionProductSummary pps on pps.PolicyID = p.PolicyID
	 left join PolicyOneLink.sa_ows_ProtectionProductSummary lpps on lpps.PolicyID = p.PolicyID
	 left join mi_insight_UserHierarchyallusers uh on uh.UserUID = s.AdviserUID and uh.effectiveenddate>getdate()
	 left join staticdata.sa_ows_ProductMergeView pmv on pmv.internalproductid = p.internalproductid

	 left join @var svar on svar.uid = s.AdviserUID
	 left join #prom pr on pr.Usr_login = s.adviseruid 

	 join staticdata.sa_ows_PolicyStatus ps on ps.policystatusid = p.status and ps.policystatusid in (0,1,2,3)

	 
where 
	 s.datesubmitted >= @StartDate2
and  s.datesubmitted <= @EndDate2
  and s.adviserUID <> '4006226' -- Test UID excluded	
group by convert(Date,s.datesubmitted)
		,s.AdviserUID
		,day(s.datesubmitted),month(s.datesubmitted),year(s.datesubmitted)
		,p.policyid
		,uh.UserDateFrom
	    ,svar.UID
		,pr.Promotiondate
		,s.personid
		,pmv.DisplayName
