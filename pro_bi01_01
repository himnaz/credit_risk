					SET @CMD = @CMD + 'sum(case when #f.date >= DATEADD(mm, DATEDIFF(mm, 0, DATEADD(yy, DATEDIFF(yy, 0, GETDATE()), 0))+9,0) and #f.date < DATEADD(mm, DATEDIFF(mm, 0, DATEADD(yy, DATEDIFF(yy, 0, GETDATE()), 0))+12, 0) then #f.' + @COL + ' else 0 end) as Q4_' + @COL +','
					END
