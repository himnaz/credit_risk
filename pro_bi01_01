  left join sa_ows_Policies pol on pol.Saleid = s.SaleId
  left join Policy.sa_ows_MortgageProduct mp on pol.internalproductid = mp.internalproductid
  left join Policy.sa_ows_ProtectionProduct pp on pol.internalproductid = pp.internalproductid
  left join mstt_Agents ag1 on s.AdviserUID = ag1.code
