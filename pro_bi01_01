Create Procedure [BI].[pr_006_Headcount]

as

Set nocount on
Set Ansi_Warnings off


declare @OL int, @Active_OL int, @Br_HC int, @Br_HC2 int

set @OL = 0 -- Full OWL headcount
set @Active_OL = 1 --Active advisers only (sellers only, includes suspended/under notice)
set @Br_HC = 0 -- Headcount for Brighton (saving in their recruitment folder)
set @Br_HC2 = 0 -- Headcount for Danny - Brighton for his Debt collection worksheets

-----------------------------------------------------------------------------------------------------------------------------
-- table for BN codes

select convert(varchar,an.agentcode) UID, min(an.agencyno) agencyno into #BNCode
from dbo.mstt_AgentAgencyNumbers an inner join cscv_AgentsHierarchy ah on ah.agentcode = convert(varchar,an.agentcode)
where an.productprovidercode in ('Zurich OWL', 'Sterling', 'SIML') and ah.asdcode =  4005013 
group by convert(varchar,an.agentcode)
-------
-- Latest panel markers
--


select ups.UPS_userid, cd.Code_Description Panel  into #panel
from sa_insight_UserPosition ups inner join
		(select ups_userid,max(ups_createddate) currdate
		from sa_insight_UserPosition ups
		where ups.ups_JobTitle = '52'
		group by ups.ups_Userid) tem
	 on ups.ups_userid = tem.ups_userid and ups.ups_createddate = tem.currdate
left join sa_insight_CodeDescription cd on cd.Code_Code = ups.UPS_Section and cd.Code_CodeType = '53'
where ups.ups_JobTitle = '52' 
-------	

select distinct
case when ah.CompetentStatusdescription like 'Pre-appointed' then NULL else ah.AgentStartDate end AgentStartDate
,ah.AgentLeftDate
,ah.AgentCode 'UID' 
,ltrim(rtrim(case when ah.CompetentStatusdescription like 'Active' and ag.GivesAdvice = 'Y' then in_uh.username else isnull(ah.agentdesc,in_uh.username) end)) 'Name'
,case when in_uh.UserJobTitleCodeSalesMgr = 54 and ah.CompetentStatusdescription like 'Active' and ag.GivesAdvice = 'Y' then 'ASM' else 

		case when ah.AgentTypeDescription = 'Principal' then 'Adviser' 
			 when ah.AgentTypeDescription = 'Seller' then 'Adviser' 
			 else ah.AgentTypeDescription
		end
		
 end 'Role'
,ah.AgentCategoryDescription Category
,ag.GivesAdvice Selling
, convert(varchar,ag.DeclarationofAssociationEffectiveDate,6)  Exp_end_date

, case when ah.AgentCode = '1002505' then 'Left' when ah.AgentCode = '1001364' then 'Left'
	   when ag.EMAIL LIKE '%Deceased%' and ah.AgentType = 43 then 'Left'
	   when	in_uh.UserContractStatus like 'Under Contract' and in_uh.UserJobTitleCodePA is null then 'Active'
	   else ah.CompetentStatusdescription	   
  end	'Status'


,case in_uh.userjobtitlecodeseller when 61 then 'Senior Protection Adviser' --Panel Adv
							 when 62 then 'Mortgage Adviser'   				-- Mort Adv
							 when 63 then 'New Protection Adviser'			--New Adv
							 Else 'Protection Adviser' end 'OWLSellerType' 

, case when ag.DeclarationofAssociationEffectiveDate is not null and ah.CompetentStatusdescription not in ('Pre-appointed','NPW') then 'Y' end 'Notice Given?'
, case when ag.Salutation is not null and ah.CompetentStatusdescription not in ('Pre-appointed','NPW') then 'Y' end 'Suspended?'
, in_uh.BQMName 'Field Sales Quality Officers'

, in_uh.OwlASMUID1
, in_uh.OwlASMUID2
, in_uh.OwlASMUID3
, in_uh.OwlASMUID4
, in_uh.OwlASMUID5

,in_uh.OwlASMName1 'ASM 1'
,in_uh.OwlASMName2 'ASM 2'
,in_uh.OwlASMName3 'ASM 3'
,in_uh.OwlASMName4 'ASM 4'
,in_uh.OwlASMName5 'ASM 5'
,pan.Panel 'Panel Marker'
, case when st.STAF_RecruitedByName like '1011623' then null else isnull(in_uh2.username,ah2.agentdesc) end 'Introducer'
,case when len(st.STAF_RecruitedByName) > 10 then null else st.STAF_RecruitedByName end 'Intro UID'
,ltrim(rtrim(ag.Address1)) 'Address 1'
,ltrim(rtrim(ag.Address2)) 'Address 2'
,ltrim(rtrim(ag.Address3)) 'Address 3'
,ltrim(rtrim(ag.Address4)) 'Address 4'
,ltrim(rtrim(ag.Address5)) 'Address 5'
,ltrim(rtrim(ag.postcode)) Postcode


,ltrim(rtrim(case when ag.TELEPHONE is NULL then icd.CD_Telephone else ag.TELEPHONE end)) telephone
,ltrim(rtrim(case when left(icd.CD_Mobile,1) <> '0' then '0' + icd.CD_Mobile else icd.CD_Mobile end)) Mobile
,ltrim(rtrim(isnull(coalesce(ag.email,cl.email),icd.cd_email))) Email

,case when USR_Login is null and ah.CompetentStatusdescription = 'Active' then 'N'
	  when ah.CompetentStatusdescription = 'Active' then 'Y'
	  else null end 'On Insight Listing' 

,case when in_uh.UserJobTitleCodePA  is null then in_uh.UserEmploymentStatus else null end 'Insight Employment Status'
,case when in_uh.UserJobTitleCodePA is null then in_uh.UserContractStatus else null end 'Insight Contract Status'
,case when in_uh.UserJobTitleCodePA is null then in_uh.UserUID  
 else null end 'Insight UID'
,case when in_uh.UserJobTitleCodePA is null then isnull(ubd.ptlcode,ag.PortalLogon) else null end PortalLogon

,ltrim(rtrim(bn.agencyno)) 'BN Code'
,'' 'ML Username'
,isnull(ah.FirmCode, USR.USR_authenticationName) 'Firm Code'
,isnull(cd.code_description,st.staf_reasonforleaving) ReasonforLeaving
into #b

from mstt_Agents ag inner join dbo.cscv_AgentsHierarchy ah on ag.CODE = ah.AgentCode and ag.manager2code ='1011671' and ag.agenttype <>2
					left join mi_insight_userhierarchyallusers in_uh on in_uh.useruid = ag.code and in_uh.effectiveenddate > getdate() and ah.CompetentStatusdescription not in ('NPW')
					left join sa_insight_UserDetails USR on USR.USR_Login = ag.code
					left join sa_insight_Staff st on st.STAF_UserID = USR.USR_ID
					left join sa_insight_CodeDescription cd on cd.code_codetype = 555 and convert(varchar,cd.code_code) = st.staf_reasonforleaving
					left join sa_insight_UserPosition UPS on UPS.UPS_UserID = st.STAF_UserID and UPS.UPS_Section <> 1
					left join dbo.cscv_AgentsHierarchy ah2 on ah2.AgentCode = st.STAF_RecruitedByName
					left join mi_insight_UserHierarchy in_uh2 on in_uh2.useruid = st.STAF_RecruitedByName
					left join dbo.sa_insight_ContactDetails icd on icd.CD_ParentID = st.STAF_ID
					left join  dbo.mstt_Clients cl on cl.AgentCode = ag.CODE
					left join [staticdata].sa_ows_SCRTY_UserAndBusinessDetails ubd on ubd.AdviserGUID = in_uh.UserGUID

				
					left join #bnCode bn on bn.UID = ag.code
					left join #panel pan on pan.ups_userid = USR.USR_ID

					--inner join (select distinct code from mstt_agents where manager2code ='1011671' and agenttype <>2) uh2 on uh2.code = in_uh.useruid

					

WHERE     (NOT (ah.AgentCode IN ('Jones', 'Michael','M1 3LD', 'Kurian','Tshuma', 'Rodzik','William', '1011671','4005317'))) --AND (COALESCE(RTRIM(ah.ASDName),'') = 'Pat Mckenna') AND
		  and (ah.AgentTypeDescription <> 'Franchise')
		  
-- Final Formatting
select
convert(int,b.uid) UID
,b.Name
,case when sum(case when b.UID = manrs.OWLASMUID2 and manrs.status = 'Active' then 1 else 0 end) >0 then 'ESM' else b.Role end as 'Role'
,b.Category, b.Selling
,case when b.Selling = 'Y' and b.Status not in ('Pre-appointed','NPW') then b.OWLSellerType else null end OWLSellerType
,b.[AgentStartDate] AgentStartDate
,b.AgentLeftDate
,b.Exp_end_date 'Expected End Date'
,b.status stats
,case when b.status = 'Active' and b.[Notice Given?] is not null and b.[Suspended?] is not null then 'Suspended and Under Notice'
	  when b.status = 'Active' and b.[Notice Given?]  is not null then 'Under Notice'
	  when b.status = 'Active' and b.[Suspended?] is not null then 'Suspended'
	  else b.status
 end Status
,b.[Notice Given?], b.[Suspended?], b.[Field Sales Quality Officers]
,b.OwlASMUID1 ASM1,b.OwlASMUID2 ASM2,b.OwlASMUID3 ASM3,b.OwlASMUID4 ASM4,b.OwlASMUID5 ASM5
,b.[ASM 1],b.[ASM 2],b.[ASM 3],b.[ASM 4],b.[ASM 5]
,b.[Panel Marker]
,b.Introducer, b.[Intro UID]
,b.[Address 1],b.[Address 2],b.[Address 3],b.[Address 4],b.[Address 5],b.[Postcode]
,left(replace(b.Telephone,' ',''),5) + ' ' + right(replace(b.Telephone,' ',''), len(replace(b.Telephone,' ',''))-5) 'Telephone Number'
,left(replace(b.Mobile,' ',''),5) + ' ' + right(replace(b.Mobile,' ',''), len(replace(b.Mobile,' ',''))-5) 'Mobile Telephone'
,b.email 'Email Address'
,b.[On Insight Listing], b.[Insight Employment Status], b.[Insight Contract Status],b.[Insight UID], b.PortalLogon 'PTL Code'
,b.[BN Code]
,b.[Firm Code]
,b.ReasonforLeaving
into #hc
from #b b left join (select uid,status, OwlASMUID2 from #b) manrs on manrs.OwlASMUID2 = b.uid

-- Excluding duplicate/Unused UID's
where b.UID not in
	('4007583','1012004','4005961','4005958','1012011')

group by b.UID, manrs.OWLASMUID2, b.Role, b.Name,b.[AgentStartDate],b.AgentLeftDate
,b.Category, b.Selling, b.Exp_end_date, b.status, b.[Notice Given?], b.[SuSpended?], b.[Field Sales Quality Officers]
,b.OwlASMUID1,b.OwlASMUID2,b.OwlASMUID3,b.OwlASMUID4,b.OwlASMUID5
,b.[ASM 1],b.[ASM 2],b.[ASM 3],b.[ASM 4],b.[ASM 5]
,b.Introducer, b.[Intro UID]
,b.[Address 1],b.[Address 2],b.[Address 3],b.[Address 4],b.[Address 5],b.[Postcode],b.email 
,b.[On Insight Listing], b.[Insight Employment Status], b.[Insight UID], b.PortalLogon
,b.[Firm Code]
,left(replace(b.Telephone,' ',''),5) + ' ' + right(replace(b.Telephone,' ',''), len(replace(b.Telephone,' ',''))-5)
,left(replace(b.Mobile,' ',''),5) + ' ' + right(replace(b.Mobile,' ',''), len(replace(b.Mobile,' ',''))-5)
,b.[BN Code]
,b.[Panel Marker]
,b.[Insight Contract Status]
,b.ReasonforLeaving
,OWLSellerType
 order by b.[Status] asc, [Selling] desc, b.[AgentStartDate] desc, [Name] asc
 
 
 if @OL = 1
	begin
		 select * from #hc
	end
	
 if @Active_OL = 1 
	begin
		select * from #hc where selling = 'Y' and stats like 'active'
	end

 if @Br_HC = 1
 	begin

		-- additional columns for Brighton Headcount
		 select hc.*, cl.BIRTHDATE DOB, COALESCE(cl.NI_Number,'') NI_Number,
				case when S.Staf_gender =1 then 'Mr' when S.Staf_gender = 2 then 'Mrs' end Title
		 from #hc hc left join dbo.mstt_Clients cl on cl.AgentCode = convert(varchar,hc.uid)
					 left join sa_insight_UserDetails USR on convert(varchar,USR.USR_Login) = convert(varchar,hc.uid)
					 left join dbo.sa_insight_Staff S ON S.STAF_UserID = USR.USR_ID
		 order by stats asc, [Selling] desc, [AgentStartDate] desc, [Name] asc		
	end
	
 if @Br_HC2 = 1
 	begin

 ----------------------------------------------------------------------------------------- ADVISER DEBT START
 
 select Businesscode, max(case when dbo.msit_OpenworkBankDetails.amount >0 then dbo.msit_OpenworkBankDetails.transactiondate else 0 end) LPD
					, sum(case when dbo.msit_OpenworkBankDetails.amount >0 and transactiondate >= '07/20/2018' then dbo.msit_OpenworkBankDetails.amount else 0 end) debt_paid
  into #LPD
			from msit_OpenworkBankDetails
			where amount >0 and TransactionType = 'Standing Order'
			group by Businesscode

	SELECT  
            dbo.msit_OpenworkBankDetails.BusinessCode,
			ah.AgentCode AgentCode, 
            CASE WHEN TotalType = 9 THEN SUM(Amount) ELSE 0.0 END AS ClosingBalance			
			into #debt
FROM  dbo.msit_OpenworkBankDetails 
            INNER JOIN dbo.msit_CommissionStatementPeriods 
                                    ON dbo.msit_OpenworkBankDetails.Month = dbo.msit_CommissionStatementPeriods.Month 
            INNER JOIN dbo.mstt_Agents 
                                    ON dbo.msit_OpenworkBankDetails.BusinessCode = dbo.mstt_Agents.CODE
            LEFT JOIN owv_AdviserBrand ab on ab.UserUID = dbo.msit_OpenworkBankDetails.BusinessCode       -- AG 30/01/2015
			JOIN dbo.cscv_AgentsHierarchy ah ON ah.FirmCode = dbo.msit_OpenworkBankDetails.BusinessCode

			inner join 
				(select max(transactiondate) transactiondate, businesscode from msit_OpenworkBankDetails where totaltype = 9 group by businesscode) tmp
				on tmp.transactiondate = msit_OpenworkBankDetails.transactiondate and tmp.businesscode = msit_OpenworkBankDetails.businesscode
WHERE   (dbo.msit_OpenworkBankDetails.TotalType = 9)
--AND         (dbo.msit_CommissionStatementPeriods.Month = dateadd(mm,datediff(mm,0,getdate()),0))
AND		brand = 'owl'
--AND         (dbo.msit_OpenworkBankDetails.Source IN ('Openwork 2005', 'Openwork 2006')) 
GROUP BY    dbo.msit_OpenworkBankDetails.Source, 
                  dbo.msit_OpenworkBankDetails.BusinessCode 
		   ,ah.AgentCode
		   ,TotalType

 ----------------------------------------------------------------------------------------- DEBT END

		--left adviser email addresses and ptl codes
		select distinct ah.code,ah.email,ah.portallogon into #eml from (select max(validtodate) validtodate, code from mstt_AgentsHistory where email <> 'Left' group by code) tmp
																			 inner join mstt_AgentsHistory ah on ah.validtodate = tmp.validtodate and ah.code = tmp.code
																			 inner join mstt_agents ag on ag.code = ah.CODE
													where ah.portallogon is not null and ag.Manager2Code = '1011671'

		select 
		uh.useruid UID,uh.username Name
		,case ag.email when'LEFT' then eml.email else ag.email end email
		,hc.[Telephone Number], hc.[Mobile Telephone]
		,hc.[Address 1],hc.[Address 2],hc.[Address 3],hc.[Address 4],hc.[Address 5],hc.[Postcode]
		,isnull(uh2.latestBUID,ag.firm) firm
		,hc.agentstartdate
		,hc.agentleftdate
		,uh.OWLASMName1
		,hc.ReasonForLeaving
		,isnull(isnull(hc.[PTL Code],eml.portallogon),tmp.ptlcode) 'PTL Code'
		,sum(de.closingbalance) debt
		,lpd.LPD last_payment_date
		,lpd.debt_paid
		,hc.Introducer
		,hc.status, hc.[notice given?],hc.[suspended?]
		,hc.[Expected End Date]

		from mi_insight_userhierarchyallusers uh left join mstt_agents ag on ag.code = uh.useruid
												 left join #eml eml on eml.code = uh.useruid
												 left join #hc hc on convert(varchar,hc.UID) = convert(varchar,uh.useruid)
												 left join #debt de on de.agentcode = uh.useruid
												 left join (select distinct adviseruid uid, ptlcode from [staticdata].sa_ows_SCRTY_InactiveUserAndBusinessDetails) tmp 
																	on tmp.uid = uh.useruid
												 left join #LPD lpd on lpd.businesscode = hc.[firm code]

												 inner join (select distinct useruid,max(businessuid) latestBUID from mi_insight_userhierarchyallusers where aduid = '4005013' and userjobtitlecodeseller is not null group by useruid) uh2 on uh2.useruid = uh.useruid
		 where effectiveenddate > getdate() 
			   			   
		 group by uh.useruid,uh.username,case ag.email when'LEFT' then eml.email else ag.email end,hc.[Telephone Number], hc.[Mobile Telephone]
		,isnull(uh2.latestBUID,ag.firm),hc.agentleftdate,uh.OWLASMName1,hc.ReasonForLeaving,isnull(isnull(hc.[PTL Code],eml.portallogon),tmp.ptlcode), lpd.LPD
		,hc.Introducer,hc.status,hc.[notice given?],hc.[suspended?],hc.[Expected End Date]
		,hc.[Address 1],hc.[Address 2],hc.[Address 3],hc.[Address 4],hc.[Address 5],hc.[Postcode],hc.agentstartdate
		,lpd.debt_paid
		drop table #eml, #debt, #LPD
end

