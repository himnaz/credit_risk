create Procedure [BI].[pr_002_DailyWrittenScanOwlForMC]

as


SET NOCOUNT ON

------------------------------------------------------------------------------------------------

declare @StartDate datetime,@EndDate datetime;

set @StartDate = CONVERT(DATETIME, '2014-12-01 00:00:00', 102) -- DATEADD(yy, DATEDIFF(yy, 0, GETDATE())-1, 0)
set @EndDate = (DATEADD(day,datediff(day,0,GETDATE()),0)) --CONVERT(DATETIME, '2017-02-28 23:59:59', 102)


-----------------------------------------------------------------------------------------------



IF OBJECT_ID('tempdb..#c') IS NOT NULL
DROP TABLE #c


SET DATEFIRST 1;

select
min(transactionid) as transactionid, po.policyref, po.cont_num, co.productcode
into #c

FROM          dbo.mstt_Commissions co INNER JOIN
                       dbo.mstt_PolicyTransactions pt ON pt.ID = co.TransactionID INNER JOIN
                       dbo.mstt_Policies po ON po.POL_NUM = co.PolicyID LEFT OUTER JOIN             
                       dbo.mstt_ProductHierarchy ph ON ph.ProductCode = co.ProductCode LEFT OUTER JOIN               
                    dbo.mstt_ProductProviders pp ON pp.ProductProviderCode = po.COMP_CODE LEFT OUTER JOIN
                       dbo.msit_CodeReportingProductCode wr ON wr.Code = ph.ReportingProductCode LEFT OUTER JOIN
                       dbo.msit_CodeCommissionShape ccs ON ccs.id = pt.CodeCommissionShapeID LEFT OUTER JOIN
                       cscv_AgentsHierarchy ah ON co.firm = ah.agentcode
where
co.agent_code not in ('10002','1011542','10004')
and co.commissiontype = 1
and co.poltrantranstype = 39
--and co.businessreason in ('NB','NI')
and (ph.productgroupname <> 'GI' or ph.productgroupname is NULL)
and (left(ccs.description,3) <> 'IMP' or ccs.description is NULL)
and (left(ccs.description,2) <> 'UA' or ccs.description is NULL)
and (co.productcode not in ('OWADVICE','OWADHOC') or co.productcode is NULL)
group by po.policyref, po.cont_num, co.productcode



--MONTH & YEAR
SELECT 'Written' as "Type", --wr.Adviser,
--CASE WHEN wr.PriAdviser = '4007583' THEN '4007584' ELSE wr.PriAdviser END AS PriAdviser,
--wr.Firm, 
CONVERT(varchar(10),wr.writtendate,103) as Date,
day(wr.writtendate) as "Day", month(wr.writtendate) as "Month", year(wr.writtendate) as "Year",
sum(case when wr.frequency = 'Single' then wr.ape * 10 else wr.ape end) as Premium, sum(wr.ape) as APE, sum(wr.NBcases) as NewPolicies,
sum(wr.distributionallowance) as DA, sum(wr.margin) as Margin,

--Protection

case when wr.productsubgroupname like '%Annuity' then 'Annuities' when ((left(wr.productcode,2) in ('OW','OZ')) or wr.productcode = 'OFHBSIPP' or wr.provider = 'Zurich PLT') then 'COB Platform' when wr.productgroupname in ('Pensions','Investment') then 'COB Off-Platform' else wr.productgroupname end as 'ProductGroupName',
case when wr.productcode like '%AVIP%' then 'AVIVA OWL' else wr.productcode end as 'productsubgroup',

wr.adminmethod

from

(SELECT  
--cast(co.AGENT_CODE as int) as Adviser, cast(pt.AGENTCODE as int) as PriAdviser,
--min(coalesce(co.firm,co.agent_code)) as Firm,
min(co.transactionid) as transactionid, 
--min(pt.writtendate) as writtendate,
min(isnull(s.DateSubmitted,pt.writtendate)) as writtendate,
datepart(week,(isnull(s.DateSubmitted,pt.writtendate))) as writtenweek, year(isnull(s.DateSubmitted,pt.writtendate)) as writtenyear,
round((case when (ph.productgroupname = 'Mortgage' and ccs.description is null) then ((pt.mortgageamount * (co.agent_perc/100)) * 0.0045) else co.Turnover end),2) as APE,
round(min(case when (ph.productgroupname = 'Protection' and ccs.description is null) then co.turnover * 2.2 
when (ph.productgroupname = 'Mortgage' and ccs.description is null) then ((pt.mortgageamount * (co.agent_perc/100)) * 0.0045) else co.distributionallowance end),2) as distributionallowance, 

round(min(case when (ph.productgroupname = 'Protection' and ccs.description is null) then ((co.turnover * 2.2) *0.7) 
when (ph.productgroupname = 'Mortgage' and ccs.description is null) then (((pt.mortgageamount * (co.agent_perc/100)) * 0.0045) * 0.9) else (co.baseamount + co.upliftamount) end),2) as NBI, 


round(min(case when (ph.productgroupname = 'Protection' and ccs.description is null) then ((co.turnover * 2.2) *0.3) 
when (ph.productgroupname = 'Mortgage' and ccs.description is null) then (((pt.mortgageamount * (co.agent_perc/100)) * 0.0045) * 0.1) else (co.salesmargin) end),2) as Margin, 

max(case when co.transactionid = c.transactionid then (co.agent_perc/100) else 0 end) as "NBCases", 
max((co.agent_perc/100)) as "AllCases", min(pt.FrequencyDescription) as frequency, min(po.PolicyRef) AS CaseID, 
po.CONT_NUM AS Policy, min(co.BusinessReason) as businessreason,
min(co.AdminMethodDescription) as adminmethoddescription, min(co.ProductCode) as productcode, min(po.COMP_CODE) AS Provider, min(rp.ReportingProductName) as reportingproductname, 
min(ph.ProductSubGroupName) as productsubgroupname, 
min(case when ph.productgroupname = 'Other' then 'Pensions' else ph.productgroupname end) as "ProductGroupName",
min(po.originatingsource) as originatingsource, min(case when ((ph.productgroupname <> 'Mortgage' and co.adminmethod NOT IN ('A','G')) or ph.productsubgroupname like '%Guaranteed Account%' or rp.reportingproductname = 'Zurich Bank Structured Product' or ph.productsubgroupname like '%Group Pension%' or po.comp_code = 'Zurich Leg' or co.productcode = 'ZGUA' or po.comp_code = 'Close' or po.comp_code = 'MSQ') then 'Non Advised' else 'Advised' end) as "Adminmethod", min(ccs.calculationcode) as calculationcode, min(ccs.description) as description, min(rtrim(ah.asdname)) as ASD


FROM          dbo.mstt_Commissions co INNER JOIN
                       dbo.mstt_PolicyTransactions pt ON pt.ID = co.TransactionID INNER JOIN
                       dbo.mstt_Policies po ON po.POL_NUM = co.PolicyID LEFT OUTER JOIN             
                       dbo.mstt_ProductHierarchy ph ON ph.ProductCode = co.ProductCode LEFT OUTER JOIN               
                    dbo.mstt_ProductProviders pp ON pp.ProductProviderCode = po.COMP_CODE LEFT OUTER JOIN
                       dbo.msit_CodeReportingProductCode rp ON rp.Code = ph.ReportingProductCode LEFT OUTER JOIN
                       dbo.msit_CodeCommissionShape ccs ON ccs.id = pt.CodeCommissionShapeID LEFT OUTER JOIN
                       #c c on c.transactionid = co.transactionid LEFT OUTER JOIN
                       cscv_AgentsHierarchy ah ON co.firm = ah.agentcode
                        left join sa_ows_Policies p on p.PolicyID = po.PolicyRef 
                        left join sa_ows_Sale s on s.SaleID = p.SaleID                    

where  
co.agent_code not in ('10002','1011542','10004')
and co.commissiontype = 1
and co.poltrantranstype = 39
and (co.adminmethoddescription <> 'Indexation' or co.adminmethoddescription is NULL)
and (left(ccs.description,3) <> 'IMP' or ccs.description is NULL)
and (left(ccs.description,2) <> 'UA' or ccs.description is NULL)
and (co.productcode not in ('OWADVICE','OWADHOC') or co.productcode is NULL)
and (rtrim(ah.ASDName) = 'Pat Mckenna' or co.agent_code in ('1011623','1011629','1011630','1011631','1011632','1011633','1011634','1011635'))---OWL POT ACCOUNT NOT COUNTED

group by cast(co.AGENT_CODE as int), cast(pt.AGENTCODE as int), round((case when (ph.productgroupname = 'Mortgage' and ccs.description is null) then ((pt.mortgageamount * (co.agent_perc/100)) * 0.0045) else co.Turnover end),2), po.policyref, po.cont_num, datepart(week,(isnull(s.DateSubmitted,pt.writtendate))), year(isnull(s.DateSubmitted,pt.writtendate))) wr

where
(wr.writtendate) >= @StartDate
and (wr.writtendate) <= @EndDate 
and (wr.caseid not in ('500020430','500020431') or wr.caseid is null)
and wr.productcode LIKE '%OWL%'

group by
CONVERT(varchar(10),wr.writtendate,103), day(wr.writtendate), month(wr.writtendate), year(wr.writtendate), --wr.Adviser, wr.PriAdviser,
--wr.Firm, 

--Protection
case when wr.productsubgroupname like '%Annuity' then 'Annuities' when ((left(wr.productcode,2) in ('OW','OZ')) or wr.productcode = 'OFHBSIPP' or wr.provider = 'Zurich PLT') then 'COB Platform' when wr.productgroupname in ('Pensions','Investment') then 'COB Off-Platform' else wr.productgroupname end,
case when wr.productcode like '%AVIP%' then 'AVIVA OWL' else wr.productcode end,
wr.adminmethod

UNION


------------------------------------------------------------------- OWS L&G ASU Product Added 20/03/17
select 
'Written' as Type,
--uh.UserUID as Adviser,
--CASE WHEN sale.AdviserUID = '4007583' THEN '4007584' WHEN sale.AdviserUID= '1012002' THEN '1012011' ELSE sale.AdviserUID END AS PriAdviser,
--uh.businessuid as Firm,
convert(varchar(10),pol.ApplicationDate,103) as Date,
Day(pol.ApplicationDate) as Day,
Month(pol.ApplicationDate) as Month,
Year(pol.ApplicationDate) as Year,
sum(pps.PremiumAmount*12) as Premium,
sum(round(pps.PremiumAmount*12,2)) as APE,
sum(1) AS NewPolicies,
sum(round(pps.PremiumAmount*12*0.35,2)) as DA,
sum(round(pps.PremiumAmount*12*0.10,2)) as Margin,
'Protection' as ProductGroupName,
'L&GASU OWL' as ProductSubGroup,
'Advised' as adminmethod

from sa_ows_Policies  pol 
join policy.sa_ows_ProtectionProductSummary pps on pps.PolicyID = pol.PolicyID
join sa_ows_sale sale on sale.SaleID = pol.SaleID
join mi_insight_UserHierarchy uh on uh.UserUID = sale.AdviserUID
where InternalProductID = 10000063
and SaleStatusID = 2 and pol.Status = 2
and sale.adviserUID <> '4006226' -- Excluding the test UID
and pol.ApplicationDate >= @StartDate
and pol.ApplicationDate <= @EndDate

group by 
convert(varchar(10),pol.ApplicationDate,103),
Day(pol.ApplicationDate),
Month(pol.ApplicationDate),
Year(pol.ApplicationDate)


--and uh.OwlASMUID2 is not null
------------------------------------------------------------------------------------------------------  L&G Code END


Order by [year] desc, [month] desc, [day] desc




