Create Procedure [BI].[pr_019_AccreditedBody]

as

IF OBJECT_ID('tempdb..#A') IS NOT NULL	
DROP TABLE #A

Select SPS_UserID, MAX(EffectiveDate) AS EffectiveDate, MAX(RenewalDate) as RenewalDate, SPS_AccreditedBodyID
into #A
FROM
  (select SPS_ID, SPS_UserID, max(SPS_EffectiveDate) AS EffectiveDate, max(SPS_RenewalDate) AS RenewalDate, SPS_AccreditedBodyID
   from dbo.sa_insight_StatementOfProfessionalStanding SPS 
   WHERE SPS.SPS_Status = 2 --(SPS.SPS_IssueDate IS NOT NULL AND SPS.SPS_Status = 2)
   GROUP BY SPS_ID, SPS_UserID, SPS_AccreditedBodyID) SPS
GROUP By SPS_UserID,SPS_AccreditedBodyID

select distinct case when USR_ExternalID = '1010364' then '1010744' when USR_ExternalID = '4001519' then '1011554' when USR_ExternalID = '1003604' then '1005181' when USR_ExternalID = '1009352' then '1010487' else USR_ExternalID end as 'UID', 
ltrim(rtrim(USR_Name)) as InsightName, AG.competentstatusdescription as Status, max(#A.effectivedate) as Effective_Date, max(#A.renewaldate) as RenewalDate, acb.acb_description as Accredited_Body,
Case when SPS.qual_Description is NULL then 'No' else 'Yes' end as 'RDR_Compliant', UQUAL_UserID, sps.code_description
from sa_insight_UserDetails UD
inner join sa_insight_UserPosition UP on UD.USR_ID = UP.UPS_UserID
inner join sa_insight_userqualification UQ on UP.UPS_UserId = UQ.UQUAL_UserID
inner join sa_insight_qualification Q on UQ.uqual_QualificationId = Q.QUAL_ID
left join mstt_Agents AG on code = case when USR_ExternalID = '65' then '0000065' else USR_ExternalID end
left join (select UD.USR_ExternalID as 'UID', 
               ltrim(rtrim(USR_Name)) as InsightName, qual_Description, max(sps.sps_effectivedate) as sps_Effective_Date, max(sps.sps_renewaldate) as sps_Renewal_Date, acb.acb_description, AG.competentstatusdescription as CompStatus, code_description
           from sa_insight_UserDetails UD
           inner join sa_insight_UserPosition UP on UD.USR_ID = UP.UPS_UserID
           inner join sa_insight_userqualification UQ on UP.UPS_UserId = UQ.UQUAL_UserID
           inner join sa_insight_qualification Q on UQ.uqual_QualificationId = Q.QUAL_ID
           left join dbo.sa_insight_StatementOfProfessionalStanding SPS on usr_id = SPS.SPS_UserID
           Left join dbo.sa_insight_AccreditedBody acb on ACB_ID = SPS.SPS_AccreditedBodyID
           left join mstt_Agents AG on code = case when USR_ExternalID = '65' then '0000065' else USR_ExternalID end
           INNER JOIN dbo.sa_insight_codedescription CD on CD.code_code = UQ.uqual_status and CD.code_codetype=508
           where Q.qual_description = 'RDR Compliant'
           and competentstatusdescription not in ('NULL','NPW','Deceased')
                 and CD.code_description ='Open'
           Group by 
           UD.USR_ExternalID,
           ltrim(rtrim(UD.USR_Name)), Q.qual_Description, acb.acb_description, AG.competentstatusdescription, code_description) SPS on SPS.UID = USR_ExternalID 
--left join dbo.sa_insight_StatementOfProfessionalStanding PS on usr_id = PS.SPS_UserID
left join #A on usr_id = #A.SPS_UserID
Left join dbo.sa_insight_AccreditedBody acb on ACB_ID = #A.SPS_AccreditedBodyID
where competentstatusdescription ='Active'

Group by case when USR_ExternalID = '1010364' then '1010744' when USR_ExternalID = '4001519' then '1011554' when USR_ExternalID = '1003604' then '1005181' when USR_ExternalID = '1009352' then '1010487' else USR_ExternalID end, 
ltrim(rtrim(USR_Name)), AG.competentstatusdescription, acb.acb_description, Case when SPS.qual_Description is NULL then 'No' else 'Yes' end, UQUAL_UserID, code_description

order by max(#A.renewaldate) desc

DROP TABLE #A
GO
