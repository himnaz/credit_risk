Script Name:	28. BQMs for Firms.sql

*******************************************************************************************************************/

Create Procedure [BI].[pr_028_BQMsForFirms]

as

select      D.DIST_ID, D.DIST_CompanyName, DIST_TradingName, DIST_CreatedDate, D.DIST_Type, D.DIST_ExternalID, ud.USR_ExternalID as BQMUID, ud.USR_Name as BQMName
from  sa_insight_UserDetails ud 
            inner join sa_insight_UserPosition up on up.UPS_UserID = ud.USR_ID 
            inner join sa_insight_UserPositionLink UPL 
                              on  UPL.UPSL_ParentUserPositionID = up.UPS_ID
                              and getdate() between UPL.UPSL_DateFrom and isnull(UPL.UPSL_DateTo,'9999-12-31')
            inner join sa_insight_Distributor D 
                              on  D.DIST_ID = UPL.UPSL_ChildUserPositionID
                              and getdate() between isnull(D.DIST_DateFrom,'1900-01-01') and isnull(D.DIST_DateTo,'9999-12-31')
                              and D.DIST_Category in (0, 1, 2, 3, 4, 5, 6, 7, 15, 16, 17, 18, 19, 20)
                              and D.DIST_Type in (0,1) -- 10=Not Set; =Franchise 
where up.UPS_JobTitle   in (7,8,9)    --7=BQM; 9=AQM
and         (getdate() between up.UPS_DateFrom and isnull(up.UPS_DateTo,'9999-12-31') OR D.DIST_Status = 1)
