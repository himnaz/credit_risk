Create procedure [BI].[pr_007_MortgageToProtection]

as

Declare @StartDate as DateTime, @MonthCount as  Int
Set @StartDate = '01-Feb-19'
Set @MonthCount = 12


create table #MortFlags
	(Category varchar(50),TransType varchar(50),Result varchar(50));

insert into #Mortflags (Category,TransType,Result) values
('BTL','First time purchase','Mortgage: BTL'),('BTL','Further advance','Mortgage: BTL'),
('BTL','Product transfer','Mortgage: BTL'),('BTL','Remortgage','Mortgage: BTL'),
('BTL','Second or subsequent purchase','Mortgage: BTL'),('BTL','Unencumbered property','Mortgage: BTL'),
('CBTL','First time purchase','Mortgage: BTL'),('CBTL','Further advance','Mortgage: BTL'),
('CBTL','Product transfer','Mortgage: BTL'),('CBTL','Remortgage','Mortgage: BTL'),
('CBTL','Second or subsequent purchase','Mortgage: BTL'),('CBTL','Unencumbered property','Mortgage: BTL'),
('Residential','First time purchase','Mortgage:  New'),('Residential','First time buyer','Mortgage:  New'),
('Residential','Further advance','Mortgage: Remo'),('Residential','Product transfer','Mortgage: PT'),
('Residential','Remortgage','Mortgage: Remo'),('Residential','Second or subsequent purchase','Mortgage:  New'),
('Residential','Unencumbered property','Mortgage:  New')

create table #UID (OldUID varchar(25), NEWUID varchar(25))
insert into #UID (OldUID,NEWUID) values
('1001687','1002949'),('1009620','2010099'),('1002082','1004215'),('1003366','2011710'), ('2008732','1001602')

create table #Exclusions (PolicyID varchar(25), SaleID varchar(25))
insert into #Exclusions (PolicyID,SaleID) values
('551342368','1249639'),('551342367','1249639') -- Test policies

SELECT 
SaleId,
count(*) numberofTrans,
sum(case when ReasonForNoRecommendationId in (10250,10254) then 1 else 0 end) Rejected,
Case when count(*) = sum(case when ReasonForNoRecommendationId in (10250,10254)  then 1 else 0 end) then 'Declaration' else 'No Declaration' end as Declaration
into #Declaration
FROM [prod_zurich_openwork_datawarehouse].[PolicyOneLink].[sa_ows_ProtectionValidation]
group by SaleId;

SELECT 
SaleId,
count(*) numberofTrans,
sum(case when ReasonForNoRecommendationId in (10250,10254,10261,10264,10262)  then 1 else 0 end) Rejected,
Case when count(*) = sum(case when ReasonForNoRecommendationId in (10250,10254,10261,10264,10262) then 1 else 0 end) then 'Declaration' else 'No Declaration' end as Declaration
into #EffectiveDeclaration
FROM [prod_zurich_openwork_datawarehouse].[PolicyOneLink].[sa_ows_ProtectionValidation]
group by SaleId;


Select
ROW_NUMBER() over (partition by SaleID order by count(*)desc) as Reason,
saleid,
inv.ValueName
--Case when count(*) = sum(case when ReasonForNoRecommendationId = 10250 then 1 else 0 end) then 'Declaration' else 'No Declaration' end as Declaration
into #MainReason
from PolicyOneLink.sa_ows_ProtectionValidation
join staticdata.sa_ows_inputvalues inv on inv.inputid = reasonfornorecommendationID
group by SaleId, inv.ValueName
order by SaleID;


Select

pol.PolicyID,
sale.PersonID,
sale.SaleID,
rtrim(pers.FirstName) as FirstName,
rtrim(pers.lastname) as LastName,
convert(varchar,pers.DateOfBirth,103) as DOB,
pers.PostCode,
pers.EmailAddress,
sale.AdviserUID,
ag.Descn AdvName,
sale.BusinessUid,
ag2.Descn BusName,

sum(ffpep.PremiumAmount*12) APE,
'' Mortgagetype,
'' MortgageCategory,
sale.SaleStatusID,
convert(date,sale.Datesubmitted) Datesubmitted,
case when sare.ReferredSaleID is null then decl.Declaration
	 when sare.IsForOpenworkProtectionTeam = 1 then 'Active PS referral' 
	 when sare.ReferredBusinessUid = '2000655' then 'Referred to Hub' 
	 else (case when sare.ReferredAdviserUID = sare.ReferringAdviserUID then 'Deferred' when sare.ReferredAdviserUID != sare.ReferringAdviserUID then 'Referred' end) end
as ProtectionAdviceHandled,
iv1.Valuename hasprotection,
ffpep.PremiumAmount,
iv2.Valuename PremiumFrequency,
ffpep.Protectionprovider,
sum(case when prod.internalproductid = 10000033 then 1 else 0 end) as WOL,
sum(case when ppbd.HasLifeCoverType = 1 or ppb.IsLife = 1 then 1 else 0 end) as Life,
sum(case when ppbd.HasCICCoverType = 1 or ppb.IsCriticalIllness = 1 then 1 else 0 end) as CIC,
sum(case when isnull(ppbd.IncomeProtectionBenefit,ppb.IncomeProtectionBenefit) > 0 then 1 else 0 end) as IncomeProtection
,mr.ValueName ReasonNeedNotAddressed

,pmv.DisplayName Type
into #Protection2



from sa_ows_Policies pol
join sa_ows_sale sale on sale.SaleID = pol.SaleID
join sa_ows_Person pers on pers.PersonID = sale.PersonID
left join policy.sa_ows_protectionproduct prod on prod.InternalProductID = pol.InternalProductID
left join policy.sa_ows_ProtectionProductSummary pps on pps.PolicyID = pol.PolicyID
left join PolicyOneLink.sa_ows_ProtectionProductSummary olpps on olpps.PolicyId = pol.PolicyID
left join policy.sa_ows_ProtectionProductBenefitDetail ppbd on ppbd.ProtectionProductID = pps.ProtectionProductID
left join PolicyOneLink.sa_ows_ProtectionProductBenefit ppb on ppb.ProtectionProductSummaryId = olpps.ProtectionProductSummaryId
left join sa_swift_s_polmai polm on polm.PolicyRef = pol.PolicyID
left join sa_swift_PolicyTransactions potr on potr.PolicyID = polm.POL_NUM and potr.TransType = 17
left join sa_ows_FactFindProtections ffp on ffp.saleid = sale.saleid -- Has protection flag added 15/09/17 JB
left join sa_ows_FactFindProtectionsExistingProtections ffpep on ffpep.saleid = sale.saleid
left join StaticData.sa_ows_InputValues iv1 on iv1.InputID = ffp.HaveprotectionsID
left join StaticData.sa_ows_InputValues iv2 on iv2.InputID = ffpep.PremiumFrequencyID
left join #MainReason mr on mr.SaleId = sale.SaleID and mr.Reason = 1
left join sa_ows_SaleReferral sare on sare.ReferringSaleID = sale.SaleID
left join #Declaration decl on decl.SaleId = sale.SaleID
left join mstt_agents ag on ag.Code = sale.AdviserUID
left join mstt_agents ag2 on ag2.Code = sale.BusinessUID
left join staticdata.sa_ows_ProductMergeView pmv on pmv.internalproductid = pol.InternalProductID


where (pps.PolicyID is not null or olpps.PolicyId is not null)
and sale.DateSubmitted is not null
and pol.Status in (0,1,2,3)
--and sale.SaleStatusID = 2
and pol.PolicyID like '55%'
and sale.DateSubmitted >= DateAdd (month,-3 -@MonthCount,@StartDate) -- extra 3 months for the Protection
and sale.DateSubmitted < @StartDate
Group by
sale.PersonID,
rtrim(pers.FirstName),
rtrim(pers.lastname),
convert(varchar,pers.DateOfBirth,103),
pers.PostCode,
sale.SaleStatusID,
pers.EmailAddress,
ffpep.PremiumAmount,
iv1.Valuename,
iv2.Valuename,
ffpep.Protectionprovider,
sale.AdviserUID,
pol.PolicyID,
sale.SaleID,
sale.BusinessUid,
convert(date,sale.Datesubmitted),ag2.Descn,ag.Descn
,mr.ValueName,
case when sare.ReferredSaleID is null then decl.Declaration
	 when sare.IsForOpenworkProtectionTeam = 1 then 'Active PS referral' 
	 when sare.ReferredBusinessUid = '2000655' then 'Referred to Hub' 
	 else (case when sare.ReferredAdviserUID = sare.ReferringAdviserUID then 'Deferred' when sare.ReferredAdviserUID != sare.ReferringAdviserUID then 'Referred' end) end
,pmv.DisplayName 
----------------------------------------------------------------


select
mps.PolicyID,
sale.PersonID,
sale.SaleID,
rtrim(pers.FirstName) as FirstName,
rtrim(pers.lastname) as LastName,
convert(varchar,pers.DateOfBirth,103) as DOB,
pers.PostCode,
pers.EmailAddress,
sale.AdviserUID,
ag.Descn AdviserName,
sale.BusinessUid,
ag2.Descn BusinessName,
case when mps.MortgageAmount is null then pmps.InterestOnlyAmount else mps.MortgageAmount end as MortgageAmount,
invtype.ValueName as MortgageType,
invCat.ValueName as MortgageCategory,
case when invCat.ValueName = 'Residential' then 1 else 2 end as CatRanking,
invtrans.ValueName as MortgageTransType,
case when invtrans.ValueName in ('Remortgage','Product transfer','Further Advance') then 2 else 1 end as TypeRank,
convert(date,sale.DateSubmitted) DateSubmitted,
inv.ValueName as ProtectionAdviceAccepted,
case when inv.ValueName = 'Yes' then 1 else 2 end as AcctRank,
case when sare.ReferredSaleID is null then decl.Declaration when sare.ReferredBusinessUid = '2000655' then 'Referred to Hub' else (case when sare.ReferredAdviserUID = sare.ReferringAdviserUID then 'Deferred' when sare.ReferredAdviserUID != sare.ReferringAdviserUID then 'Referred' end) end as ProtectionAdviceHandled,
case when pro2.AdviserUID is null then 'No' else isnull(pro.AdviserUID,pro2.AdviserUID) end as ProtectionSold,
sare.IsForOpenworkProtectionTeam,
sare.SaleReferralStatusID,
sale2.SaleStatusID as referredstatus
,mf.Result Type
,mr.ValueName ReasonNeedNotAddressed,
pro2.AdviserUID as FuzzyAdviser

--oal.CreateDate
into #Mortgages
from vw_ows_MortgageProductSummary mps  --this is a consolidated view of the PolicyOneLink.MortgageProductSummary and Policy.MortgageProductSummary table
join StaticData.sa_ows_InputValues invType on invType.InputID = mps.MortgageTypeID
join StaticData.sa_ows_InputValues invCat on invCat.InputID = mps.MortgageCategoryID
join sa_ows_Policies pol on pol.PolicyID = mps.PolicyID
join sa_ows_Sale sale on sale.SaleID = pol.SaleID
join sa_ows_Person pers on pers.PersonID = sale.PersonID
join sa_ows_FactFindObjectivesProtection ffop on ffop.SaleID = pol.SaleID
left join StaticData.sa_ows_InputValues inv on inv.InputID = ffop.IsProtectionAdviceOfferAcceptedID
left join staticdata.sa_ows_InputValues inv2 on inv2.InputID = ffop.HowIsAdviceBeingManagedID
left join policy.sa_ows_MortgageRecommendedSolution mrs on mrs.PolicyID = mps.PolicyID
left join policyonelink.sa_ows_MortgageProductSummary olmps on olmps.PolicyId = mps.PolicyID
left join policy.sa_ows_MortgageProductSummary pmps on pmps.PolicyID = mps.PolicyID
left join StaticData.sa_ows_InputValues invTrans on invtrans.InputID = case when olmps.PolicyId is null then mrs.TransactionTypeID else olmps.TransactionTypeId end
left join sa_ows_SaleReferral sare on sare.ReferringSaleID = sale.SaleID
left join sa_ows_Sale sale2 on sale2.SaleID = sare.ReferredSaleID
left join #Declaration decl on decl.SaleId = sale.SaleID
left join mstt_agents ag on ag.Code = sale.AdviserUID
left join mstt_agents ag2 on ag2.Code = sale.BusinessUID
left join #MainReason mr on mr.SaleId = sale.SaleID and mr.Reason = 1
left join #Mortflags mf on mf.Category = invCat.ValueName and mf.Transtype = invtrans.ValueName
left join #Protection2 pro2 on (ltrim(rtrim(pro2.LastName)) = ltrim(rtrim(pers.lastname)) and convert(varchar,pro2.DOB,103) = convert(varchar,pers.DateOfBirth,103)) or (ltrim(rtrim(pro2.LastName)) = ltrim(rtrim(pers.lastname)) and ltrim(rtrim(pro2.PostCode)) = ltrim(rtrim(pers.PostCode)))
Left join #Protection2 pro on pro.PersonID = sale.PersonID

--join msit_OpenworkAdviserListing oal on oal.CaseId = mps.PolicyID --This is the data table that feeds into Open Access

where sale.DateSubmitted >= DateAdd (month,-@MonthCount,@StartDate)
and sale.DateSubmitted < @StartDate
and pol.Status in (0,1,2,3)
--and sale.BusinessUid = '1010729'
--and sale.PersonID = 71770
--order by sale.DateSubmitted

select distinct
m.BusinessUID, m.BusinessName BusName
,m.AdviserUID, m.AdviserName AdvName
,m.Type
,m.ProtectionSold ProtectionAdviser
,ag.Descn ProtectionAdviserName
,m.FirstName,m.LastName
,m.PolicyID,m.SaleID,m.PersonID,m.DOB,replace(m.Postcode,',','') Postcode,replace(m.EmailAddress,',','.') EmailAddress
--,replace(m.MortgageAmount,',','')  'Mort Amount/Prot APE'
,m.DateSubmitted
,case when m.ProtectionSold <> 'No' and m.ProtectionAdviceHandled = 'Declaration' then 'No Declaration' else m.ProtectionAdviceHandled end CurrentStatus
,m.ReasonNeedNotAddressed
into #fin
from #mortgages m left join mstt_agents ag on ag.Code = ProtectionSold 
	inner join
(select max(saleid) saleid,type,personid,firstname,lastname,dob from #mortgages group by type,personid,firstname,lastname,dob ) t
	on t.saleid= m.saleid and t.type = m.type
		and (t.personid = m.personid or (t.firstname = m.firstname and t.lastname = m.lastname and t.dob = m.dob))

union all

select distinct
 BusinessUID, Busname
 ,AdviserUID, AdvName
 ,Type
 , null FMAdviser
 ,null FMName
 ,Firstname,Lastname,PolicyID,SaleID,PersonID,DOB,replace(PostCode,',','') Postcode,replace(EmailAddress,',','.')--,sum(APE)
 ,Datesubmitted
 ,ProtectionAdviceHandled,ReasonNeedNotAddressed
  from
	(
	select distinct
	'Protection: ' + p2.Type type,p2.PolicyID ,SaleID,p2.PersonID,p2.FirstName,p2.LastName,p2.DOB,p2.Postcode,EmailAddress,AdviserUID,APE,BusinessUID,MortgageType,MortgageCategory, Datesubmitted,ReasonNeedNotAddressed,ProtectionAdviceHandled,BusName,AdvName
	from #protection2 p2 inner join mstt_agents ag on ag.code = p2.AdviserUID and ag.Manager2Code <> '1011671'
						 inner join 
						 (select max(policyid) policyid,type, firstname,lastname,personid from #protection2 group by	type, firstname,lastname,personid) q			
							on q.policyid = p2.PolicyID
	-- inner join (select distinct PersonID,FirstName,LastName,DOB from #mortgages) t on (t.DOB=p2.DOB and t.FirstName = p2.FirstName and t.LastName = p2.LastName) 
	--union all		
	--select distinct
	--'Protection: '  + p2.Type type, PolicyID,SaleID,p2.PersonID,p2.FirstName,p2.LastName,p2.DOB,Postcode,EmailAddress,AdviserUID,APE,BusinessUID,MortgageType,MortgageCategory, Datesubmitted,ReasonNeedNotAddressed,ProtectionAdviceHandled,BusName,AdvName
	--from #protection2 p2 inner join (select distinct PersonID from #mortgages) t on t.PersonID = p2.PersonID
	) t2
	
				
	group by
	 BusinessUID, Busname,AdviserUID, AdvName
	,Firstname,Lastname,PolicyID,SaleID,PersonID,DOB,PostCode,EmailAddress,Datesubmitted
	,ProtectionAdviceHandled,ReasonNeedNotAddressed
	,Type

	

	

select isnull(BUID.NewUID,f.BusinessUID) BusinessUID,ag2.Descn BusName,
isnull(AUID.NewUID,f.AdviserUID) AdviserUID,ag1.Descn AdvName

,f.Type,f.ProtectionAdviser,f.ProtectionAdviserName,f.FirstName,f.Lastname,f.PolicyID,f.SaleID,f.PersonID,f.DOB,f.PostCode,f.EmailAddress,
--f.[Mort Amount/Prot APE],
f.DateSubmitted,f.CurrentStatus
,case when f.ProtectionAdviser in (null,'No') then f.ReasonNeedNotAddressed else 'N/A' end ReasonNeedNotAddressed 
,case when m2.MortNum >0 then null else 'Y' end Protectiononly
from #fin f left join #uid Auid on Auid.OldUID = f.AdviserUID
			left join #uid Buid on Buid.OldUID = f.BusinessUID
			left join mstt_Agents ag1 on ag1.code = isnull(AUID.NewUID,f.AdviserUID)
			left join mstt_Agents ag2 on ag2.code = isnull(BUID.NewUID,f.BusinessUID)

		    left join #Exclusions ex on ex.PolicyID = f.PolicyID
			
			left join (select personid,count(personid) MortNum   From #mortgages group by personid) m2 on m2.PersonID = f.PersonID -- May need fuzzy match?


where ex.PolicyID is null -- manually excluded policies

order by Busname,lastname,firstname,type desc,Datesubmitted desc

drop table #protection2,#MortFlags,#UID,#fin,#exclusions
drop table #Declaration, #MainReason,#Mortgages,#EffectiveDeclaration

