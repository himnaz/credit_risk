	/****************************************************************************

		Final summary table with full hierarchy

	****************************************************************************/

	select Type
	,cast(case when Adviser = '4007583' then '4007584' when Adviser = '1012011' then '1012002' else Adviser end as varchar) Adviser
	,Firm
	,Adminmethod
	,Productgroupname
	,Productgroupname2
	,Productsubgroup
	,productsubtype
	,daily_category
	,Date
	,Day
	,Month
	,Year
	,Premium
	,APE
	,Newpolicies
	,DA,Margin
	,Startdate	
	-- Reporting hierarchy
	,case when  asm1 is null and asm2 is null and asm3 is null and asm4 is null and asm5 is null and asm6 is null and Pristatus <> 'Adviser' then Adviser
		 when  asm2 is null and asm3 is null and asm4 is null and asm5 is null and asm6 is null then asm1
		 when  asm3 is null and asm4 is null and asm5 is null and asm6 is null then asm2
		 when  asm4 is null and asm5 is null and asm6 is null then asm3
		 when  asm5 is null and asm6 is null then asm4
		 when  asm6 is null then asm5
	end L0,

	case when  asm2 is null and asm3 is null and asm4 is null and asm5 is null and asm6 is null and Pristatus <> 'Adviser' then Adviser
		 when  asm2 is null and asm3 is null and asm4 is null and asm5 is null and asm6 is null then asm1
