Case when (min(po.PolicyRef) is null AND ph.productgroupname = 'Protection' AND co.agent_code <> '1000312') then 0 else round(min(case when (ph.productgroupname = 'Protection' and ccs.description is null) then ((co.turnover * 2.2) *0.7) 
when (ph.productgroupname = 'Mortgage' and ccs.description is null) then (((pt.mortgageamount * (co.agent_perc/100)) * 0.0045) * 0.9) else (co.baseamount + co.upliftamount) end),2)END as NBI, 


Case when (min(po.PolicyRef) is null AND ph.productgroupname = 'Protection' AND co.agent_code <> '1000312') then 0 else round(min(case when (ph.productgroupname = 'Protection' and ccs.description is null) then ((co.turnover * 2.2) *0.3) 
when (ph.productgroupname = 'Mortgage' and ccs.description is null) then (((pt.mortgageamount * (co.agent_perc/100)) * 0.0045) * 0.1) else (co.salesmargin) end),2)END as Margin, 

Case when (min(po.PolicyRef) is null AND ph.productgroupname = 'Protection' AND co.agent_code <> '1000312') then 0 else max(case when co.transactionid = c.transactionid then (co.agent_perc/100) else 0 end)END as "NBCases", 
Case when (min(po.PolicyRef) is null AND ph.productgroupname = 'Protection' AND co.agent_code <> '1000312') then 0 else max((co.agent_perc/100))END as "AllCases", 
min(pt.FrequencyDescription) as frequency, min(po.PolicyRef) AS CaseID, 
po.CONT_NUM AS Policy, min(co.BusinessReason) as businessreason,
min(co.AdminMethodDescription) as adminmethoddescription, min(co.ProductCode) as productcode, min(po.COMP_CODE) AS Provider, min(rp.ReportingProductName) as reportingproductname, 
min(ph.ProductSubGroupName) as productsubgroupname, 
min(case when ph.productgroupname = 'Other' then 'Pensions' else ph.productgroupname end) as "ProductGroupName",
min(po.originatingsource) as originatingsource, min(case when ((ph.productgroupname <> 'Mortgage' and co.adminmethod NOT IN ('A','G')) or ph.productsubgroupname like '%Guaranteed Account%' or rp.reportingproductname = 'Zurich Bank Structured Product' or ph.productsubgroupname like '%Group Pension%' or po.comp_code = 'Zurich Leg' or co.productcode = 'ZGUA' or po.comp_code = 'Close' or po.comp_code = 'MSQ') then 'Non Advised' else 'Advised' end) as "Adminmethod", min(ccs.calculationcode) as calculationcode, min(ccs.description) as description, min(rtrim(ah.asdname)) as ASD


FROM          dbo.mstt_Commissions co INNER JOIN
			  dbo.mstt_PolicyTransactions pt ON pt.ID = co.TransactionID INNER JOIN
			  dbo.mstt_Policies po ON po.POL_NUM = co.PolicyID LEFT OUTER JOIN             
			  dbo.mstt_ProductHierarchy ph ON ph.ProductCode = co.ProductCode LEFT OUTER JOIN               
		      dbo.mstt_ProductProviders pp ON pp.ProductProviderCode = po.COMP_CODE LEFT OUTER JOIN
			  dbo.msit_CodeReportingProductCode rp ON rp.Code = ph.ReportingProductCode LEFT OUTER JOIN
			  dbo.msit_CodeCommissionShape ccs ON ccs.id = pt.CodeCommissionShapeID LEFT OUTER JOIN
			  #c c on c.transactionid = co.transactionid LEFT OUTER JOIN
			  cscv_AgentsHierarchy ah ON co.firm = ah.agentcode

where  
co.agent_code not in ('10002','1011542','10004','1011623')
and co.commissiontype = 1
and co.poltrantranstype = 39
and (co.adminmethoddescription <> 'Indexation' or co.adminmethoddescription is NULL)
and (ph.productgroupname <> 'GI' or ph.productgroupname is NULL)
and (left(ccs.description,3) <> 'IMP' or ccs.description is NULL)
and (left(ccs.description,2) <> 'UA' or ccs.description is NULL)
and (co.productcode not in ('OWADVICE','OWADHOC') or co.productcode is NULL)
and (rtrim(ah.ASDName) <> 'Pat Mckenna' or ah.ASDName is Null)
----------EXCLUDE ALL GROUP PENSION BUSINESS---------------------------
and (case when ph.productsubgroupname NOT IN ('Group Pension') then 1 when (ph.productsubgroupname = 'Group Pension'and year(pt.writtendate) <2016) then 1 else 0 end) = 1
-----------------------------------------------------------------------
group by cast(co.AGENT_CODE as int), round((case when (ph.productgroupname = 'Mortgage' and ccs.description is null) then ((pt.mortgageamount * (co.agent_perc/100)) * 0.0045) else co.Turnover end),2), po.policyref, po.cont_num, datepart(week,(pt.writtendate)), year(pt.writtendate),ph.productgroupname,co.agent_code) wr

where
wr.writtendate >= @StartDate
and wr.writtendate < @EndDate
and (wr.caseid not in ('500020430','500020431','550550857') or wr.caseid is null)
--and wr.adminmethod = 'Advised'

group by
wr.adviser,
day(wr.writtendate), month(wr.writtendate), year(wr.writtendate),

--Protection
case when wr.productsubgroupname like '%Annuity' then 'Annuities' when ((left(wr.productcode,2) in ('OW','OZ')) or wr.productcode = 'OFHBSIPP' or wr.provider = 'Zurich PLT' or wr.provider = 'Pru PLT') then 'COB Platform' when wr.productgroupname in ('Pensions','Investment') then 'COB Off-Platform' else wr.productgroupname end,
case when (case when wr.productsubgroupname like '%Annuity' then 'Annuities' else wr.productgroupname end) = 'Protection' then (case when wr.provider in ('Zurich New','Zurich Leg','Zurich PNL') then 'Zurich' when wr.provider = 'Axa' then 'Friends Life' when wr.provider = 'L&G' then 'L&G' when wr.provider = 'LV' then 'LV' when wr.provider = 'PRUPROTECT' then 'PRUPROTECT' else 'Other Protection' end) 

-- Platform
when (left(wr.productcode,2) in ('OW') or wr.productcode = 'OFHBSIPP' or wr.provider = 'Pru PLT') then 'IFDL'
when (left(wr.productcode,2) in ('OZ') or wr.provider = 'Zurich PLT') then 'ZIP'

-- Annuities
when (wr.provider = 'PTSP') then 'Partnership' when wr.provider = 'MGMA' then 'MGMA'
when (wr.provider = 'PRU' and (case when wr.productsubgroupname like '%Annuity' then 'Annuities' else wr.productgroupname end) = 'Annuities') then 'Pru Ann'
when (wr.provider = 'LB' and (case when wr.productsubgroupname like '%Annuity' then 'Annuities' else wr.productgroupname end) = 'Annuities') then 'LV'
when (case when wr.productsubgroupname like '%Annuity' then 'Annuities' else wr.productgroupname end) = 'Annuities' then 'Other Annuities'
-- Off Platform

when wr.provider = 'MetLife' then 'MetLife'
when wr.provider = 'PRU' then 'Pru Bond'
when wr.provider = 'Octopus' then 'Octopus'
when (wr.productgroupname = 'Investment' and wr.productsubgroupname like '%Guaranteed Account%') then 'Structured'
when wr.productsubgroupname like '%Group%' then 'Group Pensions'
when (left(wr.productsubgroupname,3)) = 'FEE' then 'Other Fee'
when wr.productgroupname in ('Pensions','Investment') then 'Other Comm'

-- Mortgages
when wr.productgroupname = 'Mortgage' then 'Mortgage' end

Order by day(wr.writtendate)


select
cast((year(wr.writtendate)) as nvarchar(max)) + (case when month(wr.writtendate) > month(@enddate) then 'NOT YTD' else 'YTD' end) as "YTD",
case when convert(datetime, dateadd(month,datediff(Month,0,wr.writtendate),0), 102) >= dateadd(month,-12,@enddate) then 'CurrR' when convert(datetime, dateadd(month,datediff(Month,0,wr.writtendate),0), 102) >= dateadd(month,-24,@enddate) then 'PrevR' else 'NOR12' end as "R12",
wr.adviser, wr.firm,
case when wr.reportingproductname like '%Leeds & Holbeck Mortgages%' then 'Leeds Building Society' when wr.reportingproductname like '%Nationwide Mortgages%' then 'Nationwide Building Society' when wr.reportingproductname like '%Natwest Mortgages%' then 'Natwest' when wr.reportingproductname like '%Progressive Mortgages%' then 'Progressive Building Society' when wr.reportingproductname like '%Abbey Mortgages%' then 'Santander for Intermediaries' when wr.reportingproductname like '%Skipton Mortgages%' then 'Skipton Building Society' when wr.reportingproductname like '%Northern Rock%' then 'Virgin Money' when wr.reportingproductname like '%Platform%' then 'Platform (Co-op Bank)' when wr.reportingproductname like '%BM Solutions%' then 'BM Solutions (LBG)' when wr.reportingproductname like '%The Mortgage Works%' then 'The Mortgage Works (NBS)' when wr.reportingproductname like '%Godiva%' then 'Coventry' when wr.reportingproductname like '%Kensington%' then 'Investec' when wr.reportingproductname like '%Principality%' then 'Principality' else replace(replace(wr.reportingproductname,' Mortgages',''),' (TBMC)','') end as 'Provider',
(cast((month(wr.writtendate)) as nvarchar(max)) + cast((year(wr.writtendate)) as varchar(max))) as Date, datepart(week,(wr.writtendate)) as "writtenweek", year(wr.writtendate) as "WrittenYear", month(wr.writtendate) as "WrittenMonth",
wr.caseid,
wr.MortgageCategory, wr.mortgagetype, wr.InterestType, 

case when wr.LVRatio is null then 'NA' when wr.LVRatio < '61' then '0-60%' when wr.LVRatio < '71' then '61-70%' when wr.LVRatio < '81' then '71-80%' when wr.LVRatio < '91' then '81-90%' else '91+%' end as 'LTV%',
case when wr.dealperiod < 24 then '12m-23m' when wr.dealperiod < 36 then '24m-35m' when wr.dealperiod < 60 then '36m-59m' when wr.dealperiod >= 60 then '60m+' else 'NA' end as dealperiod,
wr.MortgageTransaction,
wr.NBCases

from


(SELECT  
cast(co.AGENT_CODE as int) as Adviser,
min(coalesce(co.firm,co.agent_code)) as Firm,
min(co.transactionid) as transactionid, 
min(pt.writtendate) as writtendate, min(pt.issueddate) as issueddate,
datepart(week,(pt.writtendate)) as writtenweek, year(pt.writtendate) as writtenyear,
Case when (min(po.PolicyRef) is null AND ph.productgroupname = 'Protection' AND co.agent_code <> '1000312') then 0 else round((case when (ph.productgroupname = 'Mortgage' and ccs.description is null) then ((pt.mortgageamount * (co.agent_perc/100)) * 0.0045) else co.Turnover end),2)END as APE,
Case when (min(po.PolicyRef) is null AND ph.productgroupname = 'Protection' AND co.agent_code <> '1000312') then 0 else round(min(case when (ph.productgroupname = 'Protection' and ccs.description is null) then co.turnover * 2.2 
when (ph.productgroupname = 'Mortgage' and ccs.description is null) then ((pt.mortgageamount * (co.agent_perc/100)) * 0.0045) else co.distributionallowance end),2)END as distributionallowance, 

Case when (min(po.PolicyRef) is null AND ph.productgroupname = 'Protection' AND co.agent_code <> '1000312') then 0 else round(min(case when (ph.productgroupname = 'Protection' and ccs.description is null) then ((co.turnover * 2.2) *0.7) 
when (ph.productgroupname = 'Mortgage' and ccs.description is null) then (((pt.mortgageamount * (co.agent_perc/100)) * 0.0045) * 0.9) else (co.baseamount + co.upliftamount) end),2)END as NBI, 


Case when (min(po.PolicyRef) is null AND ph.productgroupname = 'Protection' AND co.agent_code <> '1000312') then 0 else round(min(case when (ph.productgroupname = 'Protection' and ccs.description is null) then ((co.turnover * 2.2) *0.3) 
when (ph.productgroupname = 'Mortgage' and ccs.description is null) then (((pt.mortgageamount * (co.agent_perc/100)) * 0.0045) * 0.1) else (co.salesmargin) end),2)END as Margin, 
Case when (min(po.PolicyRef) is null AND ph.productgroupname = 'Protection' AND co.agent_code <> '1000312') then 0 else max(case when co.transactionid = c.transactionid then (co.agent_perc/100) else 0 end)END as "NBCases", 
Case when (min(po.PolicyRef) is null AND ph.productgroupname = 'Protection' AND co.agent_code <> '1000312') then 0 else max((co.agent_perc/100))End as "AllCases",
min(pt.FrequencyDescription) as frequency, min(po.PolicyRef) AS CaseID, 
po.CONT_NUM AS Policy, min(co.BusinessReason) as businessreason,
min(co.AdminMethodDescription) as adminmethoddescription, min(co.ProductCode) as productcode, min(po.COMP_CODE) AS Provider, min(rp.ReportingProductName) as reportingproductname, 
min(ph.ProductSubGroupName) as productsubgroupname, 
min(case when ph.productgroupname = 'Other' then 'Pensions' else ph.productgroupname end) as "ProductGroupName",
min(po.originatingsource) as originatingsource, min(case when ((ph.productgroupname <> 'Mortgage' and co.adminmethod NOT IN ('A','G')) or ph.productsubgroupname like '%Guaranteed Account%' or rp.reportingproductname = 'Zurich Bank Structured Product' or ph.productsubgroupname like '%Group Pension%' or po.comp_code = 'Zurich Leg' or co.productcode = 'ZGUA' or po.comp_code = 'Close' or po.comp_code = 'MSQ') then 'Non Advised' else 'Advised' end) as "Adminmethod", min(ccs.calculationcode) as calculationcode, min(ccs.description) as description, min(rtrim(ah.asdname)) as ASD,
min(iv.valuename) as MortgageCategory, min(iv2.valuename) as MortgageType, min(iv3.valuename) as InterestType, min(mop.MortgageLVratio) as LVRatio, min(replace(replace(replace(iv4.valuename,' years',''),'under 2',''), 'Lifetime', 100))*12 as dealperiod, min(iv5.valuename) as MortgageTransaction

FROM          dbo.mstt_Commissions co INNER JOIN
			  dbo.mstt_PolicyTransactions pt ON pt.ID = co.TransactionID INNER JOIN
			  dbo.mstt_Policies po ON po.POL_NUM = co.PolicyID LEFT OUTER JOIN             
			  dbo.mstt_ProductHierarchy ph ON ph.ProductCode = co.ProductCode LEFT OUTER JOIN               
		      dbo.mstt_ProductProviders pp ON pp.ProductProviderCode = po.COMP_CODE LEFT OUTER JOIN
			  dbo.msit_CodeReportingProductCode rp ON rp.Code = ph.ReportingProductCode LEFT OUTER JOIN
			  dbo.mstt_Clients cl ON co.CLIENT_NUM = cl.CLIENT_NUM  LEFT OUTER JOIN
			  dbo.msit_CodeCommissionShape ccs ON ccs.id = pt.CodeCommissionShapeID LEFT OUTER JOIN
			  #c c on c.transactionid = co.transactionid LEFT OUTER JOIN
			  dbo.sa_ows_policies opol ON opol.PolicyID = po.policyref LEFT OUTER JOIN
