wr.adviser, wr.firm,
case when wr.reportingproductname like '%Leeds & Holbeck Mortgages%' then 'Leeds Building Society' when wr.reportingproductname like '%Nationwide Mortgages%' then 'Nationwide Building Society' when wr.reportingproductname like '%Natwest Mortgages%' then 'Natwest' when wr.reportingproductname like '%Progressive Mortgages%' then 'Progressive Building Society' when wr.reportingproductname like '%Abbey Mortgages%' then 'Santander for Intermediaries' when wr.reportingproductname like '%Skipton Mortgages%' then 'Skipton Building Society' when wr.reportingproductname like '%Northern Rock%' then 'Virgin Money' when wr.reportingproductname like '%Platform%' then 'Platform (Co-op Bank)' when wr.reportingproductname like '%BM Solutions%' then 'BM Solutions (LBG)' when wr.reportingproductname like '%The Mortgage Works%' then 'The Mortgage Works (NBS)' when wr.reportingproductname like '%Godiva%' then 'Coventry' when wr.reportingproductname like '%Kensington%' then 'Investec' when wr.reportingproductname like '%Principality%' then 'Principality' else replace(replace(wr.reportingproductname,' Mortgages',''),' (TBMC)','') end,
(cast((month(wr.writtendate)) as nvarchar(max)) + cast((year(wr.writtendate)) as varchar(max))), datepart(week,(wr.writtendate)), year(wr.writtendate), month(wr.writtendate),
wr.NBCases,
wr.caseid,
wr.MortgageCategory, wr.mortgagetype, wr.InterestType, 
case when wr.LVRatio is null then 'NA' when wr.LVRatio < '61' then '0-60%' when wr.LVRatio < '71' then '61-70%' when wr.LVRatio < '81' then '71-80%' when wr.LVRatio < '91' then '81-90%' else '91+%' end,
case when wr.dealperiod < 24 then '12m-23m' when wr.dealperiod < 36 then '24m-35m' when wr.dealperiod < 60 then '36m-59m' when wr.dealperiod >= 60 then '60m+' else 'NA' end
, wr.MortgageTransaction

select s.PersonID as personsid, s.SaleId as saleid, s.adviseruid as adviseruid, ag1.descn as AdviserName, s.businessuid as businessuid, ag2.descn as BusinessName, pol.PolicyID as OWSPolicy, coalesce(pp.producttype, mp.producttype) as ProductType, month(s.datesubmitted) as monthsubmitted, year(s.datesubmitted) as monthsubmitted, case when P.ValueName is Null then (case when OP.isprotectionadviceofferacceptedID = '20' then 'A - NO PRO' else 'B - Old' end) else p.valuename end as Ref
