	-------------- DUPLICATE APE FOR NEW MANAGERS IN INCENTIVE PERIOD ------------------------------

			SELECT 
					h.*
					,hier.owlasmuid1 asm1
					,hier.owlasmuid2 asm2
					,hier.owlasmuid3 asm3
					,hier.owlasmuid4 asm4
					,hier.owlasmuid5 asm5
					,hier.owlasmuid6 asm6
					,CASE WHEN h.promotiondate IS NULL or h.date <= CONVERT(DATE, h.promotiondate) THEN 'Manager' 
						  WHEN h.date > CONVERT(DATE, h.promotiondate) THEN 'Adviser'
					 END PriStatus
					,1 dupe

			FROM 
					Owl_Prod_Initial h LEFT JOIN
					mi_insight_UserHierarchyAllUsers hier ON CONVERT(VARCHAR,hier.UserUID) = CONVERT(VARCHAR,h.Priadviser) AND ((CONVERT(DATE,h.date) >= hier.effectivestartdate AND CONVERT(DATE,h.date) <= hier.effectiveenddate))
				 		 
			WHERE  
					h.promotiondate BETWEEN @startdate AND @enddate),
	-------------- END DUPLICATE APE FOR NEW MANAGERS IN INCENTIVE PERIOD ------------------------------
	
	-------------- FINAL OWL SUMMARY TABLE -------------------------------------------------
	Owl_Prod AS (

			SELECT 
					Type
					,PriAdviser AS Adviser
					,Firm AS Firm
					,Date
					,Day
					,Month
					,Year 
					,SUM(Premium) AS Premium
					,SUM(APE) AS APE
					,SUM(Newpolicies) AS Newpolicies
					,SUM (DA) AS DA
					,SUM(Margin) AS Margin
/***********************************************************************************************************************
                             ADD NBI, TOTAL CASES & ReportingProductName INTO FINAL TABLE
***********************************************************************************************************************/
					,SUM(NBI) AS NBI
					,SUM(AllCases) AS AllCases
					,ReportingProductName
/**********************************************************************************************************************/
					,Productgroupname
					,ProductSubGroup
					,Adminmethod
					,'Owl' AS Channel

			FROM 
					i LEFT JOIN 
					(SELECT UserUID UID 
					 FROM  mi_insight_userhierarchyallusers 
					 WHERE userjobtitlecodeseller = 61 AND effectiveenddate > GETDATE()) Panel ON panel.UID = CASE WHEN i.Priadviser = '4007583' THEN '4007584' 
																											       ELSE i.Priadviser 
																											   END
		
			GROUP BY 
					Type
					,Adminmethod
					,PriAdviser
					,Firm
					,Productgroupname
/***********************************************************************************************************************
                             ADD ReportingProductName INTO FINAL TABLE
***********************************************************************************************************************/
					,reportingproductname

/**********************************************************************************************************************/
					,Date
					,Day
					,ProductSubGroup
					,Month
					,Year 
					,YTD)
	
	-------------- END OF FINAL OWL SUMMARY TABLE -------------------------------------------------

	
	-------------- FINAL WRITTEN BUSINESS OUTPUT CREATION ------------------------------
	INSERT bi.WrittenBusiness
				([Type]
				,[Adviser]
				,[Firm]
				,[Date]
				,[Day]
				,[Month]
				,[Year]
				,[Premium]
				,[APE]
				,[NewPolicies]
				,[DA]
				,[Margin]
/***********************************************************************************************************************
                             ADD NBI, TOTAL CASES & ReportingProductName INTO FINAL TABLE
***********************************************************************************************************************/
				,[NBI]
				,[AllCases]
				,[ReportingProductName]
/**********************************************************************************************************************/
				,[ProductGroupName]
				,[ProductSubGroup]
				,[AdminMethod]
				,[Channel]
				)
		SELECT	 ISNULL([Type], '')
				,ISNULL([Adviser], '')
				,ISNULL([Firm], '')
				,ISNULL([Date], CAST('00010101' AS DATE))
				,ISNULL([Day], 1)
				,ISNULL([Month], 1)
				,ISNULL([Year], 1)
				,ISNULL([Premium], 0.0)
				,ISNULL([APE], 0.0)
				,ISNULL([NewPolicies], 0.0)
				,ISNULL([DA], 0.0)
				,ISNULL([Margin], 0.0)
/***********************************************************************************************************************
                             ADD NBI, TOTAL CASES & ReportingProductName INTO FINAL TABLE
***********************************************************************************************************************/
				,ISNULL([NBI], 0.0)
				,ISNULL([AllCases], 0.0)
				,ISNULL([ReportingProductName], '')
/**********************************************************************************************************************/
				,ISNULL([ProductGroupName], '')
				,ISNULL([ProductSubGroup], '')
				,ISNULL([AdminMethod], '')
				,ISNULL([Channel], '')
		FROM	OW_Prod
		UNION ALL
		SELECT	 ISNULL([Type], '')
				,ISNULL([Adviser], '')
				,ISNULL([Firm], '')
				,ISNULL([Date], CAST('00010101' AS DATE))
				,ISNULL([Day], 1)
				,ISNULL([Month], 1)
				,ISNULL([Year], 1)
				,ISNULL([Premium], 0.0)
				,ISNULL([APE], 0.0)
				,ISNULL([NewPolicies], 0.0)
				,ISNULL([DA], 0.0)
				,ISNULL([Margin], 0.0)
/***********************************************************************************************************************
                             ADD NBI, TOTAL CASES & ReportingProductName INTO FINAL TABLE
***********************************************************************************************************************/
				,ISNULL([NBI], 0.0)
				,ISNULL([AllCases], 0.0)
				,ISNULL([ReportingProductName], '')
/**********************************************************************************************************************/
				,ISNULL([ProductGroupName], '')
				,ISNULL([ProductSubGroup], '')
				,ISNULL([AdminMethod], '')
				,ISNULL([Channel], '')
		FROM	Owl_Prod;
END

