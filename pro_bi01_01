				,ISNULL([ProductGroupName], '')
				,ISNULL([ProductGroupName2], '')
				,ISNULL([ProductSubGroup], '')
				,ISNULL([AdminMethod], '')
				,ISNULL([Channel], '')
		FROM	#Issued_Swift
		UNION ALL
		SELECT	 ISNULL([Type], '')
				,ISNULL([Adviser], '')
				,ISNULL([Firm], '')
				,ISNULL([Date], CAST('00010101' AS DATE))
				,ISNULL([Day], 1)
				,ISNULL([Month], 1)
				,ISNULL([Year], 1)
				,ISNULL([Premium], 0.0)
				,ISNULL([APE], 0.0)
				,ISNULL([NewPolicies], 0.0)
/**********************************************************************
NEW COLUMNS ADDED
**********************************************************************/
				,ISNULL([Cases], 0.0)
/*********************************************************************/
				,ISNULL([DA], 0.0)
				,ISNULL([Margin], 0.0)
/**********************************************************************
NEW COLUMNS ADDED
**********************************************************************/
				,ISNULL([NBI],0.0)
				,ISNULL([reportingproductname],'')
/*********************************************************************/
				,ISNULL([ProductGroupName], '')
				,ISNULL([ProductGroupName2], '')
				,ISNULL([ProductSubGroup], '')
				,ISNULL([AdminMethod], '')
				,ISNULL([Channel], '')
		FROM	#Owl_Issued_Business
		UNION ALL
		SELECT	 ISNULL([Type], '')
				,ISNULL([Adviser], '')
				,ISNULL([Firm], '')
				,ISNULL([Date], CAST('00010101' AS DATE))
				,ISNULL([Day], 1)
				,ISNULL([Month], 1)
				,ISNULL([Year], 1)
				,ISNULL([Premium], 0.0)
