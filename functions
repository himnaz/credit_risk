/****************************************************************************
Program:  	  owf_CalcDateNWorkingDaysEarlierthanDate						
Author:	      Mike Cawood
Date created:	03/09/2010							
											
Description:   

This function takes the supplied Date (@Date) and subtracts the number of days supplied
as the input parameter @Days = N (min value 0) and returns the date N working days prior.
to this date. The SWIFT CodeBankHolidays table is used to define bank holidays. This only
covers the period back to 2005.

It is called as follows:

Select dbo.owf_CalcDateNWorkingDaysEarlierthanToday('2010/09/03','0')
									
	Amendment History								
	-----------------								
											
	Date		Who			Description				
	----		---			-----------			
****************************************************************************/

CREATE FUNCTION [dbo].[owf_CalcDateNWorkingDaysEarlierthanDate]
              (@StartDate datetime, @Days int)
RETURNS Datetime
as 
BEGIN

declare @N int; set @N = -1;

Declare @Date datetime;
set @Date = dateadd(dd,0,datediff(dd,0,@StartDate))

  While (@N <= @Days)
  Begin
    set @Date = dateadd(dd,-1,@Date)
    If datepart(dw,@Date) between 2 and 6 
    and @Date not in (Select HolidayDate from sa_swift_CodeBankHolidays)
    set @N = @N+1 

    If @N = @Days
    Break
  End;

Return @Date;

END;
