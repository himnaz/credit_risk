/******************************************************************************************************************************
     Program:	owf_HashForwardUID 

	  Author:	A Groves
Date created:	07/06/2022              
                      
 Description:	This function takes an agent UID, looks up their ID on the Agents table and applies an offset. This gives us
				an unrelated number that is unique to the enterprise. This number is reversible and can be used to derive the
				UID. The purpose of the hash number is to append it to files to link the files to the enterprise but without
				using the enterprise's UID which is often used as a password.

It is called as follows:

select BI.owf_HashForwardUID('1001734')


Amendment History               
-----------------               
                      
Date		Who				Description       
----		---				-----------     
******************************************************************************************************************************/

CREATE FUNCTION [BI].[owf_HashForwardUID]
(	
	@AgentUID varchar(7)
)
returns varchar(6)
as
begin

declare @ID int,
		@Hash varchar(6)

select @ID = ID
from mstt_Agents
where Code = @AgentUID

set @Hash = right('000000' + convert(varchar(6), 420000 - @ID),6)

return @Hash

end




