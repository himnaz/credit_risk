/***********************************************************************************

Author:	A Groves

Date:	27/01/2016

Purpose:	This function was developed for use in every firm KPI function to determine
			whether or not the KPI should be calculated as they should only calculate
			quarterly.
			
			The config row on table "owt_SelectionControl" allows the normal quarterly 
			schedule to be overridden and will force the firm KPI to be calculated 
			irrespective of the date.

			Use the function as follows:
			
			if dbo.f_Insight_FirmKPIRequired(getdate()) = 1
				Calculate Firm KPI
			else
				Don't Calculate Firm KPI
			
			
AMENDMENT HISTORY
=================

Date		Author		Description
----		------		-----------

************************************************************************************/

CREATE FUNCTION [dbo].[f_Insight_FirmKPIRequired] (@RunDate datetime)

RETURNS bit

AS

BEGIN
	declare @ReturnValue bit
	
	set @ReturnValue = 0
	
	set @RunDate = dateadd(dd,0,datediff(dd,0,@Rundate))	-- strip off time
	
	if MONTH(@RunDate) in (1,4,7,10)						-- If Jan, Apr, Jul, Oct
		set @ReturnValue = 1
	else
		if exists (	select	1								-- Check if firm override has been configured
					from	owt_SelectionControl
					where	Process = 'Insight KPI Calculation'		
					and		SelectionType = 'FirmKPI'
					and		@RunDate between EffectiveStartDate and EffectiveEndDate
				   )
			Set @ReturnValue = 1

	return   @ReturnValue

END

