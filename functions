CREATE FUNCTION [dbo].[cscf_GetAgentLicences](@AgentID int,@SuperID int)  
RETURNS VARCHAR(100) AS  
BEGIN 
  
    DECLARE @Licences VARCHAR(100) 

  DECLARE @AgentLicences TABLE
    (LicenceCode VARCHAR(10))
  DECLARE @SupervisorLicences TABLE
    (LicenceCode VARCHAR(10))

  INSERT INTO @AgentLicences 
  SELECT AgentLicence.LicenceCode
    FROM mstt_Agents AS Agents
  INNER JOIN mstt_AgentLicence AS AgentLicence ON AgentLicence.AgentID = Agents.id
  WHERE
  AgentLicence.AgentID=@AgentID
  AND SUBSTRING(LicenceCode,1,1) IN ( 'E', 'K', 'P')
  AND LicenceCode NOT IN ('PGIP', 'PGIU')
  AND (AgentLicence.StartDate IS NOT NULL)
    AND (AgentLicence.EndDate IS NULL)

  INSERT INTO @SupervisorLicences 
  SELECT AgentLicence.LicenceCode
    FROM mstt_Agents AS Agents
  INNER JOIN mstt_AgentLicence AS AgentLicence ON AgentLicence.AgentID = Agents.ID
  WHERE
  AgentLicence.AgentID=@SuperID
  AND SUBSTRING(LicenceCode,1,1) IN ( 'E', 'K', 'P')
  AND LicenceCode NOT IN ('PGIP', 'PGIU')
  AND (AgentLicence.StartDate IS NOT NULL)
    AND (AgentLicence.EndDate IS NULL)

  SELECT @Licences = ISNULL(@Licences + ', ' , '') + AgentLicences.LicenceCode 
    FROM @AgentLicences AS AgentLicences
  WHERE AgentLicences.LicenceCode NOT IN
  (SELECT SupervisorLicences.LicenceCode FROM @SupervisorLicences AS SupervisorLicences) 
  
  RETURN @Licences

END


