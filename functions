                              AND CAST(CONVERT(NVARCHAR,Date_Recv, 112) AS DATETIME) < CAST(CONVERT(NVARCHAR,@StartDate, 112) AS DATETIME) 
                           ))                                          -- Commission/margin due after Opening date & received before Opening date 
                           * (-1) -- show as negative

                        WHEN @CommissionType IN (2, 15, 16, 17, 18, 19) AND @Openwork = 'Y' THEN -- Openwork Clawbacks & Adjustments
                           (SELECT 
                            CASE
                               WHEN @Openwork = 'Y' THEN ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcMarginDue_SW(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                               ELSE ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcCommissionDue_SW(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                            END
                            FROM msit_S_PACC AS Expect
                            INNER JOIN msit_PolicyTransactions PolicyTransactions ON PolicyTransactions.ID = TransactionID 
                            WHERE Type = @CommissionType
                              AND CAST(CONVERT(NVARCHAR,Date_Due, 112) AS DATETIME) < CAST(CONVERT(NVARCHAR,@StartDate, 112) AS DATETIME)
                           )                                           -- Commission/margin due before Opening date
                           +                                           -- plus
                           (SELECT
                            CASE
                               WHEN @Openwork = 'Y' THEN ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcMarginDue_SW(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                               ELSE ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcCommissionDue_SW(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                            END
                            FROM msit_S_PACC AS Expect
                            INNER JOIN msit_PolicyTransactions PolicyTransactions ON PolicyTransactions.ID = TransactionID 
                            WHERE Type = @CommissionType
                              AND CAST(CONVERT(NVARCHAR,Date_Due, 112) AS DATETIME) >= CAST(CONVERT(NVARCHAR,@StartDate, 112) AS DATETIME)
                              AND CAST(CONVERT(NVARCHAR,Date_Recv, 112) AS DATETIME) < CAST(CONVERT(NVARCHAR,@StartDate, 112) AS DATETIME) 
                           )                                           -- Commission/margin due after Opening date & received before Opening date 

          WHEN @CommissionType = 8 AND @Openwork = 'Y' THEN -- Openwork Standing Orders
                           (SELECT ISNULL(SUM(ISNULL(CAST(Pay.Amount AS DECIMAL(15,2)), 0.00)), 0.00)
                            FROM msit_S_AgmFil AS Pay
                            LEFT JOIN msit_S_Agents AS Agents ON Pay.Agent_Code = Agents.Code
                            WHERE Pay.Type = @CommissionType 
                              AND Agents.Descn <> 'Openwork' -- NOTE: Non-Openwork values summed for Openwork totals!
                              AND CAST(CONVERT(NVARCHAR,Pay.PaymentDueDate, 112) AS DATETIME) < CAST(CONVERT(NVARCHAR,@StartDate, 112) AS DATETIME)
                           )                                           -- Expenses & charges before Opening date

      ELSE
                           0
                     END
                    )
   RETURN @Result
END




