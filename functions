CREATE FUNCTION [dbo].[fnFranchiseTurnover] -- WITH RECOMPILE,ENCRYPTION
(@FranchiseCode VARCHAR (128),
@DateFrom DATETIME)
RETURNS MONEY
AS
/******************************************************************************
Copyright (C) Moore Stephens Consulting Limited 2005
Summary : %Summary%
Author  : Isaac Abraham
Created : 8th September 2005
<doc>
  <summary>%Summary%</summary>
  <param name='%Param1Name%'>%Param1Summary%</param>
  <returns>%Returns%</returns>
  <author>Isaac Abraham</author>
  <revision>
    <dateCreated>20/12/2005</dateCreated>
    <author>IA</author>
    <summary>Use both the msdt_adviser and msdt_adviserdummies to get the COMPLETE list of advisers!</summary>
  </revision>
</doc>
*******************************************************************************/
-- Function code goes here
BEGIN
DECLARE
  @Output MONEY
DECLARE @DateTo DATETIME
SET @DateTo = CAST ((DATEPART (YEAR, @DateFrom)) AS VARCHAR(4))+'-12-31'
SELECT
  @Output = SUM (Turnover)
FROM
  (SELECT FranchiseCode, AdviserId FROM msdt_adviser UNION SELECT FranchiseCode, AdviserId FROM msdt_adviserdummies) ad
JOIN
  msft_sales sa ON ad.AdviserId = sa.AdviserId
JOIN
  msdt_calendartime ca on sa.DateIssuedId = ca.DateID
JOIN
  msdt_BusinessType bt on bt.BusinessTypeId = sa.BusinessTypeId
JOIN
  mst_DateTimeControl dtc on dtc.EntryTypeId = ca.EntryTypeId
WHERE
  FranchiseCode = @FranchiseCode
  AND bt.BusinessType = 'Issued'    -- Issued business only
  AND ca.DateTime >= @DateFrom  -- Transactions only between date from...
  AND ca.DateTime <= @DateTo    -- ... to the end of that year
  AND dtc.EntryType = 'DateIssued'  -- Issued business dates
  AND DateIssuedId >= 0
RETURN ISNULL (@Output, 0)
END

