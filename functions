CREATE function [dbo].[f_Insight_GetBusinessSalesHierarchy] ()
RETURNS TABLE
AS

/************************************************************************************************
Program:  	    f_Insight_GetBusinessSalesHierarchy						
Author:	        Mike Cawood
Date created:	  10/03/2011
											
Description:   

This function returns the current Sales Hierarchy from Insight for each Business
namely BDD/BDM and Area Director. The latest instance the Business entry is used.
Note that the BDD or Area levels may not be populated particularly for inactive 
Businesses.

Execute using the following command (or use as JOIN in query):
  select * from [dbo].[f_Insight_GetBusinessSalesHierarchy] ()
									
	Amendment History								
	-----------------								
											
	Date		  Who			    Description				
	----		  ---			    -----------			
	10/02/22      Chris Mellors     Removed unneccessary insert into table variable
	                                Added DISTINCT filters to remove huge amount of duplication
									Fixed bug in HN5 join, with incorrect reference to HN4.HN_DateTo
************************************************************************************************/

RETURN

select DISTINCT
 DIST.DIST_ExternalID as BusinessUID
,coalesce(DIST.DIST_TradingName,DIST.DIST_CompanyName) as BusinessName
,cd1.Code_Description as BusinessType
,cd2.Code_Description as BusinessStatus
,Coalesce(h.BDDUID1, h.BDDUID2, h.BDDUID3, h.BDDUID4, h.BDDUID5) as BDD_UID
,Coalesce(h.BDDBDM1, h.BDDBDM2, h.BDDBDM3, h.BDDBDM4, h.BDDBDM5) as BDD_Name
,Coalesce(h.ADUID1, h.ADUID2, h.ADUID3, h.ADUID4, h.ADUID5) as AD_UID
,Coalesce(h.AD1, h.AD2, h.AD3, h.AD4, h.AD5) as AD_Name
from sa_insight_distributor DIST
inner join (Select DIST_ExternalID,max(DIST_UpdatedDate) as Updated 
			from sa_insight_Distributor
			group by DIST_ExternalID) X on x.DIST_ExternalID = DIST.DIST_ExternalID and x.Updated = DIST.DIST_UpdatedDate
left join (	select DISTINCT DIST.DIST_ExternalID as EnterpriseUID, DIST.DIST_CompanyName as EnterpriseName
			, b1.UID as 'BDDUID1', b1.AgentName as 'BDDBDM1', a1.UID as 'ADUID1', a1.AgentName as 'AD1'
			, b2.UID as 'BDDUID2', b2.AgentName as 'BDDBDM2', a2.UID as 'ADUID2', a2.AgentName as 'AD2'
			, b3.UID as 'BDDUID3', b3.AgentName as 'BDDBDM3', a3.UID as 'ADUID3', a3.AgentName as 'AD3'
			, b4.UID as 'BDDUID4', b4.AgentName as 'BDDBDM4', a4.UID as 'ADUID4', a4.AgentName as 'AD4'
			, b5.UID as 'BDDUID5', b5.AgentName as 'BDDBDM5', a5.UID as 'ADUID5', a5.AgentName as 'AD5'
			from sa_insight_distributor DIST
			left join sa_insight_hierarchynodelink HNL1 on DIST.DIST_ID = HNL1.HNL_ParentID and HNL1.HNL_DateTo is null
			left join sa_insight_hierarchynode HN1 on HNL1.HNL_NodeID = HN1.HN_ID and HN1.HN_DateTo is null
			left join sa_insight_hierarchynodelink HNL2 on HN1.HN_ID = HNL2.HNL_NodeID and HNL2.HNL_DateTo is null and HNL2.HNL_Type = '0'
			left join sa_insight_hierarchynode HN2 on HNL2.HNL_ParentID = HN2.HN_ID and HN2.HN_DateTo is null
			left join sa_insight_hierarchynodelink HNL3 on HN2.HN_ID = HNL3.HNL_NodeID and HNL3.HNL_DateTo is null and HNL3.HNL_Type = '0'
			left join sa_insight_hierarchynode HN3 on HNL3.HNL_ParentID = HN3.HN_ID and HN3.HN_DateTo is null
			left join sa_insight_hierarchynodelink HNL4 on HN3.HN_ID = HNL4.HNL_NodeID and HNL4.HNL_DateTo is null and HNL4.HNL_Type = '0'
			left join sa_insight_hierarchynode HN4 on HNL4.HNL_ParentID = HN4.HN_ID and HN4.HN_DateTo is null
			left join sa_insight_hierarchynodelink HNL5 on HN4.HN_ID = HNL5.HNL_NodeID and HNL5.HNL_DateTo is null and HNL5.HNL_Type = '0'
			left join sa_insight_hierarchynode HN5 on HNL5.HNL_ParentID = HN5.HN_ID and HN5.HN_DateTo is null
			left join (	SELECT DISTINCT USR.USR_ID as USRID, USR.USR_Name as AgentName,USR.USR_ExternalID as UID,UPS.UPS_OrganisationalUnitID as OUID,HN.HN_Description as OrganisationalUnit
						FROM sa_insight_UserPosition UPS
						LEFT JOIN sa_insight_UserDetails USR ON USR.USR_ID = UPS.UPS_UserID and USR.usr_enabledby is null
						LEFT JOIN sa_insight_HierarchyNode HN ON UPS.UPS_OrganisationalUnitID = HN.HN_ID and HN.HN_DateTo IS NULL and HN.HN_Description <> 'Support Staff'
						where  ups.ups_jobtitle in (10, 11) --BDD/BDM
						) b1 on HN1.HN_ID = b1.OUID
			left join (	SELECT DISTINCT USR.USR_ID as USRID, USR.USR_Name as AgentName,USR.USR_ExternalID as UID,UPS.UPS_OrganisationalUnitID as OUID,HN.HN_Description as OrganisationalUnit
						FROM sa_insight_UserPosition UPS
						LEFT JOIN sa_insight_UserDetails USR ON USR.USR_ID = UPS.UPS_UserID and USR.usr_enabledby is null
						LEFT JOIN sa_insight_HierarchyNode HN ON UPS.UPS_OrganisationalUnitID = HN.HN_ID and HN.HN_DateTo IS NULL and HN.HN_Description <> 'Support Staff'
						where  ups.ups_jobtitle in (10, 11) --BDD/BDM
						) b2 on HN2.HN_ID = b2.OUID
			left join (	SELECT DISTINCT USR.USR_ID as USRID, USR.USR_Name as AgentName,USR.USR_ExternalID as UID,UPS.UPS_OrganisationalUnitID as OUID,HN.HN_Description as OrganisationalUnit
						FROM sa_insight_UserPosition UPS
						LEFT JOIN sa_insight_UserDetails USR ON USR.USR_ID = UPS.UPS_UserID and USR.usr_enabledby is null
						LEFT JOIN sa_insight_HierarchyNode HN ON UPS.UPS_OrganisationalUnitID = HN.HN_ID and HN.HN_DateTo IS NULL and HN.HN_Description <> 'Support Staff'
						where  ups.ups_jobtitle in (10, 11) --BDD/BDM
						) b3 on HN3.HN_ID = b3.OUID
			left join (	SELECT DISTINCT USR.USR_ID as USRID, USR.USR_Name as AgentName,USR.USR_ExternalID as UID,UPS.UPS_OrganisationalUnitID as OUID,HN.HN_Description as OrganisationalUnit
						FROM sa_insight_UserPosition UPS
						LEFT JOIN sa_insight_UserDetails USR ON USR.USR_ID = UPS.UPS_UserID and USR.usr_enabledby is null
						LEFT JOIN sa_insight_HierarchyNode HN ON UPS.UPS_OrganisationalUnitID = HN.HN_ID and HN.HN_DateTo IS NULL and HN.HN_Description <> 'Support Staff'
						where  ups.ups_jobtitle in (10, 11) --BDD/BDM
						) b4 on HN4.HN_ID = b4.OUID
			left join (	SELECT DISTINCT USR.USR_ID as USRID, USR.USR_Name as AgentName,USR.USR_ExternalID as UID,UPS.UPS_OrganisationalUnitID as OUID,HN.HN_Description as OrganisationalUnit
						FROM sa_insight_UserPosition UPS
						LEFT JOIN sa_insight_UserDetails USR ON USR.USR_ID = UPS.UPS_UserID and USR.usr_enabledby is null
						LEFT JOIN sa_insight_HierarchyNode HN ON UPS.UPS_OrganisationalUnitID = HN.HN_ID and HN.HN_DateTo IS NULL and HN.HN_Description <> 'Support Staff'
						where  ups.ups_jobtitle in (10, 11) --BDD/BDM
						) b5 on HN5.HN_ID = b5.OUID
			left join (	SELECT USR.USR_ID as 'USRID', USR.USR_Name as 'AgentName',USR.USR_ExternalID as 'UID',UPS.UPS_OrganisationalUnitID as 'OUID',HN.HN_Description as 'Organisational Unit'
						FROM sa_insight_UserPosition UPS
						LEFT JOIN sa_insight_UserDetails USR ON USR.USR_ID = UPS.UPS_UserID 
						LEFT JOIN sa_insight_HierarchyNode HN ON UPS.UPS_OrganisationalUnitID = HN.HN_ID
						where HN.HN_DateTo IS NULL and ups.ups_jobtitle = 14 --Area Director
						) a1 on HN1.HN_ID = a1.OUID
			left join (	SELECT USR.USR_ID as 'USRID', USR.USR_Name as 'AgentName',USR.USR_ExternalID as 'UID',UPS.UPS_OrganisationalUnitID as 'OUID',HN.HN_Description as 'Organisational Unit'
						FROM sa_insight_UserPosition UPS
						LEFT JOIN sa_insight_UserDetails USR ON USR.USR_ID = UPS.UPS_UserID 
						LEFT JOIN sa_insight_HierarchyNode HN ON UPS.UPS_OrganisationalUnitID = HN.HN_ID
						where HN.HN_DateTo IS NULL and ups.ups_jobtitle = 14 --Area Director
						) a2 on HN2.HN_ID = a2.OUID
			left join (	SELECT USR.USR_ID as 'USRID', USR.USR_Name as 'AgentName',USR.USR_ExternalID as 'UID',UPS.UPS_OrganisationalUnitID as 'OUID',HN.HN_Description as 'Organisational Unit'
						FROM sa_insight_UserPosition UPS
						LEFT JOIN sa_insight_UserDetails USR ON USR.USR_ID = UPS.UPS_UserID 
						LEFT JOIN sa_insight_HierarchyNode HN ON UPS.UPS_OrganisationalUnitID = HN.HN_ID
						where HN.HN_DateTo IS NULL and ups.ups_jobtitle = 14 --Area Director
						) a3 on HN3.HN_ID = a3.OUID
			left join (	SELECT USR.USR_ID as 'USRID', USR.USR_Name as 'AgentName',USR.USR_ExternalID as 'UID',UPS.UPS_OrganisationalUnitID as 'OUID',HN.HN_Description as 'Organisational Unit'
						FROM sa_insight_UserPosition UPS
						LEFT JOIN sa_insight_UserDetails USR ON USR.USR_ID = UPS.UPS_UserID 
						LEFT JOIN sa_insight_HierarchyNode HN ON UPS.UPS_OrganisationalUnitID = HN.HN_ID
						where HN.HN_DateTo IS NULL and ups.ups_jobtitle = 14 --Area Director
						) a4 on HN4.HN_ID = a4.OUID
			left join (	SELECT USR.USR_ID as 'USRID', USR.USR_Name as 'AgentName',USR.USR_ExternalID as 'UID',UPS.UPS_OrganisationalUnitID as 'OUID',HN.HN_Description as 'Organisational Unit'
						FROM sa_insight_UserPosition UPS
						LEFT JOIN sa_insight_UserDetails USR ON USR.USR_ID = UPS.UPS_UserID 
						LEFT JOIN sa_insight_HierarchyNode HN ON UPS.UPS_OrganisationalUnitID = HN.HN_ID
						where HN.HN_DateTo IS NULL and ups.ups_jobtitle = 14 --Area Director
						) a5 on HN5.HN_ID = a5.OUID
			) h on DIST.DIST_ExternalID = h.EnterpriseUID
left join sa_insight_hierarchynodelink HNL on DIST.DIST_ID = HNL.HNL_ParentID and HNL.HNL_DateTo IS NULL
left join sa_insight_hierarchynode HN on HNL.HNL_NodeID = HN.HN_ID and HN.HN_DateTo IS NULL
left join sa_insight_CodeDescription cd1 ON DIST.DIST_Category = cd1.Code_Code AND cd1.Code_CodeType = 536 
left join sa_insight_CodeDescription cd2 ON DIST.DIST_Status = cd2.Code_Code AND cd2.Code_CodeType = 537 
where DIST.DIST_DateTo IS NULL and len(DIST.DIST_ExternalID) = 7;
