CREATE FUNCTION [dbo].[GetDecimalFromString](@mixedNumStr varchar(8000)) 

RETURNS sql_variant AS 

/****************************************************************************/
/* Name:		dbo.GetDecimalFromString									*/
/* Author:		Liam North													*/
/* Created:		2013-03-20													*/
/* Description:	Scalar function that removes any characters from a string	*/
/*				that are not numeric or a decimal point. To enforce correct */
/*				correct order in, for example, numbered lists where 1.9 is	*/
/*				followed by 1.10, a '9' is inserted as the first digit		*/
/*				after the decimal point when there are two decimal places.	*/
/*				The RETURN data type is sql_variant to enable the correct	*/
/*				number of decimal places to be retained.					*/
/*																			*/
/* Note:		This function will only work correctly when the numeric		*/
/*				characters appear at the end of the @mixedNumStr variable.	*/
/* Amendments																*/
/* When			Who			What											*/
/* ====			===			====											*/
/****************************************************************************/

BEGIN                
	BEGIN  
		-- Loop through the string variable and strip out everything apart from
		-- numbers and the decimal point
		WHILE PATINDEX('%[^0-9.]%',@mixedNumStr)> 0 
		SET @mixedNumStr = REPLACE(@mixedNumStr,SUBSTRING(@mixedNumStr,PATINDEX('%[^0-9.]%',@mixedNumStr),1),'') 
	END 
    
	-- Insert a 9 as the first digit after the decimal point where the string 
	-- has two digits after the decimal point, e.g. 1.13 becomes 1.913. 
	-- This is to ensure correct order when we use the function in an ORDER BY clause.     
	IF(SUBSTRING(REVERSE(@mixedNumStr),3,1) = '.')
		BEGIN
			SET @mixedNumStr = STUFF(@mixedNumStr,CHARINDEX('.',@mixedNumStr) + 1,0,'9')
			return CAST(@mixedNumStr as decimal(6,3)) -- return with 3 decimal places
		END
	RETURN CAST(@mixedNumStr as decimal(6,1)) -- return with one decimal place
END
