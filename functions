CREATE FUNCTION [dbo].[owf_FirstLetterOfLastWord](@Name varchar(4000))
RETURNS varchar(1)
AS
begin
	declare @Chara varchar(1)

	select @Name = dbo.owf_CleanTextForMatching(@Name)

	set @Chara = substring(reverse(@Name),patindex('%[A-Z] %',reverse(@Name)),1)

