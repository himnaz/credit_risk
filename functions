Date:		20/10/2015

Purpose:	This function was developed for the automated KPIs project (project Ringo).

			The purpose of this function is when given an end date, a duration and duration
			type, then a start date is calculated.

			Although it could be used as a generic function, the Duration Types are as
			defined by Code Group 175 in Insight. Therefore, if you require different 
			Duration Type values, then you will need to clone this function - as this 
			function nees to remain compatible with Insight.

			Input Parameters
			----------------
			
			@EndDate = date without time element
			
			@Duration = integer units
			
			@DurationType = 
			
			Insight Code Group 175:
			
			0 = Not Set
			1 = Single
			2 = Year
			3 = Quarter
			4 = Month
			5 = Week
			6 = Half Year
			7 = Day

			Call this function as follows:
			
				select [dbo].[f_Insight_StartDateFromEndDateAndDuration]('2015-09-30',1,6)

				This will give: '2015-04-01'.


AMENDMENT HISTORY
=================

Date		Author		Description
----		------		-----------
29/01/2016	A Groves	Although @EndDate has always been passed in, it was never
						used. This is now corrected so @EndDate is used instead
						of the expression "dbo.owf_LastDayOfPrevMthDtTm(getdate())".
************************************************************************************/

CREATE FUNCTION [dbo].[f_Insight_StartDateFromEndDateAndDuration] 
(
	@EndDate		datetime,
	@Duration		int,
	@DurationType	int
)

RETURNS datetime 

AS

BEGIN

	if @Duration <= 0 set @Duration = 1
	
	return
	(
		select case @DurationType
			when 0 then @EndDate - @Duration + 1				-- Not Set
			when 1 then @EndDate - @Duration + 1				-- Single
			when 2 then dateadd(yy,-@Duration,@EndDate+1)		-- Year
			when 3 then dateadd(qq,-@Duration,@EndDate+1)		-- Quarter
			when 4 then dateadd(mm,-@Duration,@EndDate+1)		-- Month
			when 5 then dateadd(ww,-@Duration,@EndDate+1)		-- Week
			when 6 then dateadd(mm,-@Duration*6,@EndDate+1)		-- Half Year
			when 7 then @EndDate - @Duration + 1				-- Day
			else @EndDate - @Duration + 1						-- Catch all = 1 day	
		end
	)
	
END

