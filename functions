CREATE FUNCTION [dbo].[msf_SQCheckPermissions] (
    @UserId              nvarchar(50)
   ,@AgentCode           nvarchar(50)
   ,@Level               nvarchar(50)
   ,@HierarchyTypeCode   nvarchar(50)
   ,@SummaryPeriod       int
)
RETURNS nvarchar(50)
AS

--########################################################################
-- Copyright (c) MOORE STEPHENS, 2006 All rights reserved
--
-- Object  : Function
-- Name    : msf_SQCheckPermissions.sql
-- Desc    : Checks if the specified user id is allowed to view data for the specified agent code
-- Owner   : BT
-- Created : 20/07/2006
-- Amended : 11/08/2006 - MK - Accepting more parameters now, (Level, HierarchyTypeCode, 
--                             SummaryPeriod) so can be used in a wider range of situations.
--                             Also being based on widely used function "msf_SQGetAgentsInSpan".
-- Amended : 17/08/2006 - BT - Pass NULL level through to new version msf_SQGetAgentsInSpan to get full list of agents in span
--
--       14/02/2007  - RH/OW - Tuned for performance as part of Agent KPI report production issue
--         - Fixes to affected procs/fns include explicit conversion of datatypes in query
--           expressions where parameter type is not matched to table data type
--           allowing Index seeks rather than scans
--         - Addition of indexes to required Quality tables
--         - Explicit alternative logic paths for queries where global parameter (eg Filter) is not supplied
--           avoiding table/index scans forced by unnecessary OR statememnts
--########################################################################

BEGIN
  --Set Default return value 
  DECLARE @RetVal nvarchar(50)
  SET @RetVal = 'DENY'
  
  --Get the user's agent code
  DECLARE @UserAgentCode nvarchar(50)
  SET @UserAgentCode = dbo.msf_SQGetAgentCode(@UserId, 'Y')

  --If the agent is the user then set return value to ALLOW
  IF @AgentCode = @UserAgentCode
    SET @RetVal = 'ALLOW'
  ELSE IF EXISTS (SELECT * FROM dbo.msf_SQGetAgentsInSpan(@UserAgentCode, NULL, @HierarchyTypeCode, @SummaryPeriod, null) 
      WHERE AgentCode = @AgentCode)
    SET @RetVal = 'ALLOW'
  ELSE
    SET @RetVal = 'DENY'
  
  RETURN @RetVal
END





