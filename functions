CREATE FUNCTION [dbo].[rdrcst_udfGetPostcodeDiffMiles]
(
	@postcode1 VARCHAR(4), 
	@postcode2 VARCHAR(4)
)
RETURNS DECIMAL(18,2)
AS
BEGIN
	DECLARE @diff DECIMAL(18,2)

	SET @postcode1 = REPLACE(@postcode1, ' ', '')
	SET @postcode2 = REPLACE(@postcode2, ' ', '')

	IF (@postcode1 IS NOT NULL) AND (@postcode2 IS NOT NULL)
	BEGIN
		DECLARE @aX INT		
		DECLARE @aY INT
		DECLARE @bX INT		
		DECLARE @bY INT

		SELECT @aX = X, @aY = Y 
		FROM [dbo].[rdr_PostCode_Coordinates]
		WHERE OutCode = @postcode1

		SELECT @bX = X, @bY = Y 
		FROM [dbo].[rdr_PostCode_Coordinates]
		WHERE OutCode = @postcode2

		SET @diff = (
					SELECT CAST (
								(SQRT((SQUARE(@aX - @bX) + SQUARE(@aY - @bY)))  * 0.000621371192)
								AS DECIMAL (18,2)
								)
				)
	END
	RETURN @diff
END

