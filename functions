CREATE FUNCTION [dbo].[cscf_GetNthNonNull](@N INT, @Str1 AS VARCHAR(255), @Str2 AS VARCHAR(255), @Str3 AS VARCHAR(255), @Str4 AS VARCHAR(255), @Str5 AS VARCHAR(255), @Str6 AS VARCHAR(255))  
RETURNS VARCHAR(255) AS  
BEGIN 
   DECLARE @NthString VARCHAR(255)
   DECLARE @I INT -- the input string we are testing
   DECLARE @F INT -- the number of non null/blank strings found

   SET @NthString = NULL
   SET @I = 1
   SET @F = 0
   WHILE @F < @N AND @I <= 6
   BEGIN
      IF @I = 1
      BEGIN
         IF @Str1 IS NOT NULL AND @Str1 <> ''
            SET @F = @F + 1
         SET @NthString = @Str1
      END
      ELSE IF @I = 2
      BEGIN
         IF @Str2 IS NOT NULL AND @Str2 <> ''
            SET @F = @F + 1
         SET @NthString = @Str2
      END
      ELSE IF @I = 3
      BEGIN
         IF @Str3 IS NOT NULL AND @Str3 <> ''
            SET @F = @F + 1
         SET @NthString = @Str3
      END
      ELSE IF @I = 4
      BEGIN
         IF @Str4 IS NOT NULL AND @Str4 <> ''
            SET @F = @F + 1
         SET @NthString = @Str4
      END
      ELSE IF @I = 5
      BEGIN
         IF @Str5 IS NOT NULL AND @Str5 <> ''
            SET @F = @F + 1
         SET @NthString = @Str5
      END
      ELSE IF @I = 6
      BEGIN
         IF @Str6 IS NOT NULL AND @Str6 <> ''
            SET @F = @F + 1
         SET @NthString = @Str6
      END
      IF @F < @N
         SET @NthString = NULL
      SET @I = @I + 1
   END

   RETURN @NthString 
END 

