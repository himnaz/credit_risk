CREATE FUNCTION [dbo].[cscf_CalcCommissionDue](@ID INT)
RETURNS DECIMAL(15,2) AS  
BEGIN 
   DECLARE @Result DECIMAL(15,2)

   -- Commission Due = Amount_Due - Margin_Due 

   SELECT @Result = (SELECT CAST(Amount_Due AS DECIMAL(15,2)) -- round the amount (so margin + commission must equal amount)
                     FROM mstt_Expectation 
                     WHERE ID = @ID)                         -- Amount Due
                    -
                    (SELECT dbo.cscf_CalcMarginDue(@ID))     -- Margin Due

   RETURN @Result
END

