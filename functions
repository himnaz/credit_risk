/****************************************************************************
     Program:   f_Insight_GetFirmsOfAllUsers        
    Author: G Kulawiak
Date created: 16/08/2010              
                      
 Description: The purpose of this function is - using Insight data only -
        to build a table of user codes along with their firm codes
        to enable a user's enterprise to be derived.

        You can use this function like a derived table and can join 
        to it.  The date parameter is used to determine which firm 
        the user belonged to on that date.  This can be significant
        as personnel move between businesses.  If you want to know
        the firm list as of now then this function can be called
        with either NULL or getdate().  

        The first use of this function is in the Expired Mandatory
        Licences Report as requested by Karen Appleby.

        A function calling example is given below:

        left join f_Insight_GetFirmsOfAllUsers(null) firm 
              on firm.UserCode = ups.ups_externalid

        or

        left join f_Insight_GetFirmsOfAllUsersNEW(null) firm 
              on firm.RoleGUID = ups.UPS_ID

        then you can use Firm.FirmCode as EnterpriseUID.


        Also, you can then join as follows for the enterprise name:

        left join sa_Insight_Distributor dist on dist.dist_externalid = firm.FirmCode

        where the enterprise name is give by: 

          Dist.DIST_CompanyName as EnterpriseName
                  
  Amendment History               
  -----------------               
                      
  Date    Who     Description       
  ----    ---     ----------- 
 
****************************************************************************/

CREATE function [dbo].[f_Insight_GetFirmsOfAllUsers](@Date as datetime)
       returns @Out table (UserCode nvarchar(50),
                           UserGUID uniqueidentifier,
                           RoleCode nvarchar(50),
                           RoleGUID uniqueidentifier,
                           FirmCode varchar(50),
                           FirmGUID uniqueidentifier)
as                           
begin
  declare @NodeLevel int
  declare @ChildNodes table (ParentID uniqueidentifier,
                             ChildID uniqueidentifier,
                             NodeLevel tinyint)
  
  select @Date = isnull(@Date, getdate()),
         @NodeLevel = 1

  insert into @ChildNodes
  select HNL_ParentID,
         HNL_NodeID,
         @NodeLevel
  from  sa_insight_HierarchyNodeLink HNL
        inner join sa_insight_Distributor D 
          on D.DIST_ID = HNL.HNL_ParentID 
          and D.DIST_Category in (1, 2, 3, 4, 5, 6, 7, 15, 16, 17, 18, 19, 20) and  -- Distributor must be a firm
          @Date between HNL.HNL_DateFrom and isnull(HNL.HNL_DateTo, '99991231')

  while @@rowcount > 0
    begin
      set @NodeLevel = @NodeLevel + 1

      insert into @ChildNodes
      select CN.ParentID,
             HNL.HNL_NodeID,
             @NodeLevel
      from @ChildNodes CN
           inner join sa_insight_HierarchyNodeLink HNL 
            on HNL.HNL_ParentID = CN.ChildID 
            and HNL.HNL_Type = 0 
            and CN.NodeLevel = @NodeLevel - 1 
            and @Date between HNL.HNL_DateFrom and isnull(HNL.HNL_DateTo,'99991231')
           left join @ChildNodes CNCR on CNCR.ChildID = HNL.HNL_NodeID and
                                         CNCR.NodeLevel < @NodeLevel - 1
      where CNCR.ParentID is null
    end
    
  insert into @Out
  select distinct USR_ExternalID,
                  USR_ID,
                  UPS_ExternalID,
                  UPS_ID,
                  DIST_ExternalID,
                  DIST_ID
  from @ChildNodes CN
       inner join sa_insight_HierarchyNodeLink HNL 
          on HNL.HNL_NodeID = CN.ChildID 
          and HNL.HNL_Type = 5 
          and @Date between HNL.HNL_DateFrom and isnull(HNL.HNL_DateTo,'99991231')
       inner join sa_insight_UserPosition P on P.UPS_ID = HNL.HNL_ParentID
       inner join sa_insight_Distributor D on D.DIST_ID = CN.ParentID
       inner join sa_insight_UserDetails U on U.USR_ID = P.UPS_UserID
  return
end




GO
