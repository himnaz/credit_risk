CREATE FUNCTION [dbo].[cscf_GetAgentAbbrevCompetencies](@AgentID int, @AtDate DATETIME)  
RETURNS VARCHAR(80) AS  
BEGIN 
   DECLARE @Competencies VARCHAR(80) 

   -- Get COB first in sequence (if exists) - abbreviate to 'C' and append status
   SELECT @Competencies = ISNULL(@Competencies + ', ' , '') + 'C/' + AgentControlFunctionCode
   FROM mstt_AgentCompetence AS AgentCompetence
   WHERE AgentID = @AgentID
     AND (DateAppointed IS NOT NULL AND CAST(CONVERT(NVARCHAR, DateAppointed, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR, @AtDate, 112) AS DATETIME))
     AND (EndDate IS NULL OR CAST(CONVERT(NVARCHAR, EndDate, 112) AS DATETIME) > CAST(CONVERT(NVARCHAR, @AtDate, 112) AS DATETIME))
     AND ComplianceCategoryCode = 'COB'

   -- Get MCOB second in sequence (if exists) - abbreviate to 'M' and append status
   SELECT @Competencies = ISNULL(@Competencies + ', ' , '') + 'M/' + AgentControlFunctionCode
   FROM mstt_AgentCompetence AS AgentCompetence
   WHERE AgentID = @AgentID
     AND (DateAppointed IS NOT NULL AND CAST(CONVERT(NVARCHAR, DateAppointed, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR, @AtDate, 112) AS DATETIME))
     AND (EndDate IS NULL OR CAST(CONVERT(NVARCHAR, EndDate, 112) AS DATETIME) > CAST(CONVERT(NVARCHAR, @AtDate, 112) AS DATETIME))
     AND ComplianceCategoryCode = 'MCOB'

   -- Get ICOB-PP third in sequence (if exists) - abbreviate to 'P' and append status
   SELECT @Competencies = ISNULL(@Competencies + ', ' , '') + 'P/' + AgentControlFunctionCode
   FROM mstt_AgentCompetence AS AgentCompetence
   WHERE AgentID = @AgentID
     AND (DateAppointed IS NOT NULL AND CAST(CONVERT(NVARCHAR, DateAppointed, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR, @AtDate, 112) AS DATETIME))
     AND (EndDate IS NULL OR CAST(CONVERT(NVARCHAR, EndDate, 112) AS DATETIME) > CAST(CONVERT(NVARCHAR, @AtDate, 112) AS DATETIME))
     AND ComplianceCategoryCode = 'ICOB-PP' -- third competency in sequence

   -- Get ICOB-GI last in sequence (if exists) - abbreviate to 'G' and append status
   SELECT @Competencies = ISNULL(@Competencies + ', ' , '') + 'G/' + AgentControlFunctionCode
   FROM mstt_AgentCompetence AS AgentCompetence
   WHERE AgentID = @AgentID
     AND (DateAppointed IS NOT NULL AND CAST(CONVERT(NVARCHAR, DateAppointed, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR, @AtDate, 112) AS DATETIME))
     AND (EndDate IS NULL OR CAST(CONVERT(NVARCHAR, EndDate, 112) AS DATETIME) > CAST(CONVERT(NVARCHAR, @AtDate, 112) AS DATETIME))
     AND ComplianceCategoryCode = 'ICOB-GI' -- last competency in sequence

   RETURN @Competencies 
END 

