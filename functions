/****************************************************************************
     Program: owf_MaskText           
	  Author: A Groves
Date created: 22/01/2022              
                      
 Description: This function is used for partially masking text. At the time
				of writing, it keeps the first 2 characters of each word in
				a text field and appends four asterisks from the fourth
				character. Where the word is shorter than three characters,
				then you get just the available character(s) with four
				asterisks appended.

				Examples are:
				Abigail Bennett -> Abi**** Ben****
				Tim Yu -> Tim**** Yu****


      It is called as follows:

	  declare @Name varchar(4000) = 'Abigail Bennett'
      select dbo.owf_MaskText(@Name)
                  
  Amendment History               
  -----------------               
                      
  Date    Who     Description       
  ----    ---     -----------     
            
****************************************************************************/

CREATE FUNCTION [dbo].[owf_MaskText](@TextToClean varchar(4000))
RETURNS varchar(4000)
AS
begin

declare @NewText varchar(4000) = '',
		@WordPosn int = 1

--Remove bad characters, multiple spaces, leading and trailing spaces, etc.
set @TextToClean =  dbo.owf_CleanText(@TextToClean)

while @TextToClean <> ''
begin
	if @WordPosn >= 2 or SUBSTRING(@TextToClean,@WordPosn,1) = ' '
	begin
		set @NewText = @NewText 
						+ ' '
						+ rtrim(LEFT(@TextToClean,@WordPosn)) 
						+ '****'
		if patindex('% %',@TextToClean) > 0
			set @TextToClean = STUFF(@TextToClean,1,patindex('% %',@TextToClean),'')
		else
			set @TextToClean = ''
		set @WordPosn = 1
	end
	else
	begin
		set @WordPosn = @WordPosn + 1
	end
end

return @NewText

end



