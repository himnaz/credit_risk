/************************************************************************************************
Program:  	    [logi].[f_Insight_OwlLicGrpToLicCodesConcatenated]
				(based on f_Insight_LicGrpToLicCodesConcatenated by Alan Groves on 03/05/2011)
Author:	        Alan Groves
Date created:	30/06/2015
											
Description:   

This function returns a single string containing a list of licence codes that belong
to a Regulation Group that is passed in as a parameter.  For example, passing in
'OWLICOB' gives the list:

'LIC118, LIC119, LIC120, LIC121, LIC122'

Note that the delimiter is a semi-colon rather than a comma so the output doesn't
cause a CSV file to misalign columns.

Execute using the following command:
  select logi.f_Insight_OwlLicGrpToLicCodesConcatenated('OWLICOB')

									
Amendment History								
-----------------								
											
Date			Who			    Description				
----------		-------------	-----------			
************************************************************************************************/

CREATE function [logi].[f_Insight_OwlLicGrpToLicCodesConcatenated] (@RegulationGroupCode varchar(100))
returns varchar(8000)
as

begin

	declare @LicCodeConcat	varchar(8000),
			@Delimiter		varchar(1)

	set @Delimiter		= ','
	set @LicCodeConcat	= ''

	select @LicCodeConcat = @LicCodeConcat + @Delimiter + ' ' + Lics.KeyValue
	from
	(
	select top 1000 KeyValue	-- top x required by syntax of derived tables in functions
	from owt_SelectionControl
	where Process = 'OwlInsightRegulationGroupToLicenceCode'
	and KeyType = @RegulationGroupCode
	order by case when KeyValue like '[a-Z][a-Z][a-Z][0-9]' then left(KeyValue,3) + '0' + right(KeyValue,1) else KeyValue end
	) Lics

	return substring(@LicCodeConcat,3,8000)

end




