/****************************************************************************
Program:	    f_Insight_GetFirmOfAllSellers                     
Author:	      M Cawood
Date created:	22/03/2011                                             
     
Description
----------- 
The purpose of this function is to build a Table of Insight Sellers which
lists the Business linked to it in Insight as at the Effective Date supplied.
If the input date is set to null then the function defaults this to getdate().

This function can be used like a derived table and joined to in queries.
It deduplicates the data by selecting the linked Business with the lowest
Node level and the latest Link Date.                                                                  

The function only selects UserPosition entries created for the Insight 
"Adviser/Seller" role. This is derived for UserType = 3 where CodeType = 11
(User Type). 

Executed as 
    select * from f_Insight_GetFirmOfAllSellers(null)
    OR
    select * from f_Insight_GetFirmOfAllSellers('1 Jan 2011')
                                                       
Amendment History                                                    
-----------------                                                    
                                                                     
Date          Who              Description                       
----          ---              -----------   

 
****************************************************************************/

create function [dbo].[f_Insight_GetFirmOfAllSellers](@EffDate as datetime)
       returns @Result table (AgentCode			    nvarchar(10),
                              BusinessCode		  nvarchar(10),
                              CategoryCode		  nvarchar(10),
                              BusinessCategory	nvarchar(50),
                              TypeCode			    nvarchar(10),
                              BusinessType		  nvarchar(50),                              
                              BusinessName		  nvarchar(255),
                              NodeLevel			    int,
					                    LastUpdated			  datetime)
as
begin

declare @Out table (AgentCode			    nvarchar(10),
                    BusinessCode		  nvarchar(10),
                    CategoryCode		  nvarchar(10),
                    BusinessCategory	nvarchar(50),
                    TypeCode			    nvarchar(10),
                    BusinessType		  nvarchar(50),
                    BusinessName		  nvarchar(255),
                    NodeLevel			    int,
					          LastUpdated			  datetime)

declare @NodeLevel int;
declare @ChildNodes table (ParentID   uniqueidentifier,
							             ChildID    uniqueidentifier,
							             NodeLevel  tinyint)
select @EffDate = isnull(@EffDate, getdate()),@NodeLevel = 1;

insert into @ChildNodes
select	HNL_ParentID,HNL_NodeID,@NodeLevel
from  sa_insight_HierarchyNodeLink HNL
inner join sa_insight_Distributor D on D.DIST_ID = HNL.HNL_ParentID 
									   and D.DIST_Category not in (9,10,11,12,13,14,23)  -- Distributor must be a firm
									   and @EffDate between HNL.HNL_DateFrom and isnull(HNL.HNL_DateTo, '31 Dec 2999')

while @@rowcount > 0
begin
  set @NodeLevel = @NodeLevel + 1

  insert into @ChildNodes
  select CN.ParentID,HNL.HNL_NodeID,@NodeLevel
  from @ChildNodes CN
  inner join sa_insight_HierarchyNodeLink HNL on HNL.HNL_ParentID = CN.ChildID and HNL.HNL_Type = 0 
												 and CN.NodeLevel = @NodeLevel - 1 and @EffDate between HNL.HNL_DateFrom and isnull(HNL.HNL_DateTo,'31 Dec 2999')
  left join @ChildNodes CNCR on CNCR.ChildID = HNL.HNL_NodeID and CNCR.NodeLevel < @NodeLevel - 1
  where CNCR.ParentID is null
end

insert into @Out
select USR_ExternalID,
DIST_ExternalID,DIST_Category,cd1.Code_Description as BusinessCategory,DIST_Type,
cd2.Code_Description as BusinessType,coalesce(DIST_TradingName,DIST_CompanyName) as BusinessName,
min(CN.NodeLevel) as NodeLevel,max(HNL_UpdatedDate) as LinkUpdated
from @ChildNodes CN
inner join sa_insight_HierarchyNodeLink HNL on HNL.HNL_NodeID = CN.ChildID and HNL.HNL_Type = 5 and @EffDate between HNL.HNL_DateFrom and isnull(HNL.HNL_DateTo,'31 Dec 2999')
inner join sa_insight_UserPosition P on P.UPS_ID = HNL.HNL_ParentID and @EffDate between P.UPS_DateFrom and isnull(P.UPS_DateTo,'31 Dec 2999')
inner join sa_insight_Distributor D on D.DIST_ID = CN.ParentID
inner join sa_insight_UserDetails U on U.USR_ID = P.UPS_UserID
left join sa_insight_CodeDescription cd1 on cd1.code_code = DIST_Category and cd1.code_codetype = 536 
left join sa_insight_CodeDescription cd2 on cd2.code_code = DIST_Type and cd2.code_codetype = 87
where len(usr_Externalid) = 7
and UPS_UserType = 3
group by USR_ExternalID,DIST_ExternalID,DIST_Category,cd1.Code_Description,DIST_Type,
cd2.Code_Description,coalesce(DIST_TradingName,DIST_CompanyName)
order by usr_Externalid

insert into @Result
Select AgentCode,BusinessCode,CategoryCode,BusinessCategory,TypeCode,BusinessType,
BusinessName,NodeLevel,LastUpdated 
from @Out T
inner join (select AgentCode as UID,Min(NodeLevel) as Node,max(LastUpdated) as Updated
			from @Out
			group by AgentCode) X on X.UID = T.AgentCode and X.Node = T.NodeLevel and X.Updated = T.LastUpdated

  return;      
end;
GO
