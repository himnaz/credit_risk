CREATE FUNCTION [dbo].[udfPbrGetBusinessDays]
(
	@StartDate DATETIME,
	@EndDate datetime
)
RETURNS INTEGER
AS
BEGIN
	DECLARE @days integer

	SELECT @days = 
		DATEDIFF(D, @StartDate,	@EndDate) - DATEDIFF(WK, @StartDate, @EndDate) * 2 
		- CASE 
			WHEN DATENAME(DW, @StartDate) <> 'Saturday' AND DATENAME(DW, @EndDate) = 'Saturday' THEN 1 
			WHEN DATENAME(DW, @StartDate) = 'Saturday' AND DATENAME(DW, @EndDate) <> 'Saturday' THEN -1 
			ELSE 0
		  END
		- (SELECT COUNT(*) FROM [dbo].[PBR_BankHolidays]
			 WHERE BankHolidayDate 
			 BETWEEN @StartDate AND @Enddate 
			 
			 /*AND DATENAME(dw, BankHolidayDate) <> 'Saturday' 
			 AND DATENAME(DW, BankHolidayDate) <> 'Sunday'*/)

	RETURN (@days)

END
