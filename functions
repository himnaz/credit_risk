CREATE FUNCTION [dbo].[cscf_DADifference](@SoldType VARCHAR(1), @StartDate VARCHAR(10), @EndDate VARCHAR(10), @Status INT, @Adjust INT)
RETURNS @retTable TABLE 
(Type   INT
,DAType VARCHAR(200)
,AmtDue DECIMAL(15,2)
,AmtRec DECIMAL(15,2)
)
AS  
BEGIN 

/*
  RH 19 Feb 2007
  Swift SR6 introduces new Status value of 3
  Need to pick this up as well as 2 when we look at status 2
  
  Func is only called from Finstat0036b

*/


   INSERT @retTable
   SELECT 
        ExpectationNew.Type AS 'Type'
      , ISNULL(ExpectationNew.Type_Description, 'Unknown') AS 'DAType'
      , ISNULL(SUM(ISNULL(CAST(ExpectationNew.AMOUNT_DUE AS DECIMAL(15,2)), 0.00)), 0.00) AS 'AmtDue' 
      , ISNULL(SUM(ISNULL(CAST(ExpectationNew.AMOUNT_REC AS DECIMAL(15,2)), 0.00)), 0.00) AS 'AmtRec' 
   
   FROM mstt_Expectation ExpectationNew --Expectation 2
      INNER JOIN mstt_PolicyTransactions PolicyTransactions ON PolicyTransactions.ID = ExpectationNew.TransactionID
      INNER JOIN mstt_Agents Agents ON PolicyTransactions.AgentCode = Agents.Code                          --restrict to
      INNER JOIN mstt_Agents Company ON Agents.CompanyCode = Company.Code and Company.Descn = 'Openwork'   --OW business
   WHERE (ExpectationNew.Type NOT IN (3,5,6,7,8,9,11,12,13,14)
       OR ExpectationNew.Type IS NULL)
   AND ExpectationNew.DATE_DUE IS NOT NULL
   AND CAST(CONVERT(NVARCHAR,ExpectationNew.DATE_DUE, 112) AS DATETIME) >= CAST(CONVERT(NVARCHAR,@StartDate, 112) AS DATETIME)
   AND CAST(CONVERT(NVARCHAR,ExpectationNew.DATE_DUE, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME)
   -- if @Status passed-in is zero, also include rows with status = null
   AND ((@Status = 1 and ExpectationNew.STATUS = 1)
    or
    (@Status = 2 and ExpectationNew.STATUS in (2,3))
    or
    (@Status = 0 AND ExpectationNew.STATUS IS NULL)
    )
   AND ExpectationNew.ADJUST = @Adjust
   AND ( ((@SoldType = 'T' OR @SoldType = 'F' OR @SoldType = 'L') AND PolicyTransactions.CommType = @SoldType) OR
         (@SoldType = 'A') ) --ALL Sold Types
   AND EXISTS (SELECT ExpectationOld.TransactionID
               FROM mstt_Expectation ExpectationOld --Expectation 1
                  INNER JOIN mstt_PolicyTransactions PolicyTransactionsOld ON PolicyTransactionsOld.ID = ExpectationOld.TransactionID
                  WHERE ExpectationOld.TransactionID  = ExpectationNew.TransactionID
                  AND ExpectationOld.Type  = ExpectationNew.Type
                  AND CAST(CONVERT(NVARCHAR,ExpectationOld.DATE_DUE, 112) AS DATETIME) = CAST(CONVERT(NVARCHAR,ExpectationNew.DATE_DUE, 112) AS DATETIME)
                  AND (ExpectationNew.DATE_RECV IS NULL OR CAST(CONVERT(NVARCHAR,ExpectationNew.DATE_RECV, 112) AS DATETIME) > CAST(CONVERT(NVARCHAR,ExpectationOld.DATE_RECV, 112) AS DATETIME))
                  AND ExpectationOld.ID <> ExpectationNew.ID --added so that linking to itself is avoided
                  AND ExpectationOld.DATE_RECV IS NOT NULL --Something has been received
               )      
   GROUP BY ExpectationNew.Type, ISNULL(ExpectationNew.Type_Description, 'Unknown')
   ORDER BY ExpectationNew.Type

   RETURN
END




