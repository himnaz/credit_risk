/****************************************************************************
     Program:   owf_DateIsWeekendProcessingDay           
      Author:	A Groves
Date created:	03/10/2012              
                      
 Description:   This function is used to determine whether the date passed in
				(usually the current date) is a weekend processing day. The 
				weekend processing day would normally be a Sunday (i.e. Saturday
				night's batch going into Sunday) unless the Sunday is 1st of
				the month when all the Month End jobs run. In this situation
				the weekend processing day is brought forward to the Saturday
				(i.e. Friday night's batch going int Saturday).

      It is called as follows:

      select dbo.owf_DateIsWeekendProcessingDay(getdate())
                  
  Amendment History               
  -----------------               
                      
  Date    Who     Description       
  ----    ---     -----------     
****************************************************************************/

CREATE   FUNCTION [dbo].[owf_DateIsWeekendProcessingDay](@CurrentDate datetime)
RETURNS varchar(1)
AS
begin

	declare @DateIsWeekendProcessingDay varchar(1)

	if datepart(dw,@CurrentDate) = 7 and day(@CurrentDate+1) = 1 -- Is Saturday and Sunday is first of the month
	or datepart(dw,@CurrentDate) = 1 and day(@CurrentDate) >= 2  -- Is Sunday and not the first of the month
		set @DateIsWeekendProcessingDay = 'Y'
	else
		set @DateIsWeekendProcessingDay = 'N'

	return @DateIsWeekendProcessingDay

end




