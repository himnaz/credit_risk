/***********************************************************************************

Author:	A Groves

Date:	20/04/2016

Purpose:	This function was developed for use in the COB servicing KPIs (adviser,
			supervisor and firm) to combine the reason descriptions into a single 
			text field to be reported by the Logi MI reports.
			
			Use the function as follows:
	
			COBSS (Adviser)
			---------------		
			dbo.f_Insight_COBServicingReasonsLongText(	kpi.KPI_Type, 1,
														cr.TotalLateReportEvents,cr.TotalActiveReportEvents,
														cr.LateReportEvents6MonthsAgo,aars.TotalClientsReviewDeclined,
														aars.TotalClientsReviewOffered,cdey.UserID,b1.AdviserUID,
														cr.FivePCLate,
								                        cr.LateBy6Months)

			OCOBSS (Supervisor)
			-------------
			dbo.f_Insight_COBServicingReasonsLongText(	kpi.KPI_Type, 1,
														cr.TotalLateReportEvents,cr.TotalActiveReportEvents,
														NULL,sars.TotalClientsReviewDeclined,
														sars.TotalClientsReviewOffered,NULL,NULL)
			OCOBSS (Firm)
			-------------
			dbo.f_Insight_COBServicingReasonsLongText(	kpi.KPI_Type, 1,
														cr.TotalLateReportEvents,cr.TotalActiveReportEvents,
														cr.LateReportEvents6MonthsAgo,fars.TotalClientsReviewDeclined,
														fars.TotalClientsReviewOffered,cdey.BusinessID,NULL)

			
			Notes
			-----
			KPIType 1 = Adviser
			KPIType 4 = Supervisor
			KPIType 9 = Firm
			
			Band 1 = Red
			Band 2 = Amber
			Band 3 = Green
			Band 4 = N/A
			
AMENDMENT HISTORY
=================

Date		Author		Description
----		------		-----------
04/06/2018	S Campbell	Remove some reasons from the COBSS Adviser KPI and add new flags for 
						Red adviser KPI measures   # CR22043
30/08/2020  S Tourlidas Changed reject to unsuitable advice
13/05/2021  S Tourlidas Adjusting to the new separated KPIs for servicing events so that it can be used 
						without late servicing events
************************************************************************************/

CREATE FUNCTION [dbo].[f_Insight_COBServicingNewReasonsLongText] 
	(@KPIType int,
	 @Band int,	
	 @TotalLateReportEvents float,
	 @TotalActiveReportEvents float,
	 @TotalActiveReviewEvents float,    --CR#16196
	 @LateReportEvents6MonthsAgo int,
	 @TotalClientsReviewDeclined float,
	 @TotalClientsReviewOffered float,
	 @ClientDeclinedEveryYearID uniqueidentifier,
	 @AQTRejectAdviserUID varchar(7),
	 @5PCLate varchar(1),   -- Added 2 extra parameters for Adviser RED KPI to avoid divide by 0 issues - CR#22043
	 @Lateby6Months Varchar(1))  
	 
RETURNS varchar(500)

AS

BEGIN

