CREATE FUNCTION [dbo].[cscf_GetSOFranchiseSum](@AgentID varchar(7), @SOCode INT, @VAT VARCHAR(1), @Paid VARCHAR(1), @Start VARCHAR(10), @End VARCHAR(10))  
RETURNS DECIMAL(15,2) AS  
BEGIN 
   DECLARE @SOTotal DECIMAL(15,2)

   SELECT @SOTotal = SUM(ISNULL(CAST((mstt_PaymentsPending.Amount) AS DECIMAL(15,2)), 0.00))
   FROM mstt_PaymentsPending
    LEFT JOIN mstt_AgentPayments ON mstt_PaymentsPending.ID = mstt_AgentPayments.AgmID
   WHERE mstt_PaymentsPending.CommissionType = 8 
  AND mstt_PaymentsPending.Agent_Code = @AgentID
  AND mstt_PaymentsPending.StandingOrderCode = @SOCode
  AND CAST(CONVERT(NVARCHAR, mstt_PaymentsPending.Due_Date, 112) AS DATETIME) >= CAST(CONVERT(NVARCHAR, @Start, 112) AS DATETIME)
      AND CAST(CONVERT(NVARCHAR, mstt_PaymentsPending.Due_Date, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR, @End, 112) AS DATETIME)
  AND ((@VAT = mstt_PaymentsPending.SubjectToVAT) OR (@VAT = 2))
        AND ((@Paid = mstt_AgentPayments.Exported) OR (@Paid = 'F' AND mstt_AgentPayments.AgmID IS NULL) OR (@Paid = 'A'))--no entry on agent payments also means unpaid
   RETURN @SOTotal 
