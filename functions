/****************************************************************************
   Program: f_Insight_GetQMsOfAllUsers                      
    Author: G Kulawiak
Date created: 17/08/2010                                             
                
 Description: The purpose of this function is - using Insight data only -
        to build a table of user codes along with their Quality
        Manager codes.  The Quality Manager list returned is 
        requested as follows:

        @QMType  Quality Manager Type
          0   AQM
          1   BQM
          2   Supervisor

        You can use this function like a derived table and can join 
        to it.  The date parameter is used to determine which Quality 
        Manager the user was linked to on that date.  This can be 
        significant as personnel move between Quality Managers.  If 
        you want to know the Quality Manager for each user as of now 
        then this function can be called with either NULL or getdate().  

        A function calling example is given below:

        left join f_Insight_GetQMsOfAllUsers(1,null) BQMList 
              on BQMList.UserCode = ups.ups_externalid        
                                      
                                                       
       Amendment History                                                    
       -----------------                                                    
                                                                           
       Date          Who                  Description                       
       ----          ---                  -----------   
 
****************************************************************************/

create function [dbo].[f_Insight_GetQMsOfAllUsers](@QMType as tinyint, 
                                                   @Date as datetime)
       returns @Out table (UserCode nvarchar(50),
                           UserGUID uniqueidentifier,
                           RoleCode nvarchar(50),
                           RoleGUID uniqueidentifier,
                           QMUserCode varchar(50),
                           QMUserGUID uniqueidentifier,
                           QMRoleCode nvarchar(50),
                           QMRoleGUID uniqueidentifier)
as                           
begin
  declare @NodeLevel int
  declare @ChildNodes table (ParentID uniqueidentifier,
                             ChildID uniqueidentifier,
                             NodeLevel tinyint)
  
  select @Date = isnull(@Date, getdate()),
         @NodeLevel = 1

  insert into @ChildNodes
  select UPSL_ParentUserPositionID,
         UPSL_ChildUserPositionID,
         @NodeLevel
  from  sa_insight_UserPositionLink UPSL
        inner join sa_insight_UserPosition QM on QM.UPS_ID = UPSL.UPSL_ParentUserPositionID and
                                                 QM.UPS_JobTitle = 7 + (@QMType + 2) % 3 and
                                                 UPSL.UPSL_LinkType = 1 and
                                                 @Date between UPSL.UPSL_DateFrom and isnull(UPSL.UPSL_DateTo, '99991231')

  while @@rowcount > 0
    begin
      set @NodeLevel = @NodeLevel + 1

      insert into @ChildNodes
      select CN.ParentID,
             UPSL.UPSL_ChildUserPositionID,
             @NodeLevel
      from @ChildNodes CN
           inner join sa_insight_UserPositionLink UPSL on UPSL.UPSL_ParentUserPositionID = CN.ChildID and
                                                          UPSL.UPSL_LinkType = 1 and
                                                          CN.NodeLevel = @NodeLevel - 1 and
                                                          @Date between UPSL.UPSL_DateFrom and isnull(UPSL.UPSL_DateTo,'99991231')
           left join @ChildNodes CNCR on CNCR.ChildID = UPSL.UPSL_ChildUserPositionID and
                                         CNCR.NodeLevel < @NodeLevel - 1
      where CNCR.ParentID is null
    end
    
  insert into @Out
  select distinct U.USR_ExternalID,
                  U.USR_ID,
                  P.UPS_ExternalID,
                  P.UPS_ID,
                  QMU.USR_ExternalID,
                  QMU.USR_ID,
                  QMP.UPS_ExternalID,
                  QMP.UPS_ID
  from @ChildNodes CN
       inner join sa_insight_UserPosition P on P.UPS_ID = CN.ChildID
       inner join sa_insight_UserDetails U on U.USR_ID = P.UPS_UserID
       inner join sa_insight_UserPosition QMP on QMP.UPS_ID = CN.ParentID
       inner join sa_insight_UserDetails QMU on QMU.USR_ID = QMP.UPS_UserID
  return
end



GO
