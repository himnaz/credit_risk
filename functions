/******************************************************************************************************************************
     Program:	owf_RunNow  
				(templated from OwlEvolution.fns_RunNow by Alan Groves on 18/05/2022)
	  Author:	A Groves
Date created:	07/06/2022              
                      
 Description:	This function takes a number of scheduling parameters and 
				determines whether or not today is the day that the 
				scheduled task should run. If it is a run day then the
				function returns 1 otherwise it returns 0.

Note: There are column constraints and table constraints defined on table
"BI.owt_CommsConfigEnterprise" to prevent incompatible scheduling 
parameters to be set up that would otherwise confuse this function.
For example, if "RunMonthDay" has a value, then columns "RunWeekDay"
and "RunWeekInterval" must both be null and the opposite must also apply.
If the run schedule is any less frequent than daily or weekly, then
column "RunMonthInterval" must have a value.

It is called as follows:

declare @ReferenceDate datetime = '2022-05-01',	--This is the date which we want to know whether or not it is a run date (in most uses it will be today's date).
		@RunStartDate datetime = '2022-05-01',	--This is the run schedule start date. The Reference Date must be on or after this date for the function to return 1 
		@RunEndDate datetime = '9999-12-31',	--This is the last day of the run window. The Reference Date must be on or before this date for the function to return 1 
		@RunDaily bit = null,					--Set to 1 if daily otherwise 0.
		@RunDailyExcWeekend bit = null,			--Set to 1 if weekends (Saturdays and Sundays) are not run dates.
		@RunWeekDay varchar(20) = 'Friday',		--Must be either 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday' or 'Sunday'
		@RunWeekInterval varchar(20) = 'First',	--Must be either 'First', 'Second', 'Third' or 'Last'
		@RunMonthDay tinyint = null,			--Must be in the range 1 to 31 inclusive.
		@RunMonthInterval tinyint = 3			--Must be either 1, 2, 3, 4, 6 or 12 (e.g. 3 would be quarterly and 12 would be annually)
select BI.owf_RunNow(@ReferenceDate,@RunStartDate,@RunEndDate,@RunDaily,@RunDailyExcWeekend,@RunWeekDay,@RunWeekInterval,@RunMonthDay,@RunMonthInterval)


Amendment History               
-----------------               
                      
Date		Who				Description       
----		---				-----------     
07/06/2022	A Groves		New parameter @RunEndDate added.          
******************************************************************************************************************************/

CREATE FUNCTION [BI].[owf_RunNow]
(	
	@ReferenceDate datetime,
	@RunStartDate datetime,
	@RunEndDate datetime,
	@RunDaily bit,
	@RunDailyExcWeekend bit,
	@RunWeekDay varchar(20),
	@RunWeekInterval varchar(20),
	@RunMonthDay tinyint,
	@RunMonthInterval tinyint
)
returns bit
as
begin

declare @RunNow bit = 0
declare @MonthArray varchar(12) = 'NNNNNNNNNNNN'
declare @LoopCounter int
declare @CurrentMonth int
declare @ReferenceMonth tinyint = month(@ReferenceDate)
declare @ReferenceDayNumber tinyint = day(@ReferenceDate)
declare @ReferenceDayName varchar(20) = datename(weekday,@ReferenceDate)
declare @StartMonth int = month(@RunStartDate)
declare @DerivedRunDate datetime

set @ReferenceDate = convert(date,@ReferenceDate)	-- strip off the time.

--Check if the config date brings the run schedule into scope. If not, then this is not a run day and the function returns 0
if @ReferenceDate between @RunStartDate and isnull(@RunEndDate,'9999-12-31')
begin
	--Daily run frequency
	if @RunDaily = 1 and not (isnull(@RunDailyExcWeekend,0) = 1 and @ReferenceDayName in ('Saturday','Sunday'))
		set @RunNow = 1
	else
	--Weekly run frequency (all config for less frequent frequencies needs to be null)
	if @ReferenceDayName = @RunWeekDay and @RunWeekInterval is null and @RunMonthDay is null and @RunMonthInterval is null
		set @RunNow = 1
	else
	--Run frequencies less frequent than daily or weekly
	if @StartMonth between 1 and 12 and @RunMonthInterval in (1,2,3,4,6,12)
	begin
		set @CurrentMonth = @StartMonth
		set @LoopCounter = 1
		while @LoopCounter <= (12/@RunMonthInterval)
		begin
			set @MonthArray = stuff(@MonthArray, @CurrentMonth,1,'Y')
			set @CurrentMonth = @CurrentMonth + @RunMonthInterval
			if @CurrentMonth > 12
				set @CurrentMonth = @CurrentMonth - 12
			set @LoopCounter = @LoopCounter + 1
		end
		--Check if it's the required "date" in the required month
		if substring(@MonthArray, @ReferenceMonth, 1) = 'Y' and @ReferenceDayNumber = @RunMonthDay
			set @RunNow = 1
		else
		--Check it's the required "day" in the required month
		if substring(@MonthArray, @ReferenceMonth, 1) = 'Y' and @RunWeekInterval is not null
		begin
			set @DerivedRunDate = BI.owf_DeriveRequestedDate(@ReferenceDate, @RunWeekDay, @RunWeekInterval)
			if @DerivedRunDate = @ReferenceDate
				set @RunNow = 1
		end
	end
end

return @RunNow

end




