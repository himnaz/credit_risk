/********************************************************************************************************/
/*  	Program:  	owf_MixCase	(based in stored proc utMixCase of 11/04/01)							*/
/*	Date created:	29/11/06																			*/
/*																										*/
/*  	Description:  	General purpose script to turn a text field into Mixed Case from any			*/
/*						other case. 																	*/
/*																										*/
/*																										*/
/*	Amendment History																					*/
/*	-----------------																					*/
/*																										*/
/*	Date		Who				Description																*/
/*	----		---				-----------																*/
/*	24/04/01	A Groves        If input is a single uppercase word of 4 characters or less				*/
/*								then leave uppercase.													*/
/*	24/04/01    A Groves        First letter following a "(" should be uppercase.						*/
/*	10/04/02	A Groves        Upper chara if after dot so P.a.f. will become P.A.F.					*/
/*								Upper after Mc i.e. McMahon.											*/
/*								Upper after O' i.e. O'Brien.											*/
/*								NOTE: Don't upper for Mac because of names like Macey,					*/
/*								Machin, etc.															*/
/*	03/04/02	A Groves        Fixed bug in McMahon processing which caused the following:				*/
/*								1) AmcOr Flexibles Europe												*/
/*								2) SimcOrp SBS Ltd														*/
/*								3) BramcOte																*/
/*								Capitalise if previous chara is ". Special processing for '				*/
/*								otherwise "Alan'S" occurs. All processing to upper whole words 			*/
/*								removed.  This is now done in MixCaseCompany.							*/
/*	09/09/02	A Groves        Migrated to SQL7 for ButterW											*/
/*								1) Renamed module														*/
/*								2) Initialized @output_string to "" instead of null.					*/
/*								3) Changed char_length to len											*/
/*	21/09/05	A Groves		Uppercase a-z if immediately after comma.								*/
/*	22/09/05	A Groves		If @input_string is null then @output_string must be null.				*/
/*								Suddenly didn't like double quotes so changed to single.				*/
/********************************************************************************************************/

CREATE FUNCTION [dbo].[owf_MixCase]
(	
	@input_string   varchar(250)

)
		RETURNS VARCHAR(250)
AS

BEGIN

DECLARE @StringLength               int,
        @Posn                       int,
        @UpperCharacter             char(1),
		@output_string				varchar(250)


if @input_string is null
	select @output_string = null
else
 	select @output_string   = ''

select @StringLength    = len(@input_string)
select @Posn            = 1
 
while @Posn <= @StringLength
begin
 
    if @Posn > 2
        if upper(substring(@input_string, @Posn-2, 2)) like 'MC'        or
           upper(substring(@input_string, @Posn-2, 2)) like '[A-Z]'''   or
           upper(substring(@input_string, @Posn-2, 2)) like ' '''
            if @Posn > 3
                if upper(substring(@input_string, @Posn-3, 1)) not like '[A-Z]'
                    if @StringLength > @Posn
                       if upper(substring(@input_string,@Posn+1,1)) like '[A-Z]'
                            select @UpperCharacter = 'Y'
                       else
                            select @UpperCharacter = 'N'
                    else
                       select @UpperCharacter = 'N'
                else
                    select @UpperCharacter = 'N'
            else
                if @StringLength > @Posn
                    if upper(substring(@input_string,@Posn+1,1)) like '[A-Z]'
                        select @UpperCharacter = 'Y'
                    else
                        select @UpperCharacter = 'N'
                else
                    select @UpperCharacter = 'N'
        else
            select @UpperCharacter = 'N'
    else
        if @Posn = 2
            if substring(@input_string, @Posn-1, 1) = ''''
                select @UpperCharacter = 'Y'
            else
                select @UpperCharacter = 'N'
        else
            select @UpperCharacter = 'N'
 
    if @UpperCharacter = 'Y'
        select @output_string = @output_string +
                    upper(substring(@input_string, @Posn, 1))
    else
        if @Posn = 1
            if substring(@input_string, @Posn, 1) like '[a-z]'
                select @output_string = @output_string +
                        upper(substring(@input_string, @Posn, 1))
            else
                select @output_string = @output_string +
                        substring(@input_string, @Posn, 1)
        else
            if substring(@input_string, @Posn-1, 1) in (' ', '(', ')', '&', '-', '/', '"', '.', ',')
                if substring(@input_string, @Posn, 1) like '[a-z]'
                    select @output_string = @output_string +
                        upper(substring(@input_string, @Posn, 1))
                else
                    select @output_string = @output_string +
                        substring(@input_string, @Posn, 1)
            else
                if upper(substring(@input_string, @Posn, 1)) not like '[A-Z]'
                    select @output_string = @output_string +
                        substring(@input_string, @Posn, 1)
                else
                    if substring(@input_string, @Posn, 1) like '[A-Z]'
                        select @output_string = @output_string +
                            lower(substring(@input_string, @Posn, 1))
                    else
                        select @output_string = @output_string +
                            substring(@input_string, @Posn, 1)
 
    select @Posn = @Posn + 1

end

/********************************************************************************************************/
/*  																									*/
/*	T H E   E N D																						*/
/*  																									*/
/********************************************************************************************************/

RETURN @output_string
END


