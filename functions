CREATE FUNCTION [dbo].[cscf_CalcMarginDue](@ID INT)
RETURNS DECIMAL(15,2) AS  
BEGIN 
   DECLARE @Result FLOAT

   -- Margin Due = Amount_Due * Margin %
 
   SELECT @Result = (SELECT Amount_Due
                     FROM mstt_Expectation 
                     WHERE ID = @ID)                             -- Amount Due
                    *
                    (SELECT dbo.cscf_CalcMarginPercent(@ID))     -- Margin %

   RETURN CAST(@Result AS DECIMAL(15,2)) -- round the result (so margin + commission must equal amount)
END

