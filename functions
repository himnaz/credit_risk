/*********************************************************************************************************

Program:		owf_DeriveRequestedDate	
				(templated from OwlEvolution.fns_DeriveRequestedDate by Alan Groves on 13/04/2022)
Author:			Alan Groves
Date created:	07/06/2022
											
Description:
===========

This scalar function returns a date that will either be the first, second, third or the last date in the 
month for the given weekday name. Examples:

1) When given the reference date 12/04/2022, the week day name 'Friday' and the week in month = 'Last', then 
	the date 29/04/2022 is returned because it is the last Friday in April 2022.

2) When given the reference date 26/04/2022, the week day name 'Tuesday' and the week in month = 'First', then 
	the date 05/04/2022 is returned because it is the first Tuesday in April 2022.

3) When given the reference date 12/04/2022, the week day name 'Friday' and the week in month = 'Second', then 
	the date 08/04/2022 is returned because it is the second Friday in April 2022.

4) When given the reference date 26/04/2022, the week day name 'Tuesday' and the week in month = 'Third', then 
	the date 19/04/2022 is returned because it is the third Tuesday in April 2022.

Note 
----
The reference date can be getdate() (with hours, minutes, seconds & milliseconds) but the date returned by the 
function will always be a datetime without the hours, minutes, seconds & milliseconds e.g. 2022-04-05 00:00:00.000.

This function is called as follows:
	
	declare @Today datetime = getdate(),		--This is the date for which the first or last date of the month is derived
			@DayName varchar(20) = 'Thursday',	--This must be either 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday' or 'Sunday'
			@WeekInMonth varchar(20) = 'First'	--This must be either 'First', 'Second', 'Third' or 'Last'
	select dbo.owf_DeriveRequestedDate(@Today, @DayName, @WeekInMonth)
			
AMENDMENT HISTORY				
=================								

Date		Author		Description
----		------		-----------

*************************************************************************************************************/

CREATE FUNCTION [dbo].[owf_DeriveRequestedDate] 
(
	@ReferenceDate datetime,
	@DayName varchar(20),
	@WeekInMonth varchar(20)
)
returns datetime
as
begin

	declare @DateInMonth datetime

	if @WeekInMonth in ('First','Second','Third')
	begin
		declare @DayNumber int = case @DayName 	
										when 'Sunday' then 8
										when 'Monday' then 9
										when 'Tuesday' then 10
										when 'Wednesday' then 11
										when 'Thursday' then 12
										when 'Friday' then 13
										when 'Saturday' then 14
										else null 
									end
		set @DateInMonth = DateAdd(day, (@DayNumber -DatePart(weekday, DateAdd(Month, DateDiff(Month, 0,  @ReferenceDate),0)))%7, DateAdd(Month, DateDiff(Month, 0,  @ReferenceDate),0))
		set @DateInMonth = @DateInMonth + case @WeekInMonth
												when 'Second' then 7
												when 'Third' then 14
												else 0	--Else must be 'First'
										  end
	end
	else if  @WeekInMonth = 'Last'
	begin
		declare @BaseDate datetime = '1900-01-01'
		set @BaseDate = case @DayName 
							when 'Monday' then 0
							when 'Tuesday' then 1
							when 'Wednesday' then 2
							when 'Thursday' then 3
							when 'Friday' then 4
							when 'Saturday' then 5
							when 'Sunday' then 6
							else null 
						end + @BaseDate

		set @DateInMonth = DateAdd(DY, DateDiff(DY, @BaseDate, DateAdd(MM, DateDiff(MM,0,@ReferenceDate),30))/7*7,@BaseDate)
	end
	else
		set @DateInMonth = null

	return @DateInMonth

end
