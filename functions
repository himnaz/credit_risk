   SELECT @CommissionType = (SELECT Type FROM msit_S_PACC WHERE ID = @ID)
   SELECT @TransactionID = (SELECT TransactionID FROM msit_S_PACC WHERE ID = @ID)

   -- Different processing according to Commission Type
   IF @CommissionType = 1
   BEGIN
      -- Join to the Commission records on transactionID and commissiontype.
      -- Sum the FixedAmount for all records found to produce the Distribution allowance. 
      -- Margin amount is FixedAmount for matched commission record(s) with GrossOrNet = 'N'   
      -- Margin % is Margin amount divided by Distribution allowance.

      SELECT @DA = (SELECT ISNULL(SUM(FixedAmount), 0)
                    FROM msit_S_AGTCOM AS Comm
                    WHERE Comm.CommissionType = @CommissionType
                    AND Comm.TransactionID = @TransactionID
                   )

      IF @DA = 0  -- avoid possibility of divide by zero
         RETURN NULL
      ELSE
         SELECT @Result = (SELECT ISNULL(SUM(FixedAmount), 0)
                           FROM msit_S_AGTCOM AS Comm
                           WHERE Comm.CommissionType = @CommissionType
                             AND Comm.TransactionID = @TransactionID
                             AND Comm.GrossOrNet = 'N'
                          )                                           -- Margin Amount
                          /
                          @DA                                         -- Distribution Allowance
   END

   ELSE IF @CommissionType IN (2, 17)
   BEGIN
      -- Join the passed-in Expectation record to Commission records on TransactionID but with CommissionType = 1. 
      -- If such Commission records exist:
         -- Sum the FixedAmount for all records found to produce the Distribution allowance. 
         -- Margin amount is FixedAmount for matched commission record(s) with GrossOrNet = 'N'   
         -- Margin % is Margin amount divided by Distribution allowance.
      -- If no such Commission records exist:
         -- Set Margin % = 0 (i.e. Commission % = 100)

      SELECT @Count = (SELECT COUNT(ID)
                       FROM msit_S_AGTCOM AS Comm
                       WHERE Comm.CommissionType = 1
                         AND Comm.TransactionID = @TransactionID
                      )
      IF @Count > 0
      BEGIN
         SELECT @DA = (SELECT ISNULL(SUM(FixedAmount), 0)
                       FROM msit_S_AGTCOM AS Comm
                       WHERE Comm.CommissionType = 1
                       AND Comm.TransactionID = @TransactionID
                      )

         IF @DA = 0  -- avoid possibility of divide by zero
            RETURN NULL
         ELSE
            SELECT @Result = (SELECT ISNULL(SUM(FixedAmount), 0)
                              FROM msit_S_AGTCOM AS Comm
                              WHERE Comm.CommissionType = 1
                                AND Comm.TransactionID = @TransactionID
                                AND Comm.GrossOrNet = 'N'
                             )                                           -- Margin Amount
                             /
                             @DA                                         -- Distribution Allowance
      END
      ELSE
      BEGIN
         SELECT @Result = 0
      END
   END

   ELSE IF @CommissionType IN (3, 4, 8, 10, 14, 15, 16, 18, 19)
   BEGIN
      -- Set Margin % = 0 (i.e. Commission % = 100)
      SELECT @Result = 0
   END

   ELSE IF @CommissionType IN (5, 6, 7, 9, 11, 12, 13, 20, 21)
   BEGIN
      -- Set Margin % = NULL (i.e. Margin % = 0; Commission % = 0)
      SELECT @Result = NULL
   END

   ELSE -- explicitly ignore unknown commission types
      -- Set Margin % = NULL (i.e. Margin % = 0; Commission % = 0)
      SELECT @Result = NULL

   RETURN @Result
END

