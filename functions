BEGIN 
   DECLARE @Result DECIMAL(15,2)
/*
  RH 19 Feb 2007
  Swift SR6 introduces new Status value of 3
  Need to pick this up as well as 2

*/

   SELECT @Result = (CASE
                        WHEN @CommissionType IN (1) AND @Openwork <> 'Y' THEN -- Non-Openwork IC
                           ((SELECT 
                            CASE
                               WHEN @Openwork = 'Y' THEN ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcMarginDue(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                               ELSE ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcCommissionDue(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                            END
                            FROM mstt_Expectation AS Expect
                            INNER JOIN mstt_PolicyTransactions PolicyTransactions ON PolicyTransactions.ID = TransactionID 
                            WHERE Type = @CommissionType
                              AND CAST(CONVERT(NVARCHAR,Date_Due, 112) AS DATETIME) < CAST(CONVERT(NVARCHAR,@StartDate, 112) AS DATETIME)
                              AND EXISTS (SELECT OtherExpect.ID
                                          FROM mstt_Expectation AS OtherExpect
