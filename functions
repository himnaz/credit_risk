/********************************************************************************************************
    Program:    owf_GetEntryDelimited                           
  Date created: 16/11/06  (Based on f_GetEntryDelimiitted By Nigel Rivett of 03/07/06)
                                              
    Description:  This utility parses a long string variable and extracts the individual variables.
                            
                          
  Amendment History                   
  -----------------           
                      
  Date    Who     Description   
  ----    ---     ----------- 
  15/10/2009  A Groves  1) Amended to allow space as a delimiter
              2) If told to expect double quotes but none present then don't look for them
********************************************************************************************************/

CREATE function [dbo].[owf_GetEntryDelimited]
(
@data_string      varchar(4000) ,
@fldnum         int ,
@delim          varchar(10) ,
@double_quote_txt_qual  varchar(1)  -- Y/N
)
returns varchar(4000)
as
begin
/*
create table #a (s varchar(1000))
insert #a select '"John","Smith","IT",2,"sql",1'
insert #a select '"Fred","Jones","Assassin",7,"Guns","5"'
insert #a select '"Peter","Brown","Politics",23,minister,5'
insert #a select '"Peter","Brown",,23,minister,5'

select a.* from
(
select  Forname   = dbo.f_GetEntryDelimited (s, 1, ',', 'Y') ,
    Surname   = dbo.f_GetEntryDelimited (s, 2, ',', 'Y') ,
    Profession  = dbo.f_GetEntryDelimited (s, 3, ',', 'Y') ,
    ProfessionExp   = dbo.f_GetEntryDelimited (s, 4, ',', 'Y') ,
    Skill     = dbo.f_GetEntryDelimited (s, 5, ',', 'Y') ,
    SkillExp  = dbo.f_GetEntryDelimited (s, 6, ',', 'Y') ,
    Invalid   = dbo.f_GetEntryDelimited (s, 7, ',', 'Y')
from #a
) a

delete #a
insert #a select '"John",,"Smith",,"IT",,2,,"sql",,1'
insert #a select '"Fred",,"Jones",,"Assassin",,7,,"Guns",,"5"'

select  Forname   = dbo.f_GetEntryDelimited (s, 1, ',,', 'Y') ,
    Surname   = dbo.f_GetEntryDelimited (s, 2, ',,', 'Y') ,
    Profession  = dbo.f_GetEntryDelimited (s, 3, ',,', 'Y') ,
    ProfessionExp   = dbo.f_GetEntryDelimited (s, 4, ',,', 'Y') ,
    Skill     = dbo.f_GetEntryDelimited (s, 5, ',,', 'Y') ,
    SkillExp  = dbo.f_GetEntryDelimited (s, 6, ',,', 'Y')
from #a

drop table #a
*/

declare @field_start    int ,
    @field_end      int ,
    @delimUsed      varchar(11) ,
    @individual_field varchar(4000)
  
  -- If told to expect double quotes but none present then don't look for them! AG 15/10/2009 (Item 2)
  if @double_quote_txt_qual = 'Y' and patindex('%"%',@data_string) = 0
    set @double_quote_txt_qual = 'N'

  select @field_start = 1 -- points to start of field

  -- Loop while scanning for next field
  while @fldnum > 0 and @field_start <= len(@data_string)
  begin

    -- Decrement field counter.  When down to zero, desired field has been found.
    select @fldnum = @fldnum - 1

    -- Find position of first character in the field given by @field_start
    if substring(@data_string, @field_start, 1) = '"' and @double_quote_txt_qual = 'Y'
    begin
      
      select  @delimUsed = '"' + @Delim ,
        @field_start = @field_start + 1
    end
    else
    begin
      select @delimUsed = @Delim
    end
    
    -- Find position of delimiter that identifies the end of the field
    select @field_end = charindex(@delimUsed, @data_string, @field_start)

    if @field_end = 0   -- delim not found so last field
      --select @field_end = datalength(@data_string) + 1 - len(@delimUsed) + len(@Delim)  AG 15/10/2009 (Item 1)
      select @field_end = datalength(@data_string) + 1 - 
          case @double_quote_txt_qual 
            when 'Y' then case len(@delimUsed) 
                      when 1 then 2 
                      else len(@delimUsed) 
                    end 
            else  case len(@delimUsed) 
                  when 0 then 1 
                  else len(@delimUsed) 
                end
            end + 
            case len(@Delim) 
              when 0 then 1 
              else len(@Delim)
            end

    -- If any field after first field then jump to start of next field
    if @fldnum > 0
      --select @field_start = @field_end +len(@delimused)   AG 15/10/2009 (Item 1)
      select @field_start = @field_end + case @double_quote_txt_qual 
                        when 'Y' then case len(@delimUsed) 
                                  when 1 then 2 
                                  else len(@delimUsed) 
                                end 
                        else  case len(@delimUsed) 
                              when 0 then 1 
                              else len(@delimUsed) 
                            end
                        end
  end

  if @field_end > @field_start
    select @individual_field = substring(@data_string, @field_start, 
                        @field_end - @field_start)
  else
    select @individual_field = null

  return  @individual_field
end








