/****************************************************************************
  	 Program:  	owf_AbbreviatedMatch					
	  Author:	A Groves
Date created:	07/06/2013			
											
 Description:   This function is used to compare two string expressions to see
				if the shorter string exactly matches the longer string for 
				the length of the shorter string.

				For example:
				FirstString		SecondString	Match
				Jo				Joanne			1
				Joe				Joseph			0
 
				It is called as follows:

				select dbo.owf_AbbreviatedMatch(@Name1,@Name2)
							
	Amendment History								
	-----------------								
											
	Date		Who			Description				
	----		---			-----------			
						
****************************************************************************/

CREATE FUNCTION [dbo].[owf_AbbreviatedMatch](@FirstString varchar(4000),@SecondString varchar(4000))
RETURNS varchar(4)
AS
begin
	declare @Match			bit,
			@FirstStrLen	int,
			@SecondStrLen	int

	select @FirstString		= dbo.owf_FirstWord(@FirstString)
	select @SecondString	= dbo.owf_FirstWord(@SecondString)

	set @FirstStrLen = len(@FirstString)
	set @SecondStrLen = len(@SecondString)

	if @FirstStrLen <= @SecondStrLen
			if @FirstString = substring(@SecondString,1,@FirstStrLen)
				set @Match = 1
			else
				set @Match = 0
	else
		if @SecondString = substring(@FirstString,1,@SecondStrLen)
				set @Match = 1
			else
				set @Match = 0

	return @Match
end


