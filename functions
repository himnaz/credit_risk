CREATE FUNCTION [BI].[owf_HashReverseID]
(	
	@AgentID varchar(6)
)
returns varchar(7)
as
begin

declare @ID int,
		@UID varchar(7)

set @ID = 420000 - convert(int,@AgentID)

select @UID = Code
from mstt_Agents
where ID = @ID

return @UID

end




