/****************************************************************************
Program:	    f_Insight_listPanelHistoryOfAllSellers                     
Author:			M Cawood
Date created:	17/08/2010                                             
     
Description
----------- 
The purpose of this function is to build a Table of Insight Sellers which
lists the Panel information held in the UPS_Section column on the Insight
UserPosition table.

This function can be used like a derived table and joined to in queries.
It derives the Seller UID held in Insight (USR_ExternalId)
Use the EffFrom and EffTo date columns to find the Panel marker effective
at a specific date (e.g. Proposal Date).                                                                  

The function only selects UserPosition entries created for the Insight 
"Adviser/Seller" role. This is derived for UserType = 3 where CodeType = 11
(User Type). 

                                                       
Amendment History                                                    
-----------------                                                    
                                                                     
Date          Who              Description                       
----          ---              -----------   
27/09/2010	M Cawood	Derive Section Description (type 53) as PANEL
26/10/2010	M Cawood	Amend derivation of EffFrom date
07/12/2010	M Cawood	Amend derivation to pull in UserPositionHistory 
                        details. 
12/11/2014	A Groves	Breakfix to increase the Size of Panel,
						TypeDescription and CodeDescription from 
						varchar(50) to varchar(100).
18/07/2018	A Groves	This function was previously returning duplicate date
						ranges for different UPS_Section codes making it 
						impossible to identify the true panel on any given
						date. It appears to have been possible on Insight to
						not close off old panel selections when an adviser 
						has moved to a new panel. Dedupe has been introduced 
						via a new CTE. 
26/04/2022	A Groves	Re-written from scratch to deal with incorrect
						EffFrom dates.
****************************************************************************/

CREATE function [dbo].[f_Insight_ListPanelHistoryOfAllSellers]()
       returns @Out table (InsightAgentUID  nvarchar(50),
                           InsightUserGUID  uniqueidentifier,
                           Section          int,                --MPC: 27/09/2010
                           Panel            varchar(100),       --MPC: 27/09/2010	AG 12/11/2014
                           EffFrom          datetime,
                           EffTo            datetime,
                           TypeDescription  varchar(100),		--AG 12/11/2014 
                           CodeType         int,
                           CodeDescription  varchar(100),		--AG 12/11/2014
                           UserTypeCode     int
                           )

as                           
begin

declare @PanelHistAll as table
(
	RowNumber int,
	Source tinyint,
	UPS_UserID uniqueidentifier,
	UPS_UserType int,
	UPS_Section int,
	Code_Description varchar(200),
	ChangedOn datetime
)

insert into @PanelHistAll
(
	RowNumber,
	Source,
	UPS_UserID,
	UPS_UserType,
	UPS_Section,
	Code_Description,
	ChangedOn
)
select	row_number() over (partition by UPS_UserID order by ChangedOn) as RowNumber, *
from
(
select	2 as Source, UPS_UserID, UPS_UserType, UPS_Section, CD.Code_Description, convert(date,UPS_UpdatedDate) as ChangedOn
from	dbo.sa_insight_UserPositionHistory uph
		left join dbo.sa_insight_CodeDescription CD on CD.Code_CodeType = 53 and CD.Code_Code = uph.UPS_Section   
where	ups_UserType = 3   --Adviser/Seller
and		UPS_ID not in (select UPS_ID from dbo.sa_insight_UserPositionHistory where UPS_DateTo is not null)
and		UPS_DateTo is null
union
select	1 as Source, UPS_UserID, UPS_UserType, UPS_Section, CD.Code_Description, convert(date,UPS_UpdatedDate) as ChangedOn
from	dbo.sa_insight_UserPosition up
		left join dbo.sa_insight_CodeDescription CD on CD.Code_CodeType = 53 and CD.Code_Code = up.UPS_Section   
where	ups_UserType = 3   --Adviser/Seller
and		UPS_ID not in (select UPS_ID from dbo.sa_insight_UserPosition where UPS_DateTo is not null)
and		UPS_DateTo is null
) a

declare @PanelHistDeduped as table
(
	RowNumber int,
	Source tinyint,
	UPS_UserID uniqueidentifier,
	UPS_UserType int,
	UPS_Section int,
	Code_Description varchar(200),
	ChangedOn datetime
)

insert into @PanelHistDeduped
(
	RowNumber,
	Source,
	UPS_UserID,
	UPS_UserType,
	UPS_Section,
	Code_Description,
	ChangedOn
)
select	RowNumber,
		Source,
		UPS_UserID,
		UPS_UserType,
		UPS_Section,
		Code_Description,
		ChangedOn
from	@PanelHistAll
where	RowNumber = 1

declare @CurrentRow int = 1
declare @MaxRow int = (select max(RowNumber) from @PanelHistAll)

while @CurrentRow <= @MaxRow
begin

	insert into @PanelHistDeduped
	(
		RowNumber,
		Source,
		UPS_UserID,
		UPS_UserType,
		UPS_Section,
		Code_Description,
		ChangedOn
	)
	select	later.RowNumber,
			later.Source,
			later.UPS_UserID,
			later.UPS_UserType,
			later.UPS_Section,
			later.Code_Description,
			later.ChangedOn
	from	@PanelHistAll earlier
			inner join @PanelHistAll later 
						on later.UPS_USerID = earlier.UPS_UserID
						and later.RowNumber = @CurrentRow + 1
	where	earlier.RowNumber = @CurrentRow
	and		earlier.UPS_Section <> later.UPS_Section
		
	set @CurrentRow = @CurrentRow + 1

end

insert into @Out 
(	InsightAgentUID,
	InsightUserGUID,
	Section        ,                        
	Panel          ,
	EffFrom        ,
	EffTo          ,
	TypeDescription,
	CodeType       ,
	CodeDescription,
	UserTypeCode
)
select	ud.USR_ExternalId as InsightAgentUID,
		ud.USR_ID as InsightUserGUID,
		phd.UPS_Section as Section,
		isnull(phd.Code_Description,'Unknown') as Panel, 
		ChangedOn as EffFrom,
		lag(ChangedOn-1,1,'9999-12-31') over (partition by UPS_UserID order by UPS_UserID, RowNumber desc) as EffTo,
		ct.CT_Description as TypeDescription,   
		phd.UPS_Section as CodeType,
		phd.Code_Description as CodeDescription,
		phd.UPS_UserType
from	@PanelHistDeduped phd
		inner join dbo.sa_insight_UserDetails ud on ud.USR_ID = phd.UPS_UserID
		inner join dbo.sa_insight_CodeType ct on ct.CT_Code = 53   --Section  

return 

end




