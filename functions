/***************************************************************************************

Name:		f_Insight_SpanOfControlAllShallow
			(templated from UDF_SpanOfControl taken from production Insight on 15/10/2015) 

Author:		A Groves

Date:		15/10/2015

Purpose:	This table function returns the span of control for:
			Job Title	Role
			4			Advisers
			5			Practice Principals
			42			Schedule E Sellers 
			9			AQM
			7			BQM
			8			Supervisor
			
			with the following roles supervising them:
			Job Title	Role
			15			BQD
			9			AQM
			7			BQM
			8			Supervisor
			
Details:	Parameters
			----------

			@LinksDateFrom - The start date on which the adviser is linked to the supervisor
			
			@LinksDateTo - The end date on which the adviser is linked to the supervisor

			Call this table function as follows:
			-----------------------------------
			
			select *
			from f_Insight_SpanOfControlAllShallow(getdate(),getdate())
			

AMENDMENT HISTORY
=================

Date		Author		Description
----		------		-----------
20/11/2015	A Groves	Amended to filter on the department of the User Position row.
						This is to fix the duplicates problem with David Blackmore, 
						Alexandra Cotton, etc. who have multiple supervisory roles
						to fix some issue in OWS. Julie Richings created the new 
						department called "KPI Supervisor" which is only set up on the
						duplicating supervisor records. Thus, if the "KPI Supervisor"
						department is present (UPS_Department<>0), then it is filtered on.
10/12/2015	A Groves	Include practice principals (and their supervisors). This group 
						was needed for the firm level "SCRG" kpi.
24/12/2015	A Groves	Ensure only one user position supervises each user position to 
						prevent dupes. This appeared to be only a problem in UAT (as
						opposed to PROD) but if it can happen, then it will happen....
14/01/2016	A Groves	Jenny AQM links to Jenny BQD. Therefore include BQD (Job Title 
						Code = 15).
12/04/2016	A Groves	SR429678. After the change of 20/11/2015 above, some users were
						randomly setting the department of supervisors to "KPI Supervisor"
						on ended roles. The CTE then selected these ended roles which 
						were then filtered out by the main query. The fix was to add the
						date filter from the main query into the CTE to stop the CTE from 
						selecting these ended "KPI Supervisor" roles. This problem came to 
						light because Peter Hockings and Jason McGimpsey were missing their 
						supervisor role (Job Title Code = 8) on the KPI population table. 
01/08/2016	A Groves	Some people were dropping out of the hierarchy and then bouncing
						back in. This was found to be a timing issue due to the fact that
						the two date parameters (@LinksDateFrom and @LinksDateTo) included
						time. The time has now been stripped out of these parameters to
						resolve the problem.
12/10/2018	A Groves	SR516787 - Three supervisors not showing linked to Heather 
						Collett-Bourne in the adviser/supervisor list in the Supervisor
						T&C MI. The root cause of this problem is where multiple supervisors
						are set up and linked to people in Insight. In this scenario, the
						adviser/supervisor needs to be linked to their default supervisor  
						and previously the default supervisor indicator was not being checked.
****************************************************************************************/

CREATE FUNCTION [dbo].[f_Insight_SpanOfControlAllShallow] 
(
	@LinksDateFrom DATETIME = null,
	@LinksDateTo DATETIME = null			
)

RETURNS 

@Users TABLE 
(
	UserPositionID				UNIQUEIDENTIFIER,	
	UserID						UNIQUEIDENTIFIER,			
	SupervisorUserPositionID	UNIQUEIDENTIFIER,
	SupervisorUserID			UNIQUEIDENTIFIER
)

AS

BEGIN

	DECLARE @CompletionTypeCode INT
	DECLARE @SupervisorLinkCode INT
	DECLARE @LocumLinkCode INT
	DECLARE @DistributorSupervisorLinkCode INT
	DECLARE @Scope_DeepSpan INT 

	declare @UserPositions TABLE 
	(
		UserPositionID				UNIQUEIDENTIFIER,	
		UserID						UNIQUEIDENTIFIER,			
		SupervisorUserPositionID	UNIQUEIDENTIFIER,
		SupervisorUserID			UNIQUEIDENTIFIER,
		DefaultSupervisor			TINYINT				-- AG 12/10/2018						
	)

	-- Fill the table variable with the rows for your result set

	SET @SupervisorLinkCode = 1;
	SET @LocumLinkCode = 2;
	SET @DistributorSupervisorLinkCode = 4;
	SET @Scope_DeepSpan = 2;

	set	@LinksDateFrom = dateadd(dd,0,datediff(dd,0,@LinksDateFrom))	-- AG 01/08/2016
	set @LinksDateTo = dateadd(dd,0,datediff(dd,0,@LinksDateTo))		-- AG 01/08/2016
	
	;with CTE_UserPositions as
	(
		select	up.UPS_UserID, up.UPS_JobTitle, max(up.UPS_Department) as Max_UPS_Department
		from	sa_insight_UserPosition up
		where	up.UPS_JobTitle in (4,5,42,8,7,9,15)	-- 4=Adviser;5=Practice Principal;42=Schedule E Seller;8=Supervisor;7=BQM;9=AQM;15=BQD		AG 10/12/2015 & 14/01/2016
		AND		(@LinksDateFrom is null					-- AG 12/04/2016 
				or (up.UPS_DateTo >= @LinksDateFrom		-- AG 12/04/2016 
				or  up.UPS_DateTo is null))				-- AG 12/04/2016 
		AND		(@LinksDateTo is null					-- AG 12/04/2016 
				or  up.UPS_DateFrom <= @LinksDateTo)	-- AG 12/04/2016 
		group by UPS_UserID, UPS_JobTitle
	)
	insert into @UserPositions 
	(
		UserPositionID,
		UserID,
		SupervisorUserPositionID,
		SupervisorUserID,
		DefaultSupervisor								-- AG 12/10/2018
	)
	SELECT	up.UPS_ID,
			up.UPS_UserID,
			SupervisorPosition.UPS_ID,
			SupervisorPosition.UPS_UserID,
			UserPositionLink.UPSL_DefaultSupervisor		-- AG 12/10/2018
	FROM	sa_insight_UserPosition up WITH (NOLOCK)
			INNER JOIN CTE_UserPositions CTE_up 
						on CTE_up.UPS_UserID = up.UPS_UserID
						and CTE_up.UPS_JobTitle = up.UPS_JobTitle
						and CTE_up.Max_UPS_Department = up.UPS_Department
			INNER JOIN sa_insight_UserPositionLink AS UserPositionLink WITH (NOLOCK)
						ON (UserPositionLink.UPSL_ChildUserPositionID = up.UPS_ID 
						AND UserPositionLink.UPSL_LinkType = @SupervisorLinkCode)
						AND (@LinksDateFrom IS NULL 
							OR ((UserPositionLink.UPSL_DateTo >= @LinksDateFrom) 
							OR  (UserPositionLink.UPSL_DateTo IS NULL)))
						AND (@LinksDateTo IS NULL 
							OR ((UserPositionLink.UPSL_ID IS NULL) 
							OR (UserPositionLink.UPSL_DateFrom <= @LinksDateTo)))
			INNER JOIN sa_insight_UserPosition as SupervisorPosition WITH (NOLOCK)
						on UserPositionLink.UPSL_ParentUserPositionID = SupervisorPosition.UPS_ID
			INNER JOIN sa_insight_UserDetails ud WITH (NOLOCK)
						ON  SupervisorPosition.UPS_UserID = ud.USR_ID
	WHERE	SupervisorPosition.UPS_JobTitle in (8,7,9,15)	--8=Supervisor;7=BQM;9=AQM;15=BQD
	AND		up.UPS_JobTitle in (4,5,42,8,7,9)				--4=Adviser;5=Practice Principal;42=Schedule E Seller;8=Supervisor;7=BQM;9=AQM		AG 10/12/2015
	AND		(@LinksDateFrom is null 
			or (up.UPS_DateTo >= @LinksDateFrom 
			or  up.UPS_DateTo is null))
	AND		(@LinksDateTo is null 
			or  up.UPS_DateFrom <= @LinksDateTo)


	/*****************************************************************************
	
	AG 24/12/2015
	Ensure only one user position supervises each user position to prevent dupes
	
	******************************************************************************/

	insert into @Users 
	(
		UserPositionID,
		UserID,
		SupervisorUserPositionID,
		SupervisorUserID
	)
	select	u1.UserPositionID,
			u1.UserID,
			u1.SupervisorUserPositionID,
			u1.SupervisorUserID
	from	@UserPositions u1
			-- AG 12/10/2018 Start
			inner join	(select	UserPositionID,
								max(DefaultSupervisor) as MaxDefaultSupervisor 
						 from	@UserPositions
						 group	by UserPositionID
						 ) u3 on u3.UserPositionID = u1.UserPositionID
			-- AG 12/10/2018 End
			inner join	(select	UserPositionID,
								DefaultSupervisor,									-- AG 12/10/2018
								min(convert(varchar(36),SupervisorUserPositionID)) as MinVarcharSupervisorUserPositionID 
						 from	@UserPositions
						 group	by UserPositionID, DefaultSupervisor				-- AG 12/10/2018
						 ) u2 on u2.UserPositionID = u1.UserPositionID
								and u2.DefaultSupervisor = u3.MaxDefaultSupervisor	-- AG 12/10/2018
								and convert(UNIQUEIDENTIFIER,u2.MinVarcharSupervisorUserPositionID) = u1.SupervisorUserPositionID

	RETURN 

END






