CREATE FUNCTION [dbo].[sa_ows_udf_SVC_GetEventReminderStatusID]
(
	@EventDate DATETIME,
	@EventComplete BIT
)
RETURNS INT
AS
BEGIN

	DECLARE @reminderStatusID INT
	IF @EventComplete = 1
		SELECT @reminderStatusID = EventReminderStatusID 
		FROM dbo.sa_ows_SVC_EventReminderStatus WITH (NOLOCK)
		WHERE EventReminderStatusText = 'Complete'

	ELSE
	BEGIN

		DECLARE @dateNow DATETIME
		SET @dateNow = GETDATE()

		--truncate time part
		SET @dateNow = DATEADD (DD, DATEDIFF(DD, 0, @dateNow), 0)
		SET @EventDate = DATEADD (DD, DATEDIFF(DD, 0, @EventDate), 0)



		-- current restriction for ease and performance of code - cannot mix ThresholdTypes
		-- and ThresholdType must be DD or MM

		IF EXISTS (SELECT (1) FROM dbo.sa_ows_SVC_EventReminderStatus 
				   WHERE ThresholdType = 'DD')
		BEGIN
			DECLARE @daysDiff AS INT 
			SET @daysDiff  = DATEDIFF(DD, @dateNow, @EventDate)

			SELECT TOP 1 @reminderStatusID = EventReminderStatusID
			FROM dbo.sa_ows_SVC_EventReminderStatus
			WHERE @daysDiff >= LowerThreshold AND @daysDiff <= UpperThreshold
		END
		ELSE
		BEGIN
			DECLARE @monthsDiff AS INT
			SET @monthsDiff  = DATEDIFF(MM, @dateNow, @EventDate)

			SELECT TOP 1 @reminderStatusID = EventReminderStatusID
			FROM dbo.sa_ows_SVC_EventReminderStatus
			WHERE @monthsDiff >= LowerThreshold AND @monthsDiff <= UpperThreshold
		END
	END
	RETURN @reminderStatusID
END



