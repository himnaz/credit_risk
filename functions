CREATE FUNCTION [dbo].[fns_DeriveGUID](@Numeric int)
RETURNS uniqueidentifier
AS
begin

declare @Guid varchar(36),
		@PartialGuid varchar(36),
		@GuidSuffixZeros varchar(12) = '000000000000'
		
if @Numeric < 0
	set @PartialGuid = '00000000-0000-0000-0001-'
