CREATE FUNCTION [dbo].[cscf_FINSTAT0028_ClosingComm](@StartDate VARCHAR(10), @EndDate VARCHAR(10), @CommissionType INT, @Openwork CHAR(1))
RETURNS DECIMAL(15,2) AS  
BEGIN 
   DECLARE @Result DECIMAL(15,2)
/*
  RH 19 Feb 2007
  Swift SR6 introduces new Status value of 3
  Need to pick this up as well as 2

*/

   SELECT @Result = (CASE
                        WHEN @CommissionType IN (1) AND @Openwork <> 'Y' THEN -- Non-Openwork IC
                           ((SELECT 
                            CASE
                               WHEN @Openwork = 'Y' THEN ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcMarginDue(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                               ELSE ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcCommissionDue(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                            END
                            FROM mstt_Expectation AS Expect
                            INNER JOIN mstt_PolicyTransactions PolicyTransactions ON PolicyTransactions.ID = TransactionID 
                            WHERE Type = @CommissionType
                              AND CAST(CONVERT(NVARCHAR,Date_Due, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME)
                              AND EXISTS (SELECT OtherExpect.ID
                                          FROM mstt_Expectation AS OtherExpect
                                          WHERE OtherExpect.Type = @CommissionType
                                            AND OtherExpect.TransactionID = Expect.TransactionID
                                            AND OtherExpect.Status in(2,3))-- IC has been received for this transaction
                           )                                           -- Commission/margin due before Closing date
                           +                                           -- plus
                           (SELECT
                            CASE
                               WHEN @Openwork = 'Y' THEN ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcMarginDue(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                               ELSE ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcCommissionDue(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                            END
                            FROM mstt_Expectation AS Expect
                            INNER JOIN mstt_PolicyTransactions PolicyTransactions ON PolicyTransactions.ID = TransactionID 
                            WHERE Type = @CommissionType
                              AND CAST(CONVERT(NVARCHAR,Date_Due, 112) AS DATETIME) > CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME)
                              AND CAST(CONVERT(NVARCHAR,Date_Recv, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME) 
                           )                                           -- Commission/margin due after Closing date & received before Closing date 
                           -                                           -- minus
                           (SELECT ISNULL(SUM(ISNULL(CAST(AgPay.Amount AS DECIMAL(15,2)), 0.00)), 0.00)
                            FROM mstt_AgentPayments AS AgPay
                            LEFT JOIN mstt_PaymentsPending AS Pay ON Pay.Id = AgPay.AgmId
                            LEFT JOIN mstt_Expectation AS Expect ON Expect.Id = Pay.Pacc_Id
                            LEFT JOIN mstt_Agents AS Agents ON AgPay.Agent_Code = Agents.Code
                            WHERE AgPay.PaymentType = @CommissionType
                              AND CAST(CONVERT(NVARCHAR,AgPay.Export_Date, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME)
                              AND ((@Openwork = 'Y' AND Agents.Descn = 'Openwork')
                                OR (@Openwork <> 'Y' AND Agents.Descn <> 'Openwork'))
                           ))                                          -- proportion of these Commissions paid before Closing date
                           * (-1) -- show as negative

                        WHEN @CommissionType IN (4, 10) AND @Openwork <> 'Y' THEN -- Non-Openwork RC & Trail
                           ((SELECT 
                            CASE
                               WHEN @Openwork = 'Y' THEN ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcMarginDue(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                               ELSE ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcCommissionDue(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                            END
                            FROM mstt_Expectation AS Expect
                            INNER JOIN mstt_PolicyTransactions PolicyTransactions ON PolicyTransactions.ID = TransactionID 
                            WHERE Type = @CommissionType
                              AND CAST(CONVERT(NVARCHAR,Date_Due, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME)
                           )                                           -- Commission/margin due before Closing date
                           +                                           -- plus
                           (SELECT
                            CASE
                               WHEN @Openwork = 'Y' THEN ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcMarginDue(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                               ELSE ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcCommissionDue(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                            END
                            FROM mstt_Expectation AS Expect
                            INNER JOIN mstt_PolicyTransactions PolicyTransactions ON PolicyTransactions.ID = TransactionID 
                            WHERE Type = @CommissionType
                              AND CAST(CONVERT(NVARCHAR,Date_Due, 112) AS DATETIME) > CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME)
                              AND CAST(CONVERT(NVARCHAR,Date_Recv, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME) 
                           )                                           -- Commission/margin due after Closing date & received before Closing date 
                           -                                           -- minus
                           (SELECT ISNULL(SUM(ISNULL(CAST(AgPay.Amount AS DECIMAL(15,2)), 0.00)), 0.00)
                            FROM mstt_AgentPayments AS AgPay
                            LEFT JOIN mstt_PaymentsPending AS Pay ON Pay.Id = AgPay.AgmId
                            LEFT JOIN mstt_Expectation AS Expect ON Expect.Id = Pay.Pacc_Id
                            LEFT JOIN mstt_Agents AS Agents ON AgPay.Agent_Code = Agents.Code
                            WHERE AgPay.PaymentType = @CommissionType
                              AND CAST(CONVERT(NVARCHAR,AgPay.Export_Date, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME)
                              AND ((@Openwork = 'Y' AND Agents.Descn = 'Openwork')
                                OR (@Openwork <> 'Y' AND Agents.Descn <> 'Openwork'))
                           ))                                          -- proportion of these Commissions paid before Closing date
                           * (-1) -- show as negative

                        WHEN @CommissionType IN (2, 15, 16, 17, 18, 19) AND @Openwork <> 'Y' THEN -- Non-Openwork Clawbacks & Adjustments
                           ((SELECT 
                            CASE
                               WHEN @Openwork = 'Y' THEN ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcMarginDue(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                               ELSE ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcCommissionDue(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                            END
                            FROM mstt_Expectation AS Expect
                            INNER JOIN mstt_PolicyTransactions PolicyTransactions ON PolicyTransactions.ID = TransactionID 
                            WHERE Type = @CommissionType
                              AND CAST(CONVERT(NVARCHAR,Date_Due, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME)
                           )                                           -- Commission/margin due before Closing date
                           * (-1) -- show clawback as negative
                           +                                           -- plus
                           (SELECT
                            CASE
                               WHEN @Openwork = 'Y' THEN ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcMarginDue(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                               ELSE ISNULL(SUM(ISNULL(CAST(dbo.cscf_CalcCommissionDue(Expect.ID) AS DECIMAL(15,2)), 0.00)), 0.00)
                            END
                            FROM mstt_Expectation AS Expect
                            INNER JOIN mstt_PolicyTransactions PolicyTransactions ON PolicyTransactions.ID = TransactionID 
                            WHERE Type = @CommissionType
                              AND CAST(CONVERT(NVARCHAR,Date_Due, 112) AS DATETIME) > CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME)
                              AND CAST(CONVERT(NVARCHAR,Date_Recv, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME) 
                           )                                           -- Commission/margin due after Closing date & received before Closing date 
                           * (-1) -- show clawback as negative
                           -                                           -- minus
                           (SELECT ISNULL(SUM(ISNULL(CAST(AgPay.Amount AS DECIMAL(15,2)), 0.00)), 0.00)
                            FROM mstt_AgentPayments AS AgPay
                            LEFT JOIN mstt_PaymentsPending AS Pay ON Pay.Id = AgPay.AgmId
                            LEFT JOIN mstt_Expectation AS Expect ON Expect.Id = Pay.Pacc_Id
                            LEFT JOIN mstt_Agents AS Agents ON AgPay.Agent_Code = Agents.Code
                            WHERE AgPay.PaymentType = @CommissionType
                              AND CAST(CONVERT(NVARCHAR,AgPay.Export_Date, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME)
                              AND ((@Openwork = 'Y' AND Agents.Descn = 'Openwork')
                                OR (@Openwork <> 'Y' AND Agents.Descn <> 'Openwork'))
                           ))                                          -- Amount paid to franchises before Closing date
                           * (-1) -- show result as negative

          WHEN @CommissionType = 8 AND @Openwork <> 'Y' THEN -- Non-Openwork Standing Orders
                           (SELECT ISNULL(SUM(ISNULL(CAST(Pay.Amount AS DECIMAL(15,2)), 0.00)), 0.00)
                            FROM mstt_PaymentsPending AS Pay
                            LEFT JOIN mstt_AgentPayments AS AgPay ON Pay.Id = AgPay.AgmId
                            LEFT JOIN mstt_Agents AS Agents ON Pay.Agent_Code = Agents.Code
                            WHERE Pay.CommissionType = @CommissionType
                              AND ((@Openwork = 'Y' AND Agents.Descn = 'Openwork')
                                OR (@Openwork <> 'Y' AND Agents.Descn <> 'Openwork'))
                              AND CAST(CONVERT(NVARCHAR,Pay.PaymentDueDate, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME)
                              AND (CAST(CONVERT(NVARCHAR,AgPay.Export_Date, 112) AS DATETIME) > CAST(CONVERT(NVARCHAR,@EndDate, 112) AS DATETIME)
                                OR AgPay.Export_Date IS NULL)
                           )                                           -- Expenses & charges before Closing date
                           * (-1) -- show as negative

                        WHEN @CommissionType IN (1) AND @Openwork = 'Y' THEN -- Openwork IC
                           ((SELECT 
