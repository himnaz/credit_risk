CREATE function [dbo].[msf_SQGetAgentsInSpan] (
    @AgentCode            nvarchar(50)
   ,@Level                nvarchar(50)
   ,@HierarchyTypeCode    nvarchar(50)
   ,@SummaryPeriod        int
   ,@Filter               nvarchar(50) = NULL
)
returns @AgentsTab table(
   [Level]           nvarchar(50)
  ,[AgentCode]       nvarchar(50)
  ,[Description]     nvarchar(255)
)
as

--########################################################################
-- Copyright (c) MOORE STEPHENS, 2006 All rights reserved
--
-- Object  : function
-- Name    : msf_SQGetAgentsInSpan.sql
-- Desc    : Return a table containing the list of agent codes within the span of the specified agent code
-- Owner   : BT
-- Created : 28/07/2006 
-- Amended : 07/08/2006 - MK - BIG change to retrieve from new table which is built in ETL
--           08/08/2006 - MK - Select ONLY the passed in AgentCode if KPILevel = 'AdviserKPI'
--           08/08/2006 - MK - Do NOT select own AgentCode if KPILevel <> 'AdviserKPI'
--           10/08/2006 - MK - Rename @KpiLevel to @Level for consistency
--                        MK - Make this return agents at any specified level, optionally
--                             applying a filter
--                        BT - Hide PS's Advisers from SQM's
--                        BT - Exclude ASQM's from appearing in SQM level
--           17/08/2006 - BT - Allow Level to be NULL to return all levels under span of control.
--                             Return all levels at or below the specified user's level
--           31/08/2006 - BT - Exclude Sole-Traders from list of Practices
--           11/12/2006 - BT - Support ID 206 - Allow SQM's to see PS's Advisers
--       14/02/2007  - RH/OW - Tuned for performance as part of Agent KPI report production issue
--         - Fixes to affected procs/fns include explicit conversion of datatypes in query
--           expressions where parameter type is not matched to table data type
--           allowing Index seeks rather than scans
--         - Addition of indexes to required Quality tables
--         - Explicit alternative logic paths for queries where global parameter (eg Filter) is not supplied
--           avoiding table/index scans forced by unnecessary OR statememnts
--
--########################################################################

begin

--Set filter to null if set to ALL option
if @Filter = '-1'
  set @Filter = null

--Set AgentCode to null if set to ALL option e.g. Head Office
if @AgentCode = '-1'
  set @AgentCode = null


-- handle null (ie head office) agent code
if @AgentCode is null
begin

  if @Level is null
  begin

    IF @Filter is null
    begin

      --Get ASD's in span of control
      insert into @AgentsTab
      select Distinct
        'ASD',
        SalesQualityASDLevelCode,
        AreaSalesDirector
      from msct_AdvisersInQualitySpan
      where HierarchyTypeCode = convert(varchar(10),@HierarchyTypeCode)
      and SummaryPeriod = @SummaryPeriod
    
      --Get ASQM's in span of control
      insert into @AgentsTab
      select Distinct
        'ASQM',
        SalesQualitySQMLevelCode,
        SalesQualityManager
      from msct_AdvisersInQualitySpan
      where HierarchyTypeCode = convert(varchar(10),@HierarchyTypeCode)
      and SummaryPeriod = @SummaryPeriod
      and SalesQualityRSMLevelCode is null --ASQM's have a null RSM level code
    
      --Get RSM's in span of control
      insert into @AgentsTab
      select Distinct
        'RSM',
        SalesQualityRSMLevelCode,
        RegionalSalesManager
      from msct_AdvisersInQualitySpan
      where HierarchyTypeCode = convert(varchar(10),@HierarchyTypeCode)
      and SummaryPeriod = @SummaryPeriod
      
      --Get SQM's in span of control
      insert into @AgentsTab
      select Distinct
        'SQM',
        SalesQualitySQMLevelCode,
        SalesQualityManager
      from msct_AdvisersInQualitySpan
      where HierarchyTypeCode = convert(varchar(10),@HierarchyTypeCode)
      and SummaryPeriod = @SummaryPeriod
      and SalesQualityRSMLevelCode is not null  --SQM's have a non-null RSM level code
      
      --Get PS's in span of control
      insert into @AgentsTab
      select Distinct
        'PS',
        SalesQualityPSLevelCode,
        PracticeSupervisor
      from msct_AdvisersInQualitySpan
      where HierarchyTypeCode = convert(varchar(10),@HierarchyTypeCode)
      and SummaryPeriod = @SummaryPeriod
      
      --Get Practices in span of control
      insert into @AgentsTab
      select Distinct
        'PRACTICE',
        qs.PracticeCode,
        qs.Practice
      from msct_AdvisersInQualitySpan qs
          inner join mstt_Agents a on a.Code = qs.PracticeCode and AgentCategory <> 'SOLE'
      where HierarchyTypeCode = convert(varchar(10),@HierarchyTypeCode)
      and SummaryPeriod = @SummaryPeriod
      
      --Get Advisers in span of control
      insert into @AgentsTab
      select Distinct
        'ADVISER',
        AgentCode,
        Agent
      from msct_AdvisersInQualitySpan
      where HierarchyTypeCode = convert(varchar(10),@HierarchyTypeCode)
      and SummaryPeriod = @SummaryPeriod
    end
    else
    begin

      --Get ASD's in span of control
      insert into @AgentsTab
      select Distinct
        'ASD',
        SalesQualityASDLevelCode,
        AreaSalesDirector
      from msct_AdvisersInQualitySpan
      where HierarchyTypeCode = convert(varchar(10),@HierarchyTypeCode)
      and SummaryPeriod = @SummaryPeriod
    
      --Get ASQM's in span of control
      insert into @AgentsTab
      select Distinct
        'ASQM',
        SalesQualitySQMLevelCode,
        SalesQualityManager
      from msct_AdvisersInQualitySpan
      where HierarchyTypeCode = convert(varchar(10),@HierarchyTypeCode)
      and SummaryPeriod = @SummaryPeriod
      and @Filter = SalesQualityASDLevelCode --Optional Filter
      and SalesQualityRSMLevelCode is null --ASQM's have a null RSM level code
    
      --Get RSM's in span of control
      insert into @AgentsTab
      select Distinct
        'RSM',
        SalesQualityRSMLevelCode,
        RegionalSalesManager
      from msct_AdvisersInQualitySpan
      where HierarchyTypeCode = convert(varchar(10),@HierarchyTypeCode)
      and SummaryPeriod = @SummaryPeriod
      and @Filter = SalesQualityASDLevelCode --Optional Filter
      
      --Get SQM's in span of control
      insert into @AgentsTab
      select Distinct
        'SQM',
        SalesQualitySQMLevelCode,
        SalesQualityManager
      from msct_AdvisersInQualitySpan
      where HierarchyTypeCode = convert(varchar(10),@HierarchyTypeCode)
      and SummaryPeriod = @SummaryPeriod
      and @Filter = SalesQualityRSMLevelCode --Optional Filter
      and SalesQualityRSMLevelCode is not null  --SQM's have a non-null RSM level code
      
      --Get PS's in span of control
      insert into @AgentsTab
      select Distinct
        'PS',
        SalesQualityPSLevelCode,
        PracticeSupervisor
      from msct_AdvisersInQualitySpan
      where HierarchyTypeCode = convert(varchar(10),@HierarchyTypeCode)
      and SummaryPeriod = @SummaryPeriod
      and @Filter = SalesQualitySQMLevelCode --Optional Filter
      
      --Get Practices in span of control
      insert into @AgentsTab
      select Distinct
        'PRACTICE',
        qs.PracticeCode,
        qs.Practice
      from msct_AdvisersInQualitySpan qs
          inner join mstt_Agents a on a.Code = qs.PracticeCode and AgentCategory <> 'SOLE'
      where HierarchyTypeCode = convert(varchar(10),@HierarchyTypeCode)
      and SummaryPeriod = @SummaryPeriod
