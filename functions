/****************************************************************************
Program:	    f_Insight_listPanelHistoryOfAllSellers                     
Author:			M Cawood
Date created:	17/08/2010                                             
     
Description
----------- 
The purpose of this function is to build a Table of Insight Sellers which
lists the Panel information held in the UPS_Section column on the Insight
UserPosition table.

This function can be used like a derived table and joined to in queries.
It derives the Seller UID held in Insight (USR_ExternalId)
Use the EffFrom and EffTo date columns to find the Panel marker effective
at a specific date (e.g. Proposal Date).                                                                  

The function only selects UserPosition entries created for the Insight 
"Adviser/Seller" role. This is derived for UserType = 3 where CodeType = 11
(User Type). 

                                                       
Amendment History                                                    
-----------------                                                    
                                                                     
Date          Who              Description                       
----          ---              -----------   
27/09/2010	M Cawood	Derive Section Description (type 53) as PANEL
26/10/2010	M Cawood	Amend derivation of EffFrom date
07/12/2010	M Cawood	Amend derivation to pull in UserPositionHistory 
                        details. 
12/11/2014	A Groves	Breakfix to increase the Size of Panel,
						TypeDescription and CodeDescription from 
						varchar(50) to varchar(100).
18/07/2018	A Groves	This function was previously returning duplicate date
						ranges for different UPS_Section codes making it 
						impossible to identify the true panel on any given
						date. It appears to have been possible on Insight to
						not close off old panel selections when an adviser 
						has moved to a new panel. Dedupe has been introduced 
						via a new CTE. 
****************************************************************************/

CREATE function [dbo].[f_Insight_ListPanelHistoryOfAllSellersLUKETEST_Backup20220504AG]()
       returns @Out table (InsightAgentUID  nvarchar(50),
                           InsightUserGUID  uniqueidentifier,
                           Section          int,                --MPC: 27/09/2010
                           Panel            varchar(100),       --MPC: 27/09/2010	AG 12/11/2014
                           EffFrom          datetime,
                           EffTo            datetime,
                           TypeDescription  varchar(100),		--AG 12/11/2014 
                           CodeType         int,
                           CodeDescription  varchar(100),		--AG 12/11/2014
                           UserTypeCode     int
                           )

as                           
begin

;with CTE_PanelHistory
as
(
select c.ups_userid,c.ups_Section,dateadd(dd,0,datediff(dd,0,c.ups_updateddate)) as UpdateDate,dateadd(dd,-1,min(n.NextUpdate)) as EffToDate, max(c.UPS_UpdatedDate) as MaxUPS_UpdatedDate
from dbo.sa_insight_UserPositionHistory c
left join (select ups_userid,dateadd(dd,0,datediff(dd,0,ups_updateddate)) as NextUpdate
         from dbo.sa_insight_UserPositionHistory
         where ups_UserType = 3   --Adviser/Seller
         union
         select ups_userid,dateadd(dd,0,datediff(dd,0,ups_updateddate)) 
         from dbo.sa_insight_UserPosition
         where ups_UserType = 3   --Adviser/Seller
         ) n on n.ups_userID = c.ups_userID  and dateadd(dd,0,datediff(dd,0,c.ups_updateddate)) < n.nextupdate
where c.ups_UserType = 3
group by c.ups_userid,c.ups_Section,dateadd(dd,0,datediff(dd,0,c.ups_updateddate))
union
select c.ups_userid,c.ups_Section,dateadd(dd,0,datediff(dd,0,c.ups_updateddate)) as UpdateDate,dateadd(dd,-1,min(n.NextUpdate)) as EffToDate, max(c.UPS_UpdatedDate) as MaxUPS_UpdatedDate
from dbo.sa_insight_UserPosition c
left join (select ups_userid,dateadd(dd,0,datediff(dd,0,ups_updateddate)) as NextUpdate
         from dbo.sa_insight_UserPositionHistory
         where ups_UserType = 3   --Adviser/Seller
         union
         select ups_userid,dateadd(dd,0,datediff(dd,0,ups_updateddate)) 
         from dbo.sa_insight_UserPosition
         where ups_UserType = 3   --Adviser/Seller
         ) n on n.ups_userID = c.ups_userID  and dateadd(dd,0,datediff(dd,0,c.ups_updateddate)) < n.nextupdate
where c.ups_UserType = 3    --Adviser/Seller
group by c.ups_userid,c.ups_Section,dateadd(dd,0,datediff(dd,0,c.ups_updateddate))
)
insert into @Out 
(	InsightAgentUID,
	InsightUserGUID,
	Section        ,                        
	Panel          ,
	EffFrom        ,
	EffTo          ,
	TypeDescription,
	CodeType       ,
	CodeDescription,
	UserTypeCode
)
select	InsightAgentUID     = USR_ExternalId,
		InsightUserGUID     = USR_ID,
		Section             = cte_ph.UPS_Section,                            
		Panel               = isnull(CD2.Code_Description,'Unknown'), 
		EffFrom				= cte_ph.UpdateDate,                           
		EffTo               = cte_ph.EffToDate,                
		TypeDescription     = CT2.CT_Description,        
		CodeType            = CD2.Code_Code,               
		CodeDescription     = CD2.Code_Description,           
		UserTypeCode        = UP.UPS_UserType               
from	dbo.sa_insight_UserPosition UP
		inner join CTE_PanelHistory cte_ph on cte_ph.UPS_UserID = UP.UPS_UserID
		inner join (select UPS_UserID, UpdateDate, EffToDate, max(MaxUPS_UpdatedDate) as MaxUPS_UpdatedDate
					from CTE_PanelHistory
					group by UPS_UserID, UpdateDate, EffToDate) dedupe
						on  dedupe.UPS_UserID = cte_ph.UPS_UserID
						and dedupe.UpdateDate = cte_ph.UpdateDate
						and isnull(dedupe.EffToDate,'1900-01-01') = isnull(cte_ph.EffToDate,'1900-01-01')
						and dedupe.MaxUPS_UpdatedDate = cte_ph.MaxUPS_UpdatedDate
		inner join dbo.sa_insight_UserDetails UD on UD.USR_ID = UP.UPS_UserID
		inner join dbo.sa_insight_CodeType CT1 on CT1.CT_CODE = 11 --User Type    
		inner join dbo.sa_insight_CodeDescription CD1 on CD1.Code_CodeType = CT1.CT_CODE and CD1.Code_Code = UP.UPS_UserType and UPS_UserType = 3 --Adviser/Seller
		inner join dbo.sa_insight_CodeType CT2 on CT2.CT_CODE = 53   --Section     
		left join dbo.sa_insight_CodeDescription CD2 on CD2.Code_CodeType = CT2.CT_CODE and CD2.Code_Code = cte_ph.UPS_Section   
where	USR_ExternalId is not NULL
Group	By  USR_ExternalId,
			USR_ID,
			cte_ph.UPS_Section, 
			isnull(CD2.Code_Description,'Unknown'),
			cte_ph.UpdateDate, 
			cte_ph.EffToDate,     
			CT2.CT_Description,   
			CD2.Code_Code,   
			CD2.Code_Description,   
			UP.UPS_UserType     
Order	by	USR_ExternalId,
			UP.UPS_UserType,        
			cte_ph.UpdateDate         

return 

end




