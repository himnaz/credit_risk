CREATE FUNCTION [dbo].[cscf_ValidateBusinessStructure](@CompanyType VARCHAR(50), @CompanyVariant CHAR(2), @BusinessType VARCHAR(1))
RETURNS @retTable TABLE 
(BusAgt_CODE VARCHAR(7)
,BusAgt_DESCN VARCHAR(255)
,Agt_AgentCategoryDescription VARCHAR(50)
,Agt_AgentTypeDescription VARCHAR(50)
,Agt_CODE VARCHAR(7)
,Agt_DESCN VARCHAR(255)
)
AS  
BEGIN 
   --@CompanyVariant Values : 
   --1A - Signifies variant for AgentType = Principal (LTD/PARTSHIP/LLP/SOLE/PRACTICE , No Active/Insufficient Active/More than 1 Active)
   --2A - Signifies variant for AgentType = Non-Principal/Principal (Sole Trader/Practice/Business ,InvalidAgent/No Active Princi with Seller/No Active Seller)
   --@BusinessType
   --N = No Filter (2,46)
   --F = Franchise (2)
   --A = Access Agent (46)
   INSERT @retTable
   SELECT 
        BusAgt.CODE AS 'BusAgt_CODE'
      , BusAgt.DESCN AS 'BusAgt_DESCN'
      , Agt.AgentCategoryDescription AS 'Agt_AgentCategoryDescription'
      , Agt.AgentTypeDescription AS 'Agt_AgentTypeDescription' 
      , Agt.CODE AS 'Agt_CODE'
      , Agt.DESCN AS 'Agt_DESCN'
   FROM mstt_Agents Agt --excludes the actual company
   INNER JOIN mstt_Agents BusAgt ON COALESCE(Agt.OfficeCode,Agt.AccessAgentCode) = BusAgt.Code
                                 AND ((@CompanyType = 'PracticeOrSoleTrader' AND RTRIM(BusAgt.AgentCategoryDescription) IN ('Practice','Sole Trader') ) OR
                                      (@CompanyType = 'Business' AND RTRIM(BusAgt.AgentCategoryDescription) IN 
                                                      ('Practice','Sole Trader','Limited Liability Partnership','Partnership','Limited Company') ) OR
                                      (RTRIM(BusAgt.AgentCategoryDescription) = @CompanyType)
                                     )
                                 AND (BusAgt.AgentType <> 49) -- exclude directly authorised businesses
                                 AND ((@BusinessType = 'N' AND BusAgt.AgentType IN (2,46)) OR --Business Type parameter
                                      (@BusinessType = 'F' AND BusAgt.AgentType = 2) OR
                                      (@BusinessType = 'A' AND BusAgt.AgentType = 46)
                                     )
   LEFT JOIN mstt_Agents Agt_1 ON COALESCE(Agt_1.OfficeCode,Agt_1.AccessAgentCode) = BusAgt.Code
                               AND ((@CompanyType = 'Sole Trader' AND @CompanyVariant = '2A' AND 
                                                 (((Agt_1.AgentType <> 43 AND Agt_1.AgentType <> 51) OR Agt_1.GivesAdvice <> 'Y') AND Agt_1.AgentType <> 5 AND Agt_1.AgentType <> 3 ) ) OR --Invalid Agents found
                                    (@CompanyType = 'Practice' AND @CompanyVariant = '2A' AND (Agt_1.AgentType = 43 OR Agt_1.AgentType = 51)) OR -- No Active Principal
                                    (@CompanyType = 'Business' AND @CompanyVariant = '2A' AND Agt_1.GivesAdvice = 'Y' ) OR -- Selling Agents
                                    (@CompanyVariant <> '2A' AND (Agt_1.AgentType = 43 OR Agt_1.AgentType = 51) ) --Principal/PFAPrincipal (For All Other Cases)
                                   )  
                               AND Agt_1.CompetentStatus = 1
   LEFT JOIN mstt_Agents Agt_2 ON COALESCE(Agt_2.OfficeCode,Agt_2.AccessAgentCode) = BusAgt.Code --For checking No principal but Active Sellers
                               AND (@CompanyType = 'Practice' AND @CompanyVariant = '2A' AND Agt_2.GivesAdvice = 'Y') -- Selling Agents
                               AND Agt_2.CompetentStatus = 1
   WHERE Agt.CompetentStatus =1 --Active Agents
   GROUP BY BusAgt.CODE, BusAgt.DESCN, Agt.CODE, Agt.DESCN, Agt.AgentCategoryDescription, Agt.AgentTypeDescription
   HAVING ((@CompanyType = 'Limited Company' AND @CompanyVariant = '1A' AND COUNT(Agt_1.CODE) < 1 ) OR --No Principal found
           (@CompanyType = 'Partnership' AND @CompanyVariant = '1A' AND COUNT(Agt_1.CODE) < 2 ) OR --Atleast 2 Principals not found
           (@CompanyType = 'Limited Liability Partnership' AND @CompanyVariant = '1A' AND COUNT(Agt_1.CODE) < 2 ) OR --Atleast 2 Principals not found
           (@CompanyType = 'PracticeOrSoleTrader' AND @CompanyVariant = '1A' AND COUNT(Agt_1.CODE) > 1 ) OR --More than 1 Principal found
           (@CompanyType = 'Sole Trader' AND @CompanyVariant = '2A' AND COUNT(Agt_1.CODE) > 0 ) OR --Invalid Agents found
           (@CompanyType = 'Practice' AND @CompanyVariant = '2A' AND (COUNT(Agt_1.CODE) < 1 AND COUNT(Agt_2.CODE) > 0) ) OR --No Principal but Active Sellers found
           (@CompanyType = 'Business' AND @CompanyVariant = '2A' AND COUNT(Agt_1.CODE) < 1 ) --No Active Seller found
          ) 
   ORDER BY BusAgt.CODE, Agt.CODE
   RETURN
END

