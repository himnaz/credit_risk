/****************************************************************************
   Program: f_Insight_GetADsOfAllUsers                      
    Author: G Kulawiak
Date created: 17/08/2010                                             
     
 Description: The purpose of this function is - using Insight data only -
        to build a table of user codes along with their Area
        Director codes. 

        You can use this function like a derived table and can join 
        to it.  The date parameter is used to determine which Area 
        Director the user was linked to on that date.  This can be 
        significant as personnel move between Area Directors.  If 
        you want to know the Area Director for each user as of now 
        then this function can be called with either NULL or getdate().  

        A function calling example is given below:

        left join f_Insight_GetADsOfAllUsers(null) ADList 
              on ADList.UserCode = ups.ups_externalid                                                                      
                                                       
       Amendment History                                                    
       -----------------                                                    
                                                                           
       Date          Who                  Description                       
       ----          ---                  -----------   
 
****************************************************************************/

create function [dbo].[f_Insight_GetADsOfAllUsers](@Date as datetime)
       returns @Out table (UserCode nvarchar(50),
                           UserGUID uniqueidentifier,
                           RoleCode nvarchar(50),
                           RoleGUID uniqueidentifier,
                           ADUserCode varchar(50),
                           ADUserGUID uniqueidentifier,
                           ADRoleCode nvarchar(50),
                           ADRoleGUID uniqueidentifier)
as                           
begin
  declare @NodeLevel int
  declare @ChildNodes table (ParentID uniqueidentifier,
                             ChildID uniqueidentifier,
                             NodeLevel tinyint)
  
  select @Date = isnull(@Date, getdate()),
         @NodeLevel = 1

  insert into @ChildNodes
  select HNL_ParentID,
         HNL_NodeID,
         @NodeLevel
  from  sa_insight_HierarchyNodeLink HNL
        inner join sa_insight_UserPosition AD on AD.UPS_ID = HNL.HNL_ParentID and
                                                 AD.UPS_JobTitle = 14 and
                                                 @Date between HNL.HNL_DateFrom and isnull(HNL.HNL_DateTo, '99991231')

  while @@rowcount > 0
    begin
      set @NodeLevel = @NodeLevel + 1

      insert into @ChildNodes
      select CN.ParentID,
             HNL.HNL_NodeID,
             @NodeLevel
      from @ChildNodes CN
           inner join sa_insight_HierarchyNodeLink HNL on HNL.HNL_ParentID = CN.ChildID and
                                                          HNL.HNL_Type = 0 and
                                                          CN.NodeLevel = @NodeLevel - 1 and
                                                          @Date between HNL.HNL_DateFrom and isnull(HNL.HNL_DateTo,'99991231')
           left join @ChildNodes CNCR on CNCR.ChildID = HNL.HNL_NodeID and
                                         CNCR.NodeLevel < @NodeLevel - 1
      where CNCR.ParentID is null
    end
    
  insert into @Out
  select distinct U.USR_ExternalID,
                  U.USR_ID,
                  P.UPS_ExternalID,
                  P.UPS_ID,
                  ADU.USR_ExternalID,
                  ADU.USR_ID,
                  ADP.UPS_ExternalID,
                  ADP.UPS_ID
  from @ChildNodes CN
       inner join sa_insight_HierarchyNodeLink HNL on HNL.HNL_NodeID = CN.ChildID and
                                                      HNL.HNL_Type = 5 and
                                                      @Date between HNL.HNL_DateFrom and isnull(HNL.HNL_DateTo,'99991231')
       inner join sa_insight_UserPosition P on P.UPS_ID = HNL.HNL_ParentID
       inner join sa_insight_UserDetails U on U.USR_ID = P.UPS_UserID
       inner join sa_insight_UserPosition ADP on ADP.UPS_ID = CN.ParentID
       inner join sa_insight_UserDetails ADU on ADU.USR_ID = ADP.UPS_UserID
  return
end




