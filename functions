/************************************************************************************************
Program:  	    f_Insight_GetSingleSellerSupervisionHierarchy 
				(based on f_Insight_GetAdviserSupervisionHierarchy &
							f_Insight_GetSellerSupervisionHierarchy)

Author:	        Alan Groves / Mike Cawood
Date created:	27/04/2011
											
Description:   

This function returns the current Supervision Hierarchy from Insight for the Seller 
passed in as a parameter.
 
This is based on logic supplied by John Homer. For the seller, the current Supervisor 
(if present), BQM (if present), AQM (if present) and AD is retrieved with UID's and Names. 

The instance of each type of Seller is selected according to the "As At Date" passed in
as a parameter and their Job Title. A variety of hierarchy structures are employed so 
some levels may be missing for some sellers. For example, some sellers are supervised 
directly by a BQM in which case the Supervisor UID is not populated.

This table function is designed to only ever return one row for one seller using their
selling User Position if they have multiple User Positions.

This function should be used using CROSS APPLY as it is anticipated that it will be 
called with a different "As At Date" for each Seller. See below for example that is
syntactically correct but doesn't make sense to do!

select ag.code, hier.AdviserName
from	mstt_agents ag
		cross apply f_Insight_GetSingleSellerSupervisionHierarchy(NULL,ag.code,ag.DateStarted) hier
where	ag.AgentType = 4 -- Seller
and		ag.competentstatus = 1

Amendment History								
-----------------								
											
Date		Who			Description				
----		---			-----------			
16/05/2011	A Groves	1) A supervisor can be either job title code 8 (as before) or user
							type 27. Note that where the job title and user type are the 
							same person, this means that in reality the seller doesn't
							have a supervisor (as such) but reports directly to a BQM (who
							fulfils the supervisor role).
************************************************************************************************/

CREATE function [dbo].[f_Insight_GetSingleSellerSupervisionHierarchy] 
	(@AdviserGUID uniqueidentifier, 
	 @AdviserUID varchar(20), 
	 @AsAtDate datetime)

returns @Agents table( [AdviserUID]						nvarchar(20)		-- AG 14/04/2011 9 character test data encountered.
					  ,[AdviserGUID]					uniqueidentifier
                      ,[AdviserName]					nvarchar(255)
					  ,[UserTypeCode]					int
                      ,[UserType]						nvarchar(100)
					  ,[JobTitleCode]					int
					  ,[JobTitle]						nvarchar(50)
                      ,[Seller]							nvarchar(3)
					  ,[AdviserEmploymentStatusCode]	int
                      ,[AdviserEmploymentStatus]		nvarchar(50)  
                      ,[ContractStatus]					nvarchar(50) 
                      ,[SupervisorUID]					nvarchar(7)
                      ,[SupervisorName]					nvarchar(255)
                      ,[BQMUID]							nvarchar(7)
                      ,[BQMName]						nvarchar(255)
                      ,[AQMUID]							nvarchar(7)
                      ,[AQMName]						nvarchar(255)
                      ,[ADUID]							nvarchar(7)
                      ,[ADName]							nvarchar(255)
                      )
as

begin

set @AsAtDate = dateadd(dd,0,datediff(dd,0,@AsAtDate))

insert into @Agents

SELECT	top 1	-- We must only return 1 row to ensure the CROSS APPLY does not increase the row count
		ud.USR_ExternalID AS [AdviserUID],
		ud.USR_ID as [AdviserGUID],		-- AG 14/04/2011
		ud.USR_Name AS [AdviserName],
		ud.USR_Type as [UserTypeCode],	-- AG 27/04/2011
		cd6.Code_Description AS [UserType],
		up5.UPS_JobTitle as [JobTitleCode],	
		cd0.Code_Description as [JobTitle],	-- AG 27/04/2011
		CASE WHEN up5.ups_id IS NULL THEN 'No' ELSE 'Yes' END AS [Seller],
		s.STAF_EmploymentStatus as [AdviserEmploymentStatusCode],	-- AG 27/04/2011
		cd5.Code_Description AS [AdviserEmploymentStatus], 
		cd7.Code_Description AS [ContractStatus], 
		CASE WHEN up1.UPS_JobTitle = 8 or up1.UPS_UserType = 27 THEN ud1.USR_ExternalID END AS [SupervisorUID],
		CASE WHEN up1.UPS_JobTitle = 8 or up1.UPS_UserType = 27 THEN ud1.USR_Name END AS [SupervisorName], 
		COALESCE (CASE WHEN up1.UPS_JobTitle = 7 THEN ud1.USR_ExternalID ELSE NULL END, 
				  CASE WHEN up2.UPS_JobTitle = 7 THEN ud2.USR_ExternalID ELSE NULL END,
					  CASE WHEN up3.UPS_JobTitle = 7 THEN ud3.USR_ExternalID ELSE NULL END) AS [BQMUID], 
		COALESCE (CASE WHEN up1.UPS_JobTitle = 7 THEN ud1.USR_Name ELSE NULL END, 
				  CASE WHEN up2.UPS_JobTitle = 7 THEN ud2.USR_Name ELSE NULL END,
					  CASE WHEN up3.UPS_JobTitle = 7 THEN ud3.USR_Name ELSE NULL END) AS [BQMName], 
		COALESCE (CASE WHEN up1.UPS_JobTitle = 9 THEN ud1.USR_ExternalID ELSE NULL END, 
					  CASE WHEN up2.UPS_JobTitle = 9 THEN ud2.USR_ExternalID ELSE NULL END, 
					  CASE WHEN up3.UPS_JobTitle = 9 THEN ud3.USR_ExternalID ELSE NULL END,
					  CASE WHEN up4.UPS_JobTitle = 9 THEN ud4.USR_ExternalID ELSE NULL END) AS [AQMUID], 
		COALESCE (CASE WHEN up1.UPS_JobTitle = 9 THEN ud1.USR_Name ELSE NULL END, 
					  CASE WHEN up2.UPS_JobTitle = 9 THEN ud2.USR_Name ELSE NULL END,
					  CASE WHEN up3.UPS_JobTitle = 9 THEN ud3.USR_Name ELSE NULL END,
					  CASE WHEN up4.UPS_JobTitle = 9 THEN ud4.USR_Name ELSE NULL END) AS [AQMName], 
		COALESCE (CASE WHEN up1.UPS_JobTitle = 14 THEN ud1.USR_ExternalID ELSE NULL END, 
					  CASE WHEN up2.UPS_JobTitle = 14 THEN ud2.USR_ExternalID ELSE NULL END,
					  CASE WHEN up3.UPS_JobTitle = 14 THEN ud3.USR_ExternalID ELSE NULL END, 
					  CASE WHEN up4.UPS_JobTitle = 14 THEN ud4.USR_ExternalID ELSE NULL END, 
					  CASE WHEN up6.UPS_JobTitle = 14 THEN ud6.USR_ExternalID ELSE NULL END) AS [ADUID], 
		COALESCE (CASE WHEN up1.UPS_JobTitle = 14 THEN ud1.USR_Name ELSE NULL END,
					  CASE WHEN up2.UPS_JobTitle = 14 THEN ud2.USR_Name ELSE NULL END,
					  CASE WHEN up3.UPS_JobTitle = 14 THEN ud3.USR_Name ELSE NULL END, 
					  CASE WHEN up4.UPS_JobTitle = 14 THEN ud4.USR_Name ELSE NULL END,
					  CASE WHEN up6.UPS_JobTitle = 14 THEN ud6.USR_Name ELSE NULL END) AS [ADName]
FROM	dbo.sa_insight_UserDetails as UD
		LEFT JOIN dbo.sa_insight_Staff as S 
					ON  S.STAF_UserID = UD.USR_ID 
					and @AsAtDate between S.STAF_DateFrom and isnull(S.STAF_DateTo,'9999-12-31') 
		LEFT JOIN dbo.sa_insight_UserPosition as UP 
					ON  UP.UPS_UserID = UD.USR_ID
					and UP.UPS_JobTitle in (3,4,42)	-- This restriction on JT MUST be here AND in where clause to work correctly 
					and @AsAtDate between UP.UPS_DateFrom and isnull(UP.UPS_DateTo,'9999-12-31')
		LEFT JOIN dbo.sa_insight_UserPositionLink as UPL 
					ON  UPL.UPSL_ChildUserPositionID = up.UPS_ID
					and @AsAtDate between UPL.UPSL_DateFrom and isnull(UPL.UPSL_DateTo,'9999-12-31')
		LEFT JOIN dbo.sa_insight_UserPosition AS UP1 
					ON  UP1.UPS_ID = UPL.UPSL_ParentUserPositionID
					and @AsAtDate between UP1.UPS_DateFrom and isnull(UP1.UPS_DateTo,'9999-12-31')
		LEFT JOIN dbo.sa_insight_UserDetails AS UD1 ON  UD1.USR_ID = UP1.UPS_UserID  
		LEFT JOIN dbo.sa_insight_UserPositionLink AS UPL1 
					ON  UPL1.UPSL_ChildUserPositionID = UP1.UPS_ID
					and @AsAtDate between UPL1.UPSL_DateFrom and isnull(UPL1.UPSL_DateTo,'9999-12-31')
		LEFT JOIN dbo.sa_insight_UserPosition AS UP2 
					ON  UP2.UPS_ID = UPl1.UPSL_ParentUserPositionID
					and @AsAtDate between UP2.UPS_DateFrom and isnull(UP2.UPS_DateTo,'9999-12-31')
		LEFT JOIN dbo.sa_insight_UserDetails AS ud2 ON up2.UPS_UserID = ud2.USR_ID 
		LEFT JOIN dbo.sa_insight_UserPositionLink AS UPL2 
					ON  UPL2.UPSL_ChildUserPositionID = up2.UPS_ID
					and @AsAtDate between UPL2.UPSL_DateFrom and isnull(UPL2.UPSL_DateTo,'9999-12-31')
		LEFT JOIN dbo.sa_insight_UserPosition AS UP3 
					ON  UP3.UPS_ID = UPL2.UPSL_ParentUserPositionID
					and @AsAtDate between UP3.UPS_DateFrom and isnull(UP3.UPS_DateTo,'9999-12-31')
		LEFT JOIN dbo.sa_insight_UserDetails AS UD3 ON UP3.UPS_UserID = UD3.USR_ID 
		LEFT JOIN dbo.sa_insight_UserPositionLink AS UPL3 
					ON  UPL3.UPSL_ChildUserPositionID = UP3.UPS_ID
					and @AsAtDate between UPL3.UPSL_DateFrom and isnull(UPL3.UPSL_DateTo,'9999-12-31')
		LEFT JOIN dbo.sa_insight_UserPosition AS UP4 
					ON  UP4.UPS_ID = UPl3.UPSL_ParentUserPositionID
					and @AsAtDate between UP4.UPS_DateFrom and isnull(UP4.UPS_DateTo,'9999-12-31')
		LEFT JOIN dbo.sa_insight_UserDetails AS ud4 ON UP4.UPS_UserID = UD4.USR_ID
		LEFT JOIN dbo.sa_insight_UserPositionLink AS UPL4 
					ON  UPL4.UPSL_ChildUserPositionID = UP4.UPS_ID
					and @AsAtDate between UPL4.UPSL_DateFrom and isnull(UPL4.UPSL_DateTo,'9999-12-31')
		LEFT JOIN dbo.sa_insight_UserPosition AS UP6 
					ON  UP6.UPS_ID = UPL4.UPSL_ParentUserPositionID 	-- AG 14/03/2011 Make up6 a left join to select those people without this level of nesting
					and @AsAtDate between UP6.UPS_DateFrom and isnull(UP6.UPS_DateTo,'9999-12-31')
		LEFT JOIN dbo.sa_insight_UserPosition AS UP5 
					ON  UP5.UPS_UserID = UD.USR_ID  
					AND @AsAtDate BETWEEN UP5.UPS_DateFrom AND ISNULL(UP5.UPS_DateTo,'9999-12-31') -- AND up5.UPS_JobTitle IN (4, 42) AG 14/04/2011  
		LEFT JOIN dbo.sa_insight_UserDetails AS UD6 ON UP6.UPS_UserID = UD6.USR_ID 
		LEFT JOIN dbo.sa_insight_CodeDescription AS cd0 ON  up.UPS_JobTitle = cd0.Code_Code AND cd0.Code_CodeType = 54
		LEFT JOIN dbo.sa_insight_CodeDescription AS cd1 ON up1.UPS_JobTitle = cd1.Code_Code AND cd1.Code_CodeType = 54 
		LEFT JOIN dbo.sa_insight_CodeDescription AS cd2 ON up2.UPS_JobTitle = cd2.Code_Code AND cd2.Code_CodeType = 54 
		LEFT JOIN dbo.sa_insight_CodeDescription AS cd3 ON up3.UPS_JobTitle = cd3.Code_Code AND cd3.Code_CodeType = 54 
		LEFT JOIN dbo.sa_insight_CodeDescription AS cd4 ON up4.UPS_JobTitle = cd4.Code_Code AND cd4.Code_CodeType = 54 
		LEFT JOIN dbo.sa_insight_CodeDescription AS cd5 ON s.STAF_EmploymentStatus = cd5.Code_Code AND cd5.Code_CodeType = 125 
		LEFT JOIN dbo.sa_insight_CodeDescription AS cd6 ON ud.USR_Type = cd6.Code_Code AND cd6.Code_CodeType = 11 
		LEFT JOIN dbo.sa_insight_CodeDescription AS cd7 ON s.STAF_ContractStatus = cd7.Code_Code AND cd7.Code_CodeType = 527 
		LEFT JOIN dbo.sa_insight_CodeDescription AS cd8 ON up6.UPS_JobTitle = cd8.Code_Code AND cd8.Code_CodeType = 54
WHERE	up.UPS_JobTitle NOT IN (28, 29, 30) --Admin 1/2/3
AND		s.STAF_ContractStatus <> 3			--Pre-Contract
AND		up.UPS_UserType NOT IN (5, 10)		--SQST Assessor/Manager
--and	cd6.Code_Code in (3,6,20,27,32,201)	-- All possible sellers: Adviser/Seller; BDD/BDM; AQM; Supervisor; DA Introducer; Principal Partner	AG 04/05/2011
and		up5.UPS_JobTitle in (3,4,42)		-- Non-Advising Seller; Financial Adviser; Schedule E Seller
and		not (cd6.Code_Code = 6				-- AG 27/04/2011 User Type BDD /BDM 
and		COALESCE (	CASE WHEN up1.UPS_JobTitle = 7 THEN ud1.USR_ExternalID ELSE NULL END, 
					CASE WHEN up2.UPS_JobTitle = 7 THEN ud2.USR_ExternalID ELSE NULL END,
					CASE WHEN up3.UPS_JobTitle = 7 THEN ud3.USR_ExternalID ELSE NULL END ) is null)	-- AG 27/04/2011 BQM is null which is valid as a BQM cannot BQM themselves
and		ud.USR_ExternalID = case when @AdviserUID is null then ud.USR_ExternalID else @AdviserUID end
and		ud.USR_ID = case when @AdviserGUID is null then ud.USR_ID else @AdviserGUID end
--order by ud.USR_ExternalID

return

end

