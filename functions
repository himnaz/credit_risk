/***********************************************************************************

Program:	owf_JobStillRunning	

Author:		A Groves

Date:		07/04/2017

Purpose:	This function was developed to check if the job whose name is passed
			in as a parameter is running at the current time. It can be used where
			sp_start_job is used because sp_start_job will error if the job is 
			already running and it doesn't seem to be possible to reset the error
			status in a TRY-CATCH block.

			Use the function as follows:
			
			if dbo.owf_JobStillRunning(@JobMName) = 0
				exec msdb.dbo.sp_start_job @JobName			
			
AMENDMENT HISTORY
=================

Date		Author		Description
----		------		-----------

************************************************************************************/

CREATE function [dbo].[owf_JobStillRunning] (@JobName varchar(300))

returns bit

as

begin

declare @StillRunning bit

if exists 
( 
	SELECT	sj.name,
			DATEDIFF(SECOND,aj.start_execution_date,GetDate()) AS Seconds 
	FROM	msdb..sysjobactivity aj 
			JOIN msdb..sysjobs sj on sj.job_id = aj.job_id 
	WHERE	aj.stop_execution_date IS NULL		-- job hasn't stopped running 
	AND		aj.start_execution_date IS NOT NULL -- job is currently running 
	and		aj.run_Requested_date IS NOT NULL 
	AND		sj.name = @JobName 
	and not exists(select 1 from msdb..sysjobactivity new 
					where new.job_id = aj.job_id 
					and new.start_execution_date > aj.start_execution_date) 
) 
	set @StillRunning = 1
else
	set @StillRunning = 0	

return @StillRunning

end

