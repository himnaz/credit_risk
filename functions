CREATE FUNCTION [dbo].[cscf_AgentHasLicence](@AgentID int, @AtDate DATETIME, @LicenceCode VARCHAR(32))
RETURNS CHAR(1) AS  
BEGIN 
   DECLARE @Result CHAR(1)
   DECLARE @RowCount INT 

   SELECT @RowCount = (SELECT COUNT(AgentLicence.LicenceCode)
                       FROM mstt_AgentLicence AS AgentLicence
                       WHERE AgentLicence.AgentID = @AgentID
                         AND AgentLicence.LicenceCode = @LicenceCode
                         AND AgentLicence.StartDate IS NOT NULL AND CAST(CONVERT(NVARCHAR,AgentLicence.StartDate,112) AS DATETIME) <= CAST(CONVERT(NVARCHAR,@AtDate,112) AS DATETIME)
                         AND (AgentLicence.EndDate IS NULL OR CAST(CONVERT(NVARCHAR,AgentLicence.EndDate,112) AS DATETIME) > CAST(CONVERT(NVARCHAR,@AtDate,112) AS DATETIME))
                      )

   IF @RowCount = 0
      SET @Result = 'N'
   ELSE
      SET @Result = 'Y'

   RETURN @Result
END

