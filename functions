CREATE FUNCTION [dbo].[udfPbrCalcEndDate]
(
	@StartDate DATETIME,
	@NumBusinessDays INT
)
RETURNS DATETIME
AS
BEGIN
	DECLARE @endDate DATETIME

	DECLARE @addDays INT
	

	DECLARE @numFullWeeks INT
	SET @numFullWeeks = CAST ((@NumBusinessDays / 5) AS INT)

	SET @addDays = @numFullWeeks * 7
		
	DECLARE @numDaysMod INT
	SET @numDaysMod = @NumBusinessDays % 5

	SET @addDays = @addDays + @numDaysMod
	
	IF (DATENAME(DW, @StartDate) = 'Tuesday' AND @numDaysMod = 4) OR
	   (DATENAME(DW, @StartDate) = 'Wednesday' AND @numDaysMod > 2) OR
	   (DATENAME(DW, @StartDate) = 'Thursday' AND @numDaysMod > 1) OR
	   (DATENAME(DW, @StartDate) = 'Friday' AND @numDaysMod > 0) OR
	   (DATENAME(DW, @StartDate) = 'Saturday')
	    
		SET @addDays = @addDays + 2

	ELSE
		IF DATENAME(DW, @StartDate) = 'Sunday' 
			SET @addDays = @addDays + 1


	SET @endDate = DATEADD (DD, @addDays, @StartDate)

	DECLARE @numBankHolidays INT
	
	SELECT @numBankHolidays = COUNT(1) 
	FROM [dbo].[PBR_BankHolidays]
	WHERE BankHolidayDate BETWEEN @StartDate AND @endDate
	 
	SET @endDate = DATEADD (DD, @numBankHolidays, @endDate)

	RETURN @endDate

END
