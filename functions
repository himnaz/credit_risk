CREATE FUNCTION [dbo].[owf_HashForwardUID]
(	
	@AgentUID varchar(7)
)
returns varchar(6)
as
begin

declare @ID int,
		@Hash varchar(6)

select @ID = ID
from mstt_Agents
where Code = @AgentUID

set @Hash = right('000000' + convert(varchar(6), 420000 - @ID),6)

return @Hash

