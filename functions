CREATE FUNCTION [dbo].[owf_AddressPremise](@AddressLine varchar(255))
RETURNS varchar(4000)
AS
begin
	declare @Premise varchar(255)
 
	if patindex('% %',@AddressLine) < LEN(@AddressLine) and patindex('% %',@AddressLine) > 1
