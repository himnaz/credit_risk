/************************************************************************************************
Program:  	    f_Insight_OwlProductTypeToLicenceCode	
				(based on f_Insight_ProductTypeToLicenceCode By Alan Groves on 11/04/2011)			
Author:	        Alan Groves
Date created:	29/06/2015
											
Description:   

This function returns the config data that determines for each Insight Product Type
(initially only one (57) for Owl) what licences need to be checked for the sale.  
It combines the config of three types to give the final output.  The three types are 
given by the following three "Process" groups:
1) 'OwlInsightProductTypeToRegulationGroup'
2) 'OwlInsightRegulationGroupToLicenceCode'
3) 'OwlInsightLicenceCheckTypeToRegulationGroup'

The parameter (@LicenceConfigAsOfDate) is used to pull in the Config that was relevant to the
particular date of interest.  This is likely to be getdate() unless reporting in an historic 
context. 

The "CheckType" that is returned will be either "M" for mandatory or "G" for Group.  Every "M" 
licence for that ProductType must be valid for a sale but only one of each "G" licence must be 
valid for a sale.

Execute using the following command (or use as JOIN in query):
  select * from [dbo].[f_Insight_OwlProductTypeToLicenceCode] ()
									
	Amendment History								
	-----------------								
											
	Date		Who			Description
	----		---			-----------			
************************************************************************************************/

CREATE function [logi].[f_Insight_OwlProductTypeToLicenceCode] (@LicenceConfigAsOfDate datetime)
returns @ProdTypeLicences table( [InsightProductTypeCode]   varchar(100)
								,[RegulationGroupCode]      varchar(100)
								,[LicenceCode]              varchar(100)
								,[CheckType]                varchar(100)
								,[EffectiveStartDate]		datetime
								,[EffectiveEndDate]			datetime
								)
as

begin

set @LicenceConfigAsOfDate = dateadd(dd,0,datediff(dd,0,@LicenceConfigAsOfDate))

insert into @ProdTypeLicences
select	ProdTypeToRegGroup.KeyType as InsightProductTypeCode,
		RegGroupToLic.KeyType as RegulationGroupCode,
		RegGroupToLic.KeyValue as LicenceCode, 
		LicChkTypToRegGroup.KeyType as CheckType,
		RegGroupToLic.EffectiveStartDate,
		RegGroupToLic.EffectiveEndDate
from	owt_SelectionControl ProdTypeToRegGroup
		inner join owt_SelectionControl RegGroupToLic 
					on  RegGroupToLic.KeyType = ProdTypeToRegGroup.KeyValue
					and @LicenceConfigAsOfDate between RegGroupToLic.EffectiveStartDate and RegGroupToLic.EffectiveEndDate
		inner join owt_SelectionControl LicChkTypToRegGroup 
					on  LicChkTypToRegGroup.KeyValue = ProdTypeToRegGroup.KeyValue
					and @LicenceConfigAsOfDate between LicChkTypToRegGroup.EffectiveStartDate and LicChkTypToRegGroup.EffectiveEndDate
where	ProdTypeToRegGroup.Process = 'OwlInsightProductTypeToRegulationGroup'
and		RegGroupToLic.Process = 'OwlInsightRegulationGroupToLicenceCode'
and		LicChkTypToRegGroup.Process = 'OwlInsightLicenceCheckTypeToRegulationGroup'
and		@LicenceConfigAsOfDate between ProdTypeToRegGroup.EffectiveStartDate and ProdTypeToRegGroup.EffectiveEndDate
order	by	ProdTypeToRegGroup.KeyType,
			RegGroupToLic.KeyType,
			RegGroupToLic.KeyValue,
			LicChkTypToRegGroup.KeyType

return

end


