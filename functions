/****************************************************************************

Program:  		owf_DateIsNAbsoluteDaysFromNextMonthlyPayRun
				(based on owf_DateIsNWorkingDaysFromNextMonthlyPayRun By A Groves 08/10/2013)
Author:			Alan Groves
Date created:	17/09/2015							
											
Description:   

This function takes the supplied number of days and a baseline date (@PayRunAfterThisDate). 
The function finds the next monthly pay day on or after the @PayRunAfterThisDate. In 
typical use, the @PayRunAfterThisDate would be getdate(). 

If the number of days is positive, then the function adds those 
days to the next monthly pay date or, if the number of days is negative then the function 
subtracts those days from the next monthly pay date. 

The @RunDate is a parameter to enable you to simulate future processing dates - but in 
practice, this date is likely to always be the current date i.e. getdate().

This function is called as follows:

	Note that these parameter values will determine if the current date is the day after
	the monthly pay run:

	declare @RunDate				datetime,
			@PayRunAfterThisDate	datetime
	set @RunDate				= getdate()
	set @PayRunAfterThisDate	= getdate()-1
	Select dbo.owf_DateIsNAbsoluteDaysFromNextMonthlyPayRun(@RunDate,@PayRunAfterThisDate,1)
									
Amendment History								
-----------------								
											
Date		Who			Description				
----		---			-----------			

****************************************************************************/

CREATE FUNCTION [dbo].[owf_DateIsNAbsoluteDaysFromNextMonthlyPayRun]
						(@RunDate datetime, @PayRunAfterThisDate datetime, @Days int)
returns varchar(1)
as 

begin

	declare @N									int,
			@Increment							int,
			@Date								datetime,
			@NoOfDaysBeforeMonthlyPayRunMatch	varchar(1)

	set @N = 0
	
	if @Days > 0									
	begin
		set @Days = -@Days							
		set	@Increment = 1							-- Going forward in time
	end
	else
		set @Increment	= -1						-- Going back in time

	set @PayRunAfterThisDate	= dateadd(dd,0,datediff(dd,0,@PayRunAfterThisDate))
	set @RunDate				= dateadd(dd,0,datediff(dd,0,@RunDate))

	select @Date = min(PeriodEndDate)				-- Get next monthly pay date
	from msit_CommissionStatementPeriods
	where PeriodEndDate >= @PayRunAfterThisDate

	while (@Days < @N)								
	begin
		set @Date = dateadd(dd,@Increment,@Date)	-- Add or subtract a day

		set @N = @N-1 

		if @N = @Days								-- If reqd number of days applied then exit
			break
	end

	if @RunDate = @Date								-- The next Payrun matches the date + offset days
		set @NoOfDaysBeforeMonthlyPayRunMatch = 'Y'
	else
		set @NoOfDaysBeforeMonthlyPayRunMatch = 'N' 

	return @NoOfDaysBeforeMonthlyPayRunMatch 

end



