AS

--########################################################################
-- Copyright (c) MOORE STEPHENS, 2006 All rights reserved
--
-- Object  : Function
-- Name    : msf_SQGetAgentCode.sql
-- Desc    : Returns the AgentCode of the specified user
-- Owner   : BT
-- Created : 05/07/2006
--
-- Amended : 31/07/2006  - BT  - Return -1 if user does not exist or is not associated with an agent code 
--           31/08/2006  - MK  - Return AgentCode of Agent Delegated To, if required  
--       12/02/2007  - BT  - Override Associated Agent with -1 if User exists in HeadOfficeUsers table (ID 211)
--       14/02/2007  - RH/OW - Tuned for performance as part of Agent KPI report production issue
--         - Fixes to affected procs/fns include explicit conversion of datatypes in query
--           expressions where parameter type is not matched to table data type
--           allowing Index seeks rather than scans
--         - Addition of indexes to required Quality tables
--         - Explicit alternative logic paths for queries where global parameter (eg Filter) is not supplied
--           avoiding table/index scans forced by unnecessary OR statememnts
--
--########################################################################

  


BEGIN
  DECLARE @RetVal nvarchar(50)
  
  if isnull(@AllowDelegates, 'N') = 'Y'
    set @UserId = (select dbo.msf_SQGetUserDelegatedFrom(@UserId))

  --Remove the domain name prefix if it exists 
  DECLARE @StrippedUser varchar(20)
  set @StrippedUser = case when charindex('\', @UserId) = 0 then @UserId 
                else substring(@UserId, charindex('\', @UserId)+1, len(@UserId)) end
                
  --Get the AgentCode from the Users table
  SET @RetVal = (SELECT [AssociatedAgent] FROM [msit_intUsers] WHERE [Name] = @StrippedUser)
  
  --Set return value to -1 if user exists in Head Office Users table
  IF (SELECT COUNT(*) FROM [msct_HeadOfficeUsers] WHERE [DomainLogin] = @Userid) >= 1
    SET @RetVal = -1


  --Set return value to -1 if user does not exist or is not associated with an agent code
  IF @RetVal IS NULL OR @RetVal = '' SET @RetVal = -1
  
  RETURN @RetVal
END









