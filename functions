/****************************************************************************
  	 Program:  	owf_CleanTextForMatching	(based on owf_CleanText of 17/03/2009)						
	  Author:	A Groves
Date created:	15/05/2013					
											
 Description:   This function is used to remove non-alphanumeric text from a
				varchar field to aid matching. The principal of matching is
				that you can remove characters - but you can't add them in.

				If you want apostrophe's, etc. then use owf_CleanText

			It is called as follows:

			select dbo.owf_CleanTextForMatching(PaymentsPending.Notes)
									
	Amendment History								
	-----------------								
											
	Date		Who			Description				
	----		---			-----------			
27/06/2013		A Groves	Keep hyphens and remove spaces around them so
							that a hypenated surname can be picked out by
							function dbo.owf_LastWord.
13/07/2016		A Groves	Corrected:	Remove space between 'Mac' and the 
							rest of the name			
****************************************************************************/

CREATE FUNCTION [dbo].[owf_CleanTextForMatching](@FieldToClean varchar(4000))
RETURNS varchar(4000)
AS
begin

	-- Replace any character that's not a hyphen, an apostrophe, an alphanumeric or a space with a space
	while patindex('%[^-0-9A-Za-z'' ]%',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('%[^0-9A-Za-z ]%',@FieldToClean),1,' ')

	-- Reduce multiple spaces to 1 space
	while patindex('%  %',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('%  %',@FieldToClean),1,'')

	-- Remove spaces around a hyphen							AG 27/06/2013
	while patindex('% - %',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('% - %',@FieldToClean),1,'')

	-- Remove space following a hyphen							AG 27/06/2013
	while patindex('%- %',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('%- %',@FieldToClean)+1,1,'')

	-- Remove space before a hyphen								AG 27/06/2013
	while patindex('% -%',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('% -%',@FieldToClean),1,'')

	-- Remove spaces around an apostrophe						AG 27/06/2013
	while patindex('% '' %',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('% '' %',@FieldToClean),1,'')

	-- Remove space following an apostrophe						AG 27/06/2013
	while patindex('%'' %',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('%'' %',@FieldToClean)+1,1,'')

	-- Remove space before an apostrophe								AG 27/06/2013
	while patindex('% ''%',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('% ''%',@FieldToClean),1,'')

	-- Remove space between ' Mac' and the rest of the name		AG 15/05/2013
	while patindex('% Mac %',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('% Mac %',@FieldToClean)+4,1,'')

	-- Remove space between 'Mac' and the rest of the name		AG 15/05/2013
	while patindex('Mac %',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('Mac %',@FieldToClean)+3,1,'')	-- AG 13/07/2016

	-- Remove space between ' Mc' and the rest of the name		AG 15/05/2013
	while patindex('% Mc %',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('% Mc %',@FieldToClean)+3,1,'')

	-- Remove space between 'Mc' and the rest of the name		AG 15/05/2013
	while patindex('Mc %',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('Mc %',@FieldToClean)+2,1,'')

	-- Remove space between ' De' and the rest of the name		AG 15/05/2013
	while patindex('% De %',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('% De %',@FieldToClean)+3,1,'')

	-- Remove space between 'De' and the rest of the name		AG 15/05/2013
	while patindex('De %',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('De %',@FieldToClean)+2,1,'')

	-- Remove spaces between 'Van Der ' and the rest of the name AG 26/06/2013
	while patindex('% Van Der %',@FieldToClean) > 0
		select @FieldToClean = stuff(@FieldToClean,patindex('% Van Der %',@FieldToClean),9,' VanDer')

	-- Remove any leading or trailing spaces
	set @FieldToClean = ltrim(rtrim(@FieldToClean))

	return @FieldToClean
end



