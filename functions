/****************************************************************************
     Program:   owf_CleanText           
    Author: A Groves
Date created: 17/03/2009              
                      
 Description:   This function is used to remove non-alphanumeric text from a
        varchar field

      It is called as follows:

      select dbo.owf_CleanText(PaymentsPending.Notes)
                  
  Amendment History               
  -----------------               
                      
  Date    Who     Description       
  ----    ---     -----------     
  03/06/2009  A Groves  Add in reduction of multiple spaces to 1 space.
  04/06/2009  A Groves  Now multiple spaces are being reduced to 1, 
              replace non-alphanumerics with a space instead of ''.
  05/06/2009  A Groves  Remove any leading or trailing spaces.
  07/07/2009  A Groves  Swap + with &.
              Swap ` with '.
              Allow apostrophe and period.              
****************************************************************************/

CREATE FUNCTION [dbo].[owf_CleanText](@FieldToClean varchar(4000))
RETURNS varchar(4000)
AS
begin
  -- Replace + with &
  set @FieldToClean = replace(@FieldToClean,'+','&')

  -- Replace ` with '
  set @FieldToClean = replace(@FieldToClean,'`','''')

  -- Remove any character that's not alphanumeric, a hyphen, space, slashes, apostrophe, ampersand and period
  while patindex('%[^-0-9A-Za-z&''./\ ]%',@FieldToClean) > 0
    select @FieldToClean = stuff(@FieldToClean,patindex('%[^-0-9A-Za-z&''./\ ]%',@FieldToClean),1,' ')

  -- Reduce multiple spaces to 1 space
  while patindex('%  %',@FieldToClean) > 0
    select @FieldToClean = stuff(@FieldToClean,patindex('%  %',@FieldToClean),1,'')

  -- Remove any leading or trailing spaces
  set @FieldToClean = ltrim(rtrim(@FieldToClean))

  return @FieldToClean
end




