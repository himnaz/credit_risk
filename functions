CREATE FUNCTION [dbo].[cscf_GetAgentQualityPoints](@AgentCode VARCHAR(7), @AtDate DATETIME)  
RETURNS INT AS  
BEGIN 
   DECLARE @Points INT
   SELECT @Points = ISNULL(SUM(ISNULL(Enquiry.Points, 0)), 0) 
   FROM msit_S_ENQURY Enquiry
   LEFT JOIN mstt_Clients Clients ON Clients.CLIENT_NUM = Enquiry.CLIENT_NUM
   WHERE Clients.REFER = @AgentCode
     AND Enquiry.EnquiryType = 3 --Breach
     AND Enquiry.BreachType = 1 --Adviser
     AND (CAST(CONVERT(NVARCHAR, Enquiry.ExpiryDate, 112) AS DATETIME) IS NULL OR
         (CAST(CONVERT(NVARCHAR, @AtDate, 112) AS DATETIME) <= CAST(CONVERT(NVARCHAR, Enquiry.ExpiryDate, 112) AS DATETIME)))
   RETURN @Points 
