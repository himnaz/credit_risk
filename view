create view [dbo].[rpt_OrphanInsightCases]
as
select c.bpol_caseid CaseID,
       c.bpol_proposaldate ProposalDate,
       c.bpol_createddate CaseCreatedDate,
       c.case_casereference OpportunityRef,
       usr_name OppCreatedBy,
       c.case_createddate OppCreatedDate
from (select c.bpol_createddate,
             o.case_casereference,
             o.case_createdby,
             o.case_createddate,
             convert(int, bpol_backofficeid) bpol_CaseID,
             dbo.f_ifdateconvert(attl_attributevalue) bpol_ProposalDate,
             row_number() over (partition by convert(int, bpol_backofficeid), dbo.f_ifdateconvert(attl_attributevalue) order by bpol_createddate) RN
      from sa_insight_basicpolicy c with (nolock)
           inner join (select case_id,
                              case_createdby,
                              case_createddate,
                              rtrim(ltrim(isnull(case_casereference, '0'))) case_casereference,
                              row_number() over (partition by rtrim(ltrim(isnull(case_casereference, '0'))) order by case_createddate) RN
                       from sa_insight_salescase with (nolock)
                       where rtrim(ltrim(isnull(case_casereference, '0'))) != '0') o on case_id = bpol_parentid and
                                                                                        rn = 1 and
                                                                                        rtrim(ltrim(isnull(bpol_backofficeid, '0'))) != '0' and
                                                                                        isnumeric(bpol_backofficeid) = 1
           left join (sa_insight_attribute with (nolock)
                      inner join sa_insight_attributelink with (nolock) on attl_attributeid = att_id and
                                                                           att_name = 'PRODUCT.PROPOSALDATE') on attl_parentid = bpol_id) c
     inner join sa_insight_userdetails with (nolock) on usr_id = c.case_createdby and
                                                        c.rn = 1
     left join obpmi_arrangement a with (nolock) on a.caseid = c.bpol_caseid and
                                                    a.submissionstatus = 1          
     left join (select pt.proposaldate,
                       p.policyref
                from sa_swift_s_polmai p with (nolock)
                     left join sa_swift_s_polmai sp with (nolock) on sp.scheme_num = p.pol_num
                     inner join sa_swift_policytransactions pt with (nolock) on pt.policyid = isnull(sp.pol_num, p.pol_num) and
                                                                                pt.proposaldate is not null and
                                                                                pt.transtype != 117 and
                                                                                isnull(pt.adminmethod, '') !='X' and
                                                                                p.scheme_num is null) p on p.proposaldate = c.bpol_proposaldate and
                                                                                                           p.policyref = c.bpol_caseid
where a.arrangementid is null and p.policyref is null
--order by c.bpol_createddate,
--         c.case_casereference,
--         c.bpol_caseid
