/****** Object:  View [dbo].[obpmi_PlanProfilePerson]    Script Date: 03/09/2012 08:34:31 ******/
CREATE view [dbo].[obpmi_PlanProfilePerson] as
SELECT ppp.Id,
       ppp.PlanId,
       ppp.GenderId,
       ppp.IsClient PrimaryClient,
       mauc.ClientEntityId,
       ppp.Title,
       ppp.FirstName,
       ppp.MiddleName,
       ppp.LastName,
       CASE WHEN (ISDATE(ppp.DateOfBirth)) = 1 THEN convert(datetime, ppp.DateOfBirth) END DateOfBirth,
       ppp.ContactId,
       ppp.TaxBandId,
       ppp.MaritalStatusId,
       c.NINumber,
       c.StatusId,
       ppp.UnsecuredDebtCurrencyId,
       ppp.AmountOfUnsecuredDebt,
       ppp.RetirementCurrencyId,
       ppp.AmountOnRetirement,
       ppp.UsedISAAllowance,
       ppp.EmploymentId,
       ppp.HealthId,
       ppp.SmokerId,
       ppp.OrdinarilyResidentId,
       l.Id LoginId,
       l.UserTypeId LoginTypeId,
       con.HouseNumber AddressHouseNumber,
       con.AddressLine1 AS HouseNumber,
       con.AddressLine2 AS HouseName,
       con.AddressLine3 AS Street,
       con.AddressLine4 AS Town,
       con.AddressLine5,
       con.PostCode,
       con.Telephone,
       con.Mobile,
       con.Email,
       con.DaytimeTelephone,
       p.InvestmentRiskQuestionnaireId,
       p.RetirementRiskQuestionnaireId,
       convert(xml, ppp.CustomXml) CustomXml
FROM sa_obp_PlanProfilePerson ppp 
     INNER JOIN obpmi_plan p ON ppp.PlanId = p.Id
     INNER JOIN sa_obp_adviceunitclient auc ON auc.AdviceUnitEntityId = p.AdviceUnitEntityId and
                                               auc.SequenceNumber = 1
     INNER JOIN sa_obp_client c ON c.EntityId = auc.ClientEntityId
     INNER JOIN sa_obp_EntityContact ec ON ec.EntityId = c.EntityId
     INNER JOIN obpmi_contact con ON con.Id = ec.ContactId
     INNER JOIN sa_obp_Login l ON c.LoginId = l.Id
	 LEFT JOIN  sa_obp_PlanSnapshot PS on PS.PlanId = P.Id				--MPC: 08/03/2012
     left join (Select OpportunityId,
--                     planid,											--MPC: 08/03/2012
					   PlanSnapshotId,									--MPC: 08/03/2012
                     row_number() over (partition by opportunityid order by currentversion desc) rn
                From sa_obp_opportunityversion ov) ov --on ppp.PlanId = ov.PlanId			--MPC: 08/03/2012
													  on PS.Id = OV.PlanSnapshotId			--MPC: 08/03/2012
     LEFT OUTER JOIN sa_obp_opportunity o ON o.Id = ov.OpportunityId						--MPC: 08/03/2012
     LEFT OUTER JOIN sa_obp_adviceunitclient mauc ON o.AdviceUnitEntityId = mauc.AdviceUnitEntityId and
                                                     ((o.PrimaryClientEntityId = mauc.ClientEntityId and
                                                       IsClient = 1) OR 
                                                      (o.PrimaryClientEntityId != mauc.ClientEntityId and
                                                       IsClient = 0))
     LEFT OUTER JOIN sa_obp_client AS OpportunityClient ON OpportunityClient.EntityId = mauc.ClientEntityId
;
