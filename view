/****** Object:  View [dbo].[rpt_Replacements]    Script Date: 03/09/2012 09:15:24 ******/
/*****************************************************************************************************
View:  	rpt_Replacements						
			
Description:	This View supports the Replacement report.

Amendment History               
-----------------               
                      
Date		Who     Description       
----		---     -----------     
09/03/2012	MPC		Amendment to cater for Database Reorganisation to be deployed 5/4/12.
					PlanID replaced by PlanSnapshotId on sa_obp_OpportunityVersion table
					which links to PlanId on Opportunity or Arranagement/Quote tables 
					via PlanSkeleton table.

*****************************************************************************************************/
CREATE view [dbo].[rpt_Replacements] as
SELECT o.ClientFacingOpportunityId OpportunityRef,
       ov.VersionDate OpportunityCompletedDate,
       S.IntegrationAlias as AgentUID,
       S.FirstName + ' ' + S.LastName as AgentName,
       jt.code_description JobTitle,
       cs.code_description ContractStatus,
       f.firmcode as FirmUID,
       dist.dist_companyname as FirmName,
       bqm.qmusercode BQMUID,
       bqmusr.usr_name BQMName,
       ad.adusercode ADUID,
       adusr.usr_name ADName
from sa_obp_Opportunity o with (nolock)
     inner join sa_obp_OpportunityVersion ov with (nolock) on ov.OpportunityID = o.id
     inner join sa_obp_OpportunityWorkflowStage ows with (nolock) on ows.id = ov.OpportunityWorkflowStageId and
                                                                     ows.milestoneid = 5
     inner join (select distinct opportunityid
                 from obpmi_arrangement with (nolock)
                 where submissionstatus = 1) atleastonesubmission on atleastonesubmission.opportunityid = o.id
	 inner join sa_obp_PlanSnapshot ps with (nolock) on ps.id = ov.PlanSnapshotId		--MPC: 09/03/2012
     inner join (select distinct planid
                 from sa_obp_PlanRetirementArrangement a with (nolock)
                      inner join sa_obp_PlanRetirementTransaction t with (nolock) on t.prospectiveid = a.Id and
                                                                                     isnull(convert(xml, T.Actions).value('(/RetirementActions/*/CustomXml/ItemCollection/Item[@name="ReplacementQuestion"]/@value)[1]', 'int'), 0) > 0
                 union
                 select distinct planid
                 from sa_obp_PlanInvestmentFundCollection a with (nolock)
                      inner join sa_obp_PlanInvestmentTransaction t with (nolock) on t.prospectiveid = a.Id and
                                                                                     isnull(convert(xml, T.Actions).value('(/InvestingActions/*/CustomXml/ItemCollection/Item[@name="EncashmentReplacementQuestion"]/@value)[1]', 'int'), 0) > 0
                 union
                 select distinct planid
                 from sa_obp_PlanProtectionPolicy a with (nolock)
                      inner join sa_obp_PlanProtectionPolicyTransaction t with (nolock) on t.prospectiveid = a.Id and
                                                                                           isnull(convert(xml, T.Actions).value('(/ProtectionActions/*/CustomXml/ItemCollection/Item[@name="CancelReplacementPolicy"]/@value)[1]', 'int'), 0) > 0
                 union
                 select distinct planid
                 from sa_obp_PlanMortgage a with (nolock)
                      inner join sa_obp_PlanMortgageTransaction t with (nolock) on t.prospectiveid = a.Id and
                                                                                   isnull(convert(xml, T.Actions).value('(/MortgageActions/*/CustomXml/ItemCollection/Item[@name="ReplacementQuestion"]/@value)[1]', 'int'), 0) > 0
                 union
                 select distinct planid
                 from sa_obp_PlanGeneralInsurancePolicy a with (nolock)
                      inner join sa_obp_PlanGeneralInsurancePolicyTransaction t with (nolock) on t.prospectiveid = a.Id and
                                                                                                 isnull(convert(xml, T.Actions).value('(/GeneralInsuranceActions/*/CustomXml/ItemCollection/Item[@name="ReplacementQuestion"]/@value)[1]', 'int'), 0) > 0) planswithreplacements on planswithreplacements.planid = ps.planid		--MPC: 09/03/2012
																																																																				 --on planswithreplacements.planid = ov.planid		--MPC: 09/03/2012
     inner join obpmi_Staff S with (nolock) on S.entityid = ov.RRIStaffEntityID
     left join sa_insight_userposition ups with (nolock) on ups.ups_externalid = s.integrationalias and
                                                            ov.versiondate between ups_datefrom and isnull(ups_dateto, '99991231') and
                                                            ups.ups_usertype = 3
     left join sa_insight_codedescription jt with (nolock) on jt.code_code = ups.ups_jobtitle and
                                                              jt.code_codetype = 54
     left join sa_insight_staff si with (nolock) on si.staf_userid = ups.ups_userid
     left join sa_insight_codedescription cs with (nolock) on cs.code_code = si.staf_contractstatus and
                                                              cs.code_codetype = 527
     left join dbo.f_insight_getfirmsofallusers(getdate()) f on f.roleguid = ups.ups_id
     left join sa_insight_distributor dist with (nolock) on dist.dist_id = f.firmguid
     left join dbo.f_insight_getqmsofallusers(1, getdate()) bqm on bqm.roleguid = ups.ups_id                                                           
     left join sa_insight_userdetails bqmusr with (nolock) on bqmusr.usr_id = bqm.qmuserguid
     left join dbo.f_insight_getadsofallusers(getdate()) ad on ad.roleguid = ups.ups_id                                                           
     left join sa_insight_userdetails adusr with (nolock) on adusr.usr_id = ad.aduserguid
;
