/****** Object:  View [BI].[vw_ows_Event]    Script Date: 7/2/2026 12:50:24 PM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO



CREATE view [BI].[vw_ows_Event]

as

select	se.ow_servicingeventid as EventMergeID,
		case when isnumeric(se.ow_legacyid) = 1 then CONVERT(int,se.ow_legacyid) else convert(int,null) end as EventID,
		case se.ow_type
			when 267000000 then 1
			when 267000001 then 2
			when 267000002 then 7
			when 267000003 then 8
			else null
		end as TypeID,
		case
			when se.ow_type in (267000000, 267000001) then se.ow_originalduedate
			when se.ow_type in (267000002, 267000003) then se.ow_datedue
			else null
		end  as DateDue,
		se.ow_details as Details,
		case ow_outcome
			when 267000000 then 1
			when 267000001 then 2
			when 267000002 then 3
			else null
		end as Outcome,
		case --PersonID must always be the client even when a partner is involved
			when p1.PersonType is null and p2.PersonType = 2 then p2p.PersonID		--No P1, P2 is a partner, so we need P2's partner
			when p1.PersonType is null then p2.PersonID								--No P1, P2 must be a client, so we take P2 
			when p1.PersonType = 2 and p2.PersonType is null then p1p.PersonID		--P1 is a partner and no P2, so we need P1's partner 
			when p1.PersonType = 2 and p2.PersonType = 2 then p1p.PersonID			--P1 and P2 are both partners so we need P1's partner 
			when p1.PersonType = 2 then p2.PersonID									--P1 is a partner, P2 must be a client, so we take P2
			else p1.PersonID														--P1 is a client, so we take P1
		end as PersonID,
		case when se.statuscode = 2 then 1 else 0 end as IsComplete,
		case when se.statuscode = 267000003 then 1 else 0 end as IsCancelled,
		case when se.statuscode = 267000004 then 1 else 0 end as IsDeleted,
		se.ow_closuredate as DateCompleted,
		se.ow_datecompletedwithclient as DateCompletedWithClient,
		case se.ow_datedueoneoffchange
			when 267000000 then 1
			when 267000001 then 2
		end as ReminderDateChangeType,
		se.ow_reasonfordatechange as ReminderDateChangeReason,
		case 
			when p1.PersonType is not null and p2.PersonType is not null then 3	--Joint 
			when p1.PersonType = 1 or p2.PersonType = 1	then 1					--Client
			else 2																--Partner
		end as CompletedFor,
		case 
			when se.ow_legacymigratedcompletedby is not null then se.ow_legacymigratedcompletedby 
			when se.statuscode = 2 then suModifiedBy.ow_adviserid
			else null
		end as CompletedBy,
		case when se.ow_legacymigratedcreatedby is not null then se.ow_legacymigratedcreatedby else suCreatedBy.ow_adviserid end as CreatedBy,
		case when se.ow_legacymigratedlastcompletedeventdate is not null then se.ow_legacymigratedupdatedby else suModifiedBy.ow_adviserid end as UpdatedBy,
		case when se.ow_legacymigrateddatecreated is not null then se.ow_legacymigrateddatecreated else se.CreatedOn end as DateCreated,
		case when se.ow_legacymigrateddateupdated is not null then se.ow_legacymigrateddateupdated else se.ModifiedOn end as DateUpdated,
		case
			when se.ow_type in (267000002,267000003) then null 	--2=Adhoc report; 3=Adhoc review
			when se.ow_type in (267000000,267000001) and se.ow_originalduedate <> se.ow_datedue then se.ow_datedue	--0=Report; 1=Review 
			else null
		end as OneOffChangeToDateDue,
		case when se.ow_legacymigratedlastcompletedeventdate is not null then se.ow_legacymigratedlastcompletedeventdate else null end as LastCompletedEventDate,
		es.ow_legacyid as EventReminderStatusID,
		case when se.ow_legacymigratedislastcompletedeventdtappdt is not null then se.ow_legacymigratedislastcompletedeventdtappdt else null end as IsLastCompletedEventDateApplicationDate,
		esCompletion.ow_legacyid as StatusWhenCompleted,
		sl.ow_servicelevelname as ServiceLevelWhenCompleted,
		se.ow_firmwhencompleted as FirmWhenCompleted,
		se.ow_reasondatecompletednotoriginalduedate as LastCompletedEventsDateChangeReason,
		se.ow_reference as CrmMessageSourceId,
		se.ow_servicingeventId as CrmSourceId,
		se.ModifiedOn as CrmLastUpdatedDate,
		convert(bit,0) as Obfuscated,
		'D365' as SourceSystem
from	BI.D365_ow_servicingevent se
		left Join BI.D365_ow_eventstatus es on es.ow_eventstatusid = se.ow_progressstatus
		left Join BI.D365_ow_eventstatus esCompletion on esCompletion.ow_eventstatusid = se.ow_statusoncompletion
		left join BI.D365_ow_servicelevel sl on sl.ow_servicelevelid = se.ow_servicelevelwhencompletedlookup
		left join BI.D365_systemuser suModifiedBy on suModifiedBy.systemuserid = se.modifiedby
		left join BI.D365_systemuser suCreatedBy on suCreatedBy.systemuserid = se.createdby
		left join sa_ows_Person p1 on p1.CrmSourceID = convert(nvarchar(150),se.ow_client1) and isnull(left(p1.CrmMessageSourceId,3),'') = 'DYN'
		left join sa_ows_Person p2 on p2.CrmSourceID = convert(nvarchar(150),se.ow_client2) and isnull(left(p2.CrmMessageSourceId,3),'') = 'DYN'
		left join sa_ows_Person p1p on p1p.PersonID = p1.PartnerPersonID
		left join sa_ows_Person p2p on p2p.PersonID = p2.PartnerPersonID
where	se.ow_type in (267000000,267000001,267000002,267000003)	--0=Report; 1=Review; 2=Adhoc Report; 3=Adhoc Review

union

select	BI.fns_DeriveGUID(EventID) as EventMergeId,
		EventID,
		TypeID,
		DateDue,
		Details,
		Outcome,
		PersonID,
		IsComplete,
		IsCancelled,
		IsDeleted,
		DateCompleted,
		DateCompletedWithClient,
		ReminderDateChangeType,
		ReminderDateChangeReason,
		CompletedFor,
		CompletedBy,
		CreatedBy,
		UpdatedBy,
		DateCreated,
		DateUpdated,
		OneOffChangeToDateDue,
		LastCompletedEventDate,
		EventReminderStatusID,
		IsLastCompletedEventDateApplicationDate,
		StatusWhenCompleted,
		ServiceLevelWhenCompleted,
		FirmWhenCompleted,
		LastCompletedEventsDateChangeReason,
		CrmMessageSourceId,
		CrmSourceId,
		CrmLastUpdatedDate,
		Obfuscated,
		'OWS' as SourceSystem
from	Events.sa_ows_Event
where	isnull(left(CrmMessageSourceId,2),'') <> 'SE'

GO
