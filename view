CREATE view [dbo].[rpt_CommissionMismatches] as
select o.ClientFacingOpportunityID OpportunityRef,
       pt.CreateDateTime,
       p.cont_num as PolicyNumber,
       p.policyref as CaseID,
       p.productcode as ProductType, 
       isnull(ph.ProductProviderCode, 'Unknown') as ProductProvider,
       pt.AgentCode,
       ag.descn as AgentName,
       convert(money, isnull(pt.comminitialamount, 0)) as SwiftDA, 
       ac.ICAmount as OBPDA,
       convert(money, abs(isnull(pt.comminitialamount, 0) - ac.ICAmount)) as DADiff,
       convert(decimal(5, 2), 100 * case when isnull(pt.comminitialamount, 0) = ac.ICAmount then 1
                                         when isnull(pt.comminitialamount, 0) < ac.ICAmount then isnull(pt.comminitialamount, 0) / ac.ICAmount
                                         else ac.ICAmount / isnull(pt.comminitialamount, 0)
                                    end) as [PerCentMatch], 
       convert(money, isnull(pt.amount, 0)) as Amount,
       code.name as Frequency,
       ac.commissionterms as CommBasis,
       isnull(panel.Code_Description, 'Not Set') Panel,
       cs.description as CommShape,
       cl.FirstNames + ' ' + cl.[Name] as ClientName,
       isnull(ph.ProductGroupName, 'Unknown') as ProdGroup
from rds_case c with (nolock)
     inner join obpmi_arrangement a with (nolock) on a.arrangementid = c.arrangementid
     inner join obpmi_arrangementcommission ac with (nolock) on ac.arrangementid = a.arrangementid
     inner join sa_obp_opportunity o with (nolock) on o.id = a.opportunityid
     inner join sa_swift_s_polmai p with (nolock) on p.pol_num = c.pol_num
     inner join sa_swift_policytransactions pt with (nolock) on pt.policyid = c.pol_num and
                                                                pt.proposaldate = a.proposaldate and
                                                                pt.transtype = 39 and
                                                                ac.premiumamount = pt.amount
     inner join (rds_code code with (nolock)
                 inner join rds_codemapping cmo with (nolock) on cmo.codeid = code.id
                 inner join config_datasource dso with (nolock) on dso.id = cmo.datasourceid and
                                                                   dso.code = 'OBP'
                 inner join rds_codemapping cms with (nolock) on cms.codeid = code.id
                 inner join config_datasource dss with (nolock) on dss.id = cms.datasourceid and
                                                                   dss.code = 'Swift'
                 inner join rds_codetype ct with (nolock) on ct.id = code.typeid and
                                                             ct.name = 'Frequency') on cmo.ssuid = ac.frequency and
                                                                                       cms.ssuid = pt.frequency
     inner join sa_swift_s_agents ag with (nolock) on ag.code = pt.agentcode
     left join mstt_Clients cl with (nolock) on cl.client_num = p.client_num
     left join mstt_ProductHierarchy ph with (nolock) on ph.ProductCode = pt.Commproductcode
     left join sa_swift_codecommissionshape cs with (nolock) on cs.id = pt.codecommissionshapeid
     left join sa_insight_CodeDescription panel with (nolock) on panel.Code_CodeType = 53 and
                                                                 left(panel.code_description, 3) = left(cs.description, 3)
where abs(isnull(pt.comminitialamount, 0) - ac.ICAmount) >= .1 or
      case when isnull(pt.comminitialamount, 0) < ac.ICAmount then isnull(pt.comminitialamount, 0) / ac.ICAmount 
           when pt.comminitialamount > ac.ICAmount then ac.ICAmount / pt.comminitialamount
           else 1.
      end <= .99
GO
