SET QUOTED_IDENTIFIER ON
GO
create view [dbo].[rpt_DuplicateOBPCases]
as
select p.policyref SwiftCaseID,
       a.ProposalDate,
       upper(a.PolicyNumber) PolicyNumber,
       a.CaseID OBPCaseID,
       upper(o.clientfacingopportunityid) OpportunityRef,
       s.firstname + ' ' + s.lastname ResponsibleIndividual
from obpmi_arrangement a with (nolock)
     inner join sa_obp_opportunity o with (nolock) on o.id = a.opportunityid and
                                                      a.submissionstatus = 1
     inner join sa_obp_opportunityversion ov with (nolock) on ov.opportunityid = o.id and
                                                              ov.currentversion = 1
     inner join obpmi_staff s with (nolock) on s.entityid = ov.RRIStaffEntityId
     inner join (select pt.proposaldate,
                        pt.policyid
                 from sa_swift_policytransactions pt with (nolock)
                 where pt.proposaldate is not null and
                       pt.transtype != 117 and
                       isnull(pt.adminmethod, '') !='X'
                 group by pt.proposaldate,
                          pt.policyid) pt on pt.proposaldate = a.proposaldate
     inner join sa_swift_s_polmai p with (nolock) on p.pol_num = pt.policyid and
                                                     (nullif(rtrim(ltrim(p.cont_num)), '') = a.PolicyNumber or
                                                      p.policyref = a.caseid)
     inner join (select p.pol_num,
                        pt.proposaldate
                 from obpmi_arrangement a with (nolock)
                      left join (rds_codemapping cmo with (nolock)
                                 inner join rds_code co with (nolock) on co.id = cmo.codeid
                                 inner join rds_codetype cto with (nolock) on cto.id = co.typeid and
                                                                              cto.name = 'Provider Grouping 1'
                                 inner join config_datasource dso with (nolock) on dso.id = cmo.datasourceid and
                                                                                   dso.code = 'OBP') on cmo.ssuid = a.provider
                      inner join (sa_swift_policytransactions pt with (nolock)
                                  inner join sa_swift_s_polmai p with (nolock) on p.pol_num = pt.policyid and
                                                                                  pt.proposaldate is not null and
                                                                                  pt.transtype != 117 and
                                                                                  isnull(pt.adminmethod, '') !='X'
                                  left join (rds_codemapping cms with (nolock)
                                             inner join rds_code cs with (nolock) on cs.id = cms.codeid
                                             inner join rds_codetype cts with (nolock) on cts.id = cs.typeid and
                                                                                          cts.name = 'Provider Grouping 1'
                                             inner join config_datasource dss with (nolock) on dss.id = cms.datasourceid and
                                                                                               dss.code = 'Swift') on cms.ssuid = p.comp_code) on pt.proposaldate = a.proposaldate and
                                                                                                                                                  (a.caseid = p.policyref or
                                                                                                                                                   (a.policynumber = nullif(rtrim(ltrim(p.cont_num)), '') and
                                                                                                                                                    (p.comp_code = a.provider or
                                                                                                                                                     co.id = cs.id)))
                 group by p.pol_num,
                          pt.proposaldate
                 having count(distinct a.OpportunityID) > 1) f on f.pol_num = p.pol_num and
                                                                  f.proposaldate = pt.proposaldate
--order by p.policyref,
--         a.caseid
