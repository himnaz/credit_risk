CREATE VIEW [dbo].[sa_CMS_MailMergeData] AS
select RecordCreated, ComplaintNo, ClientInitials, ClientSurname, ClientAddressLine1, ClientAddressLine2,ClientAddressLine3,
ClientAddressLine4, ClientAddressLine5, adv.AgentDesc as 'Adviser Name', isnull(comp.PolicyNo,'Unknown') as 'Policy' , adv.FirmDescn as 'Firm',
