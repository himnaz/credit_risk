CREATE View [dbo].[owv_AdviserBrand]
as
select	derived.UserUID,
		MAX(derived.UserName) as UserName,
		MAX(derived.Brand) as Brand
from
(
	select	ud.USR_ExternalID as UserUID,
			ud.USR_name as UserName,
			MAX(case when up.UPS_JobTitle between 51 and 58 or up.UPS_JobTitle between 61 and 63 or up.UPS_JobTitle = 65 then 'Owl' else 'Openwork' end) as Brand	--AG 15/10/2019
	from	sa_insight_UserDetails ud
			inner join sa_insight_UserPosition up on up.UPS_UserID = ud.USR_ID and up.UPS_DateTo is null	--AG 20/06/2016
	where	ud.USR_Name not like '%error%'
	and		ud.USR_ExternalID is not null
	group	by ud.USR_ExternalID, ud.USR_name

	union	-- de-dupe

	select	ag.Code as UserUID,
			ag.Descn as UserName,
			max(case when ag.Manager2Code = cde.Code then 'Owl' else 'Openwork' end) as Brand
	from	mstt_Agents ag
			left join msit_MIWarehouseCodesAndDescriptions cde on cde.ColumnName = 'Manager2Code' and cde.Description = 'Owl Financial'
			left join sa_insight_UserDetails ud on ud.USR_ExternalID = ag.Code and ud.USR_Name not like '%error%'
	where	ag.AgentType in (2,3,4,5,17,43,44,45,46,49,51,52,53,55)	-- 2, 46 & 49 are businesses
	and		ud.USR_ExternalID is null
	group by ag.Code, ag.Descn
) derived
group by derived.UserUID
