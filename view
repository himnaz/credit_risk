/*********************************************************************************************************************************************************************************************************************
Author    :- Umang Kumar Saxena
Creation Date   :- 6 June 2008
Modified        :- 07 July 2008
SR Number   :- SR197760 
Name    :- Vw_Bcode_OpenData
Description :- Fetch the desired value from table mstt_Agents agent and mstt_AgentAgencyNumbers
Outputs   :- Join will genrate output with following  columns.
      1.Business Quality Manager Id
      2.Area Director Id
      3.Swift business id
      4.Business name
      5.Swift Adviser id
      6.Adviser name
                                        7.E_code
                                        8.Business_Status
                                        9.ErrorCol

*******************************************************************************************************************************************************************************************************************************
*/
CREATE VIEW [dbo].[Vw_Bcode_OpenData]
AS
SELECT     CASE type WHEN 'A' THEN D .Manager2Code2 WHEN 'B' THEN D .Manager2Code1 END AS [Business Quality Manager id], 
                      CASE type WHEN 'A' THEN D .Manager4Code2 WHEN 'B' THEN D .Manager4Code1 END AS [Area Director id], 
                      CASE type WHEN 'A' THEN D .AgentCode2 WHEN 'B' THEN D .AgentCode1 END AS [Swift Business id], 
                      CASE type WHEN 'A' THEN D .DESCN2 WHEN 'B' THEN D .DESCN1 END AS [Business Name], 
                      CASE type WHEN 'A' THEN D .AgentCode1 WHEN 'B' THEN '' END AS [Swift Adviser Id], 
                      CASE type WHEN 'A' THEN D .DESCN1 WHEN 'B' THEN '' END AS [Adviser Name], B_CODE, 
                      CASE type WHEN 'A' THEN D .CompetentStatus2 WHEN 'B' THEN D .CompetentStatus1 END AS [Business Status], 
                      CASE WHEN type = '' THEN 'Y' ELSE 'N' END AS Errorcol
FROM         (SELECT     a.AgencyNo AS B_CODE, CASE WHEN b.Agenttype IN (2, 19, 42, 46, 47, 48, 49, 50) THEN 'B' WHEN b.Agenttype IN (3, 4, 5, 17, 43, 44, 45, 
                                              51, 52, 53, 54, 55) THEN 'A' ELSE '' END AS Type, b.CODE AS AgentCode1, b.DESCN AS DESCN1, b.Manager2Code AS Manager2Code1, 
                                              b.Manager4Code AS Manager4Code1, b.CompetentStatus AS CompetentStatus1, c.CODE AS AgentCode2, c.DESCN AS DESCN2, 
                                              c.Manager2Code AS Manager2Code2, c.Manager4Code AS Manager4Code2, c.CompetentStatus AS CompetentStatus2
                       FROM          dbo.mstt_AgentAgencyNumbers AS a INNER JOIN
                                              dbo.mstt_Agents AS b ON a.AgentCode = b.CODE LEFT OUTER JOIN
                                              dbo.mstt_Agents AS c ON b.Firm = c.CODE
                       WHERE      (a.AgencyNo LIKE 'B%')) AS D
UNION ALL
SELECT     [Business Quality Manager id], [Area Director id], [Swift Business id], [Business Name], [Swift Adviser id], [Adviser Name], [Advisor code] AS Bcode, 
                      '1' AS Expr1, 'N' AS Expr2
FROM         Head_Office_Systems.dbo.owoa_ZurichListingKnowledgeBase
WHERE     ([Advisor code] LIKE 'B%') -- steve removed on 11/01/10 -- AND ([Swift Business id] LIKE '1%')

