                         ELSE mstt_Agents.TradingName END, mstt_Agents.DESCN) AS AgentDesc, mstt_Agents.AgentCategory, mstt_Agents.AgentCategoryDescription, mstt_Agents.GivesAdvice, 
                         COALESCE (mstt_Agents.OscarDateStarted, mstt_Agents.dateStarted) AS AgentStartDate, mstt_Agents.DateLeaving AS AgentLeftDate, mstt_Agents.OscarAgentId, 
                         mstt_Agents.OscarAgentPrefix + mstt_Agents.OscarAgentSerial + mstt_Agents.OscarAgentSuffix AS AgentOscarCode, mstt_Agents.CompetentStatus, mstt_Agents.CompetentStatusDescription, 
                         mstt_Agents.FranchiseSize,
                             (SELECT        CASE WHEN mstt_Agents.FranchiseSize BETWEEN '0' AND '1' THEN 'Sole Trader' WHEN mstt_Agents.FranchiseSize BETWEEN '2' AND 
                                                         '9' THEN 'Small (2-9)' WHEN mstt_Agents.FranchiseSize > '9' THEN 'Large (10+) ' ELSE 'unknown' END AS 'FranchiseType') AS FranchiseType, mstt_Agents.Firm AS FirmCode, 
                         mstt_Agents_1.AgentType AS FirmType, mstt_Agents_1.AgentTypeDescription AS FirmTypeDescription, COALESCE (CASE WHEN LTRIM(RTRIM(mstt_Agents_1.TradingName)) = '' THEN NULL 
                         ELSE mstt_Agents_1.TradingName END, mstt_Agents_1.DESCN) AS FirmDescn, mstt_Agents_1.AgentCategory AS FirmCategory, mstt_Agents_1.AgentCategoryDescription AS FirmCategoryDesc, 
                         COALESCE (mstt_Agents_1.OscarDateStarted, mstt_Agents_1.DateStarted) AS FirmStartDate, mstt_Agents_1.DateLeaving AS FirmLeftDate, mstt_Agents_1.OscarAgentId AS FirmOscarAgentId, 
                         mstt_Agents_1.OscarAgentPrefix + mstt_Agents_1.OscarAgentSerial + mstt_Agents_1.OscarAgentSuffix AS FirmOscarCode, mstt_Agents_1.CompetentStatus AS FirmCompStatus, 
                         mstt_Agents_1.CompetentStatusDescription AS FirmCompStatDesc, mstt_Agents_1.FranchiseSize AS FirmFranchiseSize,
                             (SELECT        CASE WHEN mstt_Agents_1.FranchiseSize BETWEEN '0' AND '1' THEN 'Sole Trader' WHEN mstt_Agents_1.FranchiseSize BETWEEN '2' AND 
                                                         '9' THEN 'Small (2-9)' WHEN mstt_Agents_1.FranchiseSize > '9' THEN 'Large (10+) ' ELSE 'unknown' END AS 'FirmFranchiseType') AS FirmFranchiseType, mstt_Agents.Manager2code AS RSMCode,
                          mstt_agents_2.DESCN AS RSMName, mstt_Agents.Manager4code AS ASDCode, mstt_agents_3.DESCN AS ASDName
FROM            dbo.mstt_Agents LEFT OUTER JOIN
                         dbo.mstt_Agents AS mstt_Agents_1 ON mstt_Agents.Firm = mstt_Agents_1.CODE LEFT OUTER JOIN
                         dbo.mstt_Agents AS mstt_agents_2 ON mstt_Agents.manager2Code = mstt_agents_2.CODE LEFT OUTER JOIN
                         dbo.mstt_Agents AS mstt_agents_3 ON mstt_Agents.manager4Code = mstt_agents_3.CODE
