         LeagueIncludeFlag           = convert(varchar(1), t.LeagueIncludeFlag),
         SinglePremBasisCode         = convert(varchar(1), t.SinglePremBasisCode),
         SinglePremABCRate           = convert(float, t.SinglePremABCRate),
         RegularPremBasisCode        = convert(varchar(1), t.RegularPremBasisCode),
