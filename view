CREATE view [dbo].[cscv_RSMTurnover] as

SELECT     msft_Sales.Turnover, msdt_CalendarTime.[Month],
                      msdt_CalendarTime.[Year], msdt_Adviser.FranchiseCode, 
                      cscv_AgentsHistoryHierarchy.AgentDesc,
                      cscv_AgentsHistoryHierarchy.AgentStartDate,
                      cscv_AgentsHistoryHierarchy.AgentLeftDate,
                      cscv_AgentsHistoryHierarchy.AgentOscarCode,
                      cscv_AgentsHistoryHierarchy.RSMCode,
                      cscv_AgentsHistoryHierarchy.RSMName, 
                      cscv_AgentsHistoryHierarchy.ASDCode, 
                     cscv_AgentsHistoryHierarchy.ASDName, msdt_calendartime.datetime
FROM         cscv_AgentsHistoryHierarchy RIGHT OUTER JOIN
                      msdt_Adviser ON cscv_AgentsHistoryHierarchy.agentCode = msdt_Adviser.FranchiseCode RIGHT OUTER JOIN
                      msft_Sales ON msdt_Adviser.AdviserID = msft_Sales.AdviserId LEFT OUTER JOIN
                      msdt_CalendarTime ON msft_Sales.DateIssuedId = msdt_CalendarTime.DateID
WHERE     (msft_Sales.BusinessTypeId = 2)
and (cscv_AgentsHistoryHierarchy.validfromdate <= msdt_calendartime.datetime and
     cscv_AgentsHistoryHierarchy.validtodate >= msdt_calendartime.datetime)
and msdt_calendartime.year > 2004  --and rsmcode = 1003804
--group by asdname, rsmname ,year,month
union all 
SELECT     msft_Sales.Turnover, msdt_CalendarTime.[Month],
                      msdt_CalendarTime.[Year],msdt_Adviserdummies.FranchiseCode, 
                      cscv_AgentsHistoryHierarchy.AgentDesc,
                      cscv_AgentsHistoryHierarchy.AgentStartDate,
                      cscv_AgentsHistoryHierarchy.AgentLeftDate,
                      cscv_AgentsHistoryHierarchy.AgentOscarCode, 
                      cscv_AgentsHistoryHierarchy.RSMCode,
                      cscv_AgentsHistoryHierarchy.RSMName, 
                      cscv_AgentsHistoryHierarchy.ASDCode, 
                     cscv_AgentsHistoryHierarchy.ASDName, msdt_calendartime.datetime
FROM         cscv_AgentsHistoryHierarchy RIGHT OUTER JOIN
                      msdt_Adviserdummies ON cscv_AgentsHistoryHierarchy.agentCode = 
                      msdt_Adviserdummies.FranchiseCode RIGHT OUTER JOIN
                      msft_Sales ON msdt_Adviserdummies.AdviserID = msft_Sales.AdviserId LEFT OUTER JOIN
                      msdt_CalendarTime ON msft_Sales.DateIssuedId = msdt_CalendarTime.DateID
WHERE     (msft_Sales.BusinessTypeId = 2)
and (cscv_AgentsHistoryHierarchy.validfromdate <= msdt_calendartime.datetime and
     cscv_AgentsHistoryHierarchy.validtodate >= msdt_calendartime.datetime)
and msdt_calendartime.year > 2004  --and rsmcode = 1003804
--group by asdname, rsmname , year,month
union all 
SELECT     msft_Sales.Turnover, msdt_CalendarTime.[Month],
                      msdt_CalendarTime.[Year], msdt_Adviserdummies.FranchiseCode, 
                      msdt_Adviserdummies.Franchise, getdate(),getdate(),'Dummy',
                      msdt_Adviserdummies.RegionalSalesManagerCode,
                      cscv_AgentsHistoryHierarchy.agentdesc as RSMname, 
                      cscv_AgentsHistoryHierarchy.ASDCode, 
                     cscv_AgentsHistoryHierarchy.ASDName,msdt_calendartime.datetime
FROM         cscv_AgentsHistoryHierarchy RIGHT OUTER JOIN
                      msdt_Adviserdummies ON cscv_AgentsHistoryHierarchy.agentCode = 
                      msdt_Adviserdummies.RegionalSalesManagerCode RIGHT OUTER JOIN
                      msft_Sales ON msdt_Adviserdummies.AdviserID = msft_Sales.AdviserId LEFT OUTER JOIN
                      msdt_CalendarTime ON msft_Sales.DateIssuedId = msdt_CalendarTime.DateID
WHERE     (msft_Sales.BusinessTypeId = 2)
and (cscv_AgentsHistoryHierarchy.validfromdate <= msdt_calendartime.datetime and
     cscv_AgentsHistoryHierarchy.validtodate >= msdt_calendartime.datetime)
and msdt_calendartime.year > 2004  --and RegionalSalesManagerCode = '1003804'
and msdt_Adviserdummies.FranchiseCode like 'INACTIVE%'
--group by asdname, agentdesc , year,month
--order by 5,4,3,2




