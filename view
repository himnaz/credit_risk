create view [dbo].[rpt_OBPvsSwiftCaseMismatches]
as
select a.CaseID,
       a.ProposalDate,
       a.SubmissionDate,
       a.ArrangementType,
       a.ProductCode,
       isnull(c.name, a.Provider) Provider,
       upper(o.clientfacingopportunityid) OpportunityRef,
       count(distinct p1.pol_num) MatchesByCaseID,
       count(distinct p2.pol_num) MatchesByPolicy,
       count(distinct p.pol_num) MatchesTotal
from sa_obp_opportunity o with (nolock)
     inner join obpmi_arrangement a with (nolock) on a.opportunityid = o.id and    
                                                     a.submissionstatus = 1
     left join (rds_codemapping cm with (nolock)
                inner join rds_code c with (nolock) on c.id = cm.codeid
                inner join rds_codetype ct with (nolock) on ct.id = c.typeid and
                                                            ct.name = 'Provider Grouping 1'
                inner join config_datasource ds with (nolock) on ds.id = cm.datasourceid and
                                                                 ds.code = 'OBP') on cm.ssuid = a.provider
     left join (select p.pol_num,
                       p.policyref,
                       pt.proposaldate,
                       nullif(rtrim(ltrim(p.cont_num)), '') cont_num,
                       p.comp_code,
                       c.name providergroup,
                       c.id provgroupid
                from sa_swift_s_polmai p with (nolock)
                     left join sa_swift_s_polmai sp with (nolock) on sp.scheme_num = p.pol_num
                     inner join sa_swift_policytransactions pt with (nolock) on pt.policyid = isnull(sp.pol_num, p.pol_num) and
                                                                                pt.transtype != 117 and
                                                                                isnull(pt.adminmethod, '') !='X' and
                                                                                p.scheme_num is null
                     left join (rds_codemapping cm with (nolock)
                                inner join rds_code c with (nolock) on c.id = cm.codeid
                                inner join rds_codetype ct with (nolock) on ct.id = c.typeid and
                                                                            ct.name = 'Provider Grouping 1'
                                inner join config_datasource ds with (nolock) on ds.id = cm.datasourceid and
                                                                                 ds.code = 'Swift') on cm.ssuid = p.comp_code) p on p.proposaldate = a.proposaldate and
                                                                                                                                    (p.policyref = a.caseid or
                                                                                                                                     (p.cont_num = a.policynumber and
                                                                                                                                      (p.comp_code = a.provider or
                                                                                                                                       p.provgroupid = c.id)))
     left join (select p.pol_num,
                       pt.proposaldate,
                       p.policyref
                from sa_swift_s_polmai p with (nolock)
                     left join sa_swift_s_polmai sp with (nolock) on sp.scheme_num = p.pol_num
                     inner join sa_swift_policytransactions pt with (nolock) on pt.policyid = isnull(sp.pol_num, p.pol_num) and
                                                                                pt.proposaldate is not null and
                                                                                pt.transtype != 117 and
                                                                                isnull(pt.adminmethod, '') !='X' and
                                                                                p.scheme_num is null) p1 on p1.proposaldate = a.proposaldate and
                                                                                                            p1.policyref = a.caseid
     left join (select p.pol_num,
                       pt.proposaldate,
                       nullif(rtrim(ltrim(p.cont_num)), '') cont_num,
                       p.comp_code,
                       c.name providergroup,
                       c.id provgroupid
                from sa_swift_s_polmai p with (nolock)
                     left join sa_swift_s_polmai sp with (nolock) on sp.scheme_num = p.pol_num
                     inner join sa_swift_policytransactions pt with (nolock) on pt.policyid = isnull(sp.pol_num, p.pol_num) and
                                                                                pt.proposaldate is not null and
                                                                                pt.transtype != 117 and
                                                                                isnull(pt.adminmethod, '') !='X' and
                                                                                p.scheme_num is null
                     left join (rds_codemapping cm with (nolock)
                                inner join rds_code c with (nolock) on c.id = cm.codeid
                                inner join rds_codetype ct with (nolock) on ct.id = c.typeid and
                                                                            ct.name = 'Provider Grouping 1'
                                inner join config_datasource ds with (nolock) on ds.id = cm.datasourceid and
                                                                                 ds.code = 'Swift') on cm.ssuid = p.comp_code) p2 on p2.proposaldate = a.proposaldate and
                                                                                                                                     p2.cont_num = a.policynumber and
                                                                                                                                     (p2.comp_code = a.provider or
                                                                                                                                      p2.provgroupid = c.id)
where a.ArrangementType != 'GI' and
      a.ProductCode != 'MPPI'
group by a.CaseID,
         a.ProposalDate,
         a.SubmissionDate,
         a.ArrangementType,
         a.ProductCode,
         isnull(c.name, a.Provider),
         o.clientfacingopportunityid
having count(distinct p.pol_num) != 1 and
       count(distinct p1.pol_num) != 1
--order by a.submissiondate,
--         o.clientfacingopportunityid,
--         a.CaseID
GO
