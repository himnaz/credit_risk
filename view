create view [dbo].[obpmi_Session] as
SELECT ul.SessionKey,
       first.EntityId,
       first.[datetime] Start,
       last.[datetime] Finish,
       DateDiff(minute, first.[datetime], last.[datetime]) [DurationInMinutes],
       first.control FirstControl,
       count(*) Hits,
       count(distinct p.AdviceUnitEntityId) ClientCount,
       uu.AdviceUnitEntityId,
       uu.StaffEntityId,
       uu.StaffFirstName + ' ' + uu.StaffLastName StaffName,
       Year(first.[datetime]) [Year], 
       Month(first.[datetime]) [Month], 
       Day(first.[datetime]) [Day],
       1 [Count]
FROM sa_obp_UsageLog ul 
     inner join sa_obp_UsageLog first on first.id = (select min(u.id) from sa_obp_UsageLog U where U.sessionkey = ul.sessionkey)
     inner join sa_obp_UsageLog last on last.id = (select max(u.id) from sa_obp_UsageLog U where U.sessionkey = ul.sessionkey)
     left JOIN [sa_obp_Plan] p (nolock) ON ul.PlanId = p.[Id] and p.[Id] != '00000000-0000-0000-0000-000000000000' 
     inner join (SELECT auc.ClientEntityId EntityId,
                        au.EntityId AdviceUnitEntityId,
                        au.CreatedByStaffEntityId StaffEntityId,
                        s.FirstName StaffFirstName,
                        s.LastName StaffLastName
                 FROM sa_obp_AdviceUnitClient auc (nolock)
                      INNER JOIN sa_obp_AdviceUnit au (nolock) ON au.EntityId = auc.AdviceUnitEntityId
                      INNER JOIN sa_obp_Staff s(nolock) ON au.CreatedByStaffEntityId = s.EntityId
                 UNION
                 SELECT au.EntityId,
                        au.EntityId,
                        au.CreatedByStaffEntityId,
                        s.FirstName,
                        s.LastName
                 FROM sa_obp_AdviceUnit au (nolock)
                      INNER JOIN sa_obp_Staff s(nolock) ON au.CreatedByStaffEntityId = s.EntityId
                 UNION
                 SELECT s.EntityId,
                        null,
                        s.EntityId,
                        s.FirstName,
                        s.LastName
                 FROM sa_obp_Staff s(nolock)) uu on uu.entityid = first.entityid
group by ul.SessionKey,
         first.EntityId,
         first.[datetime],
         last.[datetime],
         DateDiff(minute, first.[datetime], last.[datetime]),
         first.control ,
         uu.AdviceUnitEntityId,
         uu.StaffEntityId,
         uu.StaffFirstName + ' ' + uu.StaffLastName,
         Year(first.[datetime]), 
         Month(first.[datetime]), 
         Day(first.[datetime])


