  SalesQualityPSLevelCode, 
  SalesQualitySQMLevelCode, 
  SalesQualityRSMLevelCode, 
  SalesQualityASDLevelCode, 
  SalesQualityCorpLevelCode, 
  PracticeCode, 
  ReportMonth, 
  SummaryPeriod, 
  ComplianceCategoryCode, 
  SubmittedRiskProposalQty, 
  SubmittedRandomProposalQty, 
  SubmittedOtherProposalQty, 
  DisclosedReplacementQty, 
  UnDisclosedReplacementQty, 
