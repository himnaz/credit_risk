CREATE VIEW [dbo].[sa_ows_SCRTY_AssociatedBusinessesMergedView]
AS 
	Select distinct b.BusinessUID, b.BusinessTradingName, b.BusinessCompanyName, 1 as ActiveFirm
				FROM StaticData.sa_ows_SCRTY_ActiveBusinesses b with (NOLOCK)
				LEFT JOIN staticdata.sa_ows_SCRTY_InactiveBusinesses b2 with (NOLOCK) on b.BusinessUID = b2.BusinessUID
				where b2.BusinessUID is null  --only where active business UID not in the inactive table - check if needed 
				and (b.BusinessContainsActiveAdvisers = 1 or b.BusinessContainsInactiveAdvisers = 1)
				UNION
				Select distinct b.BusinessUID, b.BusinessTradingName, b.BusinessCompanyName, 0 as ActiveFirm
				FROM StaticData.sa_ows_SCRTY_InactiveBusinesses b with (NOLOCK)
				LEFT JOIN staticdata.sa_ows_SCRTY_ActiveBusinesses b2 with (NOLOCK) on b.BusinessUID = b2.BusinessUID
				where b2.BusinessUID is null  --only where active business UID not in the active table - check if needed 
			    and (b.InactiveBusinessContainsActiveAdvisers = 1 or b.InactiveBusinessContainsInactiveAdvisers = 1)

