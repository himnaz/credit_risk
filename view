CREATE VIEW [dbo].[owhov_DuplicateActiveSupervisors] as
select top 100 PERCENT
  agentcode as UID,
  rtrim(descn) as Name,
  agenttypedescription as Type,
  competentstatusdescription as Status, 
  GivesAdvice,
case cansupervise 
    when 1 then 'Yes' 
    else 'No'   
    end as Supervisor, 
  case participanttype 
    when 11 then 'Span' 
    when 12 then 'Sale' 
    end as Role, 
  case defaultvalue 
    when 1 then 'Ticked' 
    end as Flag,
  count(*) as Count 
from msit_agenthierarchyhistory inner join mstt_agents on code = agentcode 
where participanttype in (11,12) 
  and defaultvalue = 1 
group by agentcode,
  descn,
  agenttypedescription,
  competentstatusdescription,
  GivesAdvice,
  case cansupervise 
    when 1 then 'Yes' 
    else 'No' 
    end, 
  case participanttype 
    when 11 then 'Span'   
    when 12 then 'Sale' 
    end, 
  case defaultvalue 
    when 1 then 'Ticked' 
    end 
  having count(*) > 1 
order by 1,2





