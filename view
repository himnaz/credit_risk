CREATE VIEW [dbo].[owhov_EDIStatementTotals] as


Select TOP 100 PERCENT
edh.Statementid as Statement,edh.datereceived as FileDate,edh.FileName as FileName,
edh.dateprocessed as DateLoaded,max(ex.comp_code) as Provider,
count(distinct case when len(edc.memberreferencenumber) > 0 then edc.memberreferencenumber 
when len(edc.policynumber) > 0 then edc.policynumber else edc.policynumber end) as PolicyCount,
count(*) as PaymentCount,sum(isnull(edc.amountreceived,0)) as TotalPayment,
sum(case when ex.type in (5,6) and ex.init_id is null then 1 else 0 end) as UnmatchedSuspenseCount,
sum(case when ex.type in (5,6) and ex.init_id is null then isnull(ex.amount_rec,0) else 0 end) as UnmatchedSuspenseAmount,
sum(case when ex.type in (5,6) and ex.init_id is not null then 1 else 0 end) as MatchedSuspenseCount,
sum(case when ex.type in (5,6) and ex.init_id is not null then isnull(ex.amount_rec,0) else 0 end) as MatchedSuspenseAmount

from msit_edifactcommissionstatementcontents edc
inner join msit_edifactcommissionstatementheader edh on edh.id = edc.statementheaderid
left outer join mstt_expectation ex on ex.id = edc.pacc_id

group by edh.Statementid,edh.datereceived,edh.FileName,edh.dateprocessed
--having sum(case when ex.type in (5,6) and ex.init_id is null then 1 else 0 end) > 0

order by edh.statementid desc






