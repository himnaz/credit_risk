CREATE VIEW [StaticData].[sa_ows_ProductMergeView]
AS 

SELECT p.[InternalProductID]
	  ,p.[ProductId]
	  ,p.[InternalProductTypeID]
	  ,p.[ProductType]
	  ,p.[DisplayName]
	  ,p.[ISLDescription]
	  ,p.[ProductCodeSwift]
	  ,p.[ValidationAction]
	  ,p.[CVITypeID]
	  ,p.[XMLMessageModel]
	  ,p.[IsJointable]
	  ,p.[IsGapFill]
	  ,p.[ExcludedFromSR]
	  ,p.[OnPlatform]
	  ,p.[IsOffshore]
	  ,NULL AS [QuoteTypeID]
	  ,p.[FeeApplies]
	  ,p.[AutoFee]
	  ,p.[Sellable]
	  ,p.[ForceTrailSplitToSeller]
	  ,p.[ForceRenewalSplitToSeller]
	  ,p.[DateCreated]
	  ,p.[DateUpdated]
	  ,p.[EffectiveStartDate]
	  ,p.[EffectiveEndDate]
	  ,p.[Notes]
	  ,p.[CreatedBy]
	  ,p.[UpdatedBy]
	  ,p.[DisplayNameForLetter]
	  ,p.[AllowCombinedOnOffPlatformSR]
	  ,p.[PlatformID]
	  ,p.[DisplayOrder]
	  ,p.[DisplayNameForGrid]
	  ,p.[DisplayNameForLATCalculationScreen]
	  ,p.[RetentionRateApplies]
	  ,p.[AccountNumberMaskType]
	  ,null as IsLifeProductType
	  ,null as IsCriticalIllnessProductType
	  ,null as IsIncomeProtectionPlanProductType
	  ,null as IsWholeOfLifeProductType
	  ,pr.DisplayName as ProviderName
	  ,pr.InternalProviderID
	  ,pr.ProviderCodeSwift	  
	  ,pp.ProductCodeDPoS
	  ,null as ApplicableCondorCode
	  ,pr.ProviderID
	  ,pr.EffectiveStartDate as ProviderStartDate
	  ,pr.EffectiveEndDate as ProviderEndDate
	  ,pp.EffectiveStartDate as ProviderProductStartDate
	  ,pp.EffectiveEndDate as ProviderProductEndDate	  
	  ,pr.ISLDescription as ProviderISLDescription
	  ,pp.ProviderCodeDPoS as ProviderCodeDPoS
	  ,null as DealID
	  ,0 as SubmissionHeaderProductType
	  , p.IsDrawdown as IsDrawdown
	   ,null as MortgageType	 
  FROM [StaticData].[sa_ows_Product] p with (nolock) 
  inner join [StaticData].sa_ows_ProviderProducts pp  with (nolock)  on p.InternalProductID = pp.InternalProductID
  inner join [StaticData].sa_ows_Provider pr  with (nolock)  on pr.InternalProviderID = pp.InternalProviderID

	UNION

SELECT p.[InternalProductID]
	  ,p.[ProductId]
	  ,p.[InternalProductTypeID]
	  ,p.[ProductType]
	  ,p.[DisplayName]
	  ,p.[ISLDescription]
	  ,p.[ProductCodeSwift]
	  ,p.[ValidationAction]
	  ,p.[CVITypeID]
	  ,p.[XMLMessageModel]
	  ,p.[IsJointable]
	  ,p.[IsGapFill]
	  ,p.[ExcludedFromSR]
	  ,p.[OnPlatform]
	  ,p.[IsOffshore]
	  ,p.[QuoteTypeID]
	  ,p.[FeeApplies]
	  ,p.[AutoFee]
	  ,p.[Sellable]
	  ,p.[ForceTrailSplitToSeller]
	  ,p.[ForceRenewalSplitToSeller]
	  ,p.[DateCreated]
	  ,p.[DateUpdated]
	  ,p.[EffectiveStartDate]
	  ,p.[EffectiveEndDate]
	  ,p.[Notes]
	  ,p.[CreatedBy]
	  ,p.[UpdatedBy]
	  ,p.[DisplayNameForLetter]
	  ,p.[AllowCombinedOnOffPlatformSR]
	  ,p.[PlatformID]
	  ,p.[DisplayOrder]
	  ,p.[DisplayNameForGrid]
	  ,p.[DisplayNameForLATCalculationScreen]
	  ,p.[RetentionRateApplies]
	  ,p.[AccountNumberMaskType]
	  ,(case when eventTypes.LifeEventType > 0 then 1 else 0 end)as IsLifeProductType
	  ,(case when eventTypes.CICEventType > 0 then 1 else 0 end) as IsCriticalIllnessProductType
	  ,(case when eventTypes.IPEventType > 0 then 1 else 0 end) as IsIncomeProtectionPlanProductType
	  ,(case when eventTypes.WOLEventType > 0 then 1 else 0 end) as IsWholeOfLifeProductType
	  ,pr.DisplayName as ProviderName
	  ,pr.InternalProviderID
	  ,pr.ProviderCodeSwift
	  ,CASE p.QuoteTypeID
			WHEN 3 THEN CONVERT(VARCHAR(15), p.InternalProductID) -- <- 3 = Accident Protection
			ELSE ISNULL(SUBSTRING(
				(
					SELECT ',' + pc.ProductCodeSwift AS [text()]
					FROM Policy.sa_ows_ProtectionProductCodes pc with (nolock) 
					WHERE pc.InternalProductID = p.InternalProductID
					AND pc.IsCondorCode = 0
					ORDER BY p.InternalProductID
					FOR XML PATH ('')
				), 2, 1000), '') 
		END AS ProductCodeDPoS
	  ,
		( SELECT top 1 pc.ProductCodeSwift 
			FROM Policy.sa_ows_ProtectionProductCodes pc with (nolock) 
			WHERE pc.InternalProductID = p.InternalProductID
			AND pc.IsCondorCode = 1) as ApplicableCondorCode
	  ,pr.ProviderID
	  ,pr.EffectiveStartDate as ProviderStartDate
	  ,pr.EffectiveEndDate as ProviderEndDate
	  ,pp.EffectiveStartDate as ProviderProductStartDate
	  ,pp.EffectiveEndDate as ProviderProductEndDate
	  ,pr.ISLDescription as ProviderISLDescription
	  ,pp.ProviderCodeDPoS as ProviderCodeDPoS
	  ,null as DealID
	  ,2 as SubmissionHeaderProductType
	  , null as IsDrawdown
	  ,null as MortgageType
  FROM [Policy].[sa_ows_ProtectionProduct] p with (nolock) 
  inner join Policy.sa_ows_ProtectionProviderProducts pp  with (nolock)  on p.InternalProductID = pp.InternalProductID
  inner join Policy.sa_ows_ProtectionProvider pr  with (nolock)  on pr.InternalProviderID = pp.InternalProviderID
  left join
  (
	select count(case when pbt.IsLifeEventType=1 then 1 end) as LifeEventType,
		   count(case when pbt.IsCICEventType=1 then 1 end) as CICEventType,
		   count(case when pbt.BenefitTypeID=4 then 1 end) as IPEventType,
		   count(case when pbt.BenefitTypeID=3 then 1 end) as WOLEventType,
		   pp.InternalProductID
		   from Policy.sa_ows_ProtectionProduct pp with (nolock)
		   inner join Policy.sa_ows_ProtectionProductBenefitTypes pbt with (nolock) on pp.InternalProductID = pbt.InternalProductID
		   group by pp.InternalProductID
  )eventTypes on eventTypes.InternalProductID = p.InternalProductID
  
  UNION

  SELECT p.[InternalProductID]
	  ,p.[ProductId]
	  ,p.[InternalProductTypeID]
	  ,p.[ProductType]
	  ,p.[DisplayName]
	  ,p.[ISLDescription]
	  ,p.[ProductCodeSwift]
	  ,p.[ValidationAction]
	  ,p.[CVITypeID]
	  ,p.[XMLMessageModel]
	  ,p.[IsJointable]
	  ,p.[IsGapFill]
	  ,p.[ExcludedFromSR]
	  ,p.[OnPlatform]
	  ,p.[IsOffshore]
	  ,0 AS [QuoteTypeID] -- <- Mortgage Brain
	  ,p.[FeeApplies]
	  ,p.[AutoFee]
	  ,p.[Sellable]
	  ,p.[ForceTrailSplitToSeller]
	  ,p.[ForceRenewalSplitToSeller]
	  ,p.[DateCreated]
	  ,p.[DateUpdated]
	  ,p.[EffectiveStartDate]
	  ,p.[EffectiveEndDate]
	  ,p.[Notes]
	  ,p.[CreatedBy]
	  ,p.[UpdatedBy]
	  ,p.[DisplayNameForLetter]
	  ,p.[AllowCombinedOnOffPlatformSR]
	  ,p.[PlatformID]
	  ,p.[DisplayOrder]
	  ,p.[DisplayNameForGrid]
	  ,p.[DisplayNameForLATCalculationScreen]
	  ,p.[RetentionRateApplies]
	  ,p.[AccountNumberMaskType]
	  ,p.IsLifeProductType
	  ,p.IsCriticalIllnessProductType
	  ,p.IsIncomeProtectionPlanProductType
	  ,p.IsWholeOfLifeProductType
	  ,pr.DisplayName as ProviderName
	  ,pr.InternalProviderID
	  ,pr.ProviderCodeSwift
	  ,pp.ProductCodeDPoS
	  ,null as ApplicableCondorCode
	  ,pr.ProviderID
	  ,pr.EffectiveStartDate as ProviderStartDate
	  ,pr.EffectiveEndDate as ProviderEndDate
	  ,pp.EffectiveStartDate as ProviderProductStartDate
	  ,pp.EffectiveEndDate as ProviderProductEndDate
	  ,pr.ISLDescription as ProviderISLDescription
	  ,pp.ProviderCodeDPoS as ProviderCodeDPoS
	  ,pr.[DealID]
	  ,1 as SubmissionHeaderProductType
	  , null as IsDrawdown
	  ,p.[MortgageType]
  FROM [Policy].[sa_ows_MortgageProduct] p with (nolock) 
  inner join Policy.sa_ows_MortgageProviderProducts pp  with (nolock)  on p.InternalProductID = pp.InternalProductID
  inner join Policy.sa_ows_MortgageProvider pr  with (nolock)  on pr.InternalProviderID = pp.InternalProviderID

