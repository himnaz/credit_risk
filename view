GO
create view [dbo].[rpt_OBPvsInsightCaseDiscrepancies]
as
select a.CaseID,
       a.SubmissionDate,
       o.clientfacingopportunityid OBPOpportunityRef,
       ov.versiondate CompletedDate,
       case when c.bpol_id is null then 'No' else 'Yes' end CaseInInsight,
       isnull(c.case_casereference, '') InsightOpportunityRef
from sa_obp_opportunity o with (nolock)
     inner join (select ov.opportunityid,        -- last ov that was completed
                        ov.versiondate,
                        row_number() over (partition by ov.opportunityid order by ov.versiondate desc) rn
                 from sa_obp_opportunityversion ov with (nolock)
                      inner join sa_obp_OpportunityWorkflowStage ows with (nolock) on ows.id = ov.OpportunityWorkflowStageId and
                                                                                               ows.milestoneid = 5) ov on ov.opportunityid = o.id and
                                                                                                                          ov.rn = 1
     inner join obpmi_arrangement a with (nolock) on a.opportunityid = o.id and    
                                                     a.submissionstatus = 1
     left join (select o.case_casereference,
                       c.bpol_id,
                       convert(int, c.bpol_backofficeid) bpol_CaseID,
                       row_number() over (partition by convert(int, c.bpol_backofficeid) order by bpol_createddate) RN
                from sa_insight_basicpolicy c with (nolock)
                     inner join (select case_id,
                                        rtrim(ltrim(isnull(case_casereference, '0'))) case_casereference,
                                        row_number() over (partition by rtrim(ltrim(isnull(case_casereference, '0'))) order by case_createddate) RN
                                 from sa_insight_salescase with (nolock)
                                 where rtrim(ltrim(isnull(case_casereference, '0'))) != '0') o on c.bpol_parentid = o.case_id and
                                                                                                  o.rn = 1 and
                                                                                                  rtrim(ltrim(isnull(c.bpol_backofficeid, '0'))) != '0' and
                                                                                                  isnumeric(c.bpol_backofficeid) = 1
                     left join (sa_insight_attribute with (nolock)
                                inner join sa_insight_attributelink with (nolock) on attl_attributeid = att_id and
                                                                                     att_name = 'PRODUCT.PROPOSALDATE') on attl_parentid = bpol_id) c on c.rn = 1 and
                                                                                                                                        c.bpol_caseid = a.caseid
where bpol_id is null or
      c.case_casereference != o.clientfacingopportunityid
--order by ov.versiondate,
--         o.clientfacingopportunityid,
--         a.CaseID
GO
/****** Object:  View [dbo].[rpt_OBPvsInsightOpportunityCaseCountMismatches]    Script Date: 7/2/2026 12:50:24 PM ******/
