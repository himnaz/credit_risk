      1.Business Quality Manager Id
      2.Area Director Id
      3.Swift business id
      4.Business name
      5.Swift Adviser id
      6.Adviser name
                                        7.B_code
                                        8.Business_Status
                                        9.ErrorCol

*******************************************************************************************************************************************************************************************************************************
*/
CREATE VIEW [dbo].[Vw_Ecode_OpenData]
AS
SELECT     CASE type WHEN 'A' THEN D .Manager2Code2 WHEN 'B' THEN D .Manager2Code1 END AS [Business Quality Manager id], 
                      CASE type WHEN 'A' THEN D .Manager4Code2 WHEN 'B' THEN D .Manager4Code1 END AS [Area Director id], 
                      CASE type WHEN 'A' THEN D .AgentCode2 WHEN 'B' THEN D .AgentCode1 END AS [Swift Business id], 
                      CASE type WHEN 'A' THEN D .DESCN2 WHEN 'B' THEN D .DESCN1 END AS [Business Name], 
                      CASE type WHEN 'A' THEN D .AgentCode1 WHEN 'B' THEN '' END AS [Swift Adviser Id], 
                      CASE type WHEN 'A' THEN D .DESCN1 WHEN 'B' THEN '' END AS [Adviser Name], E_code, 
                      CASE type WHEN 'A' THEN D .CompetentStatus2 WHEN 'B' THEN D .CompetentStatus1 END AS [Business Status], 
                      CASE WHEN type = '' THEN 'Y' ELSE 'N' END AS Errorcol
FROM         (SELECT     a.OSCAR_Prefix + a.OSCAR_Serial + a.OSCAR_Suffix AS E_code, CASE WHEN b.Agenttype IN (2, 19, 42, 46, 47, 48, 49, 50) 
                                              THEN 'B' WHEN b.Agenttype IN (3, 4, 5, 17, 43, 44, 45, 51, 52, 53, 54, 55) THEN 'A' ELSE '' END AS Type, b.CODE AS AgentCode1, 
                                              b.DESCN AS DESCN1, b.Manager2Code AS Manager2Code1, b.Manager4Code AS Manager4Code1, 
                                              b.CompetentStatus AS CompetentStatus1, c.CODE AS AgentCode2, c.DESCN AS DESCN2, c.Manager2Code AS Manager2Code2, 
                                              c.Manager4Code AS Manager4Code2, c.CompetentStatus AS CompetentStatus2
                       FROM          Head_Office_Systems.dbo.owhot_OSCARSwiftAgentXref AS a INNER JOIN
                                              dbo.mstt_Agents AS b ON a.AgentCode = b.CODE LEFT OUTER JOIN
                                              dbo.mstt_Agents AS c ON b.Firm = c.CODE) AS D
UNION ALL
SELECT     [Business Quality Manager id], [Area Director id], [Swift Business id], [Business Name], [Swift Adviser id], [Adviser Name], [Advisor code] AS Ecode, 
                      '1' AS Expr1, 'N' AS Expr2
FROM         Head_Office_Systems.dbo.owoa_ZurichListingKnowledgeBase
WHERE     ([Advisor code] LIKE 'E%') -- steve removed on 11/01/10 --AND ([Swift Business id] LIKE '1%')

