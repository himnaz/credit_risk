CREATE view [dbo].[rpt_OBPBusiness] as
select distinct o.OpportunityRef,
                case when o.case_id is null then 'No' else 'Yes' end OpportunityInInsight,
                ows.stagename OpportunityStage,
                a.arrangementtype ArrangementType,
                p.policyref SwiftCaseID,
                a.caseid OBPCaseID,
                c.ProposalDate,
                case when ptp.policyid is null then 'No' else 'Yes' end ProposalInSwift,
                ptp.createdatetime SwiftLoadDate,
                case when pti.policyid is null then 'No' else 'Yes' end PaidInSwift,
                case when c.bpol_id is null then 'No' else 'Yes' end CaseInInsight,
                isnull(p.cont_num, a.policynumber) PolicyNumber,
                a.applicationdate ApplicationDate,
                c.submissiondate SubmissionDate,
                isnull(p.comp_code, a.provider) Provider,
                isnull(p.productcode, a.productcode) Product,
                case when pqc.SalesProcess = 0 and
                          ph.DualSalesProcess = 'Y' then 'COB' 
                     else ph.RegulationDefault
                end Regulation,
                s.integrationalias OBPSellerID,
                s.firstname + ' ' + s.lastname OBPSellerName,
                isnull(ptp.agentcode, pti.agentcode) SwiftSellerID,
                u.usr_name SellerName,
                isnull(contractstatus.code_description, 'Missing in Insight') ContractStatus,
                ag.firm EnterpriseUID,
                d.dist_companyname EnterpriseName,
                isnull(ad.adusercode, ads.code) ADUID,
                isnull(adu.usr_name, ads.descn) ADName,
                c1.firstnames + ' ' + c1.name Client1Name,
                c1.birthdate Client1DOB,
                c1.Gender Client1Gender,
                c1.Postcode Client1Postcode,
                c2.firstnames + ' ' + c2.name Client2Name,
                c2.birthdate Client2DOB,
                c2.Gender Client2Gender,
                c2.Postcode Client2Postcode,
                ac.premiumamount OBPPremium,
                ac.icamount OBPCommission,
                ptp.amount SwiftPropPremium,
                ptp.CommInitialAmount SwiftPropCommission,
                ptp.CommDeductedatSource SwiftPropCommSacrifice,
                pti.amount SwiftIssPremium,
                pti.comminitialamount SwiftIssCommission,
                pti.bacsamount BACSPayments,
                os.description SwiftSource,
                case when c.pol_num is null then null
                     when isnull(ptp.createdby, pti.createdby) is null then 'Auto'
                     else 'Manual'
                end SwiftCreationMethod
from rds_case c
     inner join obpmi_arrangement a with (nolock) on a.arrangementid = c.arrangementid
     inner join rds_opportunity o with (nolock) on o.id = c.opportunityid
     left join sa_obp_opportunityversion ov with (nolock) on ov.opportunityid = o.opportunityid and
                                                             ov.currentversion = 1
     left join sa_obp_opportunityworkflowstage ows with (nolock) on ows.id = ov.OpportunityWorkflowStageId
     left join sa_swift_s_polmai p with (nolock) on p.pol_num = c.pol_num
     left join sa_swift_PolicyQualityCheckB30 pqc with (nolock) on pqc.policyid = p.pol_num
     left join ((select policyid,
                        proposaldate,
                        frequency,
                        sum(isnull(amount, 0)) amount,
                        min(createdatetime) createdatetime,
                        agentcode,
                        min(createdby) createdby,
                        sum(comminitialamount) comminitialamount,
                        sum(commdeductedatsource) commdeductedatsource
                 from sa_swift_policytransactions pt with (nolock)
                 where pt.transtype = 39 and
                       pt.proposaldate is not null and
                       isnull(pt.adminmethod, '') !='X'
                 group by policyid,
                          proposaldate,
                          frequency,
                          agentcode) ptp
                 full outer join (select policyid,
                                         proposaldate,
                                         frequency,
                                         sum(isnull(pt.amount, 0)) amount,
                                         agentcode,
                                         min(createdby) createdby,
                                         sum(comminitialamount) comminitialamount,
                                         sum(bacs.Amount) as bacsAmount 
                                  from sa_swift_policytransactions pt with (nolock)
                                       left join sa_swift_S_AGMPAY bacs with (nolock) on exported = 'T' and
                                                                                         Agent_Code = agentcode and
                                                                                         bacs.transactionid = pt.id
                                  where pt.transtype in (1, 17, 23, 45) and
                                        pt.proposaldate is not null and
                                        isnull(pt.adminmethod, '') !='X'
                                  group by policyid,
                                           proposaldate,
                                           frequency,
                                           agentcode) pti on ptp.proposaldate = pti.proposaldate and
                                                             ptp.policyid = pti.policyid and
                                                             ptp.frequency = pti.frequency) on isnull(ptp.proposaldate, pti.proposaldate) = c.proposaldate and
                                                                                               isnull(ptp.policyid, pti.policyid) = p.pol_num
     left join mstt_ProductHierarchy PH with (nolock) on PH.ProductCode = P.ProductCode
     left join (rds_code arrangementtype with (nolock)
                inner join rds_codetype ct with (nolock) on ct.id = arrangementtype.typeid and
                                                            ct.name = 'Arrangement Type') on arrangementtype.code = ph.ProductGroupCode
     left join obpmi_staff s with (nolock) on s.entityid = ov.rristaffentityid
     left join sa_insight_userdetails u with (nolock) on u.usr_externalid = coalesce(ptp.agentcode, pti.agentcode, s.integrationalias)
     left join sa_insight_staff st with (nolock) on st.staf_userid = u.usr_id
     left join sa_insight_codedescription contractstatus with (nolock) on contractstatus.code_code = st.staf_contractstatus and
                                                                          contractstatus.code_codetype = 527
     left join sa_swift_s_agents ag with (nolock) on ag.code = coalesce(ptp.agentcode, pti.agentcode, s.integrationalias)
     left join sa_swift_s_agents ads with (nolock) on ads.code = ag.manager4code
     left join sa_insight_distributor d with (nolock) on d.dist_externalid = ag.firm
     left join (dbo.f_insight_getadsofallusers(null) ad
                inner join sa_insight_userdetails adu with (nolock) on adu.usr_id = ad.aduserguid) on ad.usercode = coalesce(ptp.agentcode, pti.agentcode, s.integrationalias)
     left join sa_swift_s_client_1 c1 with (nolock) on c1.client_num = p.client_num
     left join sa_swift_s_client_1 c2 with (nolock) on c2.client_num = p.joint_num
     left join (select arrangementid,
                       cms.ssuid,
                       sum(premiumamount) premiumamount,
                       sum(icamount) icamount
                from obpmi_arrangementcommission ac with (nolock)
                     inner join rds_codemapping cmo with (nolock) on cmo.ssuid = ac.frequency
                     inner join config_datasource dso with (nolock) on dso.id = cmo.datasourceid and
                                                                       dso.code = 'OBP'
                     inner join rds_codemapping cms with (nolock) on cms.codeid = cmo.codeid
                     inner join config_datasource dss with (nolock) on dss.id = cms.datasourceid and
                                                                       dss.code = 'Swift'
                group by arrangementid,
                         cms.ssuid) ac on ac.arrangementid = c.arrangementid and
                                          ac.ssuid = isnull(ptp.frequency, pti.frequency)
     left outer join sa_swift_CodeOriginatingSources os with (nolock) on os.id = pqc.originatingsourceid
where c.submissiondate > dateadd(d, -8, datediff(d, 0, getdate()))
