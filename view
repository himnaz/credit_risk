create view [dbo].[rpt_DuplicateInsightCases]
as
select rtrim(ltrim(isnull(p1.bpol_backofficeid, '0'))) CaseID,
       dbo.f_ifdateconvert(al1.attl_attributevalue) ProposalDate,
       p1.bpol_createddate CaseCreatedDate,
       upper(rtrim(ltrim(isnull(c1.case_casereference, '0')))) OpportunityRef,
       usr_name OppCreatedBy,
       c1.case_createddate OppCreatedDate
from sa_insight_basicpolicy p1 with (nolock)
     inner join sa_insight_salescase c1 with (nolock) on c1.case_id = p1.bpol_parentid and
                                                         rtrim(ltrim(isnull(p1.bpol_backofficeid, '0'))) != '0' and
                                                         rtrim(ltrim(isnull(c1.case_casereference, '0'))) != '0'
     inner join sa_insight_userdetails with (nolock) on usr_id = c1.case_createdby
     left join (sa_insight_attribute a1 with (nolock)
                inner join sa_insight_attributelink al1 with (nolock) on al1.attl_attributeid = a1.att_id and
                                                                         a1.att_name = 'PRODUCT.PROPOSALDATE') on al1.attl_parentid = p1.bpol_id
     inner join (sa_insight_basicpolicy p2 with (nolock)
                 inner join sa_insight_salescase c2 with (nolock) on c2.case_id = p2.bpol_parentid and
                                                                     rtrim(ltrim(isnull(p2.bpol_backofficeid, '0'))) != '0' and
                                                                     rtrim(ltrim(isnull(c2.case_casereference, '0'))) != '0'
                 left join (sa_insight_attribute a2 with (nolock)
                            inner join sa_insight_attributelink al2 with (nolock) on al2.attl_attributeid = a2.att_id and
                                                                                     a2.att_name = 'PRODUCT.PROPOSALDATE') on al2.attl_parentid = p2.bpol_id) on rtrim(ltrim(isnull(p2.bpol_backofficeid, '0'))) = rtrim(ltrim(isnull(p1.bpol_backofficeid, '0'))) and
                                                                                                                                                                 dbo.f_ifdateconvert(al1.attl_attributevalue) = dbo.f_ifdateconvert(al2.attl_attributevalue) and
                                                                                                                                                                 p2.bpol_id != p1.bpol_id
group by p1.bpol_id,
         rtrim(ltrim(isnull(p1.bpol_backofficeid, '0'))),
         al1.attl_attributevalue,
         p1.bpol_createddate,
         rtrim(ltrim(isnull(c1.case_casereference, '0'))),
         usr_name,
         c1.case_createddate
--order by rtrim(ltrim(isnull(p1.bpol_backofficeid, '0'))),
--         p1.bpol_createddate
