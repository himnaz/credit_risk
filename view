                      msit_TrackGroups.DoubleCheckedBy, Agents_1.DESCN AS DoubleCheckedName, msit_TrackGroups.AgentClassID, Agents_2.DESCN AS AgentName, 
                      Agents_2.AgentType, Agents_2.AgentTypeDescription, Agents_2.SaleSupervisorCode as QualityManagerLevel1,agents_2.OfficeCode, -- Agents_2.Firm, 
                      Agents_2.AgentCategory, mstt_policies.POL_TYPE, mstt_policies.PolicyTypeDescription, mstt_policies.CONT_NUM, mstt_policies.COMP_CODE, 
                      mstt_policies.CompanyName, mstt_policies.ProductCode, mstt_policies.ProductCodeDescription, mstt_policies.PolicyRef as CaseID, mstt_policies.OriginatingSource, 
                      case mstt_policies.OriginatingSource when 1 then 'Manual' when 2 then 'ETi' when 3 then 'OTPm'  when 4 then 'OTPc' else 'Other' end as SourceSystem,
                      mstt_policies.SalesProcess, case mstt_policies.SalesProcess when 0 then 'Full' when 1 then 'Simplefied' when null then null else 'Other' end as Process ,
                      mstt_policies.Risk, 
                      case mstt_policies.Replacement when 0 then 'N ' when 1 then 'A' when 2 then 'B' when 3 then 'C' 
                      else ' ' end as ReplacementType, 
                      case mstt_policies.UndisclosedReplacement when 0 then 'N ' when 1 then 'A' when 2 then 'B' when 3 then 'C'  when 4 then  'P'
                      else ' ' end as UndisclosedReplacementType, 
                      mstt_policies.RPA, 
                      mstt_policies.ReplacedPremium, mstt_policies.MortgageRelated, mstt_policies.RetirementInvestment, mstt_policies.PPSwitch, 
                      mstt_policies.EPSReference, mstt_policies.ReferralCode, mstt_policies.SuspendCommission, mstt_policies.ProductType, 
                      mstt_policies.ReportingProductCode, mstt_policies.ProductSubGroupCode, mstt_policies.ProductGroupCode, mstt_policies.ProductCategoryCode, 
                      mstt_policies.ProductProviderCode, mstt_policies.ReportingProductProviderCode, mstt_policies.CommRepProductProviderCode, 
                      msit_TrackGroups.NBCCFailureReason, CodeNBCCFailureReason_1.Code AS FailurereasonCode, 
                      CodeNBCCFailureReason_1.Description AS FailureReasonDesc, msit_TrackGroups.NBCCFinalFailureReason, 
                      msit_CodeNBCCFailureReason.Code AS FinalFailureReasonCode, msit_CodeNBCCFailureReason.Description AS FinalFailureReasonDesc, 
                      msit_TrackGroups.Description, msit_CodeTrackGroups.Code, msit_CodeTrackGroups.CodeNBCCCode, 
                      msit_CodeNBCCHeader.Description AS NBCCHeaderDescn
FROM         msit_CodeNBCCHeader RIGHT OUTER JOIN
                      msit_CodeTrackGroups ON msit_CodeNBCCHeader.Code = msit_CodeTrackGroups.CodeNBCCCode RIGHT OUTER JOIN
                      msit_TrackGroups ON msit_CodeTrackGroups.Description = msit_TrackGroups.Description LEFT OUTER JOIN
                      msit_IntUsers IntUsers_1 ON msit_TrackGroups.CaseAcceptedBy = IntUsers_1.ID LEFT OUTER JOIN
                      msit_IntUsers ON msit_TrackGroups.TriggeredBy = msit_IntUsers.ID LEFT OUTER JOIN
                      mstt_agents ON msit_TrackGroups.FinalCheckedby = mstt_agents.CODE LEFT OUTER JOIN
                      mstt_policies ON msit_TrackGroups.PolicyID = mstt_policies.POL_NUM LEFT OUTER JOIN
                      mstt_agents Agents_1 ON msit_TrackGroups.DoubleCheckedBy = Agents_1.CODE LEFT OUTER JOIN
                      mstt_agents Agents_2 ON msit_TrackGroups.AgentCode = Agents_2.CODE LEFT OUTER JOIN
                      msit_CodeNBCCFailureReason CodeNBCCFailureReason_1 ON 
                      msit_TrackGroups.NBCCFailureReason = CodeNBCCFailureReason_1.ID LEFT OUTER JOIN
                      msit_CodeNBCCFailureReason ON msit_TrackGroups.NBCCFinalFailureReason = msit_CodeNBCCFailureReason.ID

 

