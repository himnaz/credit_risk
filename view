CREATE View [dbo].[msdv_Date]
as



select
 DateId,
 [DateTime],
 YearMonthDay,
 [Day] as [Day],
 Years    = Year,
 Quarters = YearQuarter,
 YearMonth,
 case
  when Year = '0000' then 'Unknown'
  else substring(datename(m,DateTime),1,3) + '-' + substring(year,3,2)
 end as Months,
 Weeks  = Week,
 substring(datename(m, case
  when DayOfWeek = '2' then dateadd(dd,0,DateTime)
  when DayOfWeek = '3' then dateadd(dd,-1,DateTime)
  when DayOfWeek = '4' then dateadd(dd,-2,DateTime)
  when DayOfWeek = '5' then dateadd(dd,-3,DateTime)
  when DayOfWeek = '6' then dateadd(dd,-4,DateTime)
  when DayOfWeek = '7' then dateadd(dd,-5,DateTime)
  when DayOfWeek = '1' then dateadd(dd,-6,DateTime)
  end ),1,3)+' '
  +  datename(d, case
  when DayOfWeek = '2' then dateadd(dd,0,DateTime)
  when DayOfWeek = '3' then dateadd(dd,-1,DateTime)
  when DayOfWeek = '4' then dateadd(dd,-2,DateTime)
  when DayOfWeek = '5' then dateadd(dd,-3,DateTime)
  when DayOfWeek = '6' then dateadd(dd,-4,DateTime)
  when DayOfWeek = '7' then dateadd(dd,-5,DateTime)
  when DayOfWeek = '1' then dateadd(dd,-6,DateTime)
  end)
    as [WeekStarting],
 case
  when DayOfWeek = '2' then dateadd(dd,0,DateTime)
  when DayOfWeek = '3' then dateadd(dd,-1,DateTime)
  when DayOfWeek = '4' then dateadd(dd,-2,DateTime)
  when DayOfWeek = '5' then dateadd(dd,-3,DateTime)
  when DayOfWeek = '6' then dateadd(dd,-4,DateTime)
  when DayOfWeek = '7' then dateadd(dd,-5,DateTime)
  when DayOfWeek = '1' then dateadd(dd,-6,DateTime)
  end as [WeekStartingDate],
case 
 when substring(yearquarter,5,2) = 'Q1' then 'Quarter1'
 when substring(yearquarter,5,2) = 'Q2' then 'Quarter2'
 when substring(yearquarter,5,2) = 'Q3' then 'Quarter3'
 when substring(yearquarter,5,2) = 'Q4' then 'Quarter4'
 else 'Unknown'
end as [QuarterSplit],

case
 when substring(yearmonth,5,2) = '01' then 'Jan'
 when substring(yearmonth,5,2) = '02' then 'Feb'
 when substring(yearmonth,5,2) = '03' then 'Mar'
 when substring(yearmonth,5,2) = '04' then 'Apr'
 when substring(yearmonth,5,2) = '05' then 'May'
 when substring(yearmonth,5,2) = '06' then 'Jun'
 when substring(yearmonth,5,2) = '07' then 'Jul'
 when substring(yearmonth,5,2) = '08' then 'Aug'
 when substring(yearmonth,5,2) = '09' then 'Sep'
 when substring(yearmonth,5,2) = '10' then 'Oct'
 when substring(yearmonth,5,2) = '11' then 'Nov'
 when substring(yearmonth,5,2) = '12' then 'Dec'
 else 'Unknown'
end as [MonthSplit],
 [Day] as [DAySplit],

Month as MonthNo,
Year+'-'+Month+'-'+[Day] as [YYYY-MM-DD],
substring(datename(m,DateTime),1,3)+' '+[Day] as [MMM DD],
 AggType,
 'No' as [Cumulative]
from
 msdt_Calendartime
where
 EntryTypeId =  2










