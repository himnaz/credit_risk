/****************************************************************************
     Program:   owhov_StandingOrderUnAuth
    Author: ?
Date created: ?
                      
Description:  This program creates a view that populates an automated report.
        dts : ow_daily_scansreports
        dts : ow_daily_scans_root
        job : Openwork - Swift Data Warehouse Refresh Main Batch, step 25
        This proc would be called as follows:

  Amendment History               
  -----------------               
                      
  Date    Who     Description       
  ----    ---     -----------     
  29/9/09   AH      Added two fields to the report - ptl code of person creating Standing Order
              and date Standing Order created.
  
****************************************************************************/

CREATE VIEW [dbo].[owhov_StandingOrderUnAuth] as

Select TOP 100 PERCENT
so.agentcode as AgentUID,
so.id as SOID,
(convert(varchar, so.createddate, 103)) as StandingOrderCreatedDate, -- shows dd/mm/yyyy,
iu.description as StandingOrderCreatedBy,
coalesce(ag.tradingname,ag.descn) as AgentName,
case ag.agt_type
when 2 then 'Franchise'
when 46 then 'Access'
when 49 then 'DA'
else 'Other'
end as AgentType,
case ag.competentstatus
when 1 then 'Active'
when 2 then 'Left'
when 4 then 'Canc'
when 5 then 'PreApp'
when 6 then 'NPW'
end as AgentStatus,
ag.manager2code as RSMUID,a2.descn as RSMName,
a2.manager4code as ASDUID,a3.descn as ASDName,
so.standingordercode as SOCode,so.Description as Description,
co.description as SOType,
convert(varchar,so.startdate,106) as StartDate,so.EndDate as EndDate,so.nextpaymentDue as NextPaymentOn,
case so.Frequency
when 2 then 'Mth'
when 5 then 'Ann'
when 6 then 'Sin'
else 'Oth'
end as SOFreq,
so.paymentamount as SOAmount,so.Totalpaymentamount as SoTotalAmount,
so.amountpaidtodate as SOPaidToDate,
case so.subjecttovat
when 0 then 'N'
when 1 then 'Y'
end as VATable,
un.amount as UnpaidAmount,un.paymentduedate as UnpaidPaymentDue,
case when un.paymentduedate is not null and un.paymentduedate > so.EndDate then 'Yes' 
end as PastEndDate,pa.export_date as BACSDate,un.createdatetime as UnpaidCreatedDate,
case so.authorised when 0 then 'Auth' when 1 then 'Decl' when 2 then 'O/S' end as AuthStatus,
un.amount as UnpaidListAmount,
pa.vatamount as VatAmount,pa.netamount as NetAmount,pa.amount as PaidAmount

from msit_commagentstandingorders so
inner join msit_s_agents ag on ag.code = so.agentcode
inner join msit_codestandingorders co on co.code = so.standingordercode
left outer join msit_s_agmfil un on un.agent_code = so.agentcode and un.standingorderid = so.id
left outer join msit_s_agmpay pa on pa.agmid = un.id
inner join msit_s_agents a2 on a2.code = ag.manager2code
inner join msit_s_agents a3 on a3.code = a2.manager4code
left outer join msit_IntUsers iu on so.CreatedBy = iu.ID
where 
so.authorised = 2

order by so.agentcode,so.id,un.id


