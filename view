CREATE view [dbo].[rpt_OBPCompetition] as
select distinct o.OpportunityRef,
                case when o.case_id is null then 'No' else 'Yes' end OpportunityInInsight,
                isnull(ows.stagename, case when o.id is null then 'None' else 'Complete' end) OpportunityStage,
                a.arrangementtype ProdType,
                p.policyref SwiftCaseID,
                a.caseid OBPCaseID,
                case when p.policyref = a.caseid then 'No'
                     when p.policyref is not null then 'Yes'
                end Increase,
                c.ProposalDate,
                case when ptp.policyid is null then 'No' else 'Yes' end ProposalInSwift,
                ptp.createdatetime SwiftLoadDate,
                case when pti.policyid is null then 'No' else 'Yes' end PaidInSwift,
                case when c.bpol_id is null then 'No' else 'Yes' end CaseInInsight,
                isnull(p.cont_num, a.policynumber) PolicyNumber,
                a.applicationdate ApplicationDate,
                c.submissiondate SubmissionDate,
                isnull(p.comp_code, a.provider) Provider,
                isnull(p.productcode, a.productcode) Product,
                case when pqc.SalesProcess = 0 and
                          ph.DualSalesProcess = 'Y' then 'COB' 
                     else ph.RegulationDefault
                end Regulation,
                s.integrationalias OBPSellerID,
                s.firstname + ' ' + s.lastname OBPSellerName,
                isnull(ptp.agentcode, pti.agentcode) SwiftSellerID,
                u.usr_name SellerName,
                isnull(contractstatus.code_description, 'Missing in Insight') ContractStatus,
                ag.firm EnterpriseUID,
                d.dist_companyname EnterpriseName,
                isnull(ad.adusercode, ads.code) ADUID,
                isnull(adu.usr_name, ads.descn) ADName
from rds_case c
     inner join rds_opportunity o with (nolock) on o.id = c.opportunityid and
                                                   c.submissiondate >= 'Sep 27, 2010'
     inner join obpmi_arrangement a with (nolock) on a.arrangementid = c.arrangementid
     inner join sa_obp_opportunityversion ov with (nolock) on ov.opportunityid = o.opportunityid and
                                                              ov.currentversion = 1
     left join sa_obp_opportunityworkflowstage ows with (nolock) on ows.id = ov.OpportunityWorkflowStageId
     left join sa_swift_s_polmai p with (nolock) on p.pol_num = c.pol_num
     left join sa_swift_PolicyQualityCheckB30 pqc with (nolock) on pqc.policyid = p.pol_num
     left join ((select policyid,
                        proposaldate,
                        max(agentcode) agentcode,
                        min(createdatetime) createdatetime
                 from sa_swift_policytransactions pt with (nolock)
                 where pt.transtype = 39 and
                       pt.proposaldate is not null and
                       isnull(pt.adminmethod, '') !='X'
                 group by policyid,
                          proposaldate) ptp
                 full outer join (select policyid,
                                         proposaldate,
                                         max(agentcode) agentcode
                                  from sa_swift_policytransactions pt with (nolock)
                                  where pt.transtype in (1, 17, 23, 45) and
                                        pt.proposaldate is not null and
                                        isnull(pt.adminmethod, '') !='X'
                                  group by policyid,
                                           proposaldate) pti on ptp.proposaldate = pti.proposaldate and
                                                                ptp.policyid = pti.policyid) on isnull(ptp.proposaldate, pti.proposaldate) = c.proposaldate and
                                                                                                isnull(ptp.policyid, pti.policyid) = p.pol_num
     left join mstt_ProductHierarchy PH with (nolock) on PH.ProductCode = P.ProductCode
     left join obpmi_staff s with (nolock) on s.entityid = ov.rristaffentityid
     left join sa_insight_userdetails u with (nolock) on u.usr_externalid = coalesce(ptp.agentcode, pti.agentcode, s.integrationalias)
     left join sa_insight_staff st with (nolock) on st.staf_userid = u.usr_id
     left join sa_insight_codedescription contractstatus with (nolock) on contractstatus.code_code = st.staf_contractstatus and
                                                                          contractstatus.code_codetype = 527
     left join sa_swift_s_agents ag with (nolock) on ag.code = coalesce(ptp.agentcode, pti.agentcode, s.integrationalias)
     left join sa_swift_s_agents ads with (nolock) on ads.code = ag.manager4code
     left join sa_insight_distributor d with (nolock) on d.dist_externalid = ag.firm
     left join (dbo.f_insight_getadsofallusers(null) ad
                inner join sa_insight_userdetails adu with (nolock) on adu.usr_id = ad.aduserguid) on ad.usercode = coalesce(ptp.agentcode, pti.agentcode, s.integrationalias)
