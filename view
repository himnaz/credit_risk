                      pt.IssuedTranID NOT IN
                          (SELECT DISTINCT transactionid
                            FROM          mstt_Expectation)) AND (pt.TransType IN (1, 17, 23, 39))
ORDER BY pt.PolicyID, pt.TransactionNumber

