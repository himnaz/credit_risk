/****** Object:  View [dbo].[rpt_RunningTotals]    Script Date: 03/09/2012 08:47:27 ******/
/*****************************************************************************************************
View:  	rpt_RunningTotals						
			
Description:	This View supports the Running Total report.

Amendment History               
-----------------               
                      
Date		Who     Description       
----		---     -----------     
09/03/2012	MPC		Amendment to cater for Database Reorganisation to be deployed 5/4/12.
					PlanID replaced by PlanSnapshotId on sa_obp_OpportunityVersion table
					which links to PlanId on Opportunity or Arranagement/Quote tables 
					via PlanSkeleton table.

*****************************************************************************************************/
CREATE view [dbo].[rpt_RunningTotals] as
SELECT S.IntegrationAlias as AgentUID,
       S.FirstName + ' ' + S.LastName as AgentName,
       jt.code_description JobTitle,
       cs.code_description ContractStatus,
       f.firmcode as FirmUID,
       dist.dist_companyname as FirmName,
       bqm.qmusercode BQMUID,
       bqmusr.usr_name BQMName,
       ad.adusercode ADUID,
       adusr.usr_name ADName,
       count(distinct case when ov1.versiondate > DATEADD(month, -1, DATEADD(day, DATEDIFF(day, 0, getdate()), 0)) then ov1.opportunityid end) Replacements1Month,
       count(distinct case when ov1.versiondate > DATEADD(month, -3, DATEADD(day, DATEDIFF(day, 0, getdate()), 0)) then ov1.opportunityid end) Replacements3Months,
       count(distinct ov1.opportunityid) ReplacementsTotal,
       count(distinct case when ov2.versiondate > DATEADD(month, -1, DATEADD(day, DATEDIFF(day, 0, getdate()), 0)) then ov2.opportunityid end) Switches1Month,
       count(distinct case when ov2.versiondate > DATEADD(month, -3, DATEADD(day, DATEDIFF(day, 0, getdate()), 0)) then ov2.opportunityid end) Switches3Months,
       count(distinct ov2.opportunityid) SwitchesTotal,
       count(distinct case when ov3.versiondate > DATEADD(month, -1, DATEADD(day, DATEDIFF(day, 0, getdate()), 0)) then ov3.opportunityid end) SelfInvestedFunds1Month,
       count(distinct case when ov3.versiondate > DATEADD(month, -3, DATEADD(day, DATEDIFF(day, 0, getdate()), 0)) then ov3.opportunityid end) SelfInvestedFunds3Months,
       count(distinct ov3.opportunityid) SelfInvestedFundsTotal,
       count(distinct case when ov.versiondate > DATEADD(month, -1, DATEADD(day, DATEDIFF(day, 0, getdate()), 0)) then ov.opportunityid end) OpportunitiesCompleted1Month,
       count(distinct case when ov.versiondate > DATEADD(month, -3, DATEADD(day, DATEDIFF(day, 0, getdate()), 0)) then ov.opportunityid end) OpportunitiesCompleted3Months,
       count(distinct ov.opportunityid) OpportunitiesCompletedTotal
from obpmi_Staff S with (nolock)
     inner join sa_obp_OpportunityVersion ov with (nolock) on ov.RRIStaffEntityID = S.entityid
     inner join sa_obp_OpportunityWorkflowStage ows with (nolock) on ows.id = ov.OpportunityWorkflowStageId and
