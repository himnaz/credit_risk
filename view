GO
--SELECT     CODE, ValidFromDate, ValidToDate,lastmodifieddate, Active, FranchiseSize, IDHISTid_type
--FROM         mstt_AgentsHistory WHERE idhistid_type in 
--(select max(idhistid_type)from mstt_agentsHistory group by code ,lastmodifieddate )
--or validfromdate < '1950/01/01'
--order by 1,7--
CREATE view [dbo].[cscv_AgentsHistoryHierarchy] as
SELECT     mstt_agentshistory.CODE as agentCode ,mstt_agentshistory.ValidFromDate, 
           mstt_agentshistory.ValidToDate,mstt_agentshistory.lastmodifieddate,
           mstt_agentshistory.AgentType, 
           mstt_agentshistory.AgentTypeDescription, coalesce(mstt_agentshistory.TradingName,mstt_agentshistory.DESCN) as AgentDesc, 
           mstt_agentshistory.AgentCategory, mstt_agentshistory.AgentCategoryDescription,
           mstt_agentshistory.GivesAdvice, 
           coalesce(mstt_agentshistory.OscarDateStarted , mstt_agentshistory.dateStarted) as AgentStartDate, 
           mstt_agentshistory.DateLeaving as AgentLeftDate, mstt_agentshistory.OscarAgentId,
          ( mstt_agentshistory.OscarAgentPrefix + mstt_agentshistory.OscarAgentSerial + mstt_agentshistory.OscarAgentSuffix) as AgentOscarCode,
           mstt_agentshistory.CompetentStatus, mstt_agentshistory.CompetentStatusDescription, 
           mstt_agentshistory.FranchiseSize, 
           (select  'FranchiseType' = case  when mstt_agentshistory.FranchiseSize between '0' and  '1'  then 'Sole Trader' 
                                                             when mstt_agentshistory.FranchiseSize  between  '2' and '9'  then 'Small (2-9)' 
                                                             when mstt_agentshistory.FranchiseSize  >  '9'  then 'Large (10+) ' 
                                                                                                                           else 'unknown' end)  as FranchiseType,
          mstt_agentshistory.Firm as FirmCode,  mstt_Agents_1.AgentType AS FirmType,
           mstt_Agents_1.AgentTypeDescription AS FirmTypeDescription,
           coalesce(mstt_agents_1.TradingName, mstt_Agents_1.DESCN) AS FirmDescn, mstt_Agents_1.AgentCategory AS FirmCategory,
           mstt_Agents_1.AgentCategoryDescription AS FirmCategoryDesc ,
           coalesce(mstt_Agents_1.OscarDateStarted,mstt_Agents_1.DateStarted) AS FirmStartDate,
           mstt_Agents_1.DateLeaving as FirmLeftDate,
           mstt_Agents_1.OscarAgentId AS FirmOscarAgentId, 
          ( mstt_Agents_1.OscarAgentPrefix + mstt_Agents_1.OscarAgentSerial + mstt_Agents_1.OscarAgentSuffix) as FirmOscarCode,
           mstt_Agents_1.CompetentStatus AS FirmCompStatus, mstt_Agents_1.CompetentStatusDescription AS FirmCompStatDesc,
           mstt_Agents_1.FranchiseSize AS FirmFranchiseSize,
            (select  'FirmFranchiseType' = case  when mstt_Agents_1.FranchiseSize between '0' and '1'  then 'Sole Trader' 
                                                             when mstt_Agents_1.FranchiseSize  between  '2' and '9'  then 'Small (2-9)' 
                                                             when mstt_Agents_1.FranchiseSize  >  '9'  then 'Large (10+) ' 
                                                                                                                           else 'unknown' end)  as FirmFranchiseType,
            mstt_agentshistory.Manager2code as RSMCode,
           mstt_Agents_2.Descn as RSMName ,mstt_agentshistory.Manager4code as ASDCode,
           mstt_Agents_3.Descn as ASDName 
FROM       mstt_Agentshistory LEFT OUTER JOIN
           mstt_Agents mstt_Agents_1 ON mstt_agentshistory.Firm = mstt_Agents_1.CODE left outer join
           mstt_agents mstt_agents_2 on mstt_agentshistory.manager2Code = mstt_agents_2.Code left outer join
           mstt_agents mstt_agents_3 on mstt_agentshistory.manager4Code = mstt_agents_3.Code
WHERE idhistid_type in (select max(idhistid_type)from mstt_agentsHistory group by code ,lastmodifieddate )
or validfromdate < '1950/01/01'
 


