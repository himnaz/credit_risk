/****** Object:  View [dbo].[rpt_IDChecks]    Script Date: 03/09/2012 09:12:28 ******/
/*****************************************************************************************************
View:  	rpt_IDChecks						
			
Description:	This View supports the four ID Check reports.

Amendment History               
-----------------               
                      
Date		Who     Description       
----		---     -----------     
09/03/2012	MPC		Amendment to cater for Database Reorganisation to be deployed 5/4/12.
					PlanID replaced by PlanSnapshotId on sa_obp_OpportunityVersion table
					which links to PlanId on Opportunity or Arranagement/Quote tables 
					via PlanSkeleton table.

*****************************************************************************************************/
CREATE view [dbo].[rpt_IDChecks] as
SELECT CASE isnull(idv.Cat1Count, 0) * 2 + isnull(idv.Cat2Count, 0) when 0 then 'Missing'
                                                                    when 1 THEN 'Partial'
                                                                    else 'Valid' 
       END as IDStatus,
       o.ClientFacingOpportunityId OpportunityRef,
       a.SubmissionDate,
       a.CaseID,
       a.ArrangementType,
       a.PopTS,
       C.Forename + ' '+ C.Surname as ClientName,
       ppp.PrimaryClient,
       CD.description ClientStatus,
       CASE WHEN C.GenderId in (1,2) then 'Personal'
            else 'Corporate' 
       end as ClientType,
       CASE C.GenderId WHEN 1 then 'Male' 
                       WHEN 2 then 'Female' 
                       ELSE 'Unknown' 
       end as Gender,
       c.DateOfBirth,
       c.NINumber,
       CD1.description as IDTypeDesc,
       CD2.description as EvidTypeDesc,
       II.ReferenceNumber as EvidenceReference,
       ii.DateOfIssue,
       ii.ExpiryDate,
       isnull(idv.Cat1Count, 0) as Category1Docs,
       isnull(idv.Cat2Count, 0) as Category2Docs,
       a.ProductCode as OBPProductCode,
       a.ProductName as OBPProductName,
       a.Provider,
       S.IntegrationAlias as AgentUID,
       S.FirstName + ' ' + S.LastName as AgentName,
       jt.code_description JobTitle,
       cs.code_description ContractStatus,
       f.firmcode as FirmUID,
       dist.dist_companyname as FirmName,
       sup.qmusercode SupervisorUID,
       supusr.usr_name SupervisorName,
       bqm.qmusercode BQMUID,
       bqmusr.usr_name BQMName,
       CASE WHEN c.GenderId not in (1, 2) THEN 4 
            WHEN idv.Cat1Count > 0 THEN 2 
            WHEN idv.Cat2Count > 1 THEN 3 
            ELSE 1
       END as CheckCategory
from obpmi_arrangement a with (nolock)
     inner join sa_obp_OpportunityVersion ov with (nolock) on ov.OpportunityID = a.opportunityid and
                                                              ov.CurrentVersion = 1 and
                                                              a.submissionstatus = 1
--     inner join sa_obp_OpportunityWorkflowStage ows with (nolock) on ows.id = ov.OpportunityWorkflowStageId and
--                                                       ows.milestoneid = 5
     inner join sa_obp_Opportunity o with (nolock) on o.id = a.opportunityid
	 inner join sa_obp_PlanSnapshot ps with (nolock) on ps.id = ov.PlanSnapshotId		--MPC: 09/03/2012
     Inner Join obpmi_PlanProfilePerson PPP with (nolock) on ppp.PlanId = ps.PlanId		--MPC: 09/03/2012
														 --on PPP.PlanId = a.PlanId		--MPC: 09/03/2012
     Inner Join sa_obp_Client C with (nolock) on C.EntityId = PPP.ClientEntityId
     inner join sa_obp_enumClientStatus CD with (nolock) on CD.id = C.StatusId
     inner join obpmi_Staff S with (nolock) on S.entityid = ov.RRIStaffEntityID
     left join (Select OI.OpportunityId,
                       II.ClientEntityID,
                       Sum(Case when II.TypeId in (0,1,2,3,4,6) Then 1 else 0 end) as Cat1Count,
                       Sum(Case when II.TypeId not in (0,1,2,3,4,6) Then 1 else 0 end) as Cat2Count 
                FROM sa_obp_OpportunityIdv OI with (nolock)
                     Inner Join sa_obp_IdvItem II with (nolock) on II.ID = OI.IdvItemId and
                                                                   II.Isdeleted = 0 and
                                                                   II.Id is not null
                     Inner join sa_obp_enumIdvType CD1 with (nolock) on CD1.id = II.TypeId
                     Inner join sa_obp_enumIdvEvidenceOf CD2 with (nolock) on CD2.id = II.EvidenceOf
                Group By OI.OpportunityId,
                         II.ClientEntityID) idv on idv.OpportunityId = a.OpportunityID and 
                                                   idv.ClientEntityId = c.EntityId
     left join (sa_obp_OpportunityIdv OI with (nolock)
                inner Join sa_obp_IdvItem II with (nolock) on II.ID = OI.IdvItemId and
                                                              II.IsDeleted = 0
                inner join sa_obp_enumIdvType CD1 with (nolock) on CD1.id = II.TypeId
                inner join sa_obp_enumIdvEvidenceOf CD2 with (nolock) on CD2.id = II.EvidenceOf) on oi.OpportunityID = a.OpportunityID and
                                                                                                    II.ClientEntityID = C.EntityId
     left join sa_insight_userposition ups with (nolock) on ups.ups_externalid = s.integrationalias and
                                                            a.submissiondate between ups_datefrom and isnull(ups_dateto, '99991231') and
                                                            ups.ups_usertype = 3
     left join sa_insight_codedescription jt with (nolock) on jt.code_code = ups.ups_jobtitle and
                                                              jt.code_codetype = 54
     left join sa_insight_staff si with (nolock) on si.staf_userid = ups.ups_userid
     left join sa_insight_codedescription cs with (nolock) on cs.code_code = si.staf_contractstatus and
                                                              cs.code_codetype = 527
     left join dbo.f_insight_getfirmsofallusers(getdate()) f on f.roleguid = ups.ups_id
     left join sa_insight_distributor dist with (nolock) on dist.dist_id = f.firmguid
     left join dbo.f_insight_getqmsofallusers(2, getdate()) sup on sup.roleguid = ups.ups_id                                                           
     left join sa_insight_userdetails supusr with (nolock) on supusr.usr_id = sup.qmuserguid
     left join dbo.f_insight_getqmsofallusers(1, getdate()) bqm on bqm.roleguid = ups.ups_id                                                           
     left join sa_insight_userdetails bqmusr with (nolock) on bqmusr.usr_id = bqm.qmuserguid
;
