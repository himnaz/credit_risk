CREATE view [dbo].[obpmi_Plan] as
SELECT p.[Id], 
       p.[Date],
       au.OrganisationUnitEntityId,
       p.StaffEntityId, 
       p.AdviceUnitEntityId, 
       p.InvestmentRiskLevel, 
       p.RetirementRiskLevel, 
       p.HouseholdAnnualIncome, 
       p.DependentsId, 
       p.HaveMortgageId, 
       p.MaritalStatusId, 
       p.OwnInvestmentsId, 
       p.SharedFinancesId, 
       p.PlanCreatedById, 
       p.Deleted, 
       i.EntityQuestionnaireId AS InvestmentRiskQuestionnaireId, 
       r.EntityQuestionnaireId AS RetirementRiskQuestionnaireId, 
       p.ReviewDate,
       ppp1.id [ProfilePersonId],
       ppp2.id [ProfilePersonPartnerId],
       CASE WHEN p.[Id] = au.LatestPlanId THEN 1 ELSE 0 END [Latest],
       convert(xml, p.CustomXml) CustomXml
  FROM sa_obp_Plan p (nolock)
       INNER JOIN sa_obp_AdviceUnit au (nolock) ON au.EntityId = p.AdviceUnitEntityId
       INNER JOIN sa_obp_OrganisationUnit ou (nolock) ON ou.EntityId = au.OrganisationUnitEntityId
       inner join sa_obp_PlanProfilePerson ppp1 on ppp1.PlanId = p.[Id] AND
                                                   ppp1.IsClient = 1
       inner join sa_obp_EnumQuestionnaireClass eqc on eqc.Description = 'AttitudeToRisk'
       left JOIN sa_obp_PlanCurrentQuestionnaire AS i ON i.PlanId = p.Id AND
                                                         i.Section = 1 AND 
                                                         i.QuestionnaireClassId = eqc.id
       left JOIN sa_obp_PlanCurrentQuestionnaire AS r ON r.PlanId = p.Id AND 
                                                         r.Section = 2 AND
                                                         r.QuestionnaireClassId = eqc.id
       left join sa_obp_PlanProfilePerson ppp2 on ppp2.PlanId = p.[Id] AND
                                                  ppp2.IsClient = 0

