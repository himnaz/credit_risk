CREATE view [dbo].[rpt_CBPCaseChecking] as
select top 100 percent
  cast(list.AgentCode as nvarchar(7)) as UID,
  cast(usr_name as nvarchar(50)) as [AGENT NAME],
  ulic_validfrom as [DATE CBP PASSED],
  max(isnull(list.ToCheck, 0)) as [MIN CASES TO BE CHECKED],
  max(isnull(list.Extra, 0)) as [EXTRA CASES TO BE CHECKED],
  isnull(sub_cbp_case_count, 0) as [CBP CASES SUBMITTED],
  isnull(all_cbp_case_count, 0) as [CBP CASES ALLOCATED],
  isnull(clo_cbp_case_count, 0) as [CBP CASES CLOSED],
  cast(case when max(isnull(list.ToCheck, 0)) + max(isnull(list.Extra, 0)) > isnull(all_cbp_case_count, 0) then 'NO' else 'YES' end as nvarchar(3)) as [CBP CHECKING COMPLETE],
  case when max(isnull(list.ToCheck, 0)) + max(isnull(list.Extra, 0)) > isnull(all_cbp_case_count, 0) then isnull(sub_cbp_case_count, 0) - isnull(all_cbp_case_count, 0) end as [CASES AVAILABLE FOR ALLOCATION],
  isnull(significant, 0) as [SIGNIFICANT],
  isnull(marginal, 0) as [MARGINAL],
  isnull(low, 0) as [LOW],
  isnull(passed, 0) as [PASS],
  isnull(failed, 0) as [FAIL],
  isnull(passaq, 0) as [PASS W/C]
  from sa_man_CBPCaseCheckingAgents list
    left join (select distinct ups_userid, ups_externalid from sa_insight_userposition where getdate() between ups_datefrom and isnull(ups_dateto, 'Dec 31, 9999')) ups on ups_externalid = list.agentcode
    left join sa_insight_userdetails on usr_id = ups_userid
    left join sa_insight_licence on lic_code = 'LIC19'
    left join sa_insight_userlicence on ulic_userid = usr_id and ulic_licenceid = lic_id and ulic_id = (select top 1 ulic_id from sa_insight_userlicence where ulic_userid = usr_id and ulic_licenceid = lic_id order by ulic_validfrom desc)
    left join (select count(distinct case_id) as sub_cbp_case_count, ups_userid as userid from sa_insight_salescase inner join sa_insight_userposition on ups_id = case_userpositionid inner join sa_insight_basicpolicy on bpol_parentid = case_id inner join sa_insight_producttype on prod_code = bpol_producttype and prod_shortname not in ('MORT', 'XXaa', 'ICOB') left join sa_insight_licence on lic_code = 'LIC19' left join sa_insight_userlicence on ulic_userid = ups_userid and ulic_licenceid = lic_id and ulic_id = (select top 1 ulic_id from sa_insight_userlicence where ulic_userid = ups_userid and ulic_licenceid = lic_id order by ulic_validfrom desc) where case_submitdate > isnull(ulic_validfrom, 'Dec 31, 9999') group by ups_userid) sub_count on sub_count.userid = ups_userid
    left join (select count(distinct case_id) as all_cbp_case_count, ups_userid as userid from sa_insight_salescase inner join sa_insight_basicpolicy on bpol_parentid = case_id inner join sa_insight_businessquality bq on bq_parentid = case_id inner join sa_insight_userposition on ups_id = case_userpositionid inner join sa_insight_producttype on prod_code = bpol_producttype and prod_shortname not in ('MORT', 'XXaa', 'ICOB') left join sa_insight_licence on lic_code = 'LIC19' left join sa_insight_userlicence on ulic_userid = ups_userid and ulic_licenceid = lic_id and ulic_id = (select top 1 ulic_id from sa_insight_userlicence where ulic_userid = ups_userid and ulic_licenceid = lic_id order by ulic_validfrom desc) where case_submitdate > isnull(ulic_validfrom, 'Dec 31, 9999') group by ups_userid) all_count on all_count.userid = ups_userid
    left join (select count(distinct case_id) as clo_cbp_case_count, ups_userid as userid from sa_insight_salescase inner join sa_insight_basicpolicy on bpol_parentid = case_id inner join sa_insight_businessquality bq on bq_parentid = case_id and bq_checkdate = (select max(bq_CheckDate) from sa_insight_businessquality subbq where subbq.bq_parentid = case_id) inner join sa_insight_userposition on ups_id = case_userpositionid inner join sa_insight_producttype on prod_code = bpol_producttype and prod_shortname not in ('MORT', 'XXaa', 'ICOB') left join sa_insight_licence on lic_code = 'LIC19' left join sa_insight_userlicence on ulic_userid = ups_userid and ulic_licenceid = lic_id and ulic_id = (select top 1 ulic_id from sa_insight_userlicence where ulic_userid = ups_userid and ulic_licenceid = lic_id order by ulic_validfrom desc) where case_submitdate > isnull(ulic_validfrom, 'Dec 31, 9999') and case_checkingcomplete = 1 and bq_status in (3, 4, 6, 10) group by ups_userid) clo_count on clo_count.userid = ups_userid
    left join (select count(distinct case_id) as passed, ups_userid as userid from sa_insight_salescase inner join sa_insight_basicpolicy on bpol_parentid = case_id inner join sa_insight_businessquality bq on bq_parentid = case_id and bq_checkdate = (select max(bq_CheckDate) from sa_insight_businessquality subbq where subbq.bq_parentid = case_id) and case_checkingcomplete = 1 inner join sa_insight_userposition on ups_id = case_userpositionid inner join sa_insight_producttype on prod_code = bpol_producttype and prod_shortname not in ('MORT', 'XXaa', 'ICOB') left join sa_insight_licence on lic_code = 'LIC19' left join sa_insight_userlicence on ulic_userid = ups_userid and ulic_licenceid = lic_id and ulic_id = (select top 1 ulic_id from sa_insight_userlicence where ulic_userid = ups_userid and ulic_licenceid = lic_id order by ulic_validfrom desc) where case_submitdate > isnull(ulic_validfrom, 'Dec 31, 9999') and bq_status in (3, 10) group by ups_userid) pass_count on pass_count.userid = ups_userid
    left join (select count(distinct case_id) as failed, ups_userid as userid from sa_insight_salescase inner join sa_insight_basicpolicy on bpol_parentid = case_id inner join sa_insight_businessquality bq on bq_parentid = case_id and bq_checkdate = (select max(bq_CheckDate) from sa_insight_businessquality subbq where subbq.bq_parentid = case_id) and case_checkingcomplete = 1 inner join sa_insight_userposition on ups_id = case_userpositionid inner join sa_insight_producttype on prod_code = bpol_producttype and prod_shortname not in ('MORT', 'XXaa', 'ICOB') left join sa_insight_licence on lic_code = 'LIC19' left join sa_insight_userlicence on ulic_userid = ups_userid and ulic_licenceid = lic_id and ulic_id = (select top 1 ulic_id from sa_insight_userlicence where ulic_userid = ups_userid and ulic_licenceid = lic_id order by ulic_validfrom desc) where case_submitdate > isnull(ulic_validfrom, 'Dec 31, 9999') and bq_status = 4 group by ups_userid) fail_count on fail_count.userid = ups_userid
    left join (select count(distinct case_id) as passaq, ups_userid as userid from sa_insight_salescase inner join sa_insight_basicpolicy on bpol_parentid = case_id inner join sa_insight_businessquality bq on bq_parentid = case_id and bq_checkdate = (select max(bq_CheckDate) from sa_insight_businessquality subbq where subbq.bq_parentid = case_id) and case_checkingcomplete = 1 inner join sa_insight_userposition on ups_id = case_userpositionid inner join sa_insight_producttype on prod_code = bpol_producttype and prod_shortname not in ('MORT', 'XXaa', 'ICOB') left join sa_insight_licence on lic_code = 'LIC19' left join sa_insight_userlicence on ulic_userid = ups_userid and ulic_licenceid = lic_id and ulic_id = (select top 1 ulic_id from sa_insight_userlicence where ulic_userid = ups_userid and ulic_licenceid = lic_id order by ulic_validfrom desc) where case_submitdate > isnull(ulic_validfrom, 'Dec 31, 9999') and bq_status = 6 group by ups_userid) passq_count on passq_count.userid = ups_userid
    left join (select count(distinct case_id) as significant, ups_userid as userid from sa_insight_salescase inner join sa_insight_basicpolicy on bpol_parentid = case_id inner join sa_insight_businessquality bq1 on bq1.bq_parentid = case_id and bq1.bq_checkdate = (select min(bq_CheckDate) from sa_insight_businessquality subbq where subbq.bq_parentid = case_id) inner join sa_insight_userposition on ups_id = case_userpositionid inner join sa_insight_producttype on prod_code = bpol_producttype and prod_shortname not in ('MORT', 'XXaa', 'ICOB') left join sa_insight_businessquality bqf on bqf.bq_parentid = case_id and bqf.bq_checkdate = (select max(bq_CheckDate) from sa_insight_businessquality subbq where subbq.bq_parentid = case_id) and case_checkingcomplete = 1 inner join (select bqr_caseid, bqr_businessqualityid, max(cfq_questioncode % 5) as Reason from sa_insight_businessqualityresult inner join sa_insight_complianceformquestion on cfq_id = bqr_questionid and cfq_questioncode between 157 and 161 and bqr_code = 101 group by bqr_caseid, bqr_businessqualityid having max(cfq_questioncode % 5) = 4) reason on bqr_caseid = case_id and bqr_businessqualityid = bq1.bq_id left join sa_insight_licence on lic_code = 'LIC19' left join sa_insight_userlicence on ulic_userid = ups_userid and ulic_licenceid = lic_id and ulic_id = (select top 1 ulic_id from sa_insight_userlicence where ulic_userid = ups_userid and ulic_licenceid = lic_id order by ulic_validfrom desc) where case_submitdate > isnull(ulic_validfrom, 'Dec 31, 9999') and ((bq1.bq_status = 5 and isnull(bqf.bq_status, 0) not in (3, 8, 10)) or bqf.bq_status = 6) group by ups_userid) sig_count on sig_count.userid = ups_userid
    left join (select count(distinct case_id) as marginal, ups_userid as userid from sa_insight_salescase inner join sa_insight_basicpolicy on bpol_parentid = case_id inner join sa_insight_businessquality bq1 on bq1.bq_parentid = case_id and bq1.bq_checkdate = (select min(bq_CheckDate) from sa_insight_businessquality subbq where subbq.bq_parentid = case_id) inner join sa_insight_userposition on ups_id = case_userpositionid inner join sa_insight_producttype on prod_code = bpol_producttype and prod_shortname not in ('MORT', 'XXaa', 'ICOB') left join sa_insight_businessquality bqf on bqf.bq_parentid = case_id and bqf.bq_checkdate = (select max(bq_CheckDate) from sa_insight_businessquality subbq where subbq.bq_parentid = case_id) and case_checkingcomplete = 1 inner join (select bqr_caseid, bqr_businessqualityid, max(cfq_questioncode % 5) as Reason from sa_insight_businessqualityresult inner join sa_insight_complianceformquestion on cfq_id = bqr_questionid and cfq_questioncode between 157 and 161 and bqr_code = 101 group by bqr_caseid, bqr_businessqualityid having max(cfq_questioncode % 5) = 3) reason on bqr_caseid = case_id and bqr_businessqualityid = bq1.bq_id left join sa_insight_licence on lic_code = 'LIC19' left join sa_insight_userlicence on ulic_userid = ups_userid and ulic_licenceid = lic_id and ulic_id = (select top 1 ulic_id from sa_insight_userlicence where ulic_userid = ups_userid and ulic_licenceid = lic_id order by ulic_validfrom desc) where case_submitdate > isnull(ulic_validfrom, 'Dec 31, 9999') and ((bq1.bq_status = 5 and isnull(bqf.bq_status, 0) not in (3, 8, 10)) or bqf.bq_status = 6) group by ups_userid) mar_count on mar_count.userid = ups_userid
    left join (select count(distinct case_id) as low, ups_userid as userid from sa_insight_salescase inner join sa_insight_basicpolicy on bpol_parentid = case_id inner join sa_insight_businessquality bq1 on bq1.bq_parentid = case_id and bq1.bq_checkdate = (select min(bq_CheckDate) from sa_insight_businessquality subbq where subbq.bq_parentid = case_id) inner join sa_insight_userposition on ups_id = case_userpositionid inner join sa_insight_producttype on prod_code = bpol_producttype and prod_shortname not in ('MORT', 'XXaa', 'ICOB') left join sa_insight_businessquality bqf on bqf.bq_parentid = case_id and bqf.bq_checkdate = (select max(bq_CheckDate) from sa_insight_businessquality subbq where subbq.bq_parentid = case_id) and case_checkingcomplete = 1 inner join (select bqr_caseid, bqr_businessqualityid, max(cfq_questioncode % 5) as Reason from sa_insight_businessqualityresult inner join sa_insight_complianceformquestion on cfq_id = bqr_questionid and cfq_questioncode between 157 and 161 and bqr_code = 101 group by bqr_caseid, bqr_businessqualityid having max(cfq_questioncode % 5) = 2) reason on bqr_caseid = case_id and bqr_businessqualityid = bq1.bq_id left join sa_insight_licence on lic_code = 'LIC19' left join sa_insight_userlicence on ulic_userid = ups_userid and ulic_licenceid = lic_id and ulic_id = (select top 1 ulic_id from sa_insight_userlicence where ulic_userid = ups_userid and ulic_licenceid = lic_id order by ulic_validfrom desc) where case_submitdate > isnull(ulic_validfrom, 'Dec 31, 9999') and ((bq1.bq_status = 5 and isnull(bqf.bq_status, 0) not in (3, 8, 10)) or bqf.bq_status = 6) group by ups_userid) low_count on low_count.userid = ups_userid
  where list.agentcode <> 'x'
  group by
    cast(list.AgentCode as nvarchar(7)),
    cast(usr_name as nvarchar(50)),
    ulic_validfrom,
    isnull(sub_cbp_case_count, 0),
    isnull(all_cbp_case_count, 0),
    isnull(clo_cbp_case_count, 0),
    isnull(significant, 0),
    isnull(marginal, 0),
    isnull(low, 0),
    isnull(passed, 0),
    isnull(failed, 0),
    isnull(passaq, 0)
  order by cast(list.AgentCode as nvarchar(7))

