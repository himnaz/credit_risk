/****** Object:  View [dbo].[rpt_SwiftCasesMissinInInsight]    Script Date: 7/2/2026 12:50:24 PM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
create view [dbo].[rpt_SwiftCasesMissinInInsight]
as
select swic.POL_NUM,
       swic.policyref CaseID,
       swic.cont_num PolicyNumber,
       swic.ProposalDate,
       case when insc.bpol_caseid is null then 'No' else 'Yes' end CaseInInsight,
       case when obpc.caseid is null then 'No' else 'Yes' end CaseSubmittedInOBP
from (select p.pol_num,
             p.policyref,
             pt.proposaldate,
             min(pt.createdatetime) createdatetime,
             nullif(rtrim(ltrim(p.cont_num)), '') cont_num,
             p.comp_code,
             c.id provgroupid
      from sa_swift_s_polmai p with (nolock)
           left join sa_swift_s_polmai sp with (nolock) on sp.scheme_num = p.pol_num
           inner join sa_swift_policytransactions pt with (nolock) on pt.policyid = isnull(sp.pol_num, p.pol_num) and
                                                                      p.policyref is not null and
                                                                      pt.proposaldate is not null and
                                                                      pt.transtype != 117 and
                                                                      isnull(pt.adminmethod, '') !='X' and
                                                                      p.scheme_num is null
           left join (rds_codemapping cm with (nolock)
                      inner join rds_code c with (nolock) on c.id = cm.codeid
                      inner join rds_codetype ct with (nolock) on ct.id = c.typeid and
                                                                  ct.name = 'Provider Grouping 1'
                      inner join config_datasource ds with (nolock) on ds.id = cm.datasourceid and
                                                                       ds.code = 'Swift') on cm.ssuid = p.comp_code
           left join rds_case rdscs with (nolock) on rdscs.pol_num = p.pol_num
      where rdscs.pol_num is null
      group by p.pol_num,
               p.policyref,
               pt.proposaldate,
               nullif(rtrim(ltrim(p.cont_num)), ''),
               p.comp_code,
               c.id) swic
     left join (select convert(int, bpol_backofficeid) bpol_CaseID,
                       dbo.f_ifdateconvert(attl_attributevalue) bpol_ProposalDate,
                       row_number() over (partition by convert(int, bpol_backofficeid), dbo.f_ifdateconvert(attl_attributevalue) order by bpol_createddate) RN
                from sa_insight_basicpolicy c with (nolock)
                     inner join (select case_id,
                                        row_number() over (partition by rtrim(ltrim(isnull(case_casereference, '0'))) order by case_createddate) RN
                                 from sa_insight_salescase with (nolock)
                                 where rtrim(ltrim(isnull(case_casereference, '0'))) != '0') o on case_id = bpol_parentid and
                                                                                                  rn = 1 and
                                                                                                  rtrim(ltrim(isnull(bpol_backofficeid, '0'))) != '0' and
                                                                                                  isnumeric(bpol_backofficeid) = 1
                     left join (sa_insight_attribute with (nolock)
                                inner join sa_insight_attributelink with (nolock) on attl_attributeid = att_id and
                                                                                     att_name = 'PRODUCT.PROPOSALDATE') on attl_parentid = bpol_id) insc on insc.rn = 1 and
                                                                                                                                                            insc.bpol_caseid = swic.policyref and
                                                                                                                                                            insc.bpol_proposaldate = swic.proposaldate
     left join (obpmi_arrangement obpc with (nolock)
                left join (rds_codemapping cmo with (nolock)
                           inner join rds_code co with (nolock) on co.id = cmo.codeid
                           inner join rds_codetype cto with (nolock) on cto.id = co.typeid and
                                                                        cto.name = 'Provider Grouping 1'
                           inner join config_datasource dso with (nolock) on dso.id = cmo.datasourceid and
                                                                             dso.code = 'OBP') on cmo.ssuid = obpc.provider
                left join rds_case rdsco with (nolock) on rdsco.arrangementid = obpc.arrangementid) on obpc.proposaldate = swic.proposaldate and
                                                                                                       obpc.submissionstatus = 1 and
                                                                                                       (obpc.caseid = swic.policyref or
                                                                                                        (obpc.policynumber = swic.cont_num and
                                                                                                         (swic.comp_code = obpc.provider or
                                                                                                          swic.provgroupid = co.id)))
where insc.bpol_caseid is null and
      obpc.caseid is null
--order by swic.policyref,
--         swic.proposaldate
GO
