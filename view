-- ============================================================
-- Author:           Vincent Holt
-- Create date: 25th November 2010
-- Description:      Retrieves the commissions for plans pertinent to RDR 
-- ============================================================
CREATE VIEW [dbo].[rdr_LatestCommissionRatesForRdrPlans] AS 

SELECT DISTINCT sh.ProductCode,  sh.description, sh.PremiumFrequency, sh.InitialCommissionType,
       sh.RebaseCommissionTo,
       CASE WHEN (sh.RebaseforEnhancement = 1 OR sh.RebaseCommissionTo = 0) THEN
              lcr.InitialRate
       ELSE
              CASE WHEN (sh.PremiumFrequency = 6 OR pt.ProductTypeID NOT IN (5,6,8)) THEN
                     lcr.InitialRate * sh.RebaseCommissionTo         
              ELSE
                     -- hardcoded for now to match spreadsheet
                     CASE WHEN pt.ProductTypeID = 5 THEN
                           CASE WHEN lcr.RenewalRate = 0 THEN --Initial only
                                  lcr.InitialRate * 0.38888 
                           ELSE -- Initial and renewal
                                  lcr.InitialRate * 0.3111 
                           END
                     ELSE                 
                           CASE WHEN pt.ProductTypeID = 6 THEN                           
                                  CASE WHEN lcr.RenewalRate = 0 THEN --Initial only
                                         lcr.InitialRate * 0.38888 
                                  ELSE -- Initial and renewal
                                         lcr.InitialRate * 0.47702 
                                  END                                                    
                           ELSE -- must be 8
                                  CASE WHEN pt.ProductTypeID = 8 THEN                           
                                         8.333
                                  ELSE 
                                  /*
                                         CASE WHEN pt.ProductTypeID = 15 THEN     
                                                CASE WHEN sh.PremiumFrequency = 6 THEN
                                                       CASE WHEN TrailFeeRate = 0 THEN 4.0
                                                       ELSE 
                                                              CASE WHEN TrailFeeRate = 0.25 THEN 3.0
                                                              ELSE /* TrailFeeRate = 0.5 */ 2.0 
                                                              END
                                                       END
                                                ELSE
                                                       lcr.InitialRate
                                                END
                                         ELSE */
                                                lcr.InitialRate * sh.RebaseCommissionTo
                                         --END
                                         /*
                                                CASE WHEN sh.PremiumFrequency = 6 THEN
                                                       CASE WHEN TrailFeeRate = 0 THEN 5.0
                                                       ELSE 
                                                              CASE WHEN TrailFeeRate = 0.25 THEN 4.0
                                                              ELSE /* TrailFeeRate = 0.5 */ 3.0 
                                                              END
                                                       END
                                                ELSE
                                                       CASE WHEN sh.InitialCommissionType = 1 THEN /* IT */
                                                              CASE WHEN TrailFeeRate = 0 THEN 16.0
                                                              ELSE 
                                                                     CASE WHEN TrailFeeRate = 0.25 THEN 12.8
                                                                     ELSE /* TrailFeeRate = 0.5 */ 9.6 
                                                                     END
                                                              END
                                                       ELSE /* Accruals */
                                                              CASE WHEN TrailFeeRate = 0 THEN 5.0
                                                              ELSE 
                                                                     CASE WHEN TrailFeeRate = 0.25 THEN 4.0
                                                                     ELSE /* TrailFeeRate = 0.5 */ 3.0 
                                                                     END
                                                              END
                                                       END
                                                END
                                         ELSE */
                                                --lcr.InitialRate --* sh.RebaseCommissionTo
                                         --END
                                                       
                                  END
                           END

                     END
              END
       END AS InitialRate,
       lcr.RenewalRate,
       /* 
       CASE WHEN sh.RebaseforEnhancement = 1 OR sh.RebaseCommissionTo = 0 OR pt.ProductTypeID < 5 OR pt.ProductTypeID > 11 
              OR sh.PremiumFrequency = 6 THEN
              lcr.RenewalRate 
       ELSE
              lcr.RenewalRate * sh.RebaseCommissionTo * 1.36449
       END AS RenewalRate*/ 
       --hardcoded to match spreadsheet - agreed with MO 11/1/11
       CASE WHEN (pt.ProductTypeID = 14 OR pt.ProductTypeID = 16 OR pt.ProductTypeID = 18) AND lcr.TrailFeeRate > 0 THEN 
              0.4
       ELSE

              CASE WHEN pt.ProductTypeID = 17 AND lcr.TrailFeeRate > 0 THEN 
                     0.29
              ELSE
                     lcr.TrailFeeRate 
              END
                           
              /* todo - if you want to match spreadsheet, uncomment this section (and also amend rdr_get_PlanCommissionsForEnterprise)
                     but I think the spreadsheet is wrong! 
              CASE WHEN pt.ProductTypeID = 9 THEN

                     CASE WHEN lcr.TrailFeeRate = 0.25 THEN
                           0.125
                     ELSE
                           CASE WHEN lcr.TrailFeeRate = 0.5 THEN
                                  0.25
                           ELSE
                                  0
                           END
                     END 
              ELSE
                     lcr.TrailFeeRate
              END
              */
                     
       END AS TrailFeeRate, 
       lcr.Enhancement, lcr.IndemnityDiscountRate, 
       sh.CalculationCode,  cal.InitialPeriodMaximum, cal.MinimumInitialPeriod, lcr.DateEffective,
       ppt.ProductTypeID, 
       COALESCE(prov1.CommRepProductProviderCode, pr.CompanyCode) AS ProductProviderCode, -- this is faster!
       pt.ProductGroup

       --get case (pascal case) as we want it for RDR 
/*     (SELECT TOP 1 ProductProviderCode FROM [dbo].[rdr_ProductType_Plan] pln
       WHERE 
              pln.ProductProviderCode = COALESCE(prov1.CommRepProductProviderCode, pr.CompanyCode))
              AS ProductProviderCode
*/
       FROM sa_swift_codecommissionshape sh
              INNER JOIN rdr_LatestCommisionRates lcr ON sh.id = lcr.codecommissionshapeid
              INNER JOIN rdr_Product_ProductType ppt ON ppt.ProductCode = sh.ProductCode
              LEFT JOIN sa_swift_codecommissioncalcs cal ON sh.calculationcode = cal.code
              INNER JOIN sa_swift_codeproducts pr ON pr.Code = sh.ProductCode
              LEFT JOIN mstt_ProductProviders prov1 ON prov1.ProductProviderCode = pr.CompanyCode
              INNER JOIN    rdr_ProductType pt ON pt.ProductTypeID = ppt.ProductTypeID    

       WHERE sh.productcode IN 
              (SELECT DISTINCT ProductCode from rdr_Product_ProductType)
       AND EXISTS
              (SELECT (1) FROM rdr_ProductType_Plan pln
                     INNER JOIN rdr_Product_ProductType ppt on ppt.ProductTypeID = pln.ProductTypeID
                     LEFT JOIN rdr_Product_Plan pp ON pp.ProductTypePlanID = pln.ProductTypePlanID
                     LEFT JOIN rdr_Product_Plan pp2 ON ppt.ProductCode = pp2.ProductCode

                     WHERE ppt.ProductCode = sh.productcode
                     AND 
                     ( ((cal.initialperiodmaximum IS NULL) AND (pln.PlanLength IS NULL)) OR
                     cal.initialperiodmaximum = pln.PlanLength)
                     AND
                     ((pp.ProductPlanID IS NULL) OR (pp2.ProductPlanID IS NOT NULL))                                 
                     )


       AND NOT EXISTS (SELECT 1 FROM sa_swift_codecommissionshape sh2
              INNER JOIN rdr_LatestCommisionRates lcr2 ON sh2.id = lcr2.codecommissionshapeid
              INNER JOIN rdr_Product_ProductType ppt2 ON ppt2.ProductCode = sh2.ProductCode
              LEFT JOIN sa_swift_codecommissioncalcs cal2 ON sh2.calculationcode = cal2.code
              WHERE sh2.ProductCode = sh.ProductCode AND 
                       sh2.PremiumFrequency = sh.PremiumFrequency AND
                       sh2.InitialCommissionType = sh.InitialCommissionType AND
                     (cal2.InitialPeriodMaximum = cal.InitialPeriodMaximum OR
                           ((cal2.InitialPeriodMaximum IS NULL) AND (cal.InitialPeriodMaximum IS NULL)
                                  AND pt.ProductTypeID = 9)
                     ) /* works for RTRCON - need to extend to the others! */                                        
                     AND
                       lcr2.DateEffective > lcr.DateEffective
                     AND 
                       sh2.CalculationCode <> 'CONTOUT'
                     AND
                     (ppt2.ProductTypeID NOT IN (10,12) OR lcr2.TrailFeeRate = 0)
                     AND 
                      (ppt2.ProductTypeID <> 15)
                     AND (sh2.Description NOT LIKE '%DO NOT USE%')) -- OR lcr2.TrailFeeRate = 0 OR lcr2.TrailFeeRate = 0.25 OR lcr2.TrailFeeRate = 0.5))

       AND sh.CalculationCode <> 'CONTOUT' -- not used for RDR (as yet)
       AND (pt.ProductTypeID NOT IN (10,12) OR lcr.TrailFeeRate = 0) -- only interested in trail of 0 for SECT32 & ZGUA Annuities with 0% trail
       AND (pt.ProductTypeID <> 15) -- OR TrailFeeRate = 0 OR TrailFeeRate = 0.25 OR TrailFeeRate = 0.5)
       AND (sh.Description NOT LIKE '%DO NOT USE%')
       UNION         
              SELECT 'ISA', 'Hardcoded ISA SP Zero Trail Rate to match Spreadsheet',
                     6, 1, 1, 5.0, 0, 0, 0, 0, 'HARDCODE', NULL, 0, '2011-01-01', 15, 'STIRLING', 'Investment'
       UNION         
              SELECT 'ISA', 'Hardcoded ISA Partial Trail Rate to match Spreadsheet',
                     6, 1, 1, 4.0, 0, 0.25, 0, 0, 'HARDCODE', NULL, 0, '2011-01-01', 15, 'STIRLING', 'Investment'
       UNION         
              SELECT 'ISA', 'Hardcoded ISA Full Trail Rate to match Spreadsheet',
                     6, 1, 1, 3.0, 0, 0.5, 0, 0, 'HARDCODE', NULL, 0, '2011-01-01', 15, 'STIRLING', 'Investment'
       
       UNION         
              SELECT 'ISA', 'Hardcoded ISA Full Trail Rate to match Spreadsheet',
                     2, 1, 1, 16.0, 0, 0.0, 0, 0, 'HARDCODE', 60, 0, '2011-01-01', 15, 'STIRLING', 'Investment'
       UNION         
              SELECT 'ISA', 'Hardcoded ISA Full Trail Rate to match Spreadsheet',
                     2, 1, 1, 12.8, 0, 0.25, 0, 0, 'HARDCODE', 60, 0, '2011-01-01', 15, 'STIRLING', 'Investment'
       UNION         
              SELECT 'ISA', 'Hardcoded ISA Full Trail Rate to match Spreadsheet',
                     2, 1, 1, 9.6, 0, 0.5, 0, 0, 'HARDCODE', 60, 0, '2011-01-01', 15, 'STIRLING', 'Investment'
       UNION         
              SELECT 'ISA', 'Hardcoded ISA Full Trail Rate to match Spreadsheet',
                     2, 2, 1, 5.0, 0, 0.0, 0, 0, 'HARDCODE', 60, 0, '2011-01-01', 15, 'STIRLING', 'Investment'
       UNION         
              SELECT 'ISA', 'Hardcoded ISA Full Trail Rate to match Spreadsheet',
                     2, 2, 1, 4.0, 0, 0.25, 0, 0, 'HARDCODE', 60, 0, '2011-01-01', 15, 'STIRLING', 'Investment'
       UNION         
              SELECT 'ISA', 'Hardcoded ISA Full Trail Rate to match Spreadsheet',
                     2, 2, 1, 3.0, 0, 0.5, 0, 0, 'HARDCODE', 60, 0, '2011-01-01', 15, 'STIRLING', 'Investment'

       UNION         
              SELECT 'ISA', 'Hardcoded ISA Full Trail Rate to match Spreadsheet',
                     5, 1, 1, 16.0, 0, 0.0, 0, 0, 'HARDCODE', 60, 0, '2011-01-01', 15, 'STIRLING', 'Investment'
